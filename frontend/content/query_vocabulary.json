{
  "meta": {
    "version": "3.0",
    "decided": "2026-05-02",
    "note": "Vokabular fuer den Composer der Analyse-Seite. Subjekte (mit Filtern und Einheits-Label), Filter-Definitionen mit Wert-Listen oder dynamischen Wert-Quellen, Coverage-Texte, Filter-Limit. Keine Gruppierung — der Composer rendert immer Einzelwerte und Subjekt-Uebersichtskarten."
  },
  "subjects": {
    "persons": {
      "label": "Personen",
      "filters": ["sex", "role", "qw", "org_type", "org_category"]
    },
    "sources": {
      "label": "Quellen",
      "filters": ["korpus", "decade"]
    },
    "events": {
      "label": "Rechtsgeschaefte",
      "filters": ["tx_type", "recipient_type"]
    },
    "relationships": {
      "label": "Beziehungen",
      "filters": ["rel_type", "sex"]
    }
  },
  "filters": {
    "sex": {
      "label": "Geschlecht",
      "values": [
        {"value": "f", "label": "weiblich"},
        {"value": "m", "label": "maennlich"}
      ]
    },
    "role": {
      "label": "Rolle",
      "values": [
        {"value": "issuer",    "label": "Aussteller:in"},
        {"value": "recipient", "label": "Empfaenger:in"},
        {"value": "witness",   "label": "Zeug:in"},
        {"value": "other",     "label": "sonstige Beteiligung"}
      ]
    },
    "decade": {
      "label": "Dekade",
      "value_kind": "range",
      "range": [1170, 1410],
      "step": 10,
      "value_suffix": "er"
    },
    "korpus": {
      "label": "Korpus",
      "values": [
        {"value": "QGW",          "label": "QGW"},
        {"value": "Stadtbuecher", "label": "Stadtbuecher"}
      ]
    },
    "qw": {
      "label": "Normalisierung",
      "values": [
        {"value": "2", "label": "hoch"},
        {"value": "1", "label": "mittel"},
        {"value": "0", "label": "niedrig"}
      ]
    },
    "org_type": {
      "label": "Organisationstyp",
      "value_kind": "from_data",
      "values_source": "epic_a.observations.org_type_totals",
      "value_labels": {
        "Messe": "Messe/Stiftung",
        "Pfarre": "Pfarre",
        "Stadt": "Stadt",
        "Kirche_Kapelle": "Kirche/Kapelle",
        "Altar": "Altar",
        "Dioezese_Erzdioezese": "Dioezese",
        "Kloster_m": "Kloster (m.)",
        "Gemeinde": "Gemeinde",
        "Zeche_Bruderschaft": "Zeche/Bruderschaft",
        "OTHER": "Sonstige",
        "Kloster_f": "Kloster (w.)",
        "Spital_Siechenhaus": "Spital/Siechenhaus",
        "Herzogtum": "Herzogtum",
        "Orden": "Orden",
        "Universitaet": "Universitaet",
        "Kirche": "Kirche"
      }
    },
    "org_category": {
      "label": "Organisations-Kategorie",
      "values": [
        {"value": "geistlich", "label": "geistlich"},
        {"value": "weltlich",  "label": "weltlich"},
        {"value": "sonstige",  "label": "sonstige"}
      ]
    },
    "tx_type": {
      "label": "Transaktionstyp",
      "value_kind": "from_data",
      "values_source": "epic_a.observations.transaction_types",
      "value_labels": {
        "_not_normalised": "noch nicht normalisiert",
        "Kauf": "Kauf",
        "Richtspruch": "Richtspruch",
        "Schuldbrief_Pfand": "Schuldbrief/Pfand",
        "Erbe": "Erbe",
        "Burgrecht": "Burgrecht",
        "Zahlung_Bestaetigung": "Zahlungsbestaetigung",
        "Uebergabe": "Uebergabe",
        "Revers": "Revers",
        "Verzicht": "Verzicht",
        "Stiftung": "Stiftung",
        "Vollmacht": "Vollmacht",
        "Satz": "Satz",
        "Bevollmaechtigung": "Bevollmaechtigung",
        "Lehensvergabe": "Lehensvergabe",
        "Verbot": "Verbot"
      }
    },
    "recipient_type": {
      "label": "Empfaenger-Typ",
      "value_kind": "from_data",
      "values_source": "epic_c.observations.recipient_type_totals",
      "value_labels_ref": "org_type"
    },
    "rel_type": {
      "label": "Beziehungs-Typ",
      "values": [
        {"value": "kin",    "label": "Verwandtschaft"},
        {"value": "occ",    "label": "Beruf"},
        {"value": "rep",    "label": "Vertretung"},
        {"value": "friend", "label": "Freundschaft"}
      ]
    }
  },
  "coverage": {
    "persons":       "Datenbasis: 4.214 Rechtsgeschaefte aus 1177-1414. Gezaehlt werden Nennungen, nicht individuelle Personen.",
    "sources":       "Datenbasis: 2.665 freigegebene Quellen aus QGW (2.037) und Stadtbuechern (628).",
    "events":        "Datenbasis: 4.214 Rechtsgeschaefte, davon 1.043 (24,7%) ins kontrollierte Vokabular ueberfuehrt.",
    "relationships": "Datenbasis: 12.038 annotierte Beziehungen, 5.592 beteiligte Personen."
  },
  "constraints": {
    "max_active_filters": 3
  }
}
