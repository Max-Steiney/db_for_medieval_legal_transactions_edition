   <text>
      <body>
         <div type="header">
            <p>Verwandtschaftsweisung für Ulrich Pawr</p>
         </div>
         <div type="entry" resp="rs">
            <p> Einbr. 2 Zg. (In dez: Item frewntschaft Ulreichs 4 ) des Pawm) <rs type="event"
                  ref="ev__StB_I_581">Am sambcztag vor sand Margreten tag <rs type="fn"
                     role="witness">kom fur den rat <rs type="person"
                        ref="pe__ulrich_paur_StB_I_581">Ulreich der <roleName type="prof"
                           cert="unknown">Pawr</roleName>, <roleName type="kin"
                           corresp="pe__heinrich_paur_StB_I_581"><add>sun</add></roleName><rs
                           type="person" ref="pe__heinrich_paur_StB_I_581">Hainreichs <roleName
                              type="dead">seligen</roleName> sun des <roleName type="prof"
                              cert="unknown">Pawrn</roleName></rs>,</rs> und hat da beweist mit den
                     zwain erbern mannen, mit <rs type="person" ref="pe__peter_paur_StB_I_581"
                           ><roleName type="title"><add>erbern</add></roleName>Petrein dem <roleName
                           type="prof" cert="unknown">Pawrn</roleName></rs> und mit <rs
                        type="person" ref="pe__martin_chern_StB_I_581"><roleName type="title"
                              ><add>erbern</add></roleName>Mertten dem <roleName type="prof"
                           cert="unknown">Chern</roleName> von Ertpurkch</rs></rs>, daz <rs
                     type="fn" role="issuer" cert="high"><rs type="person"
                        ref="pe__niklas_paur_StB_I_5"><add>Niclas</add></rs></rs>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__ulrich_paur_StB_I_581"
                        >er <roleName type="kin" corresp="pe__michael_paur_StB_I_581"><add>recht
                              prueder gewesen sind muterhalben</add></roleName>
                        <roleName type="kin" corresp="pe__peter_paur_StB_I_581"><add>recht prueder
                              gewesen sind muterhalben</add></roleName></rs> und <rs type="person"
                        ref="pe__michael_paur_StB_I_581">Michel <roleName type="prof" cert="unknown"
                              ><add>Pawrn</add></roleName>
                        <roleName type="kin" corresp="pe__niklas_paur_StB_I_5"
                           ><add>suen</add></roleName>
                        <roleName type="kin" corresp="pe__ulrich_paur_StB_I_581"><add>recht prueder
                              gewesen sind muterhalben</add></roleName></rs> und <rs type="person"
                        ref="pe__peter_paur_StB_I_581">Peter die <roleName type="prof"
                           cert="unknown">Pawrn</roleName>, <roleName type="kin"
                           corresp="pe__niklas_paur_StB_I_5"><add>suen</add></roleName>
                        <rs type="person" ref="pe__niklas_paur_StB_I_5">Niclas <roleName type="dead"
                              >seligen</roleName> suen des <roleName type="prof" cert="unknown"
                              >Pawrn</roleName></rs>, drey <roleName type="kin"
                           corresp="pe__ulrich_paur_StB_I_581">recht prueder</roleName>
                        <roleName type="kin" corresp="pe__ulrich_paur_StB_I_581">recht prueder
                           gewesen sind muterhalben</roleName></rs></rs>. Als darumb die obgenanten
                  erbern leut mit irn trewen an aides stat vor offem rat habent gesagt, als si ze
                  recht solten.</rs> 4) Danach gestrichenes des Parm. </p>
         </div>
