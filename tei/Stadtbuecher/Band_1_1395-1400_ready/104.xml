    <text>
        <body>
            <div type="header">
                <p>Feststellung nachgelassener Schulden aus echter Not nach Ulrich K asttner</p>
            </div>                   <div type="entry" resp="rs">
                <p> Einbr. 3 Zg., (zu 103) (Indez: Item notgult [ ... ]) (fol.17r) <rs type="event"
                        ref="ev__stb_I_104">Item desselben tags hat auch <rs type="fn"
                            role="witness"><rs type="person" ref="pe__anna_StB_I_103">die vorgenant
                                    <roleName type="title">fraw</roleName> Ann,<rs type="person"
                                    ref="pe__ulrich_chastner_StB_I_103">Ulreichs <roleName
                                        type="dead">seligen</roleName> des Kasttner</rs><roleName
                                    type="kin" corresp="pe__ulrich_chastner_StB_I_103"
                                    >wittib</roleName></rs>, mit den egenanten erbern leuten
                            beweist, als si ze recht solt, mit <rs type="person"
                                ref="pe__berthold_lang_QGW_II_I_1488"><roleName type="title"
                                        ><add>erbern</add>
                                </roleName><roleName type="title">hern</roleName> Perichtolten dem
                                Langen</rs>, <rs type="person"
                                ref="pe__niklas_radschmied_QGW_II_I_1062"><roleName type="title"
                                        ><add>erbern</add>
                                </roleName>Niclasen dem <roleName type="prof" cert="unknown"
                                    >Ratsmyd</roleName></rs> und mit <rs type="person"
                                ref="pe__jakob_ueberleger_StB_I_103"><roleName type="title"
                                        ><add>erbern</add>
                                </roleName>Jacoben dem Uberleger</rs></rs>, das <rs type="fn"
                            role="recipient"><rs type="person" ref="pe__anna_StB_I_103"
                            >sey</rs></rs>
                        <rs type="fn" role="issuer"><rs type="person"
                                ref="pe__ulrich_chastner_StB_I_103">der vorgenant ir wirt</rs></rs>
                        in rechter ehaffter notgült ze gelten hinder im lazzen hat umb drewhundert
                        phunt mynner virczehen phunt Wienner phening. Als si auch darumb mit irn
                        trewn an ayde stat vor unser in offem rat habent gesagt, als si ze recht
                        solten.</rs>
                </p>
            </div>
