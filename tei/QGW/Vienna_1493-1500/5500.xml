         <div type="abstract">
            <p><rs type="event" ref="ev__QGW_II_II_5500">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__appolonia_QGW_II_III_5500"
                        >Appolonia, des <rs type="person" ref="pe__jakob_aigner_QGW_II_III_5500"
                           >Jacob Aigner, <roleName type="occ" corresp="org__pressburg"
                              >burger</roleName> zu Prespurg,</rs> eeliche <roleName type="kin"
                           corresp="pe__jakob_aigner_QGW_II_III_5500">hausfrau</roleName></rs></rs>,
                  stellt wegen des von <rs type="person" ref="pe__laurenz_swancz_QGW_II_II_2627"
                     >ihren <roleName type="kin" corresp="pe__appolonia_QGW_II_III_5500"
                        >Eltern</roleName>, Larencz Swancz, ettwann <roleName type="occ"
                        corresp="org__wien">burger</roleName> zu Wienn,<roleName type="dead"
                           ><add>hinterlassenen</add></roleName></rs> und <rs type="person"
                     ref="pe__afra_SB_CD_01169">Affra, <roleName type="dead"
                        >hinterlassenen</roleName>
                     <roleName type="kin" corresp="pe__appolonia_QGW_II_III_5500"
                        ><add>Eltern</add></roleName></rs> Gutes, insbesondere wegen eines halben
                  Hauses, daselbs zu Wienn am Hohnmarkcht gelegn, <rs type="fn" role="recipient"><rs
                        type="person" ref="pe__jakob_aigner_QGW_II_III_5500">ihrem Manne</rs></rs>
                  eine Vollmacht aus. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_5500"><rs type="fn" role="witness">Besiegelt mit
                     dem kleinen Siegel der <rs type="org" ref="org__pressburg">Stadt Pressburg</rs>
                     .</rs>
               </rs></p>
