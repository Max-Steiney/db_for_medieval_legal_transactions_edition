   <text>
      <body>
         <div type="abstract">
            <p><rs type="fn" role="issuer">
                  <rs type="person" ref="pe__niklas_paumgartner_QGW_II_III_5484">Niclas Paungartner,
                     der <roleName type="prof">vischer</roleName>, <roleName type="title_ref"
                        select="pl__neusiedl_am_see">gesessen zu Neusidl am See</roleName>, für sich
                     und als <roleName type="rep" corresp="pe__andreas_paumgartner_QGW_II_III_5484"
                        >Bevollmächtigter</roleName><roleName type="rep"
                        corresp="pe__katharina_QGW_II_III_5484_b">Bevollmächtigter</roleName>
                     <rs type="person" ref="pe__andreas_paumgartner_QGW_II_III_5484">Andreen
                        Paungarttner zu Pamaken <roleName type="title_ref"
                           select="pl__neusiedl_am_see">daselbs am See</roleName></rs> und <rs
                        type="person" ref="pe__katharina_QGW_II_III_5484_b">Kathrein, <rs
                           type="person" ref="pe__niklas_sneider_QGW_II_III_5484">Niclasen Sneiders,
                              <roleName type="title_ref" select="pl__neusiedl_am_see">enhalb des
                              Sees gesessen</roleName></rs>, <roleName type="kin"
                           corresp="pe__niklas_sneider_QGW_II_III_5484">hausfraun</roleName></rs> ,
                     seiner <roleName type="kin" corresp="pe__andreas_paumgartner_QGW_II_III_5484"
                        >geswistreid</roleName><roleName type="kin"
                        corresp="pe__katharina_QGW_II_III_5484_b"
                     ><add>geswistreid</add></roleName>,</rs></rs> bestätigt, dass<rs type="fn"
                  role="recipient">
                  <rs type="person" ref="pe__paul_kek_QGW_II_III_5384"><roleName type="title"
                        >her</roleName> Paul Kegk, <roleName type="occ" corresp="org__wien"
                        >burgermaister</roleName>, </rs>und <rs type="org" ref="org__wien">der rat
                     gemain der stat Wienn</rs> durch <rs type="person"
                     ref="pe__laurenz_taschendorfer_QGW_II_III_5485"><roleName type="title"
                        >hern</roleName> Larenczen Taschendorffer, iren <roleName type="occ"
                        corresp="org__wien">mitgesworn des rats</roleName><roleName type="occ"
                        corresp="org__wien"><add>verweser irer stat
                     gruntbüecher</add></roleName></rs>, und <rs type="person"
                     ref="pe__johann_lanczhart_QGW_II_III_5485">Hannsen Lanczhartten, iren <roleName
                        type="occ" corresp="org__wien">mitburger</roleName>, baid <roleName
                        type="occ" corresp="org__wien">verweser irer stat
                     gruntbüecher</roleName></rs></rs> , auf den Verzicht hin, <rs type="event"
                  ref="ev__QGW_II_III_5484"> welchen <rs type="person"
                     ref="pe__margarethe_QGW_II_III_5484">Margreth, <rs type="person"
                        ref="pe__jost_von_andernach_QGW_II_III_5484">Jobsten von Adarnam, <roleName
                           type="occ" corresp="org__bacharach">mitburger</roleName> zu Pachara</rs>,
                        <roleName type="kin" corresp="pe__jost_von_andernach_QGW_II_III_5484"
                        >hausfrau</roleName>, ihre <roleName type="kin"
                        corresp="pe__niklas_paumgartner_QGW_II_III_5484"
                        >swägerin</roleName><roleName type="kin"
                        corresp="pe__katharina_QGW_II_III_5484_b"
                        ><add>swägerin</add></roleName><roleName type="kin"
                        corresp="pe__andreas_paumgartner_QGW_II_III_5484"
                        ><add>swägerin</add></roleName></rs>, von <rs type="person"
                     ref="pe__konrad_fues_QGW_II_III_5484">Cunczen Fuesen, des <roleName type="prof"
                        >schuster</roleName>, <roleName type="occ" corresp="org__wien"
                        >mitburger</roleName> daselbs zu Wienn, irs [ 438] <roleName type="kin"
                        corresp="pe__margarethe_QGW_II_III_5484">brueder</roleName>, ihres <roleName
                        type="kin" corresp="pe__niklas_paumgartner_QGW_II_III_5484"
                        >swager</roleName><roleName type="kin"
                        corresp="pe__andreas_paumgartner_QGW_II_III_5484"
                        ><add>swager</add></roleName>
                     <roleName type="kin" corresp="pe__katharina_QGW_II_III_5484_b"
                           ><add>swager</add></roleName>
                     <roleName type="dead">selign</roleName></rs>, gelassen erb und varunden guts
                  wegen, gethan hat, ihm 75 lb dn. gueter landeswerung in Osterreich ausgefolgt
                  haben, so von verkauffung und verttigung wegn ains hauss, gelegen hie undern
                  Gürtlern, darumb etwann <rs type="person" ref="pe__katharina_QGW_II_III_5484_a"
                     >Kathrein, des obgenannten Conczen Fuesen <roleName type="kin"
                        corresp="pe__konrad_fues_QGW_II_III_5484">hausfrau</roleName> , ihr
                        <roleName type="kin" corresp="pe__margarethe_QGW_II_III_5484"
                        >muem</roleName>
                     <roleName type="dead">selige</roleName></rs>, nucz und gewer gehabt hat, bei
                  dem städtischen Grundbuche hinterlegt waren</rs>. </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_5485"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="pe__wolfgang_hurber_QGW_II_III_5480"
                           ><roleName type="title">edeln</roleName> Wolfgangn Hurber<roleName
                           type="occ" corresp="org__wien"><add>burger</add></roleName></rs> und <rs
                        type="person" ref="pe__erhard_paumschaber_QGW_II_III_4464">Erharttn
                        Pemschaber, baider <roleName type="occ" corresp="org__wien"
                           >burger</roleName> zu Wienn</rs>.</rs>
               </rs></p>
         </div>
