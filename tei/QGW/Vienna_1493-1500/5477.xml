   <text>
      <body>
         <div type="abstract">
            <p>
               <rs type="fn" role="issuer"><rs type="person" ref="pe__barbara_QGW_II_III_5476"
                     >Barbara, <rs type="person" ref="pe__wolfgang_tunkchel_QGW_II_III_5476"
                        >Wolfgangn Tunkehl, <roleName type="occ" corresp="org__wien"
                           >burger</roleName> zu Wienn</rs>, <roleName type="kin"
                        corresp="pe__wolfgang_tunkchel_QGW_II_III_5476">hausfrau</roleName>, <rs
                        type="person" ref="pe__johann_leschenprant_QGW_II_III_4619">Hannsen
                        Leschenprant, <roleName type="occ" corresp="org__wien">burger</roleName>
                        daselbs</rs>, und <rs type="person" ref="pe__orea_QGW_II_III_5471">Orea,
                        seiner <roleName type="kin"
                           corresp="pe__johann_leschenprant_QGW_II_III_4619">hausfraun</roleName>
                        <roleName type="dead">selign</roleName></rs>, <roleName type="kin"
                        corresp="pe__johann_leschenprant_QGW_II_III_4619"
                        >tochter</roleName><roleName type="kin" corresp="pe__orea_QGW_II_III_5471"
                           ><add>tochter</add></roleName></rs></rs>, macht <rs type="fn"
                  role="recipient"><rs type="person" ref="pe__paul_kek_QGW_II_III_5384"><roleName
                        type="title">herrn</roleName> Pauln Kekchen, <roleName type="occ"
                        corresp="org__wien">burgermaister</roleName></rs>, <rs type="org"
                     ref="org__wien">dem Rathe und den Verwesern ihrer Grundbücher</rs></rs>
               Mittheilung von der mit <rs type="event" ref="ev__QGW_II_III_5476">Urk. n° 5476</rs>
               verbrieften Uebergabe. </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_5477"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="pe__johann_mulhauser_QGW_II_III_4119"
                        >Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Hannsen
                        Mülhauser</rs> und <rs type="person"
                        ref="pe__erhard_paumschaber_QGW_II_III_4464"><roleName type="title"
                           corresp="org__wien"><add>Bürger</add></roleName>Erharten
                     Pemschaber</rs>.</rs>
               </rs></p>
         </div>
