   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="ev__QGW_II_II_5492">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__eitelfriedrich_graf_zu_hohenzollern_QGW_II_III_5492">Ytelfriderich,
                           <roleName type="title">graven</roleName> zu Zollr,</rs>
                     <rs type="person" ref="pe__sigmund_prueschink_QGW_II_III_5492">Sigmund
                        Pruschinkh, <roleName type="title">freiherr</roleName> zu Stettemberg</rs>,
                     und <rs type="person" ref="pe__kaspar_von_roggendorf_QGW_II_III_5492">Caspar
                        von Rogendorff</rs></rs> beurkunden die in dem Streite zwischen <rs
                     type="fn" role="recipient"><rs type="person"
                        ref="pe__wolfgang_rigl_QGW_II_III_5492">&gt;Wolfgangen Rigl<roleName
                           type="occ" corresp="org__wien"><add>burgern</add></roleName></rs> ains,
                        <rs type="person" ref="pe__heinrich_rigl_QGW_II_III_5492">Hainrichen Rigl,
                           <roleName type="occ" corresp="org__wien">burgern</roleName> zu Wienn, für
                        sich selbs und <roleName type="rep"
                           corresp="pe__balthasar_rigl_QGW_II_III_5492">anstat und als
                           gerhab</roleName><roleName type="rep"
                           corresp="pe__bartholomaeus_rigl_QGW_II_III_5492"><add>anstat und als
                              gerhab</add></roleName><roleName type="rep"
                           corresp="pe__johanna_QGW_II_III_5492"><add>anstat und als
                           gerhab</add></roleName> Bertlmeen, Walthasarn, der Rigl, und Johannen,
                        seiner <roleName type="kin" corresp="pe__balthasar_rigl_QGW_II_III_5492"
                           >geswistred</roleName><roleName type="kin"
                           corresp="pe__bartholomaeus_rigl_QGW_II_III_5492"
                           >geswistred</roleName><roleName type="kin"
                           corresp="pe__johanna_QGW_II_III_5492">geswistred</roleName></rs>, und <rs
                        type="person" ref="pe__christoph_steger_QGW_II_III_5492">Cristoffen Steger
                        als <roleName type="rep" corresp="pe__thomas_meingos_QGW_II_III_5492"
                           >gewalttrager</roleName> Thoman Meigass von wegen <rs type="person"
                           ref="pe__helena_QGW_II_III_5492">Helen, seiner <roleName type="kin"
                              corresp="pe__thomas_meingos_QGW_II_III_5492">hausfrauen</roleName>,
                           auch der bemelten Rigl <roleName type="kin"
                              corresp="pe__heinrich_rigl_QGW_II_III_5492"
                        >swester</roleName></rs></rs></rs>, . . . . des andern tails . . . . von <rs
                     type="person" ref="pe__barbara_QGW_II_III_5492"><roleName type="dead"
                        >weilent</roleName> Barbara, ettwenn Hainrichen Rigl <roleName type="kin"
                        corresp="pe__heinrich_rigl_QGW_II_III_5492">witiben</roleName>, irer
                        <roleName type="kin" corresp="pe__helena_QGW_II_III_5492"
                     >endl</roleName></rs>, gelassen hab und guter , in welcher Angelegenheit schon
                  der <rs type="person" ref="pe__friedrich_iii_herzog_von_oesterreich_QGW_II_I_853"
                        ><roleName type="dead">verstorbene</roleName> Kaiser Friedrich III.</rs>
                  eine Verhandlung angesetzt hatte, gefällte Entscheidung: Die streitigen Güter mit
                  Ausnahme des Hauses, an sand Peters freithof zu Wienn gelegen, sollen in drei
                  Theile, wovon dem Heinrich mit seinen Geschwistern zwei, dem Wolfgang einer
                  zustehen soll, das Haus in zwei Theile getheilt werden, von denen Heinrich für
                  sich und seine Geschwister einen wählen darf. Wer den Spruch nicht hält, soll dem
                  Römischen Könige 1000 Ungrisch und ducaten guldein zu peen verfallen sein.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_5492"><rs type="fn" role="witness">Siegler: <rs
                        type="person" ref="pe__eitelfriedrich_graf_zu_hohenzollern_QGW_II_III_5492"
                        >Graf Eitelfriedrich</rs>, <rs type="person"
                        ref="pe__sigmund_prueschink_QGW_II_III_5492">Prüschink</rs> und der <rs
                        type="person" ref="pe__andreas_viechtenstainer_QGW_II_III_5492"><roleName
                           type="title">edle</roleName> Andre Viechtenstainer</rs>.</rs>
               </rs></p>
