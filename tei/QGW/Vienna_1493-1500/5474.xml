   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="ev__QGW_II_II_5474">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__jakob_leb_QGW_II_III_5474"
                        >Jacob Leb zu Puech<roleName type="kin"
                           corresp="pe__ulrich_leb_QGW_II_III_5474"
                           ><add>kinder</add></roleName><roleName type="kin"
                           corresp="pe__katharina_QGW_II_III_5474"><add>kinder</add></roleName></rs>
                     und <rs type="person" ref="pe__brigitta_QGW_II_III_5474">Breid, sein <roleName
                           type="kin" corresp="pe__jakob_leb_QGW_II_III_5474">swester</roleName>,
                        Stephan des Kelhaimer eeliche <roleName type="kin"
                           corresp="pe__stephan_kelhaimer_QGW_II_II_3602"
                           >hausfrau</roleName><roleName type="kin"
                           corresp="pe__ulrich_leb_QGW_II_III_5474"
                           ><add>kinder</add></roleName><roleName type="kin"
                           corresp="pe__katharina_QGW_II_III_5474"
                     ><add>kinder</add></roleName></rs></rs>, <rs type="person"
                     ref="pe__ulrich_leb_QGW_II_III_5474">Ulrich des Leben von Puech</rs> und <rs
                     type="person" ref="pe__katharina_QGW_II_III_5474">Kathrei, seiner <roleName
                        type="kin" corresp="pe__ulrich_leb_QGW_II_III_5474">hausfrau</roleName>
                     <roleName type="dead">seligen</roleName></rs>, kinder , stellen wegen des von
                  ihrem <rs type="person" ref="pe__niklas_leb_QGW_II_III_5474"><roleName type="kin"
                        corresp="pe__jakob_leb_QGW_II_III_5474">Bruder</roleName><roleName
                        type="kin" corresp="pe__brigitta_QGW_II_III_5474"
                        ><add>Bruder</add></roleName> Niklasen dem Leben, weilend <roleName
                        type="occ" corresp="org__wien">mitpurger</roleName> zu Wienn <roleName
                        type="dead">seligen</roleName></rs>, hinterlassenen Gutes dem genannten <rs
                     type="fn" role="recipient"><rs type="person"
                        ref="pe__stephan_kelhaimer_QGW_II_II_3602">Stephan Kelhaimer</rs></rs> eine
                  Vollmacht aus. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_5474"><rs type="fn" role="witness">Siegler: <rs
                        type="person" ref="pe__bernhard_schellenberger_QGW_II_III_5474">der
                           <roleName type="title">edle feste</roleName> Pernhart Schellenberger zu
                        Piberstain</rs> und der <rs type="person"
                        ref="pe__sigmund_maendl_QGW_II_III_5474"><roleName type="title"
                           >edle</roleName> Sigmund Mändl, <roleName type="occ"
                           corresp="org__luftenberg">hausphleger</roleName> zu Luftenberg</rs>.
                  </rs></rs></p>
         </div>
