   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="ev__QGW_II_II_5491">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__veit_widmer_QGW_II_III_5491">Veit Widmer, der <roleName type="prof"
                           >pegk</roleName>, <roleName type="occ" corresp="org__wien"
                           >mitburger</roleName> zu Wienn</rs>, und <rs type="person"
                        ref="pe__appolonia_QGW_II_III_5491">Appolonia, sein <roleName type="kin"
                           corresp="pe__veit_widmer_QGW_II_III_5491">hausfrau</roleName></rs></rs>,
                  verkaufen <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__paul_kek_QGW_II_III_5384"><roleName type="title"
                           >hern</roleName> Pauln Kegkn, <roleName type="occ" corresp="org__wien"
                           >burgermaister</roleName>, und des <roleName type="occ"
                           corresp="org__wien">rates</roleName> gemain der stat Wienn</rs></rs> 4 lb
                  dn. gelts purkrechts (ablösbar) auf ihrem Hause, gelegen bei den Himlportten
                  zunagst weilend <rs type="person" ref="pe__peter_reczinger_QGW_II_III_4567">Petern
                     Räczinger, des <roleName type="prof">stainmessen</roleName></rs>, haus an aim
                  tail , um 32 lb dn., welche emaln auch auf demselbn haus durch <rs type="person"
                     ref="pe__simon_haselpekch_QGW_II_III_5491">Simon Haselpegken</rs> verschriben
                  gewesen sein, . . . . . . <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__leonhard_neunkircher_QGW_II_III_5491"><roleName type="title"
                           >maister</roleName> Leonhartten Neunkircher von Amberg, <roleName
                           type="prof">licenciaten geistlichen rechten</roleName> und <roleName
                           type="occ"
                           corresp="org__wien-st_stephan-altar_zwoelfapostel-messe_ybbs_anna"
                           >caplon</roleName> der <rs type="org"
                           ref="org__wien-st_stephan-altar_zwoelfapostel-messe_ybbs_anna">mess, die
                           Anna, Hannsen von Ybss hausfrau selige, auf der Zwelifboten altar daselbs
                           zu sand Steffen gestift hat</rs></rs> , und seinen Nachfolgern</rs>.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_5491"><rs type="fn" role="witness">Besiegelt mit
                     dem städtischen <rs type="org" ref="org__wien">Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="pe__johann_mulhauser_QGW_II_III_4119">Wiener
                           <roleName type="occ" corresp="org__wien">Bürgers</roleName> Hanns
                        Mülhauser</rs>.</rs>
               </rs></p>
         </div>
         <div type="nota">
            <p>Indorsat: Rubrum 53. </p>
