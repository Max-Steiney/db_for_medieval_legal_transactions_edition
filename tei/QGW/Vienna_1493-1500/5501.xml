   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="ev__QGW_II_II_5501">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__ludwig_westhauser_QGW_II_III_5501">Ludweig Westhauser, <roleName
                           type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs></rs>,
                  verkauft <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__paul_kek_QGW_II_III_5384"><roleName type="title"
                           >herren</roleName> Pauln Kegk, <roleName type="occ" corresp="org__wien"
                           >burgermaister</roleName></rs>, und <rs type="org" ref="org__wien">des
                        rats gemain der stat zu Wienn</rs></rs> sein halbes Haus, ganczes gelegen am
                  Alten Kolmargkt zunagst maister Hannsen Goltperger, ycz pfarrer zu sant Michel
                  hie, haus, und ist der erst tail des vorgemelten haus, des gegntail Hanns Swarcz,
                  zemstrigker, innhat , um 135 lb dn. gueter landeswerung in Osterreich . . . . <rs
                     type="fn" role="recipient"><rs type="person"
                        ref="pe__oswald_entenschuester_QGW_II_III_5501">Oswolten Enttenschuester,
                        dem <roleName type="prof">schuester</roleName>, <roleName type="occ"
                           corresp="org__wien">mitburger</roleName> zu Wienn </rs>, und <rs
                        type="person" ref="pe__elisabeth_QGW_II_III_5501">Elspethen, seiner
                           <roleName type="kin" corresp="pe__oswald_entenschuester_QGW_II_III_5501"
                           >hausfrauen</roleName></rs>.</rs>
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_5501"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="pe__johann_mulhauser_QGW_II_III_4119">Wiener
                           <roleName type="occ" corresp="org__wien">Bürgers</roleName> Hanns
                        Mulhauser</rs>.</rs>
               </rs></p>
