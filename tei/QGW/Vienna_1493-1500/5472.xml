   <text>
      <body>
         <div type="abstract">
            <p>
               <rs type="fn" role="issuer"><rs type="person"
                     ref="pe__albrecht_frankch_QGW_II_II_4088">Albrecht Frankch, <roleName
                        type="occ" corresp="org__wiener_neustadt">burger</roleName> zu der
                     Neunstat,</rs> und <rs type="person" ref="pe__heinrich_frankch_QGW_II_II_4088"
                     >Hainrich Frankch, der junger, <roleName type="occ" corresp="org__wien"
                        >burger</roleName> zu Wienn, sein <roleName type="kin"
                        corresp="pe__albrecht_frankch_QGW_II_II_4088">brueder</roleName></rs></rs> ,
               machen <rs type="fn" role="recipient"><rs type="person"
                     ref="pe__paul_kek_QGW_II_III_5384"><roleName type="title">herrn</roleName>
                     Pauln Kekchen, <roleName type="occ" corresp="org__wien"
                        >burgermaister</roleName></rs>, und <rs type="org" ref="org__wien">dem rate
                     gemain der stat zu Wienn</rs></rs>, auch den innehabern irer statgrundbücher
               Mittheilung von der mit <rs type="event" ref="ev__QGW_II_III_5471">Urk. n° 5471</rs>
               verbrieften Uebergabe. </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_5472"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="pe__jakob_kraukcher_QGW_II_II_3353"
                        >Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Jacobn
                        Kraukher</rs> und <rs type="person"
                        ref="pe__johann_mulhauser_QGW_II_III_4119"> Hannsen Mülhauser<roleName
                           type="occ" corresp="org__wien"><add>Bürger</add></roleName></rs>.</rs>
               </rs></p>
         </div>
