   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="ev__QGW_II_II_5496">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__michael_vorstl_QGW_II_III_5496">Michel Vorsstl, <roleName
                           type="occ" corresp="org__obernsulz">richter</roleName></rs>, <rs
                        type="person" ref="pe__gilg_zimmermann_QGW_II_II_3264">Gilig Zimerman
                           <roleName type="prof">zechmaister</roleName></rs>, <rs type="person"
                        ref="pe__paul_zechmeister_QGW_II_III_5496">Paul Zechmaister, baid <roleName
                           type="prof">zechmaister</roleName></rs>, und <rs type="org"
                        ref="org__obernsulz">die gancz gemain zu Obernsulcz</rs></rs> verkaufen zwei
                  zur Pfarrkirche daselbst gehörige Weingärten, ainer, des sechs viertail ist,
                  genannt das Full, zunagst des obgenanntn Michel Vörsstl weingarttn, davon man
                  järlichen diennet den herrn zum Heilign Kreucz 6 dn. zu sand Michels tag zu
                  gruntdienst, und der ander, des vier viertail sind, genannt der Holczweingarttn,
                  zunagst Jannsen Wolff weingartn, davon man jerlichen dient zu des Neithartn liecht
                  in der pfarr zu Obernsulcz 5 dn. auch zu sand Michels tag zu gruntdienst, baid zu
                  Obernsulcz , um 37 lb dn. <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__wolfgang_placzer_QGW_II_III_5496"><roleName type="title"
                           >hern</roleName> Wolfgangen Placzer, <roleName type="occ"
                           corresp="org__passau-dioezese">briester</roleName> Passauer
                        bistumbs,</rs> und seinen erben</rs>. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_5496"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="pe__wolfgang_hurber_QGW_II_III_5480"
                           ><roleName type="title">edeln</roleName> Wolfgangn Hurber<roleName
                           type="occ" corresp="org__wien"><add>burger</add></roleName></rs> und <rs
                        type="person" ref="pe__johann_mulhauser_QGW_II_III_4119">Hannsen Mülhauser,
                        baider <roleName type="occ" corresp="org__wien">burger</roleName> zu
                        Wienn</rs>.</rs>
               </rs></p>
         </div>
