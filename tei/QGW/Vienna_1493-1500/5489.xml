   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="ev__QGW_II_II_5489">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__johann_mangelhaimer_QGW_II_III_5489">Hanns Mangelhaimer</rs> und
                        <rs type="person" ref="pe__achatius_mostorffer_QGW_II_III_5489">Achacz
                        Mostorffer, der <roleName type="prof">goldslaher</roleName>, <roleName
                           type="occ" corresp="org__wien">burger</roleName> zu Wienn, als <roleName
                           type="rep" corresp="pe__bartholomaeus_scherdinger_QGW_II_III_5489"
                           >Gerhaben</roleName></rs></rs>
                  <rs type="person" ref="pe__bartholomaeus_scherdinger_QGW_II_III_5489">Bertlmeen,
                        <rs type="person" ref="pe__wolfgang_scherdinger_QGW_II_III_5489">Wolffgangen
                        Scherdinger, <roleName type="dead">weilend</roleName> gesessen vor Widmertor
                        in der Laimbgrueb, <roleName type="occ" corresp="org__wien"
                           >mitburger</roleName> daselbs seligen,</rs>
                     <roleName type="kin" corresp="pe__wolfgang_scherdinger_QGW_II_III_5489"
                        >sun</roleName></rs> , verkaufen <rs type="fn" role="other"><triggerstring
                        n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__peter_haniffogel_QGW_II_III_5489"><roleName
                           type="title">maister</roleName> Petern Hanifvogel, <roleName type="occ"
                           corresp="org__wien-st_maria_am_gestade-altar_elftausend_jungfrauen"
                           >caplon</roleName> der Aindleftausent Maid altar hincz Unser Lieben
                        Frauen auf der Stetten zu Wienn</rs></rs> , drei Viertel Weingarten, gelegen
                  zu Braitensee im Altenperg . . . . zunagst der pfeiffer zech weingartten an aim
                  rain , von denen man 3 sh. dn. für zehent und pergkrecht und 4½ dn. zu voitrecht
                  dient, um 28 lb dn. <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__wandala_QGW_II_III_5489">der <roleName type="title">edln
                           frauen</roleName> Wendulen, <rs type="person"
                           ref="pe__johann_kellner_QGW_II_III_5489"><roleName type="dead"
                              >weilend</roleName>
                           <roleName type="title">hern</roleName> Johan Keller, <roleName
                              type="prof">lerer der recht</roleName> und <roleName type="occ"
                              corresp="org__heiliges_roemisches_reich">kaiserlichem
                              fiscal</roleName></rs>, gelassen <roleName type="kin"
                           corresp="pe__johann_kellner_QGW_II_III_5489">witib</roleName></rs></rs> .
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_5489"><rs type="fn" role="witness">Siegler: der
                        <rs type="person" ref="pe__heinrich_schrutauer_QGW_II_III_3421"><roleName
                           type="title">edle</roleName> Hainreich Schrutauer<roleName type="occ"
                           corresp="org__wien"><add>Bürger</add></roleName></rs> und <rs
                        type="person" ref="pe__johann_mulhauser_QGW_II_III_4119">Hanns Mülhauser,
                        beide <roleName type="occ" corresp="org__wien">Bürger</roleName> zu
                        Wien</rs>.</rs>
               </rs></p>
         </div>
