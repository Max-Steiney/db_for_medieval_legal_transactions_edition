   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="ev__QGW_II_II_5494">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__paul_kek_QGW_II_III_5384"
                        >Paul Kegk, <roleName type="occ" corresp="org__wien"
                           >burgermaister</roleName></rs>, und <rs type="org" ref="org__wien">der
                        rate gemain der stat Wienn</rs></rs> verleihen die <rs type="org"
                     ref="org__wien-st_stephan-altar_allerseelen-messe_meczner">ewige Messe, die
                     weilend <rs type="person" ref="pe__anna_QGW_II_II_3489"><roleName type="title"
                           >frau</roleName> Anna, <rs type="person"
                           ref="pe__otto_meczner_QGW_II_II_2591">Otten Meczner<roleName type="dead"
                                 ><add>witib</add></roleName></rs>
                        <roleName type="kin" corresp="pe__otto_meczner_QGW_II_II_2591"
                           >wittib</roleName>
                        <roleName type="dead">selige</roleName></rs>, auf Allerselen altar zu sand
                     Steffan hie gestift hat und die ihnen mit lediger und freier übergab</rs> . . .
                  . <rs type="person" ref="pe__michael_wisent_QGW_II_III_5494"><roleName
                        type="title">hern</roleName> Micheln Wisent ledig</rs> worden ist, . . .
                     .<rs type="fn" role="recipient">
                     <rs type="person" ref="pe__michael_deimler_QGW_II_III_5494">Michaeln Deymel von
                        Re/ob, <roleName type="occ" corresp="org__passau-dioezese"
                           >accolit</roleName> Passauer pistumbs</rs></rs> . </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_5494"><rs type="fn" role="witness">Besiegelt mit
                     ihrem anhangundem <rs type="org" ref="org__wien">statinsigl</rs>.</rs>
               </rs></p>
