   <text>
      <body>
         <div type="abstract">
            <p>
               <rs type="fn" role="issuer"><rs type="person" ref="pe__barbara_QGW_II_III_5476"
                     >Barbara, <rs type="person" ref="pe__wolfgang_tunkchel_QGW_II_III_5476"
                        >Wolfgangn Tunkehl, <roleName type="occ" corresp="org__wien"
                           >burger</roleName> zu Wienn</rs>, <roleName type="kin"
                        corresp="pe__wolfgang_tunkchel_QGW_II_III_5476">hausfrau</roleName>, <rs
                        type="person" ref="pe__johann_leschenprant_QGW_II_III_4619">Hannsen
                        Leschenprant, <roleName type="occ" corresp="org__wien">burger</roleName>
                        daselbs</rs>, und <rs type="person" ref="pe__orea_QGW_II_III_5471">Orea,
                        seiner <roleName type="kin"
                           corresp="pe__johann_leschenprant_QGW_II_III_4619">hausfraun</roleName>
                        <roleName type="dead">selign</roleName></rs>, <roleName type="kin"
                        corresp="pe__johann_leschenprant_QGW_II_III_4619"
                        >tochter</roleName><roleName type="kin" corresp="pe__orea_QGW_II_III_5471"
                           ><add>tochter</add></roleName></rs>
               </rs>, übergibt <rs type="fn" role="other">mit Handen <rs type="person"
                     ref="pe__paul_kek_QGW_II_III_5384"><roleName type="title">herren</roleName>
                     Pauln Kekchen, <roleName type="occ" corresp="org__wien"
                        >burgermaister</roleName></rs>, und des <rs type="rs" ref="org__wien">Rathes</rs></rs>
               <rs type="fn" role="recipient">dem<rs type="person"
                     ref="pe__johann_koeppl_QGW_II_III_5471">
                     <roleName type="title">edeln</roleName> Hannsen Kopplen, <roleName type="occ"
                        corresp="org__wien">burger</roleName> zu Wienn, ihrem <roleName type="kin"
                        corresp="pe__barbara_QGW_II_III_5476">vettern</roleName></rs>,</rs> all und
               yglich ihre gerechtigkait an dem in <rs type="event" ref="ev__QGW_II_III_5471"> Urk.
                  n° 5471</rs> bezeichneten Hause und Gewandgewölbe. </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_5476"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="pe__johann_mulhauser_QGW_II_III_4119">Wiener
                           <roleName type="occ" corresp="org__wien">Bürgers</roleName> Hanns
                        Mülhauser</rs>.</rs>
               </rs></p>
         </div>
