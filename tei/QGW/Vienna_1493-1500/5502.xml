   <text>
      <body>
         <div type="abstract">
            <p>
               <rs type="fn" role="issuer"><rs type="person" ref="pe__asem_prancz_QGW_II_III_5502"
                     >Asem Prancz, <roleName type="occ" corresp="org__st_andrae">burger</roleName>
                     zu Sand Andre im Lavental<add>
                        <roleName type="kin" corresp="pe__leopold_prancz_QGW_II_III_5502"
                           >bruder</roleName></add></rs>, und <rs type="person"
                     ref="pe__georg_hochholczer_QGW_II_III_5502">Jorg Hocholczer, <roleName
                        type="occ" corresp="org__uttendorf">burger</roleName> zu Uttendorf, <rs
                        type="person" ref="pe__leopold_prancz_QGW_II_III_5502">des <roleName
                           type="title">hochgelerten herrn</roleName> Leupolten Pranczen, <roleName
                           type="prof">gaistlicher rechten doctor seligen</roleName></rs>, brueder
                     und <roleName type="kin" corresp="pe__leopold_prancz_QGW_II_III_5502"
                        >vetter</roleName></rs></rs> , <rs type="event" ref="NULL">welche <rs
                     type="person" ref="pe__johann_schurling_QGW_II_III_5502">Hannsen Schurling, des
                     Römischen Königs <roleName type="occ"
                        corresp="pe__maximilian_i_kaiser_QGW_II_III_5504" cert="high"
                        >zuschroter</roleName></rs>, ihr Haus, in Kernerstrass gelegen, so mit
                  erbschaft durch obgemelts doctor Leopolden tod an sie gevallen, zu kauffen geben
                  und sich verpflichtet haben</rs>, den Käufer in Jahresfrist an die gwer solichs
               haus zu bringen, obwohl sie selbst noch nicht in das Grundbuch eingetragen sind,
               stellen zum Zwecke der erforderlichen Umschreibung <rs type="fn" role="recipient"><rs
                     type="person" ref="pe__johann_schurling_QGW_II_III_5502">dem genannten
                     Schurling</rs></rs> eine Vollmacht aus . </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_5502"><rs type="fn" role="witness">Siegler: <rs
                        type="person" ref="pe__heinrich_schrutauer_QGW_II_III_3421">der <roleName
                           type="title">edle</roleName> Hainrich Schrattauer<roleName type="occ"
                           corresp="org__wien"><add>burger</add></roleName></rs> und<rs
                        type="person" ref="pe__johann_mulhauser_QGW_II_III_4119"> Hanns Mülhauser,
                        beide <roleName type="occ" corresp="org__wien">burger</roleName> zu
                        Wyen</rs></rs>
               </rs></p>
         </div>
