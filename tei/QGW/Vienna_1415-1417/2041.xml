         <div type="abstract">
            <p><rs type="event" ref="ev__QGW_II_II_2041">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__erhard_just_QGW_II_II_2041"
                        >Erhart Just, <rs type="person"
                           ref="pe__ernst_herzog_von_oesterreich_QGW_II_I_1332"><roleName type="occ"
                              corresp="org__oesterreich-herzogtum">Herzog</roleName> Ernsts
                              <roleName type="occ"
                              corresp="pe__ernst_herzog_von_oesterreich_QGW_II_I_1332"
                              >Diener</roleName></rs></rs></rs>, schreibt <rs type="fn"
                     role="recipient">dem <rs type="person"
                        ref="pe__rudolf_angerfelder_QGW_II_I_1335"><roleName type="occ"
                           corresp="org__wien">Bürgermeister</roleName> Rudolfen dem
                        Angervelder</rs> und dem <rs type="org" ref="org__wien">Innern
                     Rathe</rs></rs>, dass er mit seinen Verwandten <rs type="person"
                     ref="pe__hans_veitsperger_QGW_II_II_2041"><roleName type="title"
                        >hern</roleName> Hannsen den Veitsperger</rs>, <roleName type="occ"
                     corresp="org__perchtoldsdorf-pfarre">pharrer</roleName> ze Perchdolczdarff
                  etc., <triggerstring n="fn">bevollmächtigt</triggerstring> habe, sein Haus, gelegen in
                  der Pippingerstrass, zu verkaufen, und bittet sie, es gegebenen Falles
                  auszurichten und zu fertigen, ihn aber aus ihrem Stadtbuche auszuschreiben.
               </rs></p>
