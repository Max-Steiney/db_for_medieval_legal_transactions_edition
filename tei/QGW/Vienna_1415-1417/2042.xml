   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="ev__QGW_II_II_2042">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_wild_QGW_II_II_2042"
                        >Ulreich der Wild, <roleName type="occ" corresp="org__wien"
                           >burger</roleName> ze Wienn</rs></rs>, verkauft <rs type="fn"
                     role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__stephan_pochaimer_QGW_II_II_2042">Stephans, <rs
                           type="person" ref="pe__thomas_pochaimer_QGW_II_II_3330">Thomans</rs>
                        <roleName type="kin" corresp="pe__thomas_pochaimer_QGW_II_II_3330"
                           >sun</roleName> zu Nidern Süfring, <roleName type="occ"
                           corresp="org__gaming-kartaeuser">Amtmann</roleName> der geistlichen
                        Herren zu sand Marienthron zu Gêmninkch, des ordens von Karthus</rs></rs>,
                  ein Joch Weingarten, gelegen an dem Harnsperg, genannt die Junkfrau, zenechst
                  Hainreichs weingarten des Lerhuber, von dem man 3 Eimer Wein zu Bergrecht und 3
                  dn. zu Voitrecht dient, um 100 lb dn. <rs type="fn" role="recipient">
                     <rs type="person" ref="pe__johann_weispacher_QGW_II_II_2042">Hansen dem
                        Weispacher, <roleName type="occ" corresp="org__wien">des rates</roleName>
                        der stat ze Wienn <add>als <roleName type="rep"
                              corresp="pe__niklas_neuchum_QGW_II_II_2042"
                           >Ausrichter</roleName></add></rs>, und <rs type="person"
                        ref="pe__niklas_radauner_QGW_II_II_2042">Niclasen dem Radauner, <roleName
                           type="occ" corresp="org__wien">burger</roleName> daselbs, als <roleName
                           type="rep" corresp="pe__niklas_neuchum_QGW_II_II_2042"
                           >Ausrichtern</roleName></rs></rs>
                  <rs type="event" ref="NULL">des in das Stadtbuch eingetragenen Geschäftes, so <rs
                        type="fn" role="issuer"><rs type="person"
                           ref="pe__niklas_neuchum_QGW_II_II_2042">Niclas <roleName type="dead"
                              >selig</roleName> der Neukum</rs></rs> getan hat</rs> , <rs type="fn"
                     role="recipient">zu der von diesem <rs type="org"
                        ref="org__wien-st_stephan-altar_st_veit-messe_neukum">bei St. Stephan
                        gestifteten Messe</rs></rs>.</rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_2042">Siegler: der <rs type="fn" role="witness"
                        ><rs type="person" ref="pe__leonhard_gaming_QGW_II_II_2042"><title>oberste
                           Bergherr</title>
                        <roleName type="prof" corresp="org__gaming-kartaeuser">prior</roleName>
                        Lienhart von Gaming</rs> und die <rs type="person"
                        ref="pe__niklas_weispacher_QGW_II_I_1298"><roleName type="occ"
                           corresp="org__wien">Wiener Bürger</roleName> Niclas der Weispacher</rs>
                     und <rs type="person" ref="pe__niklas_zinkk_QGW_II_II_3690"><add><roleName
                              type="occ" corresp="org__wien">Wiener Bürger</roleName></add>Niclas
                        der Zingk</rs></rs>. </rs></p>
         </div>
