         <div type="abstract">
            <p><rs type="event" ref="ev__QGW_II_II_2012">
               <rs type="fn" role="issuer"><rs type="person" ref="pe__barbara_QGW_II_II_2012">Barbara, Paulens des Schreiber <roleName type="kin" corresp="pe__paul_schreiber_QGW_II_II_2012">hausfrau</roleName> von
                     Leubesdorf</rs>,</rs> bevollmächtigt <rs type="fn" role="recipient"><rs type="person" ref="pe__paul_schreiber_QGW_II_II_2012">ihren Mann</rs></rs>
               hinsichtlich ihrer Rechte, die sie mit ihrer <rs type="person" ref="pe__dorothea_QGW_II_II_2012"><roleName type="kin" corresp="pe__barbara_QGW_II_II_2012">Schwester</roleName>
                  <roleName type="title">fraun</roleName> Dorotheen, <rs type="person" ref="pe__friedrich_bamberger_QGW_II_II_2012">Fridreichen des Pobenberger</rs>
                  <roleName type="kin" corresp="pe__friedrich_bamberger_QGW_II_II_2012">hausfrau</roleName></rs>, an dem halben Hause hat, gelegen ze Wienn an dem
               Hohenmarkcht, weilent genant Silbrein Hennslein haus, zenagst dem Schreinhause . </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_2012"><rs type="fn" role="witness">Besiegelt mit den Siegeln <rs type="person" ref="pe__georg_von_gainfahrn_QGW_II_II_2012">Jörgen von Gu/enfarn</rs> und [ 22]
                     <rs type="person" ref="pe__johann_leobersdorfer_QGW_II_II_2012">Hannsen des
                     Leubestorffer</rs>.</rs>
            </rs></p>
