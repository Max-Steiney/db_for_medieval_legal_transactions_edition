         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4004">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__martin_enthaimer_QGW_II_III_3968">Mert Ennthaimer, <roleName
                           type="occ" corresp="org__wien">statrichter</roleName> zu Wienn,
                        beurkundet</rs></rs>, dass vor ihm in der Bürgerschranne <rs type="person"
                     ref="pe__johann_wilderstorffer_QGW_II_IV_5510">Hanns Wilderstorffer <roleName
                        type="rep" corresp="pe__niklas_panhalm_QGW_II_III_4004"
                     >anstat</roleName></rs> des <rs type="person"
                     ref="pe__niklas_panhalm_QGW_II_III_4004"><roleName type="title"
                        >edeln</roleName> Niclasen Panhalm, <roleName type="occ" corresp="org__wien"
                        >burger</roleName> zu Wienn</rs>, durch seinen Vorsprechen zu dem <rs
                     type="person" ref="pe__martin_vorster_QGW_II_III_4004">Martino Vorster,
                     mitwoner</rs> daselbs, umb 20 lb dn. und 40 emer most, die er demselben
                  Niclasen Panhalm zu gelten schuldig wer , geklagt habe,. und spricht dem Niclasen
                  Panhalm oder dessen anwalt das Pfandrecht auf dem Gute des Schuldners zu.
               </rs></p>
