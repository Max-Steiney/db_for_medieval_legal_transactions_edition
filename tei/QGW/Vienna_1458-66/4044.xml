   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4044">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__pankraz_reuschel_QGW_II_III_4044">Pangrecz Reusschl, wonhaft zu
                        Scheprern, <rs type="person" ref="pe__wenzel_reuschel_QGW_II_III_4044"
                           >Wenczl des Reuschl, den man auch genant hat <roleName type="title"
                              >pös</roleName> Wenczl, <roleName type="dead">seligen</roleName></rs>
                        <roleName type="kin" corresp="pe__wenzel_reuschel_QGW_II_III_4044"
                           >sun</roleName></rs></rs>, etwenn wonhaft in der Zell , übergibt seinen
                  Antheil an dem von seinem <rs type="person"
                     ref="pe__stephan_reuschel_QGW_II_III_4003"><roleName type="kin"
                        corresp="pe__pankraz_reuschel_QGW_II_III_4044">Vetter</roleName> Stephan dem
                     Reuschlein</rs>, etwenn gesessen in der Schefstrass zu Wienn, hinterlassenen
                  Gute dem <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__thomas_praitenweidacher_QGW_II_II_3462">Wiener <roleName type="occ"
                           corresp="org__wien">Bürger</roleName> Thoman Praitenweidacher</rs></rs>.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4044">Besiegelt mit den Siegeln <rs type="fn"
                     role="witness"><rs type="person" ref="pe__johann_ravensburger_QGW_II_II_3264"
                        >Hannsen des Ravenspurger, des <roleName type="occ" corresp="org__wien"
                           >rats</roleName> der stat und <roleName type="occ" corresp="org__wien"
                           >urtailschreiber</roleName> zu Wienn</rs>, und <rs type="person"
                        ref="pe__johann_kuntstokch_QGW_II_II_3530">Hannsen des Kuntstokch, geswornen
                           <roleName type="prof">weger</roleName>, <roleName type="occ"
                           corresp="org__wien">burger</roleName> daselbs</rs></rs> . </rs></p>
         </div>
