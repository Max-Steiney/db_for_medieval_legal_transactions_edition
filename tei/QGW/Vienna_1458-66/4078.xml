   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4078">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__johann_harrer_QGW_II_III_4078">Hanns Harrer, <roleName type="prof"
                           >lerer in den siben freien künsten</roleName> und <roleName type="occ"
                           corresp="org__wien-universitaet">collegiat</roleName> der hochwirdigen
                        Universitet hie zu Wienn</rs></rs> , dem der <rs type="org" ref="org__wien"
                     >Bürgermeister und Rath</rs> die ewige <rs type="org"
                     ref="org__wien-st_ruprecht-messe_truebensee">Messe, so <rs type="person"
                        ref="pe__michael_QGW_II_III_4078">Michel<roleName type="kin"
                           corresp="pe__jakob_von_truebensee_QGW_II_I_1584"
                           ><add>sun</add></roleName></rs>, <rs type="person"
                        ref="pe__jakob_von_truebensee_QGW_II_I_1584">Jacoben von Trebensee sun
                           <roleName type="dead">seligen</roleName></rs>, in sand Ruprechts cappeln,
                     am Kienmarkht hie gelegen</rs>, zu stifften geschafft hat und mit lediger
                  übergab von <rs type="person" ref="pe__johann_dinkelsbuehl_QGW_II_III_4078"
                        ><roleName type="title">maister</roleName> Hannsen Tingklspübel, <roleName
                        type="prof">lerer der heiling Geschrifft</roleName></rs>, durch <rs
                     type="person" ref="pe__niklas_von_auln_QGW_II_II_3616a"><roleName type="title"
                        >maister</roleName> Niclasen von Auln, seinen <roleName type="rep"
                        corresp="pe__johann_dinkelsbuehl_QGW_II_III_4078"
                     >procuratorem</roleName></rs>, ledig worden ist , verliehen haben, gelobt,
                  dieselbe stiftungsgemäss zu verwesen. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4078"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__ulrich_griessenpekch_QGW_II_III_3878"
                           ><roleName type="title">maister</roleName> Ulreichs Griessenpekhen,
                           <roleName type="prof"> licenciaten geistlicher rechten</roleName>,
                           <roleName type="occ">statschreiber</roleName><roleName type="occ"
                           corresp="org__wien"><add>burger</add></roleName></rs>, und <rs
                        type="person" ref="pe__johann_kuntstokch_QGW_II_II_3530">Hannsen
                        Kuntstockch, gesworen <roleName type="prof">weger</roleName>, baider
                           <roleName type="occ" corresp="org__wien">burger</roleName> zu
                     Wienn</rs></rs> . </rs></p>
         </div>
