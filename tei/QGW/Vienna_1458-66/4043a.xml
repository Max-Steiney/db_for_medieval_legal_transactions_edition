   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4043a">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__peter_liebharter_QGW_II_II_3541">Peter Liebharter, <roleName
                           type="occ" corresp="org__wien-st_stephan">chorherr</roleName>
                        Allerheiligen tuembkirchen zu sand Stephan zu Wienn und <roleName type="occ"
                           corresp="org__wien-st_stephan-altar_zwoelfapostel-messe_liebhart"
                           >stiftherr</roleName> der ewigen mess in den eren des heiligen zwelfpoten
                        sand Peters auf aller Zwelfpoten altar zu sand Stephan ze Wienn</rs></rs> ,
                  der die Störung der von ihm zu dieser Messe gekauften Güter beobachtet hat,
                  bevollmächtigt <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__christian_liebharter_QGW_II_III_4043a">seinen <roleName type="kin"
                           corresp="pe__peter_liebharter_QGW_II_II_3541">Vetter</roleName>
                        <roleName type="title">hern</roleName> Cristan Liebharter, <roleName
                           type="occ" corresp="org__wien-st_stephan">korherrn</roleName> zu sand
                        Stephan und <roleName type="occ"
                           corresp="org__wien-st_stephan-altar_zwoelfapostel-messe_liebhart"
                           >capplan</roleName> der vorgenanten stift</rs></rs>, dieselben zu
                  verkaufen und den Erlös zum Nutzen der Messe auf anderen Gütern anzulegen, und
                  ertheilt ihm fernere Vollmacht wegen der Errichtung und Begehung des von ihm
                  gestifteten Jahrtages. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4043a"><rs type="fn" role="witness">Siegler: der
                        <rs type="person" ref="pe__peter_liebharter_QGW_II_II_3541">Aussteller</rs>
                     und der <rs type="person" ref="pe__peter_gerung_StB_I_492">Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName>
                        Fridrich Gerunger</rs>.</rs>
               </rs></p>
         </div>
         <div type="nota">
            <p><rs type="event" ref="ev__QGW_II_III_4043a_nota">Vidimiert in Urk. n° 4237.</rs></p>
