   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3983">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__peter_weiler_QGW_II_III_3983">Peter Weiler, <roleName type="occ"
                           corresp="org__altenburg">burger</roleName> zu Ungrischen Altenburg</rs>,
                        <rs type="person" ref="pe__konrad_reiff_SB_CD_00226">Conrat
                              Reiff<roleName type="occ" corresp="org__wien"
                           ><add>Bürger</add></roleName></rs> und <rs type="person"
                        ref="pe__johann_hendl_QGW_II_III_3983">Hanns Hendl, baid <roleName
                           type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs></rs> ,
                  stellen dem <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__konrad_muttenhauser_QGW_II_III_3983">Wiener <roleName type="occ"
                           corresp="org__wien">Bürger</roleName> Conrat Muttenhauser</rs></rs> einen
                  Schuldbrief über 600 Ungrischer guldein, rückzahlbar am nächsten sand Kathrein
                  tag, aus. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3983"><rs type="fn" role="witness">Siegler: <rs
                        type="person" ref="pe__konrad_reiff_SB_CD_00226">Conrat Reiff</rs>, <rs
                        type="person" ref="pe__johann_ravensburger_QGW_II_II_3264">Hanns
                              Ravenspurger<roleName type="occ" corresp="org__wien"
                              ><add>burger</add></roleName>, <roleName type="occ" corresp="org__wien"
                           >urtailschreiber</roleName></rs>, und <rs type="person"
                        ref="pe__johann_kuntstokch_QGW_II_II_3530">Hanns Kuntstokch, gesworner <roleName
                           type="prof">weger</roleName>, baid <roleName
                           type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs></rs> .
               </rs></p>
         </div>
