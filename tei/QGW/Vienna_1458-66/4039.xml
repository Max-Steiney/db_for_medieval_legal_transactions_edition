         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4039">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__georg_krempl_QGW_II_III_4039">Jorg Krempl<roleName type="occ"
                           corresp="org__wien"><add>rats</add></roleName></rs>, <rs type="person"
                        ref="pe__konrad_haselpekch_QGW_II_III_4039">Conrat Haselpekch, baid des
                           <roleName type="occ" corresp="org__wien">rats</roleName> der stat zu
                        Wienn</rs>, und <rs type="person"
                        ref="pe__heinrich_hindernpach_QGW_II_II_3744">Hainreich Hinderpach,
                           <roleName type="occ" corresp="org__wien">statkamrer</roleName>
                        daselbs</rs></rs> , bestätigen, von <rs type="fn" role="recipient"><rs
                        type="person" ref="pe__agnes_QGW_II_III_4039">der <roleName type="title"
                           >edeln</roleName> fraun, <roleName type="title">fraun</roleName> Agnesen,
                           <rs type="person" ref="pe__urban_hunczhaim_QGW_II_III_4039">Urbans
                           Hunczhaimer</rs>
                        <roleName type="kin" corresp="pe__urban_hunczhaim_QGW_II_III_4039"
                           >witib</roleName></rs></rs>, <rs type="fn" role="other"><triggerstring
                        n="fn">auf Geheiss</triggerstring> des <rs type="person"
                        ref="pe__wolfgang_holczer_SB_CD_01926"><roleName type="occ"
                           corresp="org__wien">Bürgermeisters</roleName> Wolfgang Holczer</rs> und
                        <rs type="org" ref="org__wien">des Rathes zu gemainer stat</rs></rs> handen
                  700 Ungrisch guldein in golt erhalten und ihr dafür den brief, der da lautt
                  tausent Ungrisch guldein, hinausgegeben zu [ 72] haben. Versorgt mit dem petschad
                  des Bürgermeisters. </rs></p>
         </div>
