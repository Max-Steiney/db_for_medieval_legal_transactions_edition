         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_3973">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__leonhard_mair_QGW_II_III_3973">Linhart Mair,
                           <roleName type="prof">briester</roleName> Regenspurger bistumb</rs></rs>,
                  dem <rs type="fn" role="recipient"><rs type="org" ref="org__wien">Bürgermeister
                        und Rath</rs></rs> die von [ 55] <rs type="person"
                     ref="pe__katharina_haimlin_QGW_II_I_1622"><roleName type="title"
                        >frau</roleName> Kathrei Haimlin</rs> in der Lantstrass hincz sand Niclas
                  ausserhalb des klosters daselbs <rs type="org"
                     ref="org__wien-st_niklas_vor_stubentor_kapelle-messe_haimlin_katharina__StB_I_370"
                     >gestiftete Messe</rs> verliehen haben, gelobt, die dazu gehörigen Weingärten
                  in gutem Stande zu erhalten und die Messe dreistund in der wochen zu lesen.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3973">Besiegelt mit den Siegeln des <rs
                     type="fn" role="witness"><rs type="person"
                        ref="pe__oswald_reicholf_QGW_II_II_2085"><roleName type="title">edeln vesten
                           ritter hern</roleName> Oswalts Reicholfs</rs> und des <rs type="person"
                        ref="pe__niklas_purger_QGW_II_III_3758">Wiener <roleName type="occ"
                           corresp="org__wien">Bürgers</roleName> Niclasen des Purger</rs></rs>.
               </rs></p>
