         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4126">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__ulrich_meczleinstorffer_QGW_II_III_3971">Ulreich Meczleinstorffer,
                           <roleName type="occ" corresp="org__wien">burgermaister</roleName></rs>,
                        <rs type="org" ref="org__wien">der rat und die gemain der stat zu
                     Wienn</rs></rs> stellen <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__stephan_probst_augustiner_QGW_II_III_4126"><roleName type="title"
                           >hern</roleName> Stephann, <roleName type="occ"
                           corresp="org__wien-st_dorothea">brobst</roleName> zu sand Dorothe zu
                        Wienn</rs>, und dem <rs type="org" ref="org__wien-st_dorothea">Convente
                        daselbst</rs></rs> einen Schuldbrief über 150 lb dn. aus. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4126">Besiegelt mit ihrem <rs type="fn"
                     role="witness"><rs type="org" ref="org__wien">klainem aufgedrukten
                        statinsigl</rs></rs>. </rs></p>
