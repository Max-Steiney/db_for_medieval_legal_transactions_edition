   <text>
      <body>
         <div type="abstract" resp="ms">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3794">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__johann_slein_QGW_II_III_3794">Hanns Slein, gesessen vor Widmertor
                        zu Wienn</rs></rs>, tritt <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__johann_stornschacz_QGW_II_III_5495">Hannsen Stornschacz, dem <roleName
                           type="prof">hantschuster</roleName>, [ 12] <roleName type="occ"
                           corresp="org__wien">mitburger</roleName> zu Wien, seinem <roleName
                           type="kin" corresp="pe__johann_slein_QGW_II_III_3794"
                        >swager</roleName></rs>, und <rs type="person"
                        ref="pe__barbara_QGW_II_III_3794">dessen <roleName type="kin"
                           corresp="pe__johann_stornschacz_QGW_II_III_5495">Hausfrau</roleName> Barbaren, seiner
                           <roleName type="kin" corresp="pe__johann_slein_QGW_II_III_3794"
                           >mumen</roleName></rs></rs>, seinen tail erbschafft und gerechtikait ab,
                  so er laut seiner in das Stadtbuch eingetragenen beweisten freuntschaft an <rs
                     type="person" ref="pe__margarethe_QGW_II_III_3794"><roleName type="title"
                        >fraun</roleName> Margrethen, <rs type="person"
                        ref="pe__erhard_wolfstain_QGW_II_III_3794">Erharts Wolfstain, des <roleName
                           type="prof">maler</roleName></rs>, <roleName type="kin"
                        corresp="pe__erhard_wolfstain_QGW_II_III_3794">hausfraun</roleName>, seiner
                        <roleName type="kin" corresp="pe__johann_slein_QGW_II_III_3794"
                        >mumen</roleName>
                     <roleName type="dead">seligen</roleName></rs>, halben tail hauss, ganczes in
                  der Sunigerstrass zenagst Stephans Kisling haus gelegen , und allem anderen von
                  ihr hinterlassenen Gute hat. </rs>
            </p>
         </div>
         <div type="seal">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3794">
                  <rs type="fn" role="witness">Besiegelt mit den Siegeln der <rs type="person"
                        ref="pe__niklas_ernst_QGW_II_III_3758">Wiener <roleName type="occ"
                           corresp="org__wien">Bürger</roleName> Niclasen des Ernsts</rs> und <rs
                        type="person" ref="pe__thomas_egkenperger_QGW_II_II_3455"><roleName
                           type="occ" corresp="org__wien"><add>Bürger</add></roleName>Thomans
                        Egkenperger.</rs></rs>
               </rs>
            </p>
         </div>
