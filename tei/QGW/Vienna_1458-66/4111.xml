   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4111">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__niklas_auf_dem_gutlein_QGW_II_III_4111">Niclas auf dem Gutlein, der
                           <roleName type="title">ersamen geistlichen herrn</roleName> zun Schotten
                        zu Wienn <roleName type="occ" corresp="org__wien-schotten"
                           >ambtman</roleName> irer grünt und güter vor Stubentor</rs> daselbs
                     gelegen, <rs type="person"
                        ref="pe__wolfgang_humel_facs_945_TextRegion_1657876477879_360">Wolfgang Huml
                           <roleName type="occ" corresp="org__wien-schotten"
                           ><add>vierer</add></roleName></rs>, <rs type="person"
                        ref="pe__johann_kolb_QGW_II_III_4111">Hanns Kolb <roleName type="occ"
                           corresp="org__wien-schotten"><add>vierer</add></roleName></rs>, <rs
                        type="person" ref="pe__michael_hauer_QGW_II_III_4111">Michel Hauer <roleName
                           type="occ" corresp="org__wien-schotten"><add>vierer</add></roleName></rs>
                     und <rs type="person" ref="pe__johann_glaser_QGW_II_III_4111">Hanns Glaser,
                        gesworn <roleName type="occ" corresp="org__wien-schotten"
                        >vierer</roleName></rs> daselbs vor Stubentor</rs> , beurkunden, dass <rs
                     type="person" ref="pe__barbara_facs_1132_TextRegion_1653397666253_1553"
                     >Barbara, <rs type="person"
                        ref="pe__oswald_prunner_facs_1132_TextRegion_1653397666253_1553">Oswalts
                        Prunner, des <roleName type="prof">oler</roleName>, <roleName type="occ"
                           corresp="org__wien">burger</roleName> daselbs</rs>, <roleName type="kin"
                        corresp="pe__oswald_prunner_facs_1132_TextRegion_1653397666253_1553"
                        >hausfrau</roleName></rs>, ihnen ihre gerechtikait gegeben und sie gebeten
                  habe, ain virtail und ain sechstail weingartens, gelegen auf dem Jeus zunagst dem
                  Gatern, zu schätzen, und dass derselbe ohne die heurige Frucht nicht mehr als 50
                  lb dn. werth sei. </rs></p>
         </div>
