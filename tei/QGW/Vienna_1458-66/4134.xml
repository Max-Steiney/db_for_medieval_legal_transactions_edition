   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4134">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__ursula_QGW_II_II_3504"
                           >Ursula<roleName type="kin"
                           corresp="pe__niklas_narczendorfer_QGW_II_II_3510"
                           ><add>tochter</add></roleName><roleName type="title"
                              ><add>chlosterjungkfraun</add></roleName><roleName type="occ"
                           corresp="org__duernstein-klarissen"
                        ><add>conventswestern</add></roleName></rs> und <rs type="person"
                        ref="pe__katharina_QGW_II_II_3504">Kathrei, <roleName type="kin"
                           corresp="pe__ursula_QGW_II_II_3504">geswistreid</roleName><roleName
                           type="kin" corresp="pe__niklas_narczendorfer_QGW_II_II_3510"
                              ><add>tochter</add></roleName><roleName type="title"
                              ><add>chlosterjungkfraun</add></roleName><roleName type="occ"
                           corresp="org__duernstein-klarissen"
                        ><add>conventswestern</add></roleName></rs>, <rs type="person"
                        ref="pe__niklas_narczendorfer_QGW_II_II_3510">Niclasen des Narczendorffer
                           <roleName type="dead">seligen</roleName></rs> tochter, baid
                     chlosterjungkfraun und conventswestern des fraunklosters zu Tyrnstain</rs> ,
                     <rs type="fn" role="recipient">an den Bürgermeister und Rath der Stadt zu Wien
                     sowie die Verweser ihrer Grundbücher</rs>. Sie, <rs type="person"
                     ref="pe__paul_narczendorfer_QGW_II_II_3734">ihr <roleName type="kin"
                        corresp="pe__ursula_QGW_II_II_3504">Bruder</roleName><roleName type="kin"
                        corresp="pe__katharina_QGW_II_II_3504"><add>Bruder</add></roleName> Paul
                     Narczendorffer</rs> und <rs type="person" ref="pe__martha__QGW_II_III_4134"
                     >ihre <roleName type="dead">verstorbene</roleName>
                     <roleName type="kin" corresp="pe__ursula_QGW_II_II_3504"
                        >Schwester</roleName><roleName type="kin"
                        corresp="pe__katharina_QGW_II_II_3504"
                        ><add>Schwester</add></roleName><roleName type="kin"
                        corresp="pe__paul_narczendorfer_QGW_II_II_3734"
                        ><add>Schwester</add></roleName> Martha</rs> seien an aim drittail hauss,
                  ganczes gelegen bei dem Rotenturn zenagst weilent Niclasen des Kramhofer haus . .
                  . ., das weilend ihres bruder Jörgen Narczendorffer seligen gewesen ist, in dem
                  Wiener Grundbuch nucz und geweer geschriben. Da nun <rs type="person"
                     ref="pe__konrad_neufarer_QGW_II_III_4134">ihr <unclear><roleName type="kin"
                           corresp="pe__ursula_QGW_II_II_3504">vetter</roleName><roleName type="kin"
                           corresp="pe__katharina_QGW_II_II_3504"
                           ><add>vetter</add></roleName><roleName type="kin"
                           corresp="pe__paul_narczendorfer_QGW_II_II_3734"
                           ><add>vetter</add></roleName><roleName type="kin"
                           corresp="pe__martha_QGW_II_II_3734"><add>vetter</add></roleName>
                     </unclear>Conrad Neufarer, <rs type="person"
                        ref="pe__johann_neufarer_QGW_II_III_4134">Hannsen des Neufarer, <roleName
                           type="occ" corresp="org__je">burger</roleName> zu Jemnicz</rs>, und
                     weilend seiner <rs type="person" ref="pe__barbara__QGW_II_III_4134"><roleName
                           type="kin" corresp="pe__johann_neufarer_QGW_II_III_4134"
                           >hausfraun</roleName> Barbaren , ihrer <roleName type="kin"
                           corresp="pe__ursula_QGW_II_II_3504">swester</roleName><roleName
                           type="kin" corresp="pe__katharina_QGW_II_II_3504"
                           ><add>swester</add></roleName><roleName type="kin"
                           corresp="pe__paul_narczendorfer_QGW_II_II_3734"
                           ><add>swester</add></roleName><roleName type="kin"
                           corresp="pe__martha__QGW_II_III_4134"><add>swester</add></roleName>
                        <roleName type="dead">seligen</roleName></rs>, <roleName type="kin"
                        corresp="pe__konrad_neufarer_QGW_II_III_4134">sun</roleName><roleName
                        type="kin" corresp="pe__barbara__QGW_II_III_4134"
                     ><add>sun</add></roleName></rs>, ein rechter miterb zu dem obgenanten drittail
                  hauss ist, so ersuchen sie, denselben in dem Grundbuch einschreiben zu lassen.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4134"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="pe__anna_QGW_II_II_3504"><roleName
                           type="occ" corresp="org__duernstein-klarissen">Aebtissin</roleName> Annen
                        von Klam</rs> und des <rs type="org" ref="org__duernstein-klarissen"
                        >Conventes</rs>.</rs>
               </rs></p>
         </div>
