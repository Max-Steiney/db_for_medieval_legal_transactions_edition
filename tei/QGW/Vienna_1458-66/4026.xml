      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4026">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__pangraz_am_lehen_QGW_II_III_4023">Pangrecz am Lehen <roleName
                           type="rep" corresp="pe__stephan_lechner_QGW_II_III_4023">übergibt
                           anstatt</roleName><roleName type="rep" corresp="pe__anna_QGW_II_III_4023"
                              ><add>übergibt anstatt</add></roleName><roleName type="rep"
                           corresp="pe__margarethe_QGW_II_III_4023"><add>übergibt
                           anstatt</add></roleName></rs></rs>
                  <rs type="person" ref="pe__stephan_lechner_QGW_II_III_4023">Stephans Lehner,
                     seines <roleName type="kin" corresp="pe__pangraz_am_lehen_QGW_II_III_4023"
                        >swager</roleName></rs>, <rs type="person" ref="pe__anna_QGW_II_III_4023"
                     >Annen, <rs type="person" ref="pe__georg_am_pach_QGW_II_III_4023">Jörgen am
                        Pach</rs>
                     <roleName type="kin" corresp="pe__georg_am_pach_QGW_II_III_4023"
                        >hausfraun</roleName>, dessen <roleName type="kin"
                        corresp="pe__stephan_lechner_QGW_II_III_4023">Schwester</roleName></rs>, und
                     <rs type="person" ref="pe__margarethe_QGW_II_III_4023">Margrethen, seiner
                        <roleName type="kin" corresp="pe__pangraz_am_lehen_QGW_II_III_4023"
                        >hausfraun</roleName>, all drei <roleName type="kin"
                        corresp="pe__stephan_lechner_QGW_II_III_4023"
                        >geswistreid</roleName><roleName type="kin"
                        corresp="pe__anna_QGW_II_III_4023"><add>geswistreid</add></roleName></rs>,
                  weilent <rs type="person" ref="pe__ulrich_am_lehen_QGW_II_III_4035">Ulreichs am
                     Lehen</rs> und <rs type="person" ref="pe__dorothea_QGW_II_III_4026">Dorotheen,
                     etwenn seiner <roleName type="kin"
                        corresp="pe__ulrich_am_lehen_QGW_II_III_4035">hausfraun</roleName></rs>,
                  kinder , allen Anspruch derselben an das von ihrem <rs type="person"
                     ref="pe__stephan_reuschel_QGW_II_III_4003"><roleName type="kin"
                        corresp="pe__stephan_lechner_QGW_II_III_4023">Vetter</roleName><roleName
                        type="kin" corresp="pe__anna_QGW_II_III_4023"
                        ><add>Vetter</add></roleName><roleName type="kin"
                        corresp="pe__margarethe_QGW_II_III_4023"><add>Vetter</add></roleName>
                     Stephan dem Reuschlein</rs>, etwenn gesessen in der Schefstrass zu Wienn,
                  hinterlassene Gut für eine Summe Geldes <rs type="fn" role="recipient"><rs
                        type="person" ref="pe__thomas_praitenweidacher_QGW_II_II_3462">Thoman dem
                        Preitenweidacher, des <roleName type="occ" corresp="org__wien"
                           >rats</roleName> der stat zu Wienn</rs></rs>. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4026">Besiegelt mit den Siegeln <rs type="fn"
                     role="witness"><rs type="person" ref="pe__johann_ravensburger_QGW_II_II_3264"
                        >Hannsen des Ravenspurger, <roleName type="occ" corresp="org__wien"
                           >urtailschreiber</roleName>
                        <roleName type="occ" corresp="org__wien"><add>burger</add></roleName></rs>,
                     und <rs type="person" ref="pe__johann_kuntstokch_QGW_II_II_3530">Hannsen des
                        Kuntstokchs, geswornen <roleName type="prof">weger</roleName>, baider
                           <roleName type="occ" corresp="org__wien">burger</roleName> zu
                     Wienn</rs></rs> . </rs></p>
         </div>
