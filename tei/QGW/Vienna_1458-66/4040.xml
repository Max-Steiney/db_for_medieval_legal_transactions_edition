   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4040">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__johann_turm_QGW_II_III_4040">Hanns Turm</rs></rs>, der in
                  städtischem Dienste, als man den grossen zeug und puchsen pei des von Phannberg
                  haus gelegt hat, darzu ihn dann <rs type="person"
                     ref="pe__heinrich_hindernpach_QGW_II_II_3744">Hainreich Hinderpach</rs>
                  geschafft hett, in den rechten arm durch den kräpffl pei dem elpogen geschossen
                  worden war, wie der <rs type="person"
                     ref="pe__heinrich_hindernpach_QGW_II_II_3744">Hinderpach</rs>, auch <rs
                     type="person" ref="pe__johann_perger_QGW_II_III_4040"><roleName type="title"
                        >maister</roleName> Hanns Perger, der <roleName type="prof"
                        >stainmecz</roleName></rs>, bezeugen können, ersucht <rs type="fn"
                     role="recipient"><rs type="org" ref="org__wien">den Bürgermeister und
                     Rath</rs></rs>, im Falle seines Todes für seine kleinen Kinder zu sorgen.
               </rs></p>
         </div>
         <div type="nota">
            <p><rs type="event" ref="ev__QGW_II_III_4040_nota">Jahrbuch der kais. Kunstsamml. 17b,
                  n° 15342 Regest.</rs></p>
