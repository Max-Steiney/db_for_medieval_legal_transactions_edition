   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4116">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__katharina_QGW_II_III_4116"
                        >Kathrei, <rs type="person" ref="pe__martin_lebm_QGW_II_III_4116">Merten
                           Lebm, etwenn <roleName type="occ" corresp="org__wien"
                              >mitburger</roleName> zu Wienn<roleName type="dead"
                              ><add>witib</add></roleName></rs>, <roleName type="kin"
                           corresp="pe__martin_lebm_QGW_II_III_4116">witib</roleName></rs></rs>,
                  übergibt ihren Erbanspruch an 300 lb dn. morgengab, welche ihr <rs type="person"
                     ref="pe__johann_goellersdorfer_QGW_II_III_3786"><roleName type="dead"
                        >verstorbener</roleName>
                     <roleName type="kin" corresp="pe__katharina_QGW_II_III_4116">Vetter</roleName>,
                     der Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Hanns
                     Gelestorffer</rs> seinen nächsten Erben als einen widerfal auf seinem Hause,
                  mit dem vordern tail in der Vordern Pekchenstrass und mit dem hintern in der
                  Hindern Pekchenstrass zunächst Micheln Scher, des fleischakcher, haus gelegen ,
                  verschrieben hatte, dem <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__thomas_swarczpek_QGW_II_III_4116">Wiener <roleName type="occ"
                           corresp="org__wien">Bürger</roleName> Thoman Swarczpekchen</rs></rs>.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4116"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__erhard_poeschendorffer_QGW_II_II_3563"
                        >der Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName>
                        Erharten des Pöschendorffer</rs> und <rs type="person"
                        ref="pe__konrad_trautmann_QGW_II_III_3987">Conraten des Trautman<roleName
                           type="occ" corresp="org__wien"><add>Bürger</add></roleName></rs>.</rs>
               </rs></p>
         </div>
