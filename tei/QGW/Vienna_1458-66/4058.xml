   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="ev__QGW_II_III_4058">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__wolfgang_wuerer_SB_CD_00708">Wolfgang Wurer, <roleName type="occ"
                           corresp="org__wien">mitburger</roleName> zu Wienn</rs></rs>, verspricht
                     <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__chrstine_QGW_II_III_4058">seiner <roleName type="kin"
                           corresp="pe__wolfgang_wuerer_SB_CD_00708">Hausfrau</roleName>
                        Cristina</rs></rs>, welche ihm in varundem gut zubracht hat 40 lb dn., den
                  gleichen Betrag und weist ihr für die 80 lb dn., die sie fortan in gesambter hand
                  weis innehaben sollen, sein gesammtes Gut. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4058"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="pe__georg_hiltprant_QGW_II_III_3937"
                        >Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName>Jörgen
                        Hiltprantcz</rs> und <rs type="person"
                        ref="pe__veit_hintperger_QGW_II_II_3311">Veiten Hindperger<roleName
                           type="occ" corresp="org__wien"><add>Bürger</add></roleName></rs></rs>.
               </rs></p>
         </div>
