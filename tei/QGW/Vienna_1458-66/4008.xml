         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4008">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__johann_gro"><roleName
                           type="title">Maister</roleName> Hanns Grössl von Dittmaning, <roleName
                           type="prof">lerer in der heiligen Geschrifft</roleName></rs></rs>, dem
                  der <rs type="fn" role="recipient"><roleName type="occ" corresp="org__wien"
                        >Bürgermeister</roleName>
                     <roleName type="title">her</roleName> Kristan Prenner und der <rs type="org"
                        ref="org__wien">Rath</rs></rs> die von <rs type="person"
                     ref="pe__michael_harrasser_QGW_II_II_3710"><roleName type="title"
                        >hern</roleName> Michel Harrasser, <roleName type="occ"
                        corresp="org__passau-dioezese">briester</roleName> Passauer bistumbs</rs>,
                  hincz sand Yeronimus hie zu Wienn zu Ehren der h. Maria gestiftete <rs type="org"
                     ref="org__wien-st_hieronymus-messe_harrasser">Messe</rs> verliehen haben,
                  gelobt, dieselbe virstund in der wochen zu lesen oder durch einen anderen Priester
                  lesen zu lassen. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4008">Besiegelt mit den Siegeln der <rs
                     type="fn" role="witness"><rs type="person"
                        ref="pe__wolfgang_holnbrunner_QGW_II_II_3079">Wiener <roleName type="occ"
                           corresp="org__wien">Bürger</roleName> Wolfgangen Holnbrunner</rs> und <rs
                        type="person" ref="pe__johann_goldner_QGW_II_III_3845">Hannsen des Golden
                           <roleName type="occ" corresp="org__wien"
                        ><add>Bürger</add></roleName></rs></rs>. </rs></p>
         </div>
