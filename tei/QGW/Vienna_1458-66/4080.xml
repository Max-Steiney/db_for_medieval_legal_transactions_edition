         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4080">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__friedrich_hasl_QGW_II_III_4080">Fridreich Hasl, der <roleName
                           type="prof">sneider</roleName>, <roleName type="occ" corresp="org__wien"
                           >mitburger</roleName> zu Wienn</rs></rs>, bestätigt, dass ihm <rs
                     type="fn" role="recipient"><rs type="person"
                        ref="pe__johann_payr_QGW_II_II_3263">Hanns Payr, der <roleName type="prof"
                           >schuster</roleName>, <roleName type="occ" corresp="org__wien"
                           >mitburger</roleName> daselbs</rs></rs>, die ihm auf Grund eines
                  Schiedspruches gebührenden 36 Ungrisch guldein in gold ausbezahlt habe. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4080"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="pe__georg_hiltprant_QGW_II_III_3937"
                        >Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Jorgen
                        Hiltprants</rs> und <rs type="person"
                        ref="pe__veit_hintperger_QGW_II_II_3311">Veiten Hindperger<roleName
                           type="occ" corresp="org__wien"><add>Bürger</add></roleName></rs></rs>.
               </rs></p>
