         <div type="abstract" resp="ms">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3800"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270"
                           ><roleName type="occ" corresp="org__heiliges_roemisches_reich"
                           >Kaiser</roleName> Friedrich III.</rs></rs> ersucht den <rs type="fn"
                     role="recipient"><rs type="org" ref="org__wien">Bürgermeister, Richter und Rath
                        zu Wien</rs></rs>, <rs type="person"
                     ref="pe__sigmund_maroltinger_QGW_II_III_3780">Sigmund Maroltinger, seinen
                        <roleName type="occ"
                        corresp="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270"
                        >Diener</roleName></rs>, der sich an seinem Hofe mit seinen getreun diensten
                  aufrichtikleich und redlich gehalten hat, zu ihrem Hauptmann aufzunehmen. </rs>
            </p>
         </div>
         <div type="nota">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3800_nota">Von anderer Hand: commissio domini
                  imperatoris propria. </rs>
