   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_3864">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__sebastian_zieglshauser_QGW_II_III_3864">Sebastian Zieglshauser,
                           <roleName type="occ" corresp="org__wien">statrichter</roleName> zu
                        Wienn</rs></rs>, beurkundet, dass der <rs type="person"
                     ref="pe__johann_kuntstokch_QGW_II_II_3530">Wiener <roleName type="occ"
                        corresp="org__wien">Bürger</roleName> Hanns Kuntstokch, gesworner <roleName
                        type="prof">weger</roleName>, als <roleName type="rep"
                        corresp="pe__christian_wissinger_QGW_II_II_3328"
                        >Vollmachtträger</roleName><roleName type="rep"
                        corresp="pe__niklas_teschler_QGW_II_II_2951"
                        ><add>Vollmachtträger</add></roleName><roleName type="rep"
                        corresp="pe__arnold_gallander_QGW_II_III_3864"
                        ><add>Vollmachtträger</add></roleName></rs>
                  <rs type="person" ref="pe__christian_wissinger_QGW_II_II_3328">Cristans des
                     Wissinger, des <roleName type="occ" corresp="org__wien">rats</roleName> der
                     stat daselbs <roleName type="rep" corresp="pe__ulrich_gundloch_QGW_II_II_2671"
                           ><add>geschefftherr</add></roleName></rs>, <rs type="person"
                     ref="pe__niklas_teschler_QGW_II_II_2951">Niclasen des Teschler <roleName
                        type="occ" corresp="org__wien"><add>burger</add></roleName><roleName
                        type="rep" corresp="pe__ulrich_gundloch_QGW_II_II_2671"
                           ><add>geschefftherr</add></roleName></rs> und <rs type="person"
                     ref="pe__arnold_gallander_QGW_II_III_3864">Arnolten des Gallander, baider
                        <roleName type="occ" corresp="org__wien">burger</roleName> daselbs, all drei
                        <roleName type="rep" corresp="pe__ulrich_gundloch_QGW_II_II_2671"
                        >geschefftherren</roleName></rs>
                  <rs type="person" ref="pe__ulrich_gundloch_QGW_II_II_2671">Ulreichs des Gundlochs
                        <roleName type="dead">seligen</roleName></rs> gescheffts , gegen den <rs
                     type="person" ref="pe__heinrich_geukramer_QGW_II_III_3894">Wiener <roleName
                        type="occ" corresp="org__wien">Bürger</roleName> Hainreich den
                     Geukramer</rs> um 20 lb dn., die dieser dem Verstorbenen schuldete, geklagt und
                  den Betrag mit rechten nottaidingen anerlangt und behabt habe, und spricht ihm das
                  Pfandrecht auf dem Gute des Geklagten zu. </rs></p>
         </div>
