         <div type="abstract" resp="ms">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3774"> <rs type="fn" role="issuer"><rs type="person"
                  ref="pe__oswald_eitzinger_QGW_II_II_3293">Oswald</rs> und <rs type="person"
                     ref="pe__stephan_eitzinger_QGW_II_II_3305">Stephan, <roleName type="kin"
                        corresp="pe__oswald_eitzinger_QGW_II_II_3293">gebrueder</roleName></rs> von
                  Eitzing,</rs> richten an <rs type="fn" role="recipient"><rs type="org"
                     ref="org__wien">Bürgermeister, Richter, Rath und die Genannten der Stadt</rs>
                     zu Wien</rs> die neuerliche Mahnung, für die Freilassung ihres von <rs
                        type="person" ref="pe__albrecht_herzog_von_oesterreich_QGW_II_II_3617"><roleName type="occ"
                           corresp="org__oesterreich-herzogtum">Herzog</roleName> Albrecht</rs> gefangenen
                  <rs type="person" ref="pe__ulrich_eitzinger_QGW_II_II_3270"><roleName type="kin"
                     corresp="pe__oswald_eitzinger_QGW_II_II_3293">Bruders</roleName><roleName
                        type="kin" corresp="pe__stephan_eitzinger_QGW_II_II_3305"
                        ><add>Bruders</add></roleName> Ulrich</rs> zu sorgen. </rs>
            </p>
         </div>
