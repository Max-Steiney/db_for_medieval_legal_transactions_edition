   <text>
      <body>
         <div type="abstract" resp="vh">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3771">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__niklas_klinsler_QGW_II_III_3771">Niclas Klinsler, <roleName
                           type="occ" corresp="org__wien-st_stephan">achter</roleName> dacz sant
                        Stephan zu Wienn</rs></rs>, dem <rs type="fn" role="recipient"><rs
                        type="org" ref="org__wien">Bürgermeister und Rath</rs></rs> die von <rs
                     type="person" ref="pe__michael_vinkch_QGW_II_I_1082">Michel Vinkch</rs> auf <rs
                     type="org" ref="org__wien-st_stephan-altar_zwoelfapostel-messe_vinkch_michael"
                     >Allerheiligen altar dacz sant Stephan gestiftete Messe</rs> verliehen haben,
                  gelobt, die dazu gehörigen Güter in gutem Stande zu erhalten und die Messe
                  dreistund in der wochen zu lesen. </rs> 
            </p>
         </div>
         <div type="seal">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3771">Besiegelt mit den Siegeln der Wiener
                  Bürger Steffan des Auer und Hannsen Malchinger. </rs>
            </p>
