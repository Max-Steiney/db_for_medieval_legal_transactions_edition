         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3861">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__prezemek_QGW_II_III_3861"
                        >Przymko, <roleName type="occ" corresp="org__teschen-herzogtum"
                           >herzog</roleName> zu Teschen</rs></rs>, ersucht <rs type="fn"
                     role="recipient"><rs type="org" ref="org__wien">den Bürgermeister, Richter und
                        Rath der Stadt Wien</rs></rs>, sich bei dem Kaiser dafür zu verwenden, dass
                  die ihm für seine <rs type="person" ref="pe__ladislaus_QGW_II_II_3461">dem
                        <roleName type="occ" corresp="org__ungarn-koenigreich">König</roleName>
                     Laslawen</rs> geleisteten Dienste gebührende Zahlung entrichtet werde.
               </rs></p>
