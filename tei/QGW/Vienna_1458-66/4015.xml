   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4015">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__alexander_tummer_QGW_II_III_4015">Alex Tummer, <roleName
                           type="prof">lerer geistlicher rechten</roleName>, <roleName type="occ"
                           corresp="org__wien-st_niklas_vor_stubentor_kapelle-altar_fron-messe_mayr_otto"
                           >capplan</roleName> der <rs type="org"
                           ref="org__wien-st_niklas_vor_stubentor_kapelle-altar_fron-messe_mayr_otto"
                           >mess, die weilent <rs type="person" ref="pe__otto_mair_QGW_II_I_1651"
                              >Ott Mair <roleName type="dead">säliger</roleName></rs> auf dem
                           Fronaltar in sand Niclas capellen, ausserhalb des closters vor Stubentor
                           hie zu Wienn in der Lantstrass gelegen</rs>, gestifft hat, und <roleName
                           type="occ" corresp="org__wien-st_stephan-altar_allerheiligen"
                              ><add>capplan</add></roleName> ain <rs type="org"
                           ref="org__wien-st_stephan-altar_allerheiligen">mess, die <rs
                              type="person" ref="pe__simon_von_retz_QGW_II_II_3460"><roleName
                                 type="title">herr</roleName> Simon von Retz, gracianer</rs>, auf
                           Allerheiligen altar in sand Steffans pfarrkirchen hie zu Wienn</rs> zu
                        desselben Ott Mairs stifft zu lesen fürgenommen hat</rs></rs>, so ihm der
                     <rs type="person" ref="pe__christian_prenner_SB_CD_01257"><roleName type="occ"
                        corresp="org__wien">Bürgermeister</roleName>
                     <roleName type="title">her</roleName> Cristan Prenner</rs> und <rs type="org"
                     ref="org__wien">der Rath</rs> nach hern Simon von Retz willigem übergeben
                  verliehen haben, gelobt das Haus, pei sand Jacob gelegen, peulich und die anderen
                  zu der Messe gehörigen Güter innezuhaben und die Messe ainsten auf dem egenanten
                  Fronaltar und aine auf Allerheiligen altar zu lesen oder durch einen anderen
                  Priester lesen zu lassen. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4015">Siegler: <rs type="fn" role="witness">der
                        <rs type="person" ref="pe__alexander_tummer_QGW_II_III_4015">Aussteller</rs>
                     und der <rs type="person" ref="pe__niklas_vorstl_QGW_II_II_3265">Wiener
                           <roleName type="occ" corresp="org__wien">Bürger</roleName> Niclas
                        Vorstl</rs>.</rs>
               </rs></p>
         </div>
