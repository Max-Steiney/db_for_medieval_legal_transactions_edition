         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4003"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__niklas_Lechner_QGW_II_III_4003">Niclas Lechner,
                        gesessen in der Scheffstrass vor Stubentor zu Wienn</rs></rs>, stellt
                  hinsichtlich seines Anspruches an das von der <rs type="fn" role="recipient"><rs
                        type="person" ref="pe__anna_QGW_II_III_4003">unmündigen <roleName
                           type="title">junkfrau</roleName> Anna, <rs type="person"
                           ref="pe__stephan_reuschel_QGW_II_III_4003"><roleName type="dead"
                              >weilent</roleName> Stephans des Reuschleins, seines <roleName
                              type="kin" corresp="pe__niklas_Lechner_QGW_II_III_4003"
                              >o/ehems</roleName></rs>, <roleName type="kin"
                           corresp="pe__stephan_reuschel_QGW_II_III_4003"
                     >tochter</roleName></rs></rs>, hinterlassene Gut seinem öhem Wolfgangen Reuschl
                  eine Vollmacht aus. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4003"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="pe__johann_ravensburger_QGW_II_II_3264"
                        >Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Hannsen
                        des Ravenspurger, <roleName type="occ" corresp="org__wien"
                           >urtailschreiber</roleName></rs>, und <rs type="person"
                        ref="pe__johann_kuntstokch_QGW_II_II_3530">Hannsen des Kuntstokch, geswornen <roleName
                           type="prof">weger</roleName><roleName
                           type="occ" corresp="org__wien"><add>Bürger</add></roleName></rs>.</rs>
               </rs></p>
         </div>
