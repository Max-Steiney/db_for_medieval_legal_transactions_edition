   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3962">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__georg_grillenoder_facs_573_TextRegion_1656869272257_2972">Jorg
                        Grillenöder, der <roleName type="prof">leinbater</roleName>, <roleName
                           type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs>, und
                        <rs type="person" ref="pe__barbara_facs_573_TextRegion_1656869272257_2972"
                        >Barbara, sein <roleName type="kin"
                           corresp="pe__georg_grillenoder_facs_573_TextRegion_1656869272257_2972"
                           >hausfrau</roleName></rs></rs>, verkaufen <rs type="fn" role="other"
                        ><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__jakob_starch_QGW_II_II_3557">des <roleName
                           type="occ" corresp="org__wien">Bürgermeisters</roleName>
                        <roleName type="title">herrn</roleName> Jacoben Starch</rs> und <rs
                        type="org" ref="org__wien">des Rathes</rs></rs> ihr Haus, gelegen in der
                  Kernerstrass zenagst des Prantesser haus, um 250 lb dn. <rs type="fn"
                     role="recipient"><rs type="person"
                        ref="pe__andreas_zeisselmaurer_QGW_II_III_3962">Andre Zeisselmaurer, dem
                           <roleName type="prof">maier</roleName>, <roleName type="occ"
                           corresp="org__wien">mitburger</roleName> zu Wienn</rs>, und <rs
                        type="person" ref="pe__elisabeth_QGW_II_III_3962">Elspethen, seiner
                           <roleName type="kin" corresp="pe__andreas_zeisselmaurer_QGW_II_III_3962"
                           >hausfraun</roleName></rs></rs>. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3962"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="pe__johann_kuntstokch_QGW_II_II_3530">Wiener
                           <roleName type="occ" corresp="org__wien">Bürgers</roleName> Hanns
                        Kuntstokch, gesworner <roleName type="prof">
                          weger</roleName></rs>.</rs>
               </rs></p>
         </div>
         <div type="nota">
            <p><rs type="event" ref="ev__QGW_II_III_3962_nota">Indorsat: Andreen Zeislmaurer haus in
                  der Kernerstras, des stet Andre Swarcz und Brigida, seiner hausfraun, in dem neun
                  gruntpuch an der gwer, anno etc. Lxxxist . </rs></p>
         </div>
