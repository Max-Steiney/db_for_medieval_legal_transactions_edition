   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3956">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__helena_QGW_II_III_3956"
                        >Helena, <rs type="person" ref="pe__andreas_perleinsreutter_QGW_II_III_3934"
                           >Andres Perleinsreitter</rs>
                        <roleName type="kin" corresp="pe__andreas_perleinsreutter_QGW_II_III_3934"
                           >hausfrau</roleName>, <rs type="person"
                           ref="pe__leopold_weiss_QGW_II_II_2987">Leopolcz des Weissen <roleName
                              type="dead">säligen</roleName></rs>
                        <roleName type="kin" corresp="pe__leopold_weiss_QGW_II_II_2987"
                           >tochter</roleName></rs></rs>, theilt <rs type="fn" role="issuer"><rs
                        type="org" ref="org__wien">dem Bürgermeister und Rathe der Stadt zu
                        Wien</rs></rs> mit, dass <rs type="person" ref="pe__helena_QGW_II_III_3956"
                        >sie</rs> ihre Hälfte des ihr und ihrer <rs type="person"
                        ref="pe__margarethe_facs_751_TextRegion_1658304069070_121"><roleName
                           type="kin" corresp="pe__helena_QGW_II_III_3956">Mutter</roleName>
                        Margreten</rs> von ihrem Vater anerstorbenen Hauses, glegen zu Wienn in der
                     Münsserstrass zunagst Hannsen von Eslorn haus an aim tail und stösst mit dem
                     andern tail in den Kamerhof, <rs type="person"
                           ref="pe__ulrich_welzly_QGW_II_III_3956">dem <roleName type="title"
                              >edln</roleName>
                           <roleName type="title">herrn</roleName>, <roleName type="title"
                              >hern</roleName> Ulreichen Welczlin, des heiligen Römischen Reichs
                              <roleName type="occ" corresp="org__heiliges_roemisches_reich"
                              >canzler</roleName></rs> , verkauft habe, und ersucht sie, diesem
                     das Haus zu fertigen.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3956"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__andreas_perleinsreutter_QGW_II_III_3934"
                        >Andreen Perleinsreitter</rs> und des <rs type="person"
                        ref="pe__konrad_freitag_QGW_II_III_3956"><roleName type="title"
                           >edln</roleName> Conraten des Freitags</rs></rs>. </rs></p>
         </div>
