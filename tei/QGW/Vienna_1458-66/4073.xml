   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4073">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__wilhelm_summer_QGW_II_III_4073">Wilhalm Summer, gesessen zu
                        Perchtoldstorff</rs>, und <rs type="person" ref="pe__anna_QGW_II_III_4073"
                        >Anna, sein <roleName type="kin"
                           corresp="pe__wilhelm_summer_QGW_II_III_4073"
                     >hausfrau</roleName></rs></rs>, stellen <rs type="fn" role="recipient"><rs
                        type="person" ref="pe__katharina_QGW_II_III_4073"><roleName type="title"
                           >fraun</roleName> Kathrein, <rs type="person"
                           ref="pe__johann_oedenacker_QGW_II_III_3776">Hannsen Odenakchrer <roleName
                              type="dead"><add>selig</add></roleName></rs>
                        <roleName type="kin" corresp="pe__johann_oedenacker_QGW_II_III_3776"
                           >witib</roleName>, <roleName type="occ" corresp="org__wien"
                           >burgerin</roleName> zu Wienn</rs></rs>, einen Schuldbrief über 8 lb dn..
                  rückzahlbar am nächsten sand Merten tag, aus. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4073">Besiegelt mit den Siegeln der <rs
                     type="fn" role="witness"><rs type="person"
                        ref="pe__georg_hiltprant_QGW_II_III_4012">Wiener <roleName type="occ"
                           corresp="org__wien">Bürger</roleName> Jörgen Hiltprant</rs> und <rs
                        type="person" ref="pe__johann_kuntstokch_QGW_II_II_3530"><roleName
                           type="occ" corresp="org__wien"><add>burger</add></roleName> Hannsen
                        Kuntstokch, gesworn <roleName type="prof">weger</roleName></rs></rs>.
               </rs></p>
         </div>
         <div type="nota">
            <p><rs type="event" ref="ev__QGW_II_III_4073_nota">Indorsat: das sein unvermailigt
                  Schuldbrief, sein al prescribiert. </rs></p>
         </div>
