         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_3950">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__jakob_starch_QGW_II_II_3557">Jacob Starch, burgermaister</rs>, und
                     der <rs type="org" ref="org__wien">rat</rs> der stat zu Wienn</rs> übergeben
                  die unmündigen Kinder ihres <rs type="person" ref="pe__johann_keusch_SB_CD_00689"
                        ><roleName type="dead">verstorbenen</roleName>
                     <roleName type="occ" corresp="org__wien">Mitbürgers</roleName> Hannsen
                     Keuschen</rs>, <rs type="person"
                     ref="pe__johann_keusch_facs_689_TextRegion_1657538844699_1159">Hennslein
                        <roleName type="kin" corresp="pe__johann_keusch_SB_CD_00689"
                        ><add>sun</add></roleName></rs>, <rs type="person"
                     ref="pe__katharina_facs_689_TextRegion_1657538844699_1159">Kathrein <roleName
                        type="kin" corresp="pe__johann_keusch_SB_CD_00689"
                        ><add>tochter</add></roleName></rs> und <rs type="person"
                     ref="pe__johann_keusch_facs_689_TextRegion_1657538844699_1159_a">Hennslein
                        <roleName type="kin" corresp="pe__johann_keusch_SB_CD_00689"
                        ><add>sun</add></roleName></rs>, in gerhabsweise <rs type="fn"
                     role="recipient"><rs type="person" ref="pe__johann_kanstorffer_QGW_II_II_3401"
                        >Hannsen Kanstorffer, ihrem <roleName type="occ" corresp="org__wien"
                           >mitgesworn</roleName> des rats</rs>, und <rs type="person"
                        ref="pe__heinrich_smauss_QGW_II_III_3897">Hainreichen Smaussen, ihrem
                           <roleName type="occ" corresp="org__wien">mitburger</roleName></rs></rs>.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3950">Besiegelt mit ihrem <rs type="fn"
                     role="witness"><rs type="org" ref="org__wien">klainem anhangundem
                        statinsigl</rs></rs>. </rs></p>
