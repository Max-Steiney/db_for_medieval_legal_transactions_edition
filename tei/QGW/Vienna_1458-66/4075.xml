   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4075">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__johann_von_gera_QGW_II_II_3278">Hanns von Gerau, <roleName
                           type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs></rs>,
                  übergibt <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__ursula_QGW_II_III_4074">seiner <roleName type="kin"
                           corresp="pe__johann_von_gera_QGW_II_II_3278">Hausfrau</roleName> Ursulen,
                        die emaln <rs type="person" ref="pe__peter_engelhartsstetter_QGW_II_II_3435"
                           >Petern Engelhartsteter <roleName type="dead">seligen</roleName></rs>
                        auch <roleName type="kin"
                           corresp="pe__peter_engelhartsstetter_QGW_II_II_3435">elichen</roleName>
                        gehabt hat</rs></rs>, an den 1200 Ungrischen guldein, die er ihr auf seinem
                  Gute laut eines von <rs type="person"
                     ref="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270"><roleName type="occ"
                        corresp="org__heiliges_roemisches_reich">Kaiser</roleName> Friedrich
                     III.</rs> bestätigten gemechtbriefs verschrieben hatte, sein Haus und stadl
                  daran, innerhalb der Maur an dem Pibersturn zu Wienn gelegen, zu freier Verfügung
                  und ersucht den <rs type="org" ref="org__wien">Bürgermeister und Rath, sowie die
                     Verweser ihrer Grundbücher</rs>, sie in ihrem Grundbuch nucz und geweer seczen
                  und inschreiben zu lassen. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4075"><rs type="fn" role="witness">Siegler: der
                        <rs type="person" ref="pe__johann_von_gera_QGW_II_II_3278"> Aussteller</rs>,
                     die <rs type="person" ref="pe__johann_dechsenpekch_QGW_II_II_3580"><roleName
                           type="title">edeln</roleName> und der <roleName type="title"
                           >vesst</roleName>
                        <roleName type="title">ritter</roleName>
                        <roleName type="title">her</roleName> Hanns der Dechsenpekch</rs> und <rs
                        type="person" ref="pe__peter_strasser_QGW_II_II_3260">Peter Strosser zum
                           Gundrams<roleName
                              type="title"><add>edeln</add></roleName> und der <roleName type="title"
                                 ><add>vesst</add></roleName>
                           <roleName type="title"><add>ritter</add></roleName>
                           <roleName type="title"><add>her</add></roleName> </rs>.</rs>
               </rs></p>
         </div>
