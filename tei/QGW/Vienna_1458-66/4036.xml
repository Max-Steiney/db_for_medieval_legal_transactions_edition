   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4036">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__anna_QGW_II_III_4035">Anna,
                           <rs type="person" ref="pe__andreas_QGW_II_III_4035"> Andre,
                              <unclear>weilendt gesessen im Kirchperger Wingkl und in Starhnberger
                              herschafft</unclear><roleName type="dead"
                           ><add>witib</add></roleName></rs>
                        <roleName type="kin" corresp="pe__andreas_QGW_II_III_4035">witib</roleName>
                        und <rs type="person" ref="pe__stephan_reuschel_QGW_II_III_4003">Steffan des
                           Reuschleins, weilendt <roleName type="occ" corresp="org__wien"
                              >burger</roleName> zu Wienn, <unclear>gesessen in der Scheffstrass vor
                              Stubmertor</unclear><roleName type="dead"><add>von diesem
                                 hinterlassenen</add></roleName></rs>, <roleName type="kin"
                           corresp="pe__stephan_reuschel_QGW_II_III_4003">swester</roleName></rs>,
                        <rs type="person" ref="pe__johann_QGW_II_III_4035">Hanns<roleName type="kin"
                           corresp="pe__katharina_QGW_II_III_4035"
                           ><add>geswistredt</add></roleName><roleName type="kin"
                           corresp="pe__dorothea_QGW_II_III_4035"
                           ><add>geswistredt</add></roleName><roleName type="kin"
                           corresp="pe__konrad_der_smid_QGW_II_III_4035"
                           ><add>kinder</add></roleName><roleName type="kin"
                           corresp="pe__stephan_reuschel_QGW_II_III_4003"
                           ><add>enengkl</add></roleName></rs>, <rs type="person"
                        ref="pe__katharina_QGW_II_III_4035">Katherina<roleName type="kin"
                           corresp="pe__dorothea_QGW_II_III_4035"
                           ><add>geswistredt</add></roleName><roleName type="kin"
                           corresp="pe__konrad_der_smid_QGW_II_III_4035"
                           ><add>kinder</add></roleName><roleName type="kin"
                           corresp="pe__stephan_reuschel_QGW_II_III_4003"
                           ><add>enengkl</add></roleName></rs> und <rs type="person"
                        ref="pe__dorothea_QGW_II_III_4035">Dorothea<roleName type="kin"
                           corresp="pe__konrad_der_smid_QGW_II_III_4035"
                           ><add>kinder</add></roleName><roleName type="kin"
                           corresp="pe__stephan_reuschel_QGW_II_III_4003"
                           ><add>enengkl</add></roleName></rs>, all dreu geswistredt, <rs
                        type="person" ref="pe__konrad_der_smid_QGW_II_III_4035">Kunczen des Smidts,
                           <unclear>weilendt gesessen zu Lembach bei Valkenstain</unclear>
                        <roleName type="dead">saligen</roleName></rs>, kinder, des benanten Steffan
                     Reuschleins enengkl</rs> , stellen hinsichtlich des von diesem hinterlassenen
                  Gutes <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__leonhard_der_weber_QGW_II_III_4036">ihrem <roleName type="kin"
                           corresp="pe__anna_QGW_II_III_4035">sun</roleName> und <roleName
                              type="kin" corresp="pe__johann_QGW_II_III_4035">steuffater</roleName><roleName
                                 type="kin" corresp="pe__dorothea_QGW_II_III_4035"><add>steuffater</add></roleName><roleName
                                    type="kin" corresp="pe__katharina_QGW_II_III_4035"><add>steuffater</add></roleName>
                        Lienharten [ 71] dem <roleName type="prof">Weber</roleName>,
                           <unclear>gesessen zu Mos</unclear></rs>, und <rs type="person"
                        ref="pe__johann_durhenwald_QGW_II_III_4036">Hannsen dem Durhenwald</rs></rs>
                  eine Vollmacht aus. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4036"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__erhard_althaimer_QGW_II_III_4023"
                        >Erharten des Althaimer, <roleName type="occ"
                           corresp="org__schaumberg-grafschaft">landtrichter</roleName> im Tunautal
                        in der graffschafft zu Schaunberg etc</rs> ., und <rs type="person"
                        ref="pe__kaspar_rottaler_QGW_II_III_4023">Casparn des Rottaler, ainer
                           <roleName type="occ" corresp="org__eferding">des rats</roleName> der stat
                        zu Eferding und <roleName type="occ" corresp="org__eferding"
                           >spitalmaister</roleName> daselbs</rs>.</rs>
               </rs></p>
         </div>
