   <text>
      <body>
         <div type="abstract" resp="vh">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3790">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__sigmund_ii_graf_QGW_II_III_3788">Sigmund, <roleName type="occ"
                           corresp="org__grafschaft_st_georgen_und_boesing">graff</roleName> zu Sand
                        Georigen und Posing etc.,</rs></rs> ersucht den <rs type="fn"
                     role="recipient"><rs type="org" ref="org__wien">Bürgermeister der Stadt zu
                        Wien</rs></rs>, dafür zu sorgen, dass das dem <rs type="person"
                     ref="pe__niklas_planer_QGW_II_II_3692">Nicolae Planer</rs> versetzte clainat
                     <rs type="person" ref="pe__hermann_steinfelder_QGW_II_III_3788">seinem
                        <roleName type="rep" corresp="pe__sigmund_ii_graf_QGW_II_III_3788">Diener
                     </roleName>Herman Steinfelder</rs> eingeantwortet werde, und an die von Wienn
                  weisung zu tun, dass der Schaden, welcher seinen Leuten von den ihren durch die
                  prunst ergangen ist, vergütet werde. </rs>
            </p>
         </div>
         <div type="nota">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3790_nota">Adresse aussen.</rs>
            </p>
