         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3960">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__niklas_QGW_II_III_3960"
                           ><roleName type="title">Bruder</roleName> Niclas, <roleName type="occ"
                           corresp="org__friesach-pfarre">pharrer</roleName> zu Friesach Teutsches
                        ordens</rs></rs>, stellt hinsichtlich der 31 Ungrischer [ 52] guldein,
                  welche ihm <rs type="person" ref="pe__matthias_swabniczer_QGW_II_III_3960">Mathes
                     Swabniczer, <roleName type="occ" corresp="org__wien">mitburger</roleName> zu
                     Wienn</rs>, schuldig ist, <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__ulrich_kamrer_QGW_II_III_3960"><roleName type="title"
                           >hern</roleName> Ulrichen Kamrer, <roleName type="occ"
                           corresp="org__deutsche_herren">kapplan</roleName> im Teutschen haus zu
                        Wienn</rs></rs>, eine Vollmacht aus. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3960"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__pankraz_kreuczer_QGW_II_III_3808"
                           ><roleName type="title">maister</roleName> Pangreczen Kreuczer, <roleName
                           type="prof">lerer</roleName> in der erznei</rs>, und des <rs
                        type="person" ref="pe__stephan_kisling_QGW_II_II_3622">Wiener <roleName
                           type="occ" corresp="org__wien">Bürgers</roleName> Stephan
                     Kisling</rs></rs>. </rs></p>
         </div>
