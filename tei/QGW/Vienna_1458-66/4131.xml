   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4131">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__michael_hebl_QGW_II_II_3551">Michel Hebl, <roleName type="occ"
                           corresp="org__wien">burger</roleName> zu Wienn</rs></rs>, verkauft <rs
                     type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs
                        type="person" ref="pe__ulrich_meczleinstorffer_QGW_II_III_3971"><roleName
                           type="occ" corresp="org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Ulreich Meczleinstorffer</rs> und des
                        <rs type="org" ref="org__wien">Rathes</rs></rs> ein Haus, gelegen in der
                  Kernerstrass am egk, do man an den Neunmarkcht get, genant das Zieglhaus, und
                  stosset mit dem vordern tail an Petern Weissen, des tischer, haus und mit dem
                  hindern tail an weilent Philippen, des sailer seligen, haus , um dreuhundert und
                  [. . .] zigk lb dn. dem <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__christian_perger_QGW_II_III_4131">Wiener <roleName type="occ"
                           corresp="org__wien">Bürger</roleName> Cristan Perger</rs> und <rs
                        type="person" ref="pe__elisabeth_QGW_II_III_4131">Elspethen, seiner
                           <roleName type="kin" corresp="pe__christian_perger_QGW_II_III_4131"
                           >hausfrau</roleName></rs></rs>. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4131">Besiegelt mit dem <rs type="fn"
                     role="witness"><rs type="org" ref="org__wien">städtischen Grundsiegel</rs> und
                     dem Siegel des <rs type="person" ref="pe__simon_lempl_QGW_II_II_4131">Wiener
                           <roleName type="occ" corresp="org__wien">Bürgers</roleName> Simon
                        Lempl</rs></rs>. </rs></p>
         </div>
