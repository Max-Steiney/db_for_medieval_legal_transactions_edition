   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3961"><rs type="fn" role="issuer">
                     <rs type="person" ref="pe__katharina_facs_620_TextRegion_1658731841659_98"
                        >Kathrei, <rs type="person"
                           ref="pe__konrad_wann_facs_620_TextRegion_1658731841659_98">Conrads Wann
                           von Kembnaten <roleName type="dead"><add>wittib</add></roleName></rs>
                        <roleName type="kin"
                           corresp="pe__konrad_wann_facs_620_TextRegion_1658731841659_98"
                           >wittib</roleName></rs></rs>, theilt <rs type="fn" role="recipient"><rs
                        type="org" ref="org__wien">dem Bürgermeister, Richter und Rathe der Stadt zu
                        Wien sowie den Verwesern ihrer Grundbücher</rs></rs> mit, dass <rs
                     type="person" ref="pe__katharina_facs_620_TextRegion_1658731841659_98">sie</rs>
                  ihr Haus, gelegen mit ainer sehen zunagst sand Jacobs freithoftor und mit dem
                  andern zunagst dem haus, genant der Erich, zu Wienn , <rs type="person"
                     ref="pe__paul_wann_QGW_II_III_3895">ihrem <roleName type="kin"
                        corresp="pe__katharina_facs_620_TextRegion_1658731841659_98"
                        >Sohne</roleName>
                     <roleName type="title">maister</roleName> Pauln Wann von Kembnaten</rs>
                  abgetreten habe, und ersucht sie, diesen in ihr Grundbuch nucz und gewer schreiben
                  zu lassen. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3961"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="pe__wolfgang_holnbrunner_QGW_II_II_3079"
                        >Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Wolfgangs
                        Hollnbrunner</rs> und <rs type="person" ref="pe__johann_gold_QGW_II_II_3565"
                        >Hannsen Gold<roleName type="occ" corresp="org__wien"
                           ><add>Bürger</add></roleName></rs></rs>. </rs></p>
         </div>
