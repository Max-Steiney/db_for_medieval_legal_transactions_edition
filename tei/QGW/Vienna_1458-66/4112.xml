   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4112">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__niklas_macz_QGW_II_III_4112">Niclas Macz von Michelstat, <roleName
                           type="occ" corresp="org__passau-dioezese">accolitus</roleName> Passauer
                        bistumbs</rs></rs>, dem der <rs type="person"
                     ref="pe__ulrich_meczleinstorffer_QGW_II_III_3971"><roleName type="occ"
                        corresp="org__wien">Bürgermeister</roleName>
                     <roleName type="title">herr</roleName> Ulrich Meczleinstorffer</rs> und der <rs
                     type="org" ref="org__wien">Rath der Stadt zu Wien</rs> die <rs type="org"
                     ref="org__wien-st_ruprecht-messe_truebensee">ewige Messe</rs>, welche <rs
                     type="person" ref="pe__michael_QGW_II_III_4078">Michel, <rs type="person"
                        ref="pe__jakob_von_truebensee_QGW_II_I_1584">Jacoben von Trebensee</rs>
                     <roleName type="kin" corresp="pe__jakob_von_truebensee_QGW_II_I_1584"
                        >sun</roleName>
                     <roleName type="dead">seliger</roleName></rs>, in sand Ruprechts cappellen, am
                  Chienmarkcht hie gelegen, ze stifften geschafft hat , verliehen haben, gelobt, die
                  dazu gehörigen Güter innezuhaben und die Messe dreistund in der wochen zu lesen.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4112">Besiegelt mit den Siegeln der <rs
                     type="fn" role="witness"><rs type="person"
                        ref="pe__georg_hiltprant_QGW_II_III_3937">Wiener <roleName type="occ"
                           corresp="org__wien">Bürger</roleName> Jorgen des Hildprants</rs> und <rs
                        type="person"
                        ref="pe__veit_griessenpekh_Genanntenliste_1461-64_facs_1_tr_7_tl_26"
                           ><roleName type="title">maister</roleName> Veiten Griessenpekch <roleName
                           type="occ" corresp="org__wien"><add>burger</add></roleName></rs></rs>.
               </rs></p>
         </div>
