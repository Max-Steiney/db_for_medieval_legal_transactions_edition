   <text>
      <body>
         <div type="abstract" resp="ms">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3802">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__stephan_prugk_QGW_II_III_3802">Stephanus von Prugk<roleName
                           type="title"><add>maister der siben freien
                           kunsten</add></roleName><roleName type="occ"
                           corresp="pe__erhard_von_weitra_QGW_II_III_3802"
                           ><add>geschefftleut</add></roleName></rs>, <rs type="person"
                        ref="pe__paul_sweigker_QGW_II_II_3726">Paulus Sweigker von Bamberg<roleName
                           type="title"><add>maister der siben freien
                           kunsten</add></roleName><roleName type="occ"
                           corresp="pe__erhard_von_weitra_QGW_II_III_3802"
                           ><add>geschefftleut</add></roleName></rs> und <rs type="person"
                        ref="pe__kolomann_von_weitra_QGW_II_III_3802">Colomanus von Weitra, all drei
                           <roleName type="title">maister der siben freien
                           kunsten</roleName><roleName type="occ"
                           corresp="pe__erhard_von_weitra_QGW_II_III_3802"
                           ><add>geschefftleut</add></roleName></rs>, <rs type="person"
                        ref="pe__erhard_von_weitra_QGW_II_III_3802"><roleName type="title"
                           >maister</roleName> Erharts von Weitra, <roleName type="dead"
                           >weilent</roleName>
                        <roleName type="occ" corresp="org__wien-st_stephan">achtter</roleName> dacz
                        sand Stephan hie zu Wienn seligen</rs>, geschefftleut</rs>, bestätigen, dass
                  ihnen zu ausrichtigung des benanten gescheffts <rs type="fn" role="recipient"><rs
                        type="person" ref="pe__sigmund_rogler_QGW_II_III_3802">Sigmund Rogler, der
                           <roleName type="prof">maurer</roleName></rs></rs>, 10 lb dn. ausbezahlt
                  habe, welche maister Erhart in das haus, das ettwenn Hannsen Frolichs, des
                  kursner, gewesen ist, gegen der Statmaur über zenagst hern Hannsen Schedleins haus
                  gelegen , nach Schätzung der städtischen Werkleute verbaut hatte. </rs>
            </p>
