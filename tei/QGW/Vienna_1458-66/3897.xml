   <text>
      <body>
         <div type="abstract" resp="ms">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3897">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__michael_widmer_QGW_II_III_3897">Michel Widmer, <roleName
                           type="prof">der glaser</roleName>, <roleName type="occ"
                           corresp="org__wien"> mitboner</roleName> zu Wienn</rs></rs>, bestätigt,
                  dass <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__andreas_schoenprugker_QGW_II_II_3376">Andre Schönprugker, <roleName
                           type="occ" corresp="org__wien">des rats</roleName><roleName type="occ"
                           corresp="org__wien"><add>verweser der stat
                        gruntpücher</add></roleName></rs>, und <rs type="person"
                        ref="pe__thomas_egkenperger_QGW_II_II_3455">Thoman Egkenperger, <roleName
                           type="occ" corresp="org__wien">burger</roleName>, baid <roleName
                           type="occ" corresp="org__wien">verweser der stat
                        gruntpücher</roleName></rs></rs> , ihm <rs type="fn" role="other"
                        ><triggerstring n="fn">über Auftrag</triggerstring>
                     <rs type="org" ref="org__wien">des Rathes</rs></rs> und <rs type="fn"
                     role="other"><triggerstring n="fn">mit Wissen und Willen</triggerstring><rs
                        type="person" ref="pe__heinrich_smauss_QGW_II_III_3897"> Hainreichen
                        Smaussen, seines <roleName type="kin"
                           corresp="pe__michael_widmer_QGW_II_III_3897">swehers</roleName>, auch
                           <roleName type="occ" corresp="org__wien">mitburger</roleName> zu
                        Wienn</rs></rs>, der sich umb <rs type="person"
                     ref="pe__wolfgang_QGW_II_III_3897">Wolfgangen<roleName type="kin"
                        corresp="pe__michael_widmer_QGW_II_III_3897"
                        ><add>kinder</add></roleName><roleName type="kin"
                        corresp="pe__ursula_QGW_II_III_3897"><add>kinder</add></roleName></rs>, <rs
                     type="person" ref="pe__barbara_QGW_II_III_3897">Barbaren<roleName type="kin"
                        corresp="pe__michael_widmer_QGW_II_III_3897"
                        ><add>kinder</add></roleName>><roleName type="kin"
                        corresp="pe__ursula_QGW_II_III_3897"><add>kinder</add></roleName></rs> und
                     <rs type="person" ref="pe__anna_QGW_II_III_3897">Annen, seine ungevogte
                        <roleName type="kin" corresp="pe__michael_widmer_QGW_II_III_3897"
                        >kinder</roleName><roleName type="kin" corresp="pe__ursula_QGW_II_III_3897"
                           ><add>kinder</add></roleName></rs> aus seiner ersten <rs type="person"
                     ref="pe__ursula_QGW_II_III_3897"><roleName type="kin"
                        corresp="pe__michael_widmer_QGW_II_III_3897">Ehe</roleName> mit Ursulen, <rs
                        type="person" ref="pe__johann_vendl_QGW_II_III_3897"> Hannsen Vendl
                           <roleName type="dead">seligen</roleName></rs>
                     <roleName type="kin" corresp="pe__johann_vendl_QGW_II_III_3897"
                        >tochter</roleName></rs>, angenommen hat, 50 lb dn. ausbezahlt haben, die
                  ihm zu seiner <rs type="person" ref="pe__margarethe_QGW_II_III_3897"><roleName
                        type="kin" corresp="pe__michael_widmer_QGW_II_III_3897">hausfraun</roleName>
                     Margreten, auch des benanten Hainreichs Smaussen <roleName type="kin"
                        corresp="pe__heinrich_smauss_QGW_II_III_3897">tochter</roleName></rs>, zu
                  heiratgut gevallen und geben sein worden, an den 99 lb dn., so denselben kinden
                  von <rs type="person" ref="pe__magdalena_QGW_II_III_3897">Magdalen, <rs
                        type="person" ref="pe__peter_waicz_QGW_II_I_1666">Petern Waiczen, des
                           <roleName type="prof">kürsner</roleName></rs>, <roleName type="kin"
                        corresp="pe__peter_waicz_QGW_II_I_1666">hausfraun</roleName>
                     <roleName type="dead">seligen</roleName></rs>, sind anerstorben . </rs>
            </p>
         </div>
         <div type="seal">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3897">
                  <rs type="fn" role="witness">Besiegelt mit den Siegeln <rs type="person"
                        ref="pe__martin_guldein_QGW_II_III_3897"><roleName type="title"
                           >maister</roleName> Merten Guldein, <roleName type="prof">lerer in der
                           erznei</roleName>, <roleName type="occ" corresp="org__wien">des
                           rats</roleName> und <roleName type="occ"
                           corresp="org__oesterreich-herzogtum">kellermaister</roleName> in
                        Österreich</rs>, <rs type="person" ref="pe__heinrich_smauss_QGW_II_III_3897"
                        >seines swagers</rs>, und des <rs type="person"
                        ref="pe__georg_gredinger_QGW_II_II_3727">Wiener <roleName type="occ"
                           corresp="org__wien">Bürgers</roleName> Jorgen Gredinger</rs>.</rs>
               </rs>
            </p>
         </div>
