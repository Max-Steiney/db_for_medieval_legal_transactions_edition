   <text>
      <body>
         <div type="abstract">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3759">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__sigmund_halbemer_QGW_II_III_5388">Sigmund Halbemer, <roleName
                           type="occ" corresp="org__wien-st_stephan">ächter</roleName> dacz sand
                        Stephan zu Wienn</rs></rs>, dem <rs type="fn" role="recipient"><rs
                        type="org" ref="org__wien">Bürgermeister und Rath</rs></rs> die <rs
                     type="org" ref="org__wien-st_stephan-altar_st_maria-messe_redischer_elisabeth"
                     >Messe</rs>, so <rs type="person" ref="pe__elisabeth_QGW_II_III_4077"><roleName
                        type="title">frau</roleName> Elspeth, <rs type="person"
                        ref="pe__stefan_redischer_QGW_II_II_2040a">Stephans Redischer vom
                        Weinhaus</rs>
                     <roleName type="kin" corresp="pe__stefan_redischer_QGW_II_II_2040a"
                        >witib</roleName></rs>, und <rs type="person"
                     ref="pe__dorothea_QGW_II_III_3759">Dorothe, <rs type="person"
                        ref="pe__niklas_tanwald_QGW_II_III_3759">Niclasen vom Tanwald</rs>
                     <roleName type="kin" corresp="pe__niklas_tanwald_QGW_II_III_3759"
                        >hausfrau</roleName></rs>, hincz sand Stephan hie zu stifften geschafft ,
                  verliehen haben, gelobt, die dazu gehörigen Güter in gutem Stand zu halten, die
                  Messe dreistund in der wochen zu lesen und von dem Hause im Kumphgesslein jährlich
                  an sand Michels tag der stat kamrern 6 sh. dn. zu gruntdinst zu reichen. </rs>
            </p>
         </div>
         <div type="seal">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3759"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="pe__niklas_purger_QGW_II_III_3758"
                        >Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Niclasen
                        des Burger</rs> und <rs type="person" ref="pe__niklas_ernst_SB_CD_01146"
                           >Niclasen des Ernst<roleName type="occ" corresp="org__wien"><add>Bürger</add></roleName></rs>.</rs>
               </rs>
            </p>
         </div>
