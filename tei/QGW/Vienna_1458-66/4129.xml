   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4129">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__niklas_leutel_QGW_II_II_3410">Niclas Leutl, <roleName type="occ"
                           corresp="org__wien">burger</roleName> zu Wienn</rs>, und <rs
                        type="person" ref="pe__erasmus_frankch_QGW_II_III_3959">Erasm Frankch
                           <roleName type="rep" corresp="pe__susanne_QGW_II_III_4129"
                              ><add>stellvertretend</add></roleName><roleName type="rep"
                           corresp="pe__wenzel_QGW_II_III_4129"
                           ><add>stellvertretend</add></roleName><roleName type="rep"
                           corresp="pe__wolfgang_QGW_II_III_4129"
                           ><add>stellvertretend</add></roleName></rs></rs> stellen für sich und der
                  erstere für seine unmündigen <rs type="person" ref="pe__susanne_QGW_II_III_4129"
                        ><roleName type="kin" corresp="pe__erasmus_frankch_QGW_II_III_3959"
                        >Kinder</roleName> Susannen</rs>, <rs type="person"
                     ref="pe__wolfgang_QGW_II_III_4129">Wolfgangen <roleName type="kin"
                        corresp="pe__erasmus_frankch_QGW_II_III_3959"><add>sun</add></roleName></rs>
                  und <rs type="person" ref="pe__wenzel_QGW_II_III_4129">Wenzlaben <roleName
                        type="kin" corresp="pe__erasmus_frankch_QGW_II_III_3959"
                        ><add>sun</add></roleName></rs> wegen einer verlorenen bewerten grundtzedel,
                  welche <rs type="person" ref="pe__dorothea_facs_216_TextRegion_1644498965730_994"
                     >Dorothe, Niclasen Leutl <roleName type="kin"
                        corresp="pe__niklas_leutel_QGW_II_II_3410">hausfrau</roleName>
                     <roleName type="dead">selige</roleName></rs>, . . . über ain haus, undern
                  Satlern hie gelegen zenagst weilent Jorgen Pramperger haus, darumb sie und <rs
                     type="person" ref="pe__ursula_facs_216_TextRegion_1644498965730_994">Ursula,
                        <rs type="person" ref="pe__johann_frankch_QGW_II_III_4129">Hannsen
                        Frankchen</rs>
                     <roleName type="kin" corresp="pe__johann_frankch_QGW_II_III_4129"
                        >hausfrau</roleName>, ir <roleName type="kin"
                        corresp="pe__dorothea_facs_216_TextRegion_1644498965730_994"
                        >swester</roleName>
                     <roleName type="dead">seligen</roleName></rs>, mit einander nucz und gwer
                  geschriben gewesen sein , genommen hatte, dem. <rs type="fn" role="recipient"><rs
                        type="org" ref="org__wien">Bürgermeister und Rathe sowie den Verwesern ihres
                        Grundbuches</rs></rs> einen Revers aus. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4129">Siegler: <rs type="fn" role="witness"><rs
                        type="person" ref="pe__niklas_leutel_QGW_II_II_3410">Niclas Leutl</rs> und
                     der <rs type="person"
                        ref="pe__veit_griessenpekh_Genanntenliste_1461-64_facs_1_tr_7_tl_26">Wiener
                           <roleName type="occ" corresp="org__wien">Bürger</roleName>
                        <roleName type="title">maister</roleName> Veit Griessenpekch</rs></rs>.
               </rs></p>
         </div>
