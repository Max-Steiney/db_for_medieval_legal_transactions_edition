   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4074"><rs type="fn" role="issuer">
                     <rs type="person" ref="pe__wolfgang_frumolt_QGW_II_III_4074">Wolfgang Frumolt,
                        gesessen zu Erdpurg,</rs> und <rs type="person"
                        ref="pe__johann_frumolt_QGW_II_III_4074">Hanns Frumolt, gesessen zu Grossen
                        Enczestorff, sein <roleName type="kin"
                           corresp="pe__wolfgang_frumolt_QGW_II_III_4074"
                     >bruder,</roleName></rs></rs> bestätigen, dass ihnen <rs type="fn"
                     role="recipient"><rs type="person" ref="pe__christian_schoeppl_QGW_II_III_4074"
                        >Cristan Schöppl, der <roleName type="prof">vischer</roleName>, <roleName
                           type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs></rs>, 12
                  lb dn. ausgerichtet habe, die er ihnen von wegen ains halben heusleins, gancz
                  gelegen im Obern Werd zunagst Simons Seidleins seligen haus , schuldete, das ihnen
                  von ihrer <rs type="person"
                     ref="pe__katharina_facs_571_TextRegion_1656869212906_2954"><roleName type="kin"
                        corresp="pe__wolfgang_frumolt_QGW_II_III_4074">Mutter</roleName><roleName
                        type="kin" corresp="pe__johann_frumolt_QGW_II_III_4074"
                        ><add>Mutter</add></roleName> Kathrein, <rs type="person"
                        ref="pe__georg_alphart_QGW_II_II_2557">Jorgen Alpharten</rs>
                     <roleName type="kin" corresp="pe__georg_alphart_QGW_II_II_2557"
                        >hausfraun</roleName>, die <rs type="person"
                        ref="pe__siegfried_frumolt_QGW_II_III_4074"><roleName type="dead"
                           >emaln</roleName> Seifriden Frumolten, ihren <roleName type="kin"
                           corresp="pe__wolfgang_frumolt_QGW_II_III_4074">vater</roleName><roleName
                           type="kin" corresp="pe__johann_frumolt_QGW_II_III_4074"
                           ><add>vater</add></roleName></rs>, auch <roleName type="kin"
                        corresp="pe__siegfried_frumolt_QGW_II_III_4074">elichen</roleName> gehabt
                     hat</rs>, anerstorben war und das sie ihm verkauft hatten. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4074"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__johann_ravensburger_QGW_II_II_3264"
                        >Hannsen des Ravenspurger, des <roleName type="occ" corresp="org__wien"
                           >rats</roleName> und <roleName type="occ" corresp="org__wien"
                           >urtailschreiber</roleName> zu Wienn</rs>, und <rs type="person"
                        ref="pe__johann_kuntstokch_QGW_II_II_3530">Hannsen des Kuntstokch, geswornen
                           <roleName type="prof">weger</roleName>, <roleName
                           type="occ" corresp="org__wien">burger</roleName> daselbs</rs></rs> .
               </rs></p>
         </div>
