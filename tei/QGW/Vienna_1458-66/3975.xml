   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3975"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270"
                           ><roleName type="occ" corresp="org__heiliges_roemisches_reich"
                           >Kaiser</roleName> Friedrich III.</rs></rs> befiehlt <rs type="fn"
                     role="recipient"><rs type="org" ref="org__wien">dem Bürgermeister, Richter,
                        Rathe, den Genannten und Bürgern zu Wien</rs></rs>, da sein <rs
                     type="person" ref="pe__albrecht_herzog_von_oesterreich_QGW_II_II_3617"><roleName type="kin"
                        corresp="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270"
                        >Bruder</roleName>
                     <roleName type="occ" corresp="org__oesterreich-herzogtum">Herzog</roleName>
                     Albrecht</rs> sich bei jeczvergangen tagen aus seinem rat und dienst gemüssigt
                  hat und sunst die leuff in diesen zeiten etwas selczam und sorgleich seinn , weder
                  diesen noch den <rs type="person" ref="pe__sigmund_QGW_II_II_3631"><roleName
                        type="occ" corresp="org__tirol-grafschaft">Herzog</roleName> Sigmund</rs> in
                  die Stadt einzulassen. </rs></p>
         </div>
         <div type="nota">
            <p><rs type="event" ref="ev__QGW_II_III_3975_nota">Von anderer Hand: commissio domini
                  imperatoris in consilio. </rs></p>
