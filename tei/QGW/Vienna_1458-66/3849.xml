   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_3849">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__matthias_prel_QGW_II_III_3849">Mathes Prêl, gesessen zu
                        Nustorf</rs>, und <rs type="person" ref="pe__katharina_QGW_II_III_3849"
                        >Kathrei, sein <roleName type="kin"
                           corresp="pe__matthias_prel_QGW_II_III_3849"
                  >hausfrau</roleName></rs></rs>, verkaufen <rs type="fn" role="other"><triggerstring
                        n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__johann_hechtl_QGW_II_II_3480"><roleName type="title"
                           >herrn</roleName> Hannsen Hechtl, <roleName type="occ"
                           corresp="org__klosterneuburg-augustiner_chorherren">corherren</roleName>
                        und <roleName type="occ" corresp="org__klosterneuburg">obristen kellner
                        </roleName>Unser Lieben Fraun gotshauss zu Closterneunburg</rs></rs> , drei
                  Viertel Weingarten, gelegen am Mitterperg pei Salmanstorf zunagst Lienharts
                  Gruenpacher seligen weingarten, von dem man 1½ Eimer Most zu Bergrecht und 9 ort
                  zu foitrecht dient, um 124 lb dn. <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__thomas_ulman_QGW_II_II_3539">hern Thoman Ulman, <roleName
                           type="occ" corresp="org__wien-st_hieronymus-messe_rauffenvoglin"
                           >kaplan</roleName> der von <rs type="person"
                           ref="pe__margarethe_rauffenvoglin_QGW_II_III_3786">Margreth
                           Raufenfoglin</rs> in sand Jeronimus cappelln zu Wienn gestifteten
                        Messe</rs>, zu <rs type="org"
                        ref="org__wien-st_hieronymus-messe_rauffenvoglin">dieser Messe</rs></rs>.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3849">Siegler: <rs type="fn" role="witness"><rs
                        type="person" ref="pe__christian_schoenperger_QGW_II_III_3849">der <roleName
                           type="occ" corresp="org__klosterneuburg-augustiner_chorherren">oberste
                           Kellner</roleName> und Cristan Schönnperger, <roleName type="occ"
                           corresp="org__klosterneuburg">burger</roleName> zu
                     Closterneunburg</rs></rs>. </rs></p>
         </div>
         <div type="nota">
            <p><rs type="event" ref="ev__QGW_II_III_3849_nota">Die angehängten Siegel
               fehlen.</rs></p>
         </div>
