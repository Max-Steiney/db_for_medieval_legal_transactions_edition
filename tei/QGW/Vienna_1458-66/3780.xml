   <text>
      <body>
         <div type="abstract" resp="ms">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3780">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__barbara_QGW_II_II_3643"
                        >Barbara, <rs type="person" ref="pe__philipp_sailer_QGW_II_II_3643"
                           >Philipps, sailer,<roleName type="dead"><add>wittib</add></roleName></rs>
                        <roleName type="kin" corresp="pe__philipp_sailer_QGW_II_II_3643"
                           >wittib</roleName></rs></rs>, verkauft <rs type="fn" role="other"
                        ><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person"
                        ref="pe__jakob_starch_QGW_II_II_3557"><roleName type="occ"
                           corresp="org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Jacoben Starch</rs> und des <rs
                        type="org" ref="org__wien">Rathes</rs></rs> ihr Haus, gelegen am Neunmarkcht
                  am egk zenagst Thoman Markter, des smids, haus an aim tail, von dem man hern
                  Wolfgangen Stadler, Caplan der von Niclas Karner auf sand Jacobs altar dacz sand
                  Stephan gestifteten Messe, 10 lb dn. zu Burgrecht (abzulösen um 152 lb dn.) dient,
                  um 148 lb dn. <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__matthias_zeller_QGW_II_III_3780">Matthesen Zeller, dem
                     kuntter</rs>, <rs type="person" ref="pe__gertrud_QGW_II_III_3780">Gedrauten,
                        seiner <roleName type="kin" corresp="pe__matthias_zeller_QGW_II_III_3780"
                           >hausfraun</roleName></rs>, und <rs type="person"
                        ref="pe__georg_hagenperger_QGW_II_III_3780">Jörgen Hagenperger, dem
                        sailer</rs>, <rs type="person" ref="pe__barbara_QGW_II_III_3780">Barbaren,
                        seiner <roleName type="kin" corresp="pe__georg_hagenperger_QGW_II_III_3780"
                           >hausfraun</roleName>.</rs></rs>
               </rs>
            </p>
         </div>
         <div type="seal">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3780"><rs type="fn" role="witness">Besiegelt mit dem <rs type="org" ref="org__wien"
                  >städtischen Grundsiegel</rs> und dem Siegel des <rs type="person"
                     ref="pe__niklas_purger_QGW_II_III_3758">Wiener <roleName type="occ"
                        corresp="org__wien">Bürgers</roleName> Niclas Purger</rs>.</rs> </rs>
            </p>
         </div>
         <div type="nota">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3780_nota">Indorsat: nunc Thoman Enengkl von
                  Ennse. </rs>
            </p>
