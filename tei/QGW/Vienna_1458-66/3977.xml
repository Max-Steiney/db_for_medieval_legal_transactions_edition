         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3977">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__johann_markchdorf_QGW_II_III_3977"><roleName type="title"
                           >Pruder</roleName> Hanns Markchdorf, <roleName type="occ"
                           corresp="org__wien-karmeliter">prior</roleName> des klosters Unser Fraun
                        prüder ordens von dem perg Carmelo, gelegen am Hof zu Wienn</rs>, und <rs
                        type="org" ref="org__wien-karmeliter">der convent gemain</rs> daselbs</rs>
                  geben <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__ulrich_holczleittner_facs_1128_TextRegion_1653916710050_421"
                        >Ulreichen Holczleitter</rs>, und <rs type="person"
                        ref="pe__anna_facs_1128_TextRegion_1653916710050_421">Annen, seiner
                           <roleName type="kin"
                           corresp="pe__ulrich_holczleittner_facs_1128_TextRegion_1653916710050_421"
                           >hausfraun</roleName>, <rs type="person"
                           ref="pe__peter_swab_facs_933_TextRegion_1644919222888_1778">Petern
                           Swaben, des <roleName type="prof">furtmüllner</roleName>
                           <roleName type="dead">seligen</roleName></rs>, <roleName type="kin"
                           corresp="pe__peter_swab_facs_933_TextRegion_1644919222888_1778"
                           >tochter</roleName></rs></rs>, 2 lb dn. geltes purekrechts von ihrem
                  Hause, gelegen vor Kernertor an der Mietstat zenagst des kuphersmids haus, um 16
                  lb dn. abzulösen. </rs></p>
         </div>
