   <text>
      <body>
         <div type="abstract" resp="ms">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3763">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__wolfgang_ruber_QGW_II_III_3763">Wolfgang Ruber von Krembs,
                           <roleName type="prof">briester</roleName></rs> Passauer bistumbs</rs>,
                  dem <rs type="org" ref="org__wien">Bürgermeister und [ 4] Rath</rs> die von <rs
                     type="person" ref="pe__elisabeth_QGW_II_I_1498"><roleName type="title"
                        >frau</roleName> Elspeth, <rs type="person" ref="pe__ulrich_QGW_II_I_1498"
                        >Ullreichs, <roleName type="prof">kerzenmacher</roleName>
                        <roleName type="dead"><add>witib</add></roleName></rs>, <roleName type="kin"
                        corresp="pe__ulrich_QGW_II_I_1498">witib</roleName></rs>, auf <rs type="fn"
                     role="recipient"><rs type="org" ref="org__wien-st_stephan-altar_allerheiligen"
                        >Allerheiligen altar dacz sand Stephan gestiftete Messe</rs></rs> verliehen
                  haben, gelobt, dass er den weingarten, gelegen bei Peczleinstorf an der Hohenwart,
                  genant das Eisengretl, des ain jeuch ist, peulichen mitsambt den aindlef phunt
                  pheningen purkchrechtgült, so zu derselben mess gehörnt, innhaben, nüczen und
                  niessen , und die Messe dreistund in der wochen, am Montag, Mittwoch und Freitag,
                  lesen wolle. </rs>
            </p>
         </div>
         <div type="seal">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3763"><rs type="fn" role="witness">Besiegelt mit den Siegeln der Wiener <rs type="person"
                  ref="pe__niklas_purger_QGW_II_III_3758"><roleName type="occ"
                     corresp="org__wien">Bürger</roleName> Niclasen des Purger</rs> und <rs
                        type="person" ref="pe__johann_viregk_SB_CD_01573"><roleName type="occ"
                           corresp="org__wien"><add>Bürger</add></roleName>Hannsen Viregken</rs>.</rs> </rs>
            </p>
