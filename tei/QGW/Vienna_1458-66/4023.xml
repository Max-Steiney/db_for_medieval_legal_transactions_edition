   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4023">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__stephan_lechner_QGW_II_III_4023">Steffan Lehner<roleName type="kin"
                           corresp="pe__anna_QGW_II_III_4023"
                           ><add>geswistred</add></roleName><roleName type="kin"
                           corresp="pe__margarethe_QGW_II_III_4023"
                        ><add>geswistred</add></roleName></rs>, <rs type="person"
                        ref="pe__anna_QGW_II_III_4023">Anna, <rs type="person"
                           ref="pe__georg_am_pach_QGW_II_III_4023">Jorgen am Pach</rs> eliche
                           <roleName type="kin" corresp="pe__georg_am_pach_QGW_II_III_4023"
                           >hausfrau</roleName><roleName type="kin"
                           corresp="pe__margarethe_QGW_II_III_4023"
                        ><add>geswistred</add></roleName></rs>, und <rs type="person"
                        ref="pe__margarethe_QGW_II_III_4023">Margreth, <rs type="person"
                           ref="pe__pangraz_am_lehen_QGW_II_III_4023">Pangraczen am Lehen</rs>
                        eliche <roleName type="kin" corresp="pe__pangraz_am_lehen_QGW_II_III_4023"
                           >hausfrau</roleName></rs>, alle dreu geswistred</rs> , stellen
                  hinsichtlich des von <rs type="person" ref="pe__stephan_reuschel_QGW_II_III_4003"
                     >ihrem <roleName type="kin" corresp="pe__stephan_lechner_QGW_II_III_4023"
                        >Vetter</roleName><roleName type="kin" corresp="pe__anna_QGW_II_III_4023"
                           ><add>Vetter</add></roleName><roleName type="kin"
                        corresp="pe__margarethe_QGW_II_III_4023"><add>Vetter</add></roleName>
                     Steffan Räuschl, <unclear>etwen gesessen in der Scheffstrass vor
                        Stubmertor</unclear> und <roleName type="occ" corresp="org__wien"
                        >burger</roleName> zu Wienn</rs>, hinterlassenen Gutes dem genannten <rs
                     type="fn" role="recipient"><rs type="person"
                        ref="pe__pangraz_am_lehen_QGW_II_III_4023">Pangraczen am Lehen</rs></rs>
                  eine Vollmacht aus. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4023"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__erhard_althaimer_QGW_II_III_4023"
                        >Erharten des Althaimer, <roleName type="occ"
                           corresp="org__schaumberg-grafschaft">landtrichter</roleName> im Tunautal
                        in der graffschafft Schaunberg etc.</rs>, und <rs type="person"
                        ref="pe__kaspar_rottaler_QGW_II_III_4023">Casparn des Rottaler, <roleName
                           type="occ" corresp="org__eferding">spitalmaister</roleName> zu
                        Eferding</rs>.</rs>
               </rs></p>
         </div>
