         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4072">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__oswald_treskircher_QGW_II_III_4070">Oswald Dreskircher, <roleName
                           type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs></rs>,
                  stellt <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__Georg_himperger_prior_augustiner_QGW_II_III_4072"><roleName
                           type="title">bruder</roleName> Jorgen Himperger, <roleName type="occ"
                           corresp="org__wien-st_dorothea">prior</roleName> zu den Augustinern zu
                        Wienn</rs>, und dem <rs type="org" ref="org__wien-st_dorothea">convent
                        gemain daselbs</rs></rs> einen Schuldbrief über 40 lb dn. für Wein aus und
                  verpflichtet sich zur Rückzahlung am nächsten sant Jörgen tag. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4072">Siegler: der <rs type="fn" role="witness"
                        ><rs type="person" ref="pe__oswald_treskircher_QGW_II_III_4070"
                        >Aussteller</rs> und der <rs type="person"
                        ref="pe__niklas_leutel_QGW_II_II_3410">Wiener <roleName type="occ"
                           corresp="org__wien">Bürger</roleName> Niclas Leytl</rs></rs>. </rs></p>
         </div>
