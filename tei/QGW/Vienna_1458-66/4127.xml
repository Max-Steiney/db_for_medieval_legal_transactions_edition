   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4127">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__johann_von_spaur_QGW_II_III_4127">Hanns von Spaur, <roleName
                           type="occ" corresp="org__tirol-grafschaft">erbschenck</roleName> zu
                        Tirol</rs></rs>, bestätigt von dem <rs type="org" ref="org__wien"
                     >Bürgermeister, Richter, Rathe, den Genannten und Bürgern zu Wien</rs> an den
                  1200 Ungerisch und ducaten guldein, die ihm <rs type="person"
                     ref="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270"><roleName type="occ"
                        corresp="org__heiliges_roemisches_reich">Kaiser</roleName> Friedrich</rs>
                  wegen etlicher Forderungen zugesprochen hatte, 1046 guldein erhalten zu haben.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4127">Besiegelt mit den Siegeln der <rs
                     type="fn" role="witness"><rs type="person"
                        ref="pe__bernhard_praun_QGW_II_III_4127"><roleName type="title">edeln vesten
                           ritter, hern</roleName> Pernharten Praun</rs> und <rs type="person"
                        ref="pe__christoph_quas_QGW_II_III_4127">Kristoffen Quas <roleName
                           type="title"><add>ritter</add></roleName></rs></rs>. </rs></p>
         </div>
