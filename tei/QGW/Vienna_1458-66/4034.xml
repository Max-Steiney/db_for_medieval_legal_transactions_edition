   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4034">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__martin_herzogenperger_facs_757_TextRegion_1658304674709_312">Mert
                        Herzogenperger, <roleName type="occ" corresp="org__wien">burger</roleName>
                        zu Wienn</rs></rs>, verkauft <rs type="fn" role="other"><triggerstring n="fn"
                        >mit Handen</triggerstring>
                     <rs type="person" ref="pe__wolfgang_holczer_SB_CD_01926">des <roleName
                           type="occ" corresp="org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Wolfgangs Holczer</rs> und <rs
                        type="org" ref="org__wien">des Rathes</rs></rs> 6 lb dn. geltes purkrechts
                  (ablösbar) auf seinem Hause, gelegen pei Peurertor am egk zenagst weilent
                  Larenczen Wienner, des goltsmid, haus, um 48 lb dn., die emaln gelegen gewesen
                  sind auf Hannsen Planer, des ledrer, haus, gelegen im Greut zenagst der Mulgassen
                  an aim tail , . . . <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__georg_romer_QGW_II_III_4034"><roleName type="title">hern</roleName>
                        Jorgen Römer, <roleName type="occ" corresp="org__wien-st_stephan"
                           >gracianer</roleName> zu sand Steffan zu Wienn, <roleName type="occ"
                           corresp="org__wien-st_maria_am_gestade-altar_elftausend_jungfrauen-messe_steg_heinrich"
                           >Caplan</roleName> der von Hainreich vom Steg auf der Aindleftausent Maid
                        altar zu Unser fraun auf der Stetten gestifteten Messe, und seinen <rs
                           type="org"
                           ref="org__wien-st_maria_am_gestade-altar_elftausend_jungfrauen-messe_steg_heinrich"
                           >Nachfolgern</rs></rs>.</rs>
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4034"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="pe__johann_molter_QGW_II_II_3525">Wiener <roleName
                           type="occ" corresp="org__wien">Bürgers</roleName> Hanns Molter</rs>.</rs>
               </rs></p>
