   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_3872">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__stephan_kerner_QGW_II_III_3872">Steffan Kerner, der <roleName
                           type="prof">kürsner</roleName>, <roleName type="occ" corresp="org__wien"
                           >bürger</roleName> zu Wienn</rs></rs>, stellt seinen <rs type="fn"
                     role="recipient"><rs type="person" ref="pe__agnes_QGW_II_III_4657"><roleName
                           type="title">unmündigen</roleName>
                        <roleName type="kin" corresp="pe__stephan_kerner_QGW_II_III_3872"
                           >Töchtern</roleName> zweiter Ehe, junkchfraun Agnesen</rs> und <rs
                        type="person" ref="pe__magdalena_QGW_II_III_4657">Magdalen <roleName
                           type="title"><add>unmündige</add></roleName>
                        <roleName type="kin" corresp="pe__stephan_kerner_QGW_II_III_3872"
                              ><add>Tochter</add></roleName>
                     </rs></rs>, einen Schuldbrief über 29 lb dn. landeswerung in Österreich aus,
                  die herkomen sind von dem sacz des hauss, gelegen vor Stubentor pei der prugk, das
                     <rs type="person" ref="pe__gottfried_oler_QGW_II_III_3872">Gotfrid, oler</rs>,
                  und <rs type="person" ref="pe__johann_stainprecher_QGW_II_II_2017">Hanns,
                     stainprecher</rs> , ihm zu Handen seiner <rs type="person"
                     ref="pe__magdalena_QGW_II_III_3872"><roleName type="kin"
                        corresp="pe__stephan_kerner_QGW_II_III_3872">Tochter</roleName>
                     Magdalen</rs> aus seiner früheren <rs type="person"
                     ref="pe__margarethe_QGW_II_III_3872"><roleName type="kin"
                        corresp="pe__stephan_kerner_QGW_II_III_3872">Ehe</roleName> mit Margrethen,
                        <rs type="person" ref="pe__friedrich_riser_QGW_II_III_3872">Fridreichs
                        Riser</rs>
                     <roleName type="kin" corresp="pe__friedrich_riser_QGW_II_III_3872"
                        >tochter</roleName></rs>, in der Schotten gruntpuch versaczt heten.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3872">Besiegelt mit den Siegeln <rs type="fn"
                     role="witness"><rs type="person" ref="pe__johann_eslarn_QGW_II_III_3913"
                        >Hannsen von Eslorn <roleName type="occ" corresp="org__wien"
                           >burger</roleName></rs> und <rs type="person"
                        ref="pe__veit_hintperger_QGW_II_II_3311">Veiten Hindperger, paid <roleName
                           type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs></rs>. [
                  29] </rs></p>
         </div>
