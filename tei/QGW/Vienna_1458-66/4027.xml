         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4027">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__christian_prenner_SB_CD_01257">Kristan Prenner, burgermaister</rs>,
                     und der<rs type="org" ref="org__wien"> rat gemain der stat zu Wienn</rs></rs>
                  verkaufen dem <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__hartung_von_kappel_QGW_II_III_3807"><roleName type="title"
                           >maister</roleName> Harttung von Kappeln, <roleName type="prof"
                           >lerer</roleName> baider rechten</rs></rs>, 100 guter Ungrischer guldein,
                  all gerecht in gold und wag, jerlicher gült (ablösbar) umb 2000 guter Ungrischer
                  guldein, auch gerecht in gold und wag, die sie in disen swern kriegsleuffen zu
                  gemainem nucz der stat gewendet haben. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4027">Besiegelt mit ihrem <rs type="fn"
                     role="witness"><rs type="org" ref="org__wien">klainem anhangundem
                        statinsigl</rs></rs>. </rs></p>
