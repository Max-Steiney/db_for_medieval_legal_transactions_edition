   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4130">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__andreas_ottenperger_QGW_II_III_4130">Andre Ottenperger, <roleName
                           type="occ" corresp="org__hainburg">burger</roleName> zu Haimburg</rs>,
                     und <rs type="person" ref="pe__klara_QGW_II_III_4130">Clara, sein <roleName
                           type="kin" corresp="pe__andreas_ottenperger_QGW_II_III_4130"
                           >hausfrau</roleName>, die <roleName type="kin"
                           corresp="pe__heinrich_kilau_QGW_II_III_3887">emaln</roleName> den <rs
                           type="person" ref="pe__heinrich_kilau_QGW_II_III_3887">Kyllau <roleName
                              type="dead">seligen</roleName></rs></rs></rs> auch elichen gehabt hat
                  , bestätigen, dass sie den Satz von 90 Ungrisch guldein in gold, die ihnen noch an
                  den 54 Ungrischen guldein in gold und 100 lb dn. ausstanden, für welche <rs
                     type="person" ref="pe__johann_sumerpekh_QGW_II_III_3887">Hanns Sumerpekch
                        <roleName type="dead">seliger</roleName></rs> und <rs type="person"
                     ref="pe__dorothea_SB_CD_00308">Dorothe, sein <roleName type="kin"
                        corresp="pe__johann_sumerpekh_QGW_II_III_3887">hausfrau</roleName></rs>,
                  ihnen ihr Haus zu Wienn am Kienmarkcht zenagst Jorigen Silberprenner haus gelegen,
                  verpfändet hatten, dem <rs type="person" ref="pe__johann_spiegler_QGW_II_III_4130"
                     >Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Hannsen
                     Spiegler, der obgenanten Dorotheen <roleName type="kin"
                        corresp="pe__dorothea_SB_CD_00308">sun</roleName></rs>, gegen Abstattung des
                  Darlehens übergeben haben. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4130">Besiegelt mit den Siegeln der <rs
                     type="fn" role="witness"><rs type="person"
                        ref="pe__thomas_praitenweidacher_QGW_II_II_3462">Wiener <roleName type="occ"
                           corresp="org__wien">Bürger</roleName> Thomans Praitenweidacher</rs> und
                        <rs type="person" ref="pe__veit_hintperger_QGW_II_II_3311">Veiten Hindperger
                           <roleName type="occ" corresp="org__wien"
                        ><add>burger</add></roleName></rs></rs>. </rs></p>
         </div>
