   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4053">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__kunigunde_QGW_II_III_4053"
                        >Kunigund, <rs type="person" ref="pe__johann_hagen_QGW_II_III_4053">Hannsen
                           Hagen <roleName type="dead"><add>selig</add></roleName></rs>
                        <roleName type="kin" corresp="pe__johann_hagen_QGW_II_III_4053"
                           >witib</roleName></rs></rs>, verkauft <rs type="fn" role="other"
                        ><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person"
                        ref="pe__friedrich_ebmer_QGW_II_II_3350"><roleName type="title">edeln vesten
                           ritter . . . hern</roleName> Fridreich Ebmer, <roleName type="occ"
                           corresp="org__wien">burgermaister</roleName>, und <roleName type="occ"
                           corresp="org__wien">des Rathes</roleName></rs></rs> ein Haus, gelegen in
                  der Weihenpurkch zenagst maister Larenczen, des stainmeczen und paumaister zu sand
                  Steffan, haus , um 165 Ungrisch guldein . . . . <rs type="fn" role="recipient"><rs
                        type="person" ref="pe__wolfgang_joppel_QGW_II_III_4053">Wolfgangen Joppel
                           <roleName type="rep" corresp="pe__veit_schattauer_QGW_II_II_3676"
                              ><add>geschefftherr</add></roleName><roleName type="occ"
                           corresp="org__wien"><add>burger</add></roleName></rs>, <rs type="person"
                        ref="pe__andreas_stainprecher_QGW_II_III_4053">Andren Stainprecher,
                           <roleName type="rep" corresp="pe__veit_schattauer_QGW_II_II_3676"
                              ><add>geschefftherr</add></roleName><roleName type="occ"
                           corresp="org__wien">burgern</roleName> zu Wienn</rs>, und <rs
                        type="person" ref="pe__lukas_paumgartner_QGW_II_III_4053">Lucasen
                        Paungartner <roleName type="rep"
                           corresp="pe__veit_schattauer_QGW_II_II_3676"
                           ><add>geschefftherr</add></roleName></rs></rs>, all drei <rs
                     type="person" ref="pe__veit_schattauer_QGW_II_II_3676">Veiten Schattauer, auch
                     weilent <roleName type="occ" corresp="org__wien">burger</roleName> daselbs
                        <roleName type="dead">seligen</roleName></rs>, geschefftleuten , zu diesem
                  Geschäfte. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4053">Besiegelt mit dem <rs type="fn"
                     role="witness"><rs type="org" ref="org__wien">städtischen Grundsiegel</rs> und
                     dem Siegel des <rs type="person" ref="pe__niklas_leutel_QGW_II_II_3410">Wiener
                           <roleName type="occ" corresp="org__wien">Bürgers</roleName> Niclas
                        Leutel</rs></rs>. </rs></p>
         </div>
