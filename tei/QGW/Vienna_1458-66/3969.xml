   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_3969">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__agathe_QGW_II_III_3969">Agatha, <rs type="person"
                           ref="pe__wolfgang_retenperger_QGW_II_II_3515">Wolfgangs
                           Re/atenperger</rs>
                        <roleName type="kin" corresp="pe__wolfgang_retenperger_QGW_II_II_3515"
                           >hausfrau</roleName></rs>, und <rs type="person"
                        ref="pe__margarethe_QGW_II_III_3969">Margreth, <rs type="person"
                           ref="pe__johann_froner_QGW_II_III_3905">Hannsen Froner</rs>
                        <roleName type="kin" corresp="pe__johann_froner_QGW_II_III_3905"
                           >hausfrau</roleName>, ir <roleName type="kin"
                           corresp="pe__agathe_QGW_II_III_3969">tochter</roleName></rs></rs> ,
                  bestätigen, von ihrem <rs type="person"
                     ref="pe__johann_haringseer_QGW_II_III_3910"><roleName type="kin"
                        corresp="pe__agathe_QGW_II_III_3969">Schwager</roleName> Hanns Haringseer,
                        <roleName type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs>, 50
                  lb dn. erhalten zu haben, welche ihnen <rs type="person"
                     ref="pe__klara_QGW_II_III_3969">frau Klara, <rs type="person"
                        ref="pe__johann_haringseer_QGW_II_II_2387">Hannsen Haringseer, <rs
                           type="person" ref="pe__johann_haringseer_QGW_II_III_3910">seins <roleName
                              type="kin" corresp="pe__johann_haringseer_QGW_II_II_2387"
                              >vater</roleName></rs></rs>, <roleName type="kin"
                        corresp="pe__johann_haringseer_QGW_II_II_2387">wittib</roleName>, ihre
                        <roleName type="kin" corresp="pe__agathe_QGW_II_III_3969">swester</roleName>
                     und <roleName type="kin" corresp="pe__margarethe_QGW_II_III_3969"
                        >mum</roleName>
                     <roleName type="dead">selige</roleName></rs>, geschafft hat von den 200 lb dn.,
                  die sie auf desselben Haringseer haus, in der Münsserstrass zunagst des Pilgreim
                  haus gelegen, gehabt hat . </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3969">Besiegelt mit den Siegeln <rs type="fn"
                     role="witness"><rs type="person"
                        ref="pe__sebastian_zieglshauser_QGW_II_III_3864">Sebastians Ziegelshauser,
                           <roleName type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs>,
                     und <rs type="person" ref="pe__ulrich_hirssauer_QGW_II_II_3239">Ulreichs
                        Hirssauer, <roleName type="occ" corresp="org__wien">statschreiber</roleName>
                        daselbs</rs></rs>. </rs></p>
         </div>
