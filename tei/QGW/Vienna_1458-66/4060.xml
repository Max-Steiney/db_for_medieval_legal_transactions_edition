         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4060">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__stephan_eitzinger_QGW_II_II_3305">Steffan Eiczinger von
                        Eiczing</rs></rs> fordert <rs type="fn" role="recipient"><rs type="org"
                        ref="org__wien">den Bürgermeister, Rath, die Genannten und gemain der stat
                        zu Wienn</rs></rs> unter Berufung auf seine früheren Zuschriften und unter
                  Androhung von Gegengewalt neuerdings auf, ihm hinsichtlich der Jahrgült, welche
                     <rs type="person" ref="pe__ulrich_eitzinger_QGW_II_II_3270">sein <roleName
                        type="dead">verstorbener</roleName>
                     <roleName type="kin" corresp="pe__stephan_eitzinger_QGW_II_II_3305"
                        >Bruder</roleName>
                     <roleName type="title">her</roleName> Ulreich von Eiczing</rs> von weilenten
                     <rs type="person" ref="pe__johann_maires_QGW_II_III_4060"><roleName
                        type="title">maister</roleName> Hannsen von Meyrs <roleName type="dead"
                        >eriben</roleName></rs> auf gemaine statt Wienn gekaufft hat, . . . .
                  unverzogenlich ausrichtung und zalung zu tun . </rs></p>
         </div>
         <div type="nota">
            <p><rs type="event" ref="ev__QGW_II_III_4060_nota">Indorsat: praesentata feria 3a post
                  Jacobi im snit (Juli 26) anno etc. lxiii°. </rs></p>
         </div>
