   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4071">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__oswald_treskircher_QGW_II_III_4070">Oswald Dreskircher, <roleName
                           type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs></rs>,
                  stellt <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__ruprecht_QGW_II_III_4071"><roleName type="occ"
                           corresp="org__wien-heiligengeistspital">bruder</roleName> Rueprechten,
                           <roleName type="title">maister</roleName> zum Heiligengeist zu Wienn</rs>
                     vor Kernertor, und dem <rs type="org" ref="org__wien-heiligengeistspital"
                        >convent gemain</rs> daselbs</rs> einen Schuldbrief über 74 lb dn. guter
                  landeswerung in Österreich für Wein aus und verpflichtet sich zur Rückzahlung in
                  zwei Raten an dem nächsten sand Jörgen und sant Giligen tag. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4071">Siegler: der <rs type="fn" role="witness"
                        ><rs type="person" ref="pe__oswald_treskircher_QGW_II_III_4070"
                        >Aussteller</rs> und <rs type="person"
                        ref="pe__johann_ravensburger_QGW_II_II_3264">Hanns Ravenspurger, des
                           <roleName type="occ" corresp="org__wien">rats</roleName> und <roleName
                           type="occ" corresp="org__wien">urtailschreiber</roleName> zu
                     Wienn</rs></rs>. </rs></p>
         </div>
