   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4119">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__matthias_angerfelder_QGW_II_II_3334">Mathes Angerfelder, <roleName
                           type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs></rs>,
                  verkauft <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des
                        <rs type="person" ref="pe__ulrich_matzleinsdorfer_QGW_II_II_3362"><roleName
                           type="occ" corresp="org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Ulreichen Meczleinstorrfer</rs> und
                        <rs type="org" ref="org__wien">des Rathes</rs></rs> sein Haus und das
                  zuheusl hinden daran, gelegen am Kienmarkt zunagst Hannsen des Mülhauser haus an
                  aim tail und an dem andern zunagst Chunczen Pinter von Nürnberg, des kramer, haus,
                  das von <rs type="person" ref="pe__johann_meichsner_QGW_II_II_3600">Hannsen
                     Meichsner, <roleName type="occ" corresp="org__wien">mitburger</roleName> hie zu
                     Wienn</rs>, mit kauff an ihn komen ist, und zwar eine Hälfte <rs type="fn"
                     role="recipient"><rs type="person" ref="pe__johann_schürger_QGW_II_III_4119"
                        >Hannsen Schürger, <roleName type="occ" corresp="org__krems"
                           >statschreiber</roleName> zu Krembs</rs>, und <rs type="person"
                        ref="pe__anna_QGW_II_III_4119">Annen, seiner <roleName type="kin"
                           corresp="pe__johann_schürger_QGW_II_III_4119">hausfraun</roleName></rs>,
                     die andere Hälfte <rs type="person" ref="pe__barbara_QGW_II_III_4119"><roleName
                           type="title">junkchfraun</roleName> Barbaren, <rs type="person"
                           ref="pe__georg_heubekch_QGW_II_III_4119">Jörgen des Heybekchen, weilent
                           gesessen zu Utldorff <roleName type="dead">seligen</roleName></rs>,
                           <roleName type="kin" corresp="pe__georg_heubekch_QGW_II_III_4119"
                           >tochter</roleName></rs> .</rs>
               </rs></p>
