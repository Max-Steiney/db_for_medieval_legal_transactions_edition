         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_3988">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__stephan_eitzinger_QGW_II_II_3305">Stephan Eiczinger von
                        Eiczing</rs></rs> ersucht den <rs type="fn" role="recipient"><rs type="org"
                        ref="org__wien">Bürgermeister, Richter, Rath, die Genannten und gancze
                        gemain der stat ze Wienn</rs></rs>, ihm den Ausstand an der Jahrgült von 100
                  lb dn., welche <rs type="person" ref="pe__johann_von_maires_QGW_II_II_3818"
                        ><roleName type="title">maister</roleName> Hanns von Meyrs</rs> auf der
                  Stadt gehabt und sein <rs type="person" ref="pe__ulrich_eitzinger_QGW_II_II_3270"
                        ><roleName type="dead">verstorbener</roleName>
                     <roleName type="kin" corresp="pe__stephan_eitzinger_QGW_II_II_3305"
                        >Bruder</roleName>
                     <roleName type="title">her</roleName> Ulrich von Eiczing</rs> von dessen Erben
                  gekauft hatte, und die haubtsumme selbst auszuzahlen. </rs></p>
         </div>
         <div type="nota">
            <p><rs type="event" ref="ev__QGW_II_III_3988_nota">Adresse aussen.</rs></p>
