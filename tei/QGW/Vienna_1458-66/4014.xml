         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4014">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__christian_witel_QGW_II_III_4014">Kristan Witel von Vilshoven,
                           <roleName type="occ" corresp="org__passau">briester</roleName> Passauer
                        pistumbs</rs></rs>, <rs type="fn" role="recipient"><rs type="org"
                        ref="org__wien">dem Bürgermeister und Rath</rs></rs> die von dem <rs
                     type="org"
                     ref="org__wien-st_stephan-kapelle_st_erasmus_im_neuen_karner_auf_dem_st_stephansfriedhof"
                     >Krannest auf sand Helena altar in der Gruft underm Korner gestiftete
                     Messe</rs> verliehen haben, gelobt, dieselbe zwir in der wochen zu lesen.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4014"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="pe__johann_angerfelder_QGW_II_II_3473"
                        >Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Hannsen
                        Angervelder</rs> und <rs type="person"
                        ref="pe__wilhelm_sambs_QGW_II_II_3379">Wilhalm Samsen<roleName type="occ"
                           corresp="org__wien"><add>Bürger</add></roleName></rs></rs>. </rs></p>
         </div>
