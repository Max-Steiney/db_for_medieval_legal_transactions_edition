   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4037">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__leonhard_weber_QGW_II_III_4037">Lienhart Weber, <unclear>gesessen
                           zu Mos</unclear></rs>, und <rs type="person"
                        ref="pe__johann_durhenwald_QGW_II_III_4036">Hanns Durchenwald,
                           <unclear>gesessen zu Lengpach</unclear></rs></rs>, übergeben anstatt <rs
                     type="person" ref="pe__anna_QGW_II_III_4035">Annen, <rs type="person"
                        ref="pe__andreas_QGW_II_III_4035">Andren, weilent <unclear>gesessen in
                           Kirchperger Winkchel und in Starhenberger herrschaft</unclear><roleName
                           type="dead"><add>witiben</add></roleName></rs>, <roleName type="kin"
                        corresp="pe__andreas_QGW_II_III_4035">witiben</roleName> und <rs
                        type="person" ref="pe__stephan_reuschel_QGW_II_III_4003">Stephans des
                        Reuschleins, <unclear>etwenn gesessen in der Scheffstrass vor Stubentor zu
                           Wienn</unclear><roleName type="dead"
                        ><add>hinterlassenen</add></roleName></rs>, <roleName type="kin"
                        corresp="pe__stephan_reuschel_QGW_II_III_4003">swester</roleName> , ihrer
                        <roleName type="kin" corresp="pe__leonhard_weber_QGW_II_III_4037"
                        >muter</roleName> und <roleName type="kin"
                        corresp="pe__johann_durhenwald_QGW_II_III_4036">swiger</roleName></rs>,
                  deren Antheil an dem von Letzterem hinterlassenen Gute um eine Summe Geldes dem
                     <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__thomas_praitenweidacher_QGW_II_II_3462">Wiener <roleName type="occ"
                           corresp="org__wien">Bürger</roleName> Thoman dem
                           Praitenbeidacher<roleName type="rep" corresp="pe__anna_QGW_II_III_4035"
                        /></rs></rs>. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4037"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__johann_ravensburger_QGW_II_II_3264"
                        >Hannsen des Ravenspurger, des <roleName type="occ" corresp="org__wien">rats
                           der stat</roleName> und <roleName type="occ" corresp="org__wien"
                           >urtailschreiber</roleName> zu Wienn</rs>, und <rs type="person"
                        ref="pe__johann_kuntstokch_QGW_II_II_3530">Hannsen des Kuntstokchs, gesworen
                           <roleName type="prof">weger</roleName>, <roleName type="occ"
                           corresp="org__wien">burger</roleName> daselbs</rs> .</rs>
               </rs></p>
         </div>
         <div type="nota">
            <p><rs type="event" ref="ev__QGW_II_III_4037_nota">Indorsat: Hannsen Praitenweidacher
                  brief über sein haus, genant des Reischl haus, in der Scheffstrass gelegen .
               </rs></p>
         </div>
