   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4035">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__wolfgang_QGW_II_III_4035"
                        >Wolffgang, <unclear>gesessen zu Obrkirchen im Haihenpach</unclear></rs>,
                        <rs type="person" ref="pe__ulrich_am_lehen_QGW_II_III_4035">Ulreich im
                        Lehen</rs> daselbs und <rs type="person"
                        ref="pe__johann_wirdt_QGW_II_III_4035">Hanns Wirdt, <unclear>gesessen zu
                           Haihenpachkirchen in der graffschafft Schaumberg</unclear></rs></rs> ,
                  bestätigen, dass <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__anna_QGW_II_III_4035">Anna, <rs type="person"
                           ref="pe__andreas_QGW_II_III_4035">Andre, weilendt <unclear>gesessen in
                              Kirchperger Wingkl</unclear><roleName type="dead"
                              ><add>witib</add></roleName></rs>, <roleName type="kin"
                           corresp="pe__andreas_QGW_II_III_4035">witib</roleName> und <rs
                           type="person" ref="pe__stephan_reuschel_QGW_II_III_4003">Steffan des
                           Reuschleins, weilendt <roleName type="occ" corresp="org__wien"
                              >burger</roleName> zu Wienn, <unclear>gesessen in der
                              Scheffstrass</unclear></rs>, <roleName type="kin"
                           corresp="pe__stephan_reuschel_QGW_II_III_4003">swester</roleName></rs>,
                     und <rs type="person" ref="pe__johann_QGW_II_III_4035">Hanns<roleName
                           type="kin" corresp="pe__katharina_QGW_II_III_4035"
                           ><add>geswistredt</add></roleName><roleName type="kin"
                           corresp="pe__dorothea_QGW_II_III_4035"
                           ><add>geswistredt</add></roleName><roleName type="kin"
                           corresp="pe__konrad_der_smid_QGW_II_III_4035"
                           ><add>kinder</add></roleName><roleName type="kin"
                           corresp="pe__stephan_reuschel_QGW_II_III_4003"
                           ><add>enenkchel</add></roleName></rs>, <rs type="person"
                        ref="pe__katharina_QGW_II_III_4035">Katherina<roleName type="kin"
                           corresp="pe__dorothea_QGW_II_III_4035"
                           ><add>geswistredt</add></roleName><roleName type="kin"
                           corresp="pe__konrad_der_smid_QGW_II_III_4035"
                           ><add>kinder</add></roleName><roleName type="kin"
                           corresp="pe__stephan_reuschel_QGW_II_III_4003"
                           ><add>enenkchel</add></roleName></rs> und <rs type="person"
                        ref="pe__dorothea_QGW_II_III_4035">Dorothea<roleName type="kin"
                           corresp="pe__konrad_der_smid_QGW_II_III_4035"
                           ><add>kinder</add></roleName><roleName type="kin"
                           corresp="pe__stephan_reuschel_QGW_II_III_4003"
                           ><add>enenkchel</add></roleName></rs>, geswistredt, <rs type="person"
                        ref="pe__konrad_der_smid_QGW_II_III_4035">Kunczen des <roleName type="prof"
                           >Smidts</roleName>, weilendt <unclear>gesessen zu Lempach bei
                           Valknstein</unclear>
                        <roleName type="dead">saligen</roleName></rs>, kinder</rs> , zu ihnen mit
                  der Nachricht von dem in Wien erfolgten <rs type="person"
                     ref="pe__stephan_reuschel_QGW_II_III_4003"><roleName type="dead"
                        >Ableben</roleName> des Steffan Reuschl</rs> gekommen seien, und bezeugen,
                  dass Anna des Verstorbenen rechte Schwester, die drei Geschwister seine enenkchel
                  seien. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4035"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__erhard_althaimer_QGW_II_III_4023"
                        >Erharten Althaimer, <roleName type="occ"
                           corresp="org__schaumberg-grafschaft">landtrichter</roleName> im Tunautal
                        in der graffschafft Schaunberg</rs>, und <rs type="person"
                        ref="pe__kaspar_rottaler_QGW_II_III_4023">Casparn des Rottaler, ainer
                           <roleName type="occ" corresp="org__eferding">des rats</roleName> der stat
                        zu Eferding und <roleName type="occ" corresp="org__eferding"
                           >spitalmaister</roleName> daselbs</rs></rs> . </rs></p>
         </div>
