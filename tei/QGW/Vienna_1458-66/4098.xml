   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4098">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__juliana_SB_CD_01509"
                        >Juliana, <rs type="person" ref="pe__georg_krempl_QGW_II_III_4039">Jorgen
                           Krempl, <roleName type="occ" corresp="org__wien">burger</roleName> zu
                           Wienn</rs>, <roleName type="kin"
                           corresp="pe__georg_krempl_QGW_II_III_4039">hausfrau</roleName></rs></rs>,
                  deren Mann aus dem Gefängnisse, in das ihn der <rs type="person"
                     ref="pe__ulrich_matzleinsdorfer_QGW_II_II_3362"><roleName type="occ"
                        corresp="org__wien">Bürgermeister</roleName>
                     <roleName type="title">herr</roleName> Ulreich Meczleinstorffer</rs> und <rs
                     type="org" ref="org__wien">der Rath</rs> gelegt hatten, wider sein Gelöbnis
                  entflohen war, wofür sie sich diesen in erbere bewarung gab, aus der sie <rs
                     type="fn" role="other"><triggerstring n="fn">über Bitten</triggerstring> der <rs
                        type="person" ref="pe__georg_schekch_QGW_II_II_3528"><roleName type="title"
                           >edeln</roleName> Jorgen Schekchen vom Wald</rs> und <rs type="person"
                        ref="pe__erasmus_feuchter_QGW_II_III_3899">Erasms des Feuchter<roleName
                           type="title"><add>edeln</add></roleName></rs></rs> entlassen worden war,
                  gelobt dem <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__ulrich_matzleinsdorfer_QGW_II_II_3362">Bürgermeister</rs> und <rs
                        type="org" ref="org__wien">Rathe</rs></rs> Urfehde. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4098"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__johann_lainbacher_QGW_II_III_4420"
                        >Niclasen Lainbacher, der hochwirdigen Universitet <roleName type="occ"
                           corresp="org__wien-universitaet">richter</roleName><roleName type="occ"
                              corresp="org__wien"><add>burger</add></roleName></rs>, und <rs
                        type="person" ref="pe__johann_kuntstokch_QGW_II_II_3530">Hannsen Kuntstokch,
                        gesworn <roleName type="prof">weger</roleName>, baider <roleName type="occ"
                           corresp="org__wien">burger</roleName> zu Wienn</rs></rs> . </rs></p>
         </div>
