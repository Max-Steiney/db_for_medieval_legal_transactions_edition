   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3963">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__juliana_QGW_II_III_3951"
                           ><roleName type="title">Swester</roleName> Juliana Tumbriczerin,
                           <roleName type="occ" corresp="org__wien-st_laurenz_am_alten_fleischmarkt"
                           >maistrin</roleName> des fraunclosters hincz sand Larenczen zu
                     Wienn</rs>, und <rs type="org" ref="org__wien-st_laurenz_am_alten_fleischmarkt"
                        >der convent gemain</rs> daselbs</rs> verkaufen <rs type="fn" role="other"
                        ><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__jakob_starch_QGW_II_II_3557">des <roleName
                           type="occ" corresp="org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Jacoben Starch</rs> und <rs
                        type="org" ref="org__wien">des Rathes</rs></rs> ein Haus, gelegen zu Wienn
                  am Grashof bei der Heiligenkreuzer hof zenagst Otten Meczner haus, das ihrer <rs
                     type="person" ref="pe__margarethe_QGW_II_III_3963"><roleName type="title"
                        >conventswester</roleName> Margreth, <rs type="person"
                        ref="pe__konrad_ottinger_QGW_II_III_3963">Conrats Ottinger<roleName
                           type="dead"><add>seligen</add></roleName></rs> und <rs type="person"
                        ref="pe__agnes_QGW_II_III_3963">Agnesen, seiner <roleName type="kin"
                           corresp="pe__konrad_ottinger_QGW_II_III_3963">hausfraun</roleName>,
                           <roleName type="dead">seligen</roleName></rs>
                     <roleName type="kin" corresp="pe__agnes_QGW_II_III_3963"
                        >tochter</roleName><add>ottinger</add></rs>, angeerbt ist , um 160 lb dn.
                     <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__niklas_reschel_QGW_II_III_3963">Niclasen Reschel</rs></rs>.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3963"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__juliana_QGW_II_III_3951">der
                        Meisterin</rs> und <rs type="org"
                        ref="org__wien-st_laurenz_am_alten_fleischmarkt">des Conventes</rs> und dem
                        <rs type="org" ref="org__wien">städtischen Grundsiegel</rs></rs>. </rs></p>
         </div>
