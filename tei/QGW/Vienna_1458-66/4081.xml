   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4081">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__ulrich_matzleinsdorfer_QGW_II_II_3362">Ulreich Meczleinstorffer,
                           <roleName type="occ" corresp="org__wien">burgermaister</roleName>,</rs>
                     und der <rs type="org" ref="org__wien">rat gemain der stat zu Wienn</rs></rs>
                  übergeben <rs type="person" ref="pe__wolfgang_QGW_II_III_4081">Wolfgangen<roleName
                        type="kin" corresp="pe__christian_flemming_QGW_II_III_4081"><add>unmündige
                           Kinder</add></roleName><roleName type="kin"
                        corresp="pe__anna_QGW_II_III_4081"><add>unmündige
                     Kinder</add></roleName></rs>, <rs type="person"
                     ref="pe__michael_QGW_II_III_4081">Micheln<roleName type="kin"
                        corresp="pe__christian_flemming_QGW_II_III_4081"><add>unmündige
                        Kinder</add></roleName><roleName type="kin"
                        corresp="pe__anna_QGW_II_III_4081"><add>unmündige
                     Kinder</add></roleName></rs> und <rs type="person"
                     ref="pe__walburga_QGW_II_III_4081">Waltpurgen<roleName type="kin"
                        corresp="pe__christian_flemming_QGW_II_III_4081"><add>unmündige
                        Kinder</add></roleName><roleName type="kin"
                        corresp="pe__anna_QGW_II_III_4081"><add>unmündige
                     Kinder</add></roleName></rs>, <rs type="person"
                     ref="pe__christian_flemming_QGW_II_III_4081">Cristans Fleming, des <roleName
                        type="prof">fleischakcher</roleName>, weilent ihres <roleName type="occ"
                        corresp="org__wien">mitburger</roleName>
                     <roleName type="dead">seligen</roleName></rs>, und <rs type="person"
                     ref="pe__anna_QGW_II_III_4081">Annen, seiner <roleName type="kin"
                        corresp="pe__christian_flemming_QGW_II_III_4081">hausfraun</roleName>, die
                     jecz <rs type="person" ref="pe__christoph_oeczestorffer_QGW_II_II_3245"
                        >Kristoffen Oczestorffer</rs> auch <roleName type="kin"
                        corresp="pe__christoph_oeczestorffer_QGW_II_II_3245">elichen</roleName>
                     hat</rs>, unmündige Kinder,<rs type="fn" role="other">
                     <triggerstring n="fn">auf Bitten</triggerstring> ihrer <rs type="person"
                        ref="pe__anna_QGW_II_III_4081">Mutter</rs></rs> in <rs type="person"
                     ref="pe__niklas_lainbacher_QGW_II_II_2652"><roleName type="rep"
                        corresp="pe__wolfgang_QGW_II_III_4081">gerhabsweise</roleName><roleName
                        type="rep" corresp="pe__michael_QGW_II_III_4081"
                        ><add>gerhabsweise</add></roleName><roleName type="rep"
                        corresp="pe__walburga_QGW_II_III_4081"><add>gerhabsweise</add></roleName>
                     Niclasen Lainbacher, der <roleName type="title">hochwirdigen</roleName>
                     <roleName type="prof">Schul richter</roleName><roleName type="occ"
                        corresp="org__wien"><add>Mitbürgern</add></roleName></rs>, und <rs
                     type="person" ref="pe__erhard_oertl_QGW_II_III_4081">Erharten Örtl, dem
                        <roleName type="prof">fleischakher</roleName> , ihren <roleName type="occ"
                        corresp="org__wien">Mitbürgern</roleName><roleName type="rep"
                        corresp="pe__wolfgang_QGW_II_III_4081"
                        ><add>gerhabsweise</add></roleName><roleName type="rep"
                        corresp="pe__michael_QGW_II_III_4081"
                        ><add>gerhabsweise</add></roleName><roleName type="rep"
                        corresp="pe__walburga_QGW_II_III_4081"
                     ><add>gerhabsweise</add></roleName></rs>. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4081"><rs type="fn" role="witness">Besiegelt mit
                     ihrem klainem anhangundem <rs type="org" ref="org__wien">statinsigl</rs></rs>.
               </rs></p>
