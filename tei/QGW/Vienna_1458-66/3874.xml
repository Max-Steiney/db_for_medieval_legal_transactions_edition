   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3874"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270"
                           ><roleName type="occ" corresp="org__heiliges_roemisches_reich"
                           >Kaiser</roleName> Friedrich III.</rs></rs> übersendet <rs type="fn"
                     role="recipient"><rs type="org" ref="org__wien">dem Bürgermeister, Richter und
                        Rathe zu Wien</rs></rs> eine Abschrift des neuerdings von dem <rs
                     type="person" ref="pe__lassla_graf_QGW_II_III_3819"><roleName type="title"
                        >Grafen</roleName> Lasslaw von Pösing</rs> eingelangten Schreibens und seine
                  Antwort auf dasselbe. </rs></p>
         </div>
         <div type="nota">
            <p><rs type="event" ref="ev__QGW_II_III_3874_nota">Von anderer Hand: commissio domini
                  imperatoris in consilio. </rs></p>
