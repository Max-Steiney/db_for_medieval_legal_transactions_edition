   <text>
      <body>
         <div type="abstract" resp="ms">
            <p>
               <rs type="event" ref="ev__QGW_II_III_3781">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__oswald_eitzinger_QGW_II_II_3293">Oswald</rs> und <rs type="person"
                        ref="pe__stephan_eitzinger_QGW_II_II_3305">Steffan, <roleName type="kin"
                           corresp="pe__oswald_eitzinger_QGW_II_II_3293">gebrüder</roleName> von
                        Eyczing</rs>,</rs> richten an den <rs type="fn" role="recipient"
                     ref="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270"><roleName type="occ"
                        corresp="org__heiliges_roemisches_reich">Kaiser</roleName></rs> die
                  neuerliche Bitte, seinen <rs type="person" ref="pe__albrecht_herzog_von_oesterreich_QGW_II_II_3617"
                        ><roleName type="kin"
                        corresp="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270"
                        >Bruder</roleName>
                     <roleName type="occ" corresp="org__oesterreich-herzogtum">Herzog</roleName>
                     Albrecht</rs> zur Freilassung ihres <rs type="person"
                     ref="pe__ulrich_eitzinger_QGW_II_II_3270"><roleName type="kin"
                        corresp="pe__oswald_eitzinger_QGW_II_II_3293">Bruders</roleName><roleName
                        type="kin" corresp="pe__stephan_eitzinger_QGW_II_II_3305"
                        ><add>Bruders</add></roleName> Ulrich</rs> zu veranlassen, indem sie
                  erklären, dass sie erenthalben ihren bruder in solher venknuss williclich nicht
                  lenger gelassen möchten. </rs>
            </p>
         </div>
