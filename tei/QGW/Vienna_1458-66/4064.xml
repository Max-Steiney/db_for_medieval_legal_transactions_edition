   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4064"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__albrecht_herzog_von_oesterreich_QGW_II_II_3617"><roleName type="occ"
                           corresp="org__oesterreich-herzogtum">Erzherzog</roleName> Albrecht
                        VI.</rs></rs> bestätigt, dass ihm <rs type="person"
                     ref="pe__michael_phuntimaschen_QGW_II_III_4064">Michel Pfuntimaschen <roleName
                        type="occ" corresp="org__wien"><add>burger</add></roleName></rs>, <rs
                     type="person" ref="pe__erhard_poeschendorffer_QGW_II_II_3563">Erhart
                     Pöschendarffer <roleName type="occ" corresp="org__wien"
                        ><add>burger</add></roleName></rs>, <rs type="person"
                     ref="pe__gregor_herman_QGW_II_III_4064">Gregorig Herman, <roleName type="prof"
                        >puchfeler</roleName>
                     <roleName type="occ" corresp="org__wien"><add>burger</add></roleName></rs>, <rs
                     type="person" ref="pe__gilg_von_herzogenburg_QGW_II_III_4064">Gilig, <roleName
                        type="prof">riemer</roleName> von Herzogburg <roleName type="occ"
                        corresp="org__wien"><add>burger</add></roleName></rs>, <rs type="person"
                     ref="pe__ruprecht_paumgartner_QGW_II_III_4064">Rueprecht Paungartner, <roleName
                        type="prof">riemer</roleName>
                     <roleName type="occ" corresp="org__wien"><add>burger</add></roleName></rs>, <rs
                     type="person" ref="pe__konrad_reutter_QGW_II_III_4064">Conrad Reutter,
                        <roleName type="prof">appotecker</roleName>
                     <roleName type="occ" corresp="org__wien"><add>burger</add></roleName></rs>, <rs
                     type="person" ref="pe__zirfos_waczlab_QGW_II_III_4064">Zirfos Waczlab,
                        <roleName type="prof">wuntarzt</roleName>
                     <roleName type="occ" corresp="org__wien"><add>burger</add></roleName></rs>, <rs
                     type="person" ref="pe__thomas_meichsner_QGW_II_III_4064">Thoman Meichsner
                        <roleName type="occ" corresp="org__wien"><add>burger</add></roleName></rs>
                  und <rs type="person" ref="pe__konrad_kuendle_QGW_II_III_4064">Conrat Kuendle,
                        <roleName type="prof">tuchscherer</roleName>
                     <roleName type="occ" corresp="org__wien"><add>burger</add></roleName></rs> ,
                  seine burger hie, <rs type="person"
                     ref="pe__michael_mannersdorffer_QGW_II_III_4064">Micheln Menesdarffer</rs>
                  porgen von der groben verhandlung wegen, so derselb Menestarffer wider ihn und die
                  Seinigen getan, 5000 Hungrisch gulden entrichtet haben. </rs></p>
         </div>
         <div type="nota">
            <p><rs type="event" ref="ev__QGW_II_III_4064_nota">Von anderer Hand: commissio domini
                  archiducis per consilium. </rs></p>
