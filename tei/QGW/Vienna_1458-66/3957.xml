   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3957">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__helena_QGW_II_III_3956"
                        >Helena, <rs type="person" ref="pe__leopold_weiss_QGW_II_II_2987">Leopolts
                           Weissen <roleName type="dead">seligen</roleName></rs>
                        <roleName type="kin" corresp="pe__leopold_weiss_QGW_II_II_2987"
                           >tochter</roleName> und <rs type="person"
                           ref="pe__andreas_perleinsreutter_QGW_II_III_3934">Andres Perleinsreutter,
                              <roleName type="occ" corresp="org__gmunden">ambtman</roleName> zu
                           Gmunden</rs>, eliche <roleName type="kin"
                           corresp="pe__andreas_perleinsreutter_QGW_II_III_3934"
                        >hausfrau</roleName></rs></rs> , ersucht <rs type="fn" role="recipient"><rs
                        type="org" ref="org__wien">den Bürgermeister und Rath der Stadt zu Wien
                        sowie die Verweser ihrer Grundbücher</rs></rs> neuerdings, dem <rs
                     type="person" ref="pe__ulrich_welzly_QGW_II_III_3956"><roleName type="occ"
                        corresp="org__heiliges_roemisches_reich">Kanzler</roleName>
                     <roleName type="title">hern</roleName> Ulrichen Welczli</rs> das vorangeführte
                  Haus zu fertigen. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3957"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="pe__konrad_freitag_QGW_II_III_3956"
                           ><roleName type="title">edln</roleName> Conradten des
                              Freytags<roleName type="occ" corresp="org__gmunden"
                              ><add>burger</add></roleName></rs> und <rs type="person"
                        ref="pe__johann_haus_QGW_II_III_3957">Hannsen vom Haus, baid <roleName
                           type="occ" corresp="org__gmunden">burger</roleName> zu Gmunden</rs>.</rs>
               </rs></p>
         </div>
