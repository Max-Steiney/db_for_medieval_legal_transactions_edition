   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3974">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__georg_ott_QGW_II_III_3974"
                        >Jörig Ott, <roleName type="occ" corresp="org__augsburg">statvogt</roleName>
                        zu Augspurg</rs>, und <rs type="person"
                        ref="pe__georg_pfister_QGW_II_III_3974">Jörig Pfister, <roleName type="occ"
                           corresp="org__augsburg">burggraf</roleName> daselbs</rs></rs>,
                  beurkunden, dass vor dem offenen Gerichte auf dem Rathhause zu Augsburg <rs
                     type="person" ref="pe__johann_meuting_QGW_II_III_3974">Hanns Meuting, gesessen
                     zu Meutingen</rs>, und <rs type="person"
                     ref="pe__afra_eisenman_QGW_II_III_3974">Afra Eisenma/ennin, sein eliche
                        <roleName type="kin" corresp="pe__johann_meuting_QGW_II_III_3974"
                        >wirtin</roleName></rs>, <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__konrad_eisenman_QGW_II_III_3974">Cunraten Eisenman, gesessen zu
                        Ahingen , <roleName type="rep" corresp="pe__johann_meuting_QGW_II_III_3974"
                           >bevollmächtigt</roleName><roleName type="rep"
                           corresp="pe__afra_eisenman_QGW_II_III_3974"
                           ><add>bevollmächtigt</add></roleName> haben<roleName type="kin"
                           corresp="pe__johann_meuting_QGW_II_III_3974"
                           ><add>swagers</add></roleName><roleName type="kin"
                           corresp="pe__afra_eisenman_QGW_II_III_3974"
                        ><add>pruder</add></roleName></rs></rs>, <rs type="person"
                     ref="pe__stephan_eisenman_QGW_II_III_3974"><roleName type="title"
                        >maister</roleName> Stephan Eisenmans, des <roleName type="prof"
                        >büchsenmaisters</roleName>, als irs swagers und pruder <roleName
                        type="dead">säligen</roleName></rs>, verlaussen habe, erb und erbgüter, so
                  vil in das gepürt , einzufordern und zu übernehmen. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3974"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="pe__georg_ott_QGW_II_III_3974"
                        >Aussteller</rs><rs type="person" ref="pe__georg_pfister_QGW_II_III_3974"
                           ><add>Aussteller</add></rs> von gerichts wegen.</rs>
               </rs></p>
         </div>
