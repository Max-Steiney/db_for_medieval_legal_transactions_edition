   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4082">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__adam_von_stauden_QGW_II_III_4082">Adam von Stauden aus Preussen,
                        jecz gesessen zu Dreskirchen</rs></rs>, den <rs type="fn" role="recipient"
                        ><rs type="person" ref="pe__johann_duerr_QGW_II_III_4082">Hanns
                           Dürr<roleName type="kin" corresp="pe__adam_von_stauden_QGW_II_III_4082"
                              ><add>sun</add><roleName type="occ" corresp="org__wien"
                                 ><add>mitburger</add></roleName></roleName></rs> und <rs
                        type="person" ref="pe__paul_duerr_QGW_II_III_4082">Paul Dürr, sein <roleName
                           type="kin" corresp="pe__adam_von_stauden_QGW_II_III_4082">sun</roleName>,
                           <roleName type="occ" corresp="org__wien">mitburger</roleName> zu
                        Wienn</rs></rs>, in der nagstvergangen Vasten ausserhalb der stat Wienn
                  gefangen und in die stat gefürt , wobei sie ihm zwai ros und vertigung genomen
                  haben, bestätigt, seine ros und genomen gerat wieder zurückerhalten zu haben und
                  gelobt den Beiden sowie allen Inwohnern der Stadt Urfehde. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4082"><rs type="fn" role="witness">Besiegelt mit
                     dem Siegel des <rs type="person" ref="pe__johann_holubarsy_QGW_II_II_3652"
                           ><roleName type="title">edeln</roleName>
                        <roleName type="title">vesten</roleName>
                        <roleName type="title">ritter</roleName>
                        <roleName type="title">hern</roleName> Hannsen Holubersy</rs></rs>.
               </rs></p>
         </div>
