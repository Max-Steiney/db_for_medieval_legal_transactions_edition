   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3939">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__dorothea_SB_CD_00310"
                        >Dorothe, <rs type="person" ref="pe__oswald_feuchter_QGW_II_III_3939"
                           >Oswalts Feuchter</rs>
                        <roleName type="kin" corresp="pe__oswald_feuchter_QGW_II_III_3939"
                           >hausfrau</roleName>, die <rs type="person"
                           ref="pe__sigmund_schmied_SB_CD_00310"><roleName type="dead"
                              >emaln</roleName> Sigmunden, <roleName type="prof">smid</roleName> vor
                           Stubentor, auch <roleName type="kin" corresp="pe__dorothea_SB_CD_00310"
                              >eelichen</roleName> gehabt hat</rs></rs></rs> , übergibt <rs
                     type="fn" role="recipient"><rs type="person"
                        ref="pe__konrad_peutinger_QGW_II_III_3939">Kunraten Peuttinger <roleName
                           type="rep" corresp="pe__ludwig_meuting_QGW_II_III_3939"
                        >anstat</roleName></rs></rs>, und zu handen <rs type="person"
                     ref="pe__ludwig_meuting_QGW_II_III_3939">Ludweigen Meutting von Augspurg</rs>,
                  irer gesellschaft und iren erben , ihr Haus, gelegen vor Stubentor zu Wienn auf
                  dem Graben am egk zenagst Trinkchsaus, des smids, haus, für die 141 ½ guldein
                  Ungrisch, gerecht in gold und wag, für welche es ihnen verpfändet ist, und die 5½
                  lb dn., welche Kunrat Peuttinger für sie in die statsteur und ansleg beczalt hat,
                  zu freier Verfügung. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3939"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__wolfgang_holnbrunner_QGW_II_II_3079"
                        >Wolfgangs Holnbrunner<roleName type="occ" corresp="org__wien"
                              ><add>burger</add></roleName></rs> und <rs type="person"
                        ref="pe__johann_gold_QGW_II_II_3565">Hannsen Gold, baid <roleName type="occ"
                           corresp="org__wien">burger</roleName> zu Wienn</rs>.</rs>
               </rs></p>
         </div>
