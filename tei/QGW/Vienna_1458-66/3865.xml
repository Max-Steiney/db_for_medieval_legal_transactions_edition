   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="ev__QGW_II_III_3865"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270"
                           ><roleName type="occ" corresp="org__heiliges_roemisches_reich"
                           >Kaiser</roleName> Friedrich III.</rs></rs> theilt <rs type="fn"
                     role="recipient"><rs type="person"
                        ref="pe__bernhard_schaumberg_QGW_II_III_3755">dem <roleName type="occ"
                           corresp="org__oesterreich-herzogtum">Landmarschall</roleName> in
                        Oesterreich <roleName type="title">Grafen</roleName> Pernhart von
                        Schaunberg</rs></rs> und seinen Amtsnachfolgern mit, dass er <rs type="org"
                     ref="org__wien-zeche_fleischhauer" cert="medium">den Fleischhackern zu Wien</rs> die Gnaden,
                  Freiheiten und Privilegien, die sie von seinen Vorgängern erhalten haben,
                  bestätigt habe. </rs></p>
         </div>
         <div type="nota">
            <p><rs type="event" ref="ev__QGW_II_III_3865_nota">Von anderer Hand: commissio domini
                  imperatoris in consilio. </rs></p>
         </div>
