   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4077">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__johann_paur_QGW_II_III_4077">Hanns Pauer von Eschperstorf,
                           <roleName type="occ" corresp="org__passau-dioezese">briester</roleName>
                        Passauer bistumbs</rs></rs>, dem <rs type="fn" role="recipient"><rs
                        type="org" ref="org__wien">Bürgermeister und Rath der Stadt zu
                     Wien</rs></rs> die ewige Messe, so weilent <rs type="person"
                     ref="pe__elisabeth_QGW_II_III_4077"><roleName type="title">frau</roleName>
                     Elspeth, <rs type="person" ref="pe__stefan_redischer_QGW_II_II_2040a">Stephans
                        Redischer vom Neunhaus<roleName type="dead"><add>witib</add></roleName></rs>
                     <roleName type="kin" corresp="pe__stefan_redischer_QGW_II_II_2040a"
                        >witib</roleName></rs>, und <rs type="person"
                     ref="pe__dorothea_QGW_II_III_4077"><roleName type="title">frau</roleName>
                     Dorothe, <rs type="person" ref="pe__niklas_tainfalt_QGW_II_III_4077">Niclasen
                        von Tainfalt</rs>
                     <roleName type="kin" corresp="pe__niklas_tainfalt_QGW_II_III_4077"
                        >hausfrau</roleName></rs>, hincz <rs type="org" ref="org__wien-st_stephan"
                     >sand Stephan</rs> hie zu Wienn ze stifften geschafft habend , verliehen haben,
                  gelobt, das zur <rs type="org"
                     ref="org__wien-st_stephan-altar_st_maria-messe_redischer_elisabeth">Messe</rs>
                  gehörige Haus im Kumphgesslein peulich und unwugstlich innezuhaben und die Messe
                  dreistund in der wochen zu lesen. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4077"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__ulrich_griessenpekch_QGW_II_III_3878"
                           ><roleName type="title">maister</roleName> Ulreichs Griessenpekhen,
                           <roleName type="prof">licenciaten geistlicher rechten</roleName>,
                           <roleName type="occ" corresp="org__wien"
                           >statschreiber</roleName><roleName type="occ" corresp="org__wien"
                              ><add>burger</add></roleName></rs>, und <rs type="person"
                        ref="pe__erhard_poeschendorffer_QGW_II_II_3563">Erharten Pöschendorffer,
                        baider <roleName type="occ" corresp="org__wien">burger</roleName> zu
                        Wienn</rs> .</rs>
               </rs></p>
         </div>
