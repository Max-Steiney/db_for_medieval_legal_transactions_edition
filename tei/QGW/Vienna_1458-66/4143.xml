      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4143">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__jakob_gsmechl_QGW_II_II_3259">Jacob Gsmechl, <roleName type="occ"
                           corresp="org__wien">burger</roleName> zu Wienn</rs></rs>, dem seine <rs
                     type="fn" role="recipient"><rs type="person"
                        ref="pe__dorothea_gsmechlin_QGW_II_III_4143"><roleName type="title"
                           >Frau</roleName> Dorothe, <rs type="person"
                           ref="pe__kaspar_struczl_QGW_II_III_4231">Casparn Strüczl <roleName
                              type="dead">seligen</roleName></rs>
                        <roleName type="kin" corresp="pe__kaspar_struczl_QGW_II_III_4231"
                           >tochter</roleName></rs></rs>, 200 lb dn. zu rechter haimsteur zugebracht
                  hat, verspricht ihr dagegen 300 lb dn. zu rechter morgengab und setzt ihr für
                  diese 500 lb dn. <rs type="fn" role="other"><triggerstring n="fn">mit
                        Handen</triggerstring> des <rs type="person"
                        ref="pe__ulrich_meczleinstorffer_QGW_II_III_3971"><roleName type="occ"
                           corresp="org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Ulreichs Meczleinstorffer</rs> und
                     des <rs type="org" ref="org__wien">Rathes</rs></rs> sein [ 104] Haus, gelegen
                  am Hohenmarkht zenagst Steffans Stressl, ainer des rats der egenanten stat zu
                  Wienn, haus, zu ainem rechten fürphand . </rs></p>
         </div>
         <div type="nota">
            <p><rs type="event" ref="ev__QGW_II_III_4143_nota">Indorsat: heiratbrief der Gsmechlin.
               </rs></p>
