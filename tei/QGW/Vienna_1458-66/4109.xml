         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4109">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__berthold_von_ellerbach_QGW_II_II_3649">Pertold von Eilerbach,
                           <roleName type="title">herr</roleName> zu Ebran, <roleName type="occ"
                           corresp="org__ungarn-koenigreich">obrister marschalh</roleName> des
                        kunigreich Hungern und <roleName type="occ" corresp="org__eisenburg"
                           >span</roleName> zu Wereticz und Eisenburgk</rs></rs> , theilt dem <rs
                     type="fn" role="recipient"><rs type="org" ref="org__wien">Bürgermeister,
                        Richter und Rath zu Wien</rs></rs> auf ihre Anfrage mit, dass ihr <rs
                     type="person" ref="pe__johann_gold_QGW_II_II_3565"><roleName type="occ"
                        corresp="org__wien">Bürger</roleName> Hanns Gold</rs> ihm für seinen Theil
                  gancz ausrichtung getan hat. </rs></p>
