   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4093"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__johann_gebel_QGW_II_III_3822">Hanns Gebl, <roleName
                           type="occ" corresp="org__oesterreich-herzogtum">landschreiber</roleName>
                        ob der Enns</rs>, und <rs type="person" ref="pe__felicitas_SB_CD_00617"
                        >Felicitas, sein <roleName type="kin"
                           corresp="pe__johann_gebel_QGW_II_III_3822">hausfrau</roleName>, <rs
                           type="person" ref="pe__johann_han_SB_CD_00617">Hannsen Han von Zabarn,
                           des <roleName type="prof">puchsenmaister</roleName>
                           <roleName type="dead">seligen</roleName></rs>, <roleName type="kin"
                           corresp="pe__johann_han_SB_CD_00617">tochter</roleName></rs></rs> ,
                  zeigen dem <rs type="fn" role="recipient"><rs type="org" ref="org__wien"
                        >Bürgermeister und Rathe der Stadt zu Wien</rs></rs> sowie den Verwesern
                  ihres Grundbuches an, dass sie ihr Haus, gelegen in der Kernerstrass zu Wienn
                  zenagst Wolfgangs Holenbrunner haus an aim tail und an dem andern zenagst dem
                  gesslein , dem <rs type="person" ref="pe__piro_keser_QGW_II_III_4093">Piro Keser,
                        <roleName type="occ" corresp="org__wien-st_stephan">laiguster</roleName> zu
                     sand Stephan</rs>, und <rs type="person" ref="pe__margarethe_QGW_II_III_4093"
                     >Margrethen, seiner <roleName type="kin"
                        corresp="pe__piro_keser_QGW_II_III_4093">hausfraun</roleName></rs>, verkauft
                  haben, und ersuchen sie, diese in das gruntbuch nucz und geweer zu schreiben,
                  sowie den übersandten, von dem Aussteller und dem <rs type="person"
                     ref="pe__georg_pellndorfer_QGW_II_III_4068"><roleName type="title">edeln
                        vessten ritter hern</roleName> Jorgen von Pellendorf, . . . . <roleName
                        type="occ" corresp="org__wien">anwalt</roleName> in dem rate der stat zu
                     Wienn</rs> , besiegelten Kaufbrief mit dem städtischen Grundsiegel zu fertigen.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4093">Siegler: der <rs type="fn" role="witness"
                        ><rs type="person" ref="pe__johann_gebel_QGW_II_III_3822">Aussteller</rs>
                     und <rs type="person" ref="pe__georg_pellndorfer_QGW_II_III_4068"><roleName
                           type="title">her</roleName> Jorg von Pellendorf</rs></rs>. </rs></p>
         </div>
