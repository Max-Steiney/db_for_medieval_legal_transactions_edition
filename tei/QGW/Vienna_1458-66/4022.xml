   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4022">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__wolfgang_reuschel_QGW_II_III_4022">Wolfgang Reusschl, <rs
                           type="person" ref="pe__andreas_reuschel_QGW_II_III_4022">Andres
                           Reusschleins in der Zell <roleName type="dead">seligen</roleName></rs>
                        <roleName type="kin" corresp="pe__andreas_reuschel_QGW_II_III_4022"
                           >sun</roleName></rs></rs>, übergibt für eine Summe Geldes allen seinen
                  tail und gerechtikait, so ihm aus allen <rs type="person"
                     ref="pe__stephan_reuschel_QGW_II_III_4003">seines <roleName type="kind"
                        corresp="pe__wolfgang_reuschel_QGW_II_III_4022">vetern</roleName> Stephans
                     des Reusschleins, etwen gesessen in der Scheffstrass zu Wienn <roleName
                        type="dead">seligen</roleName></rs>, gelassen gut . . . . mocht zugepüren ,
                  dem <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__thomas_praitenweidacher_QGW_II_II_3462">Thoman Praitenbeidacher,
                           <roleName type="occ" corresp="org__wien">des rats</roleName> der stat zu
                        Wienn</rs>.</rs>
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4022"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="pe__johann_renhart_QGW_II_III_4022"
                        >Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Hannsen
                        des Renharts</rs> und <rs type="person"
                        ref="pe__johann_ravensburger_QGW_II_II_3264">Hannsen des Ravenspurger,
                           <roleName type="occ" corresp="org__wien"
                           >urtailschreiber</roleName><roleName type="occ" corresp="org__wien"
                              ><add>Bürger</add></roleName></rs></rs>. </rs></p>
         </div>
