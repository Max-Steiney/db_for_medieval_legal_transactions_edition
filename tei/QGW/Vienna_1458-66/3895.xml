   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="ev__QGW_II_III_3895">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__wolfgang_phannhaimer_QGW_II_III_3895">Wolfgang Phannhaimer,
                           <roleName type="prof">der rostauscher</roleName>, <roleName type="occ"
                           corresp="org__wien">mitboner</roleName> zu Wienn</rs>, und <rs
                        type="person" ref="pe__elisabeth_QGW_II_III_3895">Elspeth, sein <roleName
                           type="kin" corresp="pe__wolfgang_phannhaimer_QGW_II_III_3895"
                           >hausfrau</roleName></rs></rs>, stellen <rs type="person"
                     ref="pe__paul_wann_QGW_II_III_3895"><roleName type="title">maister</roleName>
                     Pauln Wann von Kemnaten, ihrem <roleName type="kin"
                        corresp="pe__elisabeth_QGW_II_III_3895">swager</roleName> und <roleName
                        type="kin" corresp="pe__wolfgang_phannhaimer_QGW_II_III_3895"
                        >vettern</roleName></rs>, einen Schuldbrief über 200 lb dn. landeswerung in
                  Österreich aus und setzen ihm <rs type="fn" role="other"><triggerstring n="fn">mit
                        Handen</triggerstring>
                     <rs type="person" ref="pe__jakob_starch_QGW_II_II_3557">des <roleName
                           type="occ" corresp="org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Jacoben Starch</rs> und <rs
                        type="org" ref="org__wien">des Rathes</rs></rs> ihr Haus, gelegen zenagst
                  sand Jacobs freithof mit ainer seitten und mit der andern zenagst dem haus,
                  genannt der Erich , zu einem rechten fürphant. </rs></p>
         </div>
