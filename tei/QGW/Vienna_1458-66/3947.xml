   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_3947"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__niklas_vischer_QGW_II_III_3947"> Niclas Vischer,
                        gesessen zu Lach</rs></rs>, verkauft <rs type="fn" role="other"><triggerstring
                        n="fn">mit Handen</triggerstring> seiner <rs type="person"
                        ref="pe__anna_voesendorfferin_QGW_II_III_3947"><roleName type="title"
                           >gruntfraun swester</roleName> Annen Vösendorfferin, <roleName type="occ"
                           corresp="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen"
                           >abtessin</roleName> des fraunklosters zu sand Niclas vor
                     Stubentor</rs></rs> , drei Viertel Weingarten, gelegen im hindern Mittertal
                  zunagst Hannsen des Meulinger weingarten, von denen man 1½ Eimer Most im Lesen zu
                  Bergrecht und 7½ dn. zu Voitrecht dient, um 40 lb dn. <rs type="fn"
                     role="recipient"><rs type="person" ref="pe__konrad_eisenhut_QGW_II_III_3947"
                        >Kunczen Eisenhut, dem <roleName type="prof">kursner</roleName>, [ 49]
                           <roleName type="occ" corresp="org__wien">mitburger</roleName> zu
                        Wienn</rs>, und <rs type="person" ref="pe__anna_QGW_II_III_3947">Annen,
                        seiner <roleName type="kin" corresp="pe__konrad_eisenhut_QGW_II_III_3947"
                           >hausfraun</roleName></rs></rs>. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3947">Besiegelt mit den Siegeln der <rs
                     type="fn" role="witness"><rs type="person"
                        ref="pe__anna_voesendorfferin_QGW_II_III_3947">Aebtissin</rs> und des <rs
                        type="person" ref="pe__veit_hintperger_QGW_II_II_3311">Wiener <roleName
                           type="occ" corresp="org__wien">Bürgers</roleName> Veit
                     Hindperger</rs></rs>. </rs></p>
         </div>
