   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3896">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__matthias_holczler_QGW_II_III_3896">Mathes <add>Hölczler</add></rs>
                     und <rs type="person" ref="pe__colman_holczler_QGW_II_III_3896">Colman,
                           <roleName type="kin" corresp="pe__matthias_holczler_QGW_II_III_3896"
                           >geprüder</roleName>, die Hölczler</rs></rs> theilen <rs type="fn"
                     role="recipient"><rs type="org" ref="org__wien">dem Bürgermeister und Rathe der
                        Stadt zu Wien, sowie den Verwesern ihrer Grundbücher</rs></rs> mit, dass sie
                  ihr Haus am Liechtensteg under den Taschnern, genant das Taschnhaus, zunagst dem
                  Ratgesslein an aim tail und an dem andern zunagst dem haus am egk, genant das
                  Smergrübl , <rs type="person" ref="pe__hartung_von_kappel_QGW_II_III_3807">dem
                        <roleName type="title">maister</roleName> Harttung von Capellen, <roleName
                        type="prof">lerer bebstlicher und kaiserlicher rechten</roleName>, ihrem
                        <roleName type="kin" corresp="pe__colman_holczler_QGW_II_III_3896"
                        >swager</roleName><roleName type="kin"
                           corresp="pe__matthias_holczler_QGW_II_III_3896"
                     ><add>swager</add></roleName></rs>, verkauft haben, und ersuchen sie, diesen in ihr
                  gruntpuch nucz und geweer zu setzen. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3896"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951"
                           ><roleName type="occ" corresp="org__wien">Wiener Bürger</roleName>
                        Niclasen Teschler</rs> und <rs type="person"
                        ref="pe__georg_talhaimer_QGW_II_II_3559"><roleName type="occ"
                              corresp="org__wien"><add>Bürger</add></roleName>Jörgen
                        Talhaimer</rs></rs>. </rs></p>
         </div>
