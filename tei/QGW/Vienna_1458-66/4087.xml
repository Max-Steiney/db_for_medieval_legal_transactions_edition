   <text>
      <body>
         <div type="abstract" resp="vh">
            <p><rs type="event" ref="ev__QGW_II_III_4087">
                  <rs type="fn" role="issuer"><rs type="org" ref="org__wien">Burgermaister und rat
                        der stat zu Wienn</rs></rs> übergeben <rs type="person"
                     ref="pe__hippolytus_jerusalemer_QGW_II_III_4087">Yppoliten, <rs type="person"
                        ref="pe__wolfgang_jerusalemer_QGW_II_III_4087">Wolfgangs Jerusalemer, des
                           <roleName type="prof">messrer</roleName>
                        <roleName type="dead"><add>selig</add></roleName></rs>, und <rs
                        type="person" ref="pe__osanna_QGW_II_III_4087">Osannen, seiner <roleName
                           type="kin" corresp="pe__wolfgang_jerusalemer_QGW_II_III_4087"
                           >hausfraun</roleName>, <roleName type="dead">seligen</roleName></rs>,
                        <roleName type="title">unmündigen</roleName>
                     <roleName type="kin" corresp="pe__wolfgang_jerusalemer_QGW_II_III_4087"
                        >Sohn</roleName>
                     <roleName type="kin" corresp="pe__osanna_QGW_II_III_4087"
                        ><add>Sohn</add></roleName></rs>, in gerhabsweise ihren <rs type="fn"
                     role="recipient"><rs type="person" ref="pe__johann_thiem_QGW_II_III_4087"
                           ><roleName type="occ" corresp="org__wien">Mitbürgern</roleName> Hannsen
                        Thiem</rs> und <rs type="person"
                        ref="pe__bernhard_waidhover_QGW_II_III_4087"><roleName type="occ"
                           corresp="org__wien"><add>mitbürger</add></roleName> Pernharten Waidhover,
                        dem <roleName type="prof">puchveler</roleName></rs></rs>. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4087">Besiegelt mit ihrem <rs type="fn"
                     role="witness"><rs type="org" ref="org__wien">klainem anhangundem
                        statinsigl</rs></rs>. </rs></p>
         </div>
