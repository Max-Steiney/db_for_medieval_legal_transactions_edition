   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3982">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__wilhelm_verl_QGW_II_III_3982">Wilhalm Verl bestätigt für sich und
                           <roleName type="rep" corresp="pe__margarethe_QGW_II_III_3982"
                           >anstatt</roleName><roleName type="rep"
                           corresp="pe__johann_verl_QGW_II_III_3982"
                        ><add>anstatt</add></roleName></rs></rs>
                  <rs type="person" ref="pe__margarethe_QGW_II_III_3982"><roleName type="title"
                        >fraun</roleName> Margreten, <rs type="person"
                        ref="pe__ulrich_feustrer_QGW_II_III_3982">Ulreichs des Feustrer <roleName
                           type="dead">seligen</roleName></rs>
                     <roleName type="kin" corresp="pe__ulrich_feustrer_QGW_II_III_3982"
                        >tochter</roleName> und <rs type="person"
                        ref="pe__peter_verl_QGW_II_III_3982">Petern des Verl</rs>
                     <roleName type="kin" corresp="pe__peter_verl_QGW_II_III_3982"
                     >wittib</roleName>, seiner <roleName type="kin"
                        corresp="pe__wilhelm_verl_QGW_II_III_3982">Mutter</roleName></rs>, und <rs
                     type="person" ref="pe__johann_verl_QGW_II_III_3982">Hannsen Verl, seines
                        <roleName type="kin" corresp="pe__wilhelm_verl_QGW_II_III_3982"
                        >Bruders</roleName></rs></rs>, dass ihm der <rs type="fn" role="recipient"
                     ><rs type="person" ref="pe__johann_haringseer_QGW_II_III_3910">Wiener <roleName
                        type="occ" corresp="org__wien">Bürger</roleName> Hanns Haringseer</rs> 50 lb
                  dn. entrichtet habe, welche die Schwester der vorgenannten Margret, <rs
                     type="person" ref="pe__klara_SB_CD_00777"><roleName type="title"
                        >frau</roleName> Clara, <rs type="person"
                        ref="pe__johann_haringseer_QGW_II_II_2387">Hannsen des alten Haringseer</rs>
                     <roleName type="kin" corresp="pe__johann_haringseer_QGW_II_II_2387"
                        >witib</roleName><roleName type="kin"
                           corresp="pe__margarethe_QGW_II_III_3982"><add>Schwester</add></roleName></rs>,
                  ihm und seinem Bruder geschafft hatte. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3982"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__sebastian_zieglshauser_QGW_II_III_3864"
                        >Sebastians Ziegelshauser, <roleName type="occ" corresp="org__wien"
                           >burger</roleName> zu Wienn</rs>, und <rs type="person"
                        ref="pe__ulrich_hirssauer_QGW_II_II_3239">Ulreich Hirssauer, <roleName
                           type="occ" corresp="org__wien">statschreiber</roleName>
                     daselbs</rs>.</rs>
               </rs></p>
         </div>
