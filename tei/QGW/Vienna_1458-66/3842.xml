   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_3842">
                  <rs type="person" role="issuer"><rs type="person"
                        ref="pe__paul_obermair_QGW_II_III_3842">Paul Obermair von Ror, <roleName
                           type="prof">baccalaureus in den siben freien
                     künsten</roleName>,</rs></rs> dem <rs type="fn" role="recipient"><rs type="org"
                        ref="org__wien">Bürgermeister und Rath der Stadt zu Wien</rs></rs> die von
                     <rs type="person" ref="pe__martin_von_stetten_QGW_II_III_3842"><roleName
                        type="title">hern</roleName> Mertt von Stetten in <rs type="org"
                        ref="org__wien-st_agnes_auf_der_himmelpforte-kapelle_st_katharina-messe_stetten"
                        >sant Kathrein kappellen zu der Himelporten gestiftete Messe</rs> verliehen
                     haben</rs>, gelobt, die dazu gehörigen Güter in gutem Stande zu erhalten und
                  die Messe virstund in der wochen zu lesen. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_3842"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__heinrich_stupper_QGW_II_II_3573"
                           ><roleName type="title">hern</roleName> Hainreichs Stupper, <roleName
                           type="occ" corresp="org__wien-st_stephan">korherr</roleName></rs>, und
                     hern <rs type="person"
                        ref="pe__ulrich_wolf_facs_54_TextRegion_1649669357074_188">Ulreichs Wolf,
                           <roleName type="occ" corresp="org__wien-st_stephan-altar_st_martin"
                           >kaplan</roleName> sand Mertten altar hincz sand Stephan</rs> .</rs>
               </rs></p>
