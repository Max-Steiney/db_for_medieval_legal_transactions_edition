   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4117">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__erhard_sesmer_QGW_II_III_4117">Erhart Sesmer, der <roleName
                           type="prof">schuster</roleName>, <roleName type="occ" corresp="org__wien"
                           >mitburger</roleName> zu Wienn</rs>, und <rs type="person"
                        ref="pe__magdalena_QGW_II_III_4117">Magdalen, sein <roleName type="kin"
                           corresp="pe__erhard_sesmer_QGW_II_III_4117">hausfrau</roleName>, <rs
                           type="person" ref="pe__michael_weniger_SB_CD_01106">Micheln Weniger, des
                              <roleName type="prof">schuster</roleName>, <roleName type="occ"
                              corresp="org__wien">burger</roleName> daselbs</rs>, und <rs
                           type="person" ref="pe__katharina_QGW_II_III_4117">Kathrein, seiner
                              <roleName type="kin" corresp="pe__michael_weniger_SB_CD_01106">erern
                              hausfraun</roleName>
                           <roleName type="dead">seligen</roleName></rs>, <roleName type="kin"
                           corresp="pe__michael_weniger_SB_CD_01106">tochter</roleName><roleName
                           type="kin" corresp="pe__katharina_QGW_II_III_4117"
                           ><add>tochter</add></roleName></rs></rs> , verzichten für 40 lb dn. gegen
                  dem egenanten <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__michael_weniger_SB_CD_01106">Micheln Weniger, ihrem <roleName
                           type="kin" corresp="pe__erhard_sesmer_QGW_II_III_4117">sweher</roleName>
                        und <roleName type="kin" corresp="pe__magdalena_QGW_II_III_4117"
                           >vater</roleName></rs>, und <rs type="person"
                        ref="pe__ursula_QGW_II_III_4117">Ursulen, seiner <roleName type="kin"
                           corresp="pe__michael_weniger_SB_CD_01106">hausfraun</roleName></rs></rs>,
                  auf das mütterliche Erbtheil der Magdalen und auf jeden andern Erbanspruch.
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4117"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="pe__johann_hashart_QGW_II_II_3424"
                           ><roleName type="title">edeln</roleName> Hannsen Hasharts, ainer des
                           <roleName type="occ" corresp="org__wien">rats</roleName> der stat zu
                        Wienn</rs>, <rs type="person" ref="pe__georg_hiltprant_QGW_II_III_4012"
                        >Jörgen Hiltprants<roleName type="occ" corresp="org__wien"
                           ><add>burger</add></roleName></rs> und <rs type="person"
                        ref="pe__veit_hintperger_QGW_II_II_3311">Veiten Hindperger, baid <roleName
                           type="occ" corresp="org__wien">burger</roleName> daselbs</rs> .</rs>
               </rs></p>
         </div>
