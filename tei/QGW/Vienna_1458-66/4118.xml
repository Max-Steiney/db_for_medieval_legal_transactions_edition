   <text>
      <body>
         <div type="abstract" resp="ms">
            <p><rs type="event" ref="ev__QGW_II_III_4118">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__katharina_QGW_II_III_4118"
                        >Magdalen, <rs type="person" ref="pe__johann_pasel_StB_I_129">Hannsen
                              Pasler<roleName type="dead"><add>witib</add></roleName></rs>
                        <roleName type="kin" corresp="pe__johann_pasel_StB_I_129"
                        >witib</roleName></rs></rs>, welche von <rs type="person"
                     ref="pe__martin_enthaimer_QGW_II_III_3968">dem <roleName type="occ"
                        corresp="org__wien">Stadtrichter</roleName> Mertten Ennthaimer</rs> umb
                  dieberei willen gefangen genommen, dann aber durch Gocz willen freigelassen worden
                  war, gelobt <rs type="fn" role="recipient">dem <rs type="org" ref="org__wien"
                        >Bürgermeister, Richter, Rathe, allen Bürgern und Inwohnern der Stadt
                        Wien</rs> sowie allen, welche an ihrer Gefangennahme Schuld trugen</rs>,
                  Urfehde. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_III_4118"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="pe__georg_reicholf_QGW_II_II_3611"
                        >Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Jörgen
                        Reicholf</rs> und <rs type="person"
                        ref="pe__johann_kuntstokch_QGW_II_II_3530">Hannsen Kuntstokch<roleName
                           type="occ" corresp="org__wien"><add>Bürger</add></roleName></rs>.</rs>
               </rs></p>
         </div>
