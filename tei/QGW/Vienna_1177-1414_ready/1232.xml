                           <roleName type="dead"><add>witib</add></roleName></rs>, <roleName type="kin" corresp="pe__heinrich_haubner_QGW_II_I_1232">witib</roleName>, die nu
                        Niclasen den Schermitzer <roleName type="kin" corresp="pe__niklas_von_der_schemnitz_iii_QGW_II_I_1371"><add>frau</add></roleName>
