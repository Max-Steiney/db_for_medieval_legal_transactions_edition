   <text>
      <body>
         <div type="abstract" resp="cs">
            <p><rs type="event" ref="ev__QGW_II_I_1870">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__dorothea_QGW_II_I_1870"
                        >Dorothe <roleName type="kin" corresp="pe__johann_wiczinger_QGW_II_I_1870"
                              ><add>witib</add></roleName><add>für</add><roleName type="rep"
                           corresp="pe__barbara_QGW_II_I_1870"><add>für</add></roleName></rs>,</rs>
                  <rs type="person" ref="pe__johann_wiczinger_QGW_II_I_1870">Hannsen <roleName
                        type="dead">witiben</roleName> des Wiczinger,</rs><rs type="fn"
                     role="issuer">
                     <rs type="person" ref="pe__johann_QGW_II_I_1870">Hanns<roleName type="kin"
                           corresp="pe__dorothea_QGW_II_I_1870"><add>sun</add></roleName></rs> und
                        <rs type="person" ref="pe__lukas_QGW_II_I_1870">Lucas, ir <roleName
                           type="kin" corresp="pe__dorothea_QGW_II_I_1870"
                     >su/en</roleName>,</rs></rs>
                  <triggerstring n="disp">beurkunden</triggerstring> für sich und für die noch nicht <rs
                     type="person" ref="pe__barbara_QGW_II_I_1870">vogtbare <roleName type="title"
                        >junkfraun</roleName> Barbaren, ihre <roleName type="kin"
                        corresp="pe__dorothea_QGW_II_I_1870">Tochter</roleName>, beziehungsweise
                        <roleName type="kin" corresp="pe__lukas_QGW_II_I_1870"
                        >Schwester</roleName><roleName type="kin" corresp="pe__johann_QGW_II_I_1870"
                           ><add>schwester</add></roleName>,</rs> aus dem <rs type="event"
                              ref="ev__QGW_II_I_1845">Geschäfte <rs type="person" ref="pe__leonhard_schaur_QGW_II_I_1242">des <roleName type="kin"
                           corresp="pe__dorothea_QGW_II_I_1870">Bruders</roleName> der Dorothea,
                           <roleName type="title">hern</roleName> Lienharts des Schaur</rs>,</rs>
                  600 guter guldein und den hausgerecht, das Wohnhaus und alle gekauften
                     Weingärten<triggerstring n="disp"> erhalten zu haben.</triggerstring></rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_I_1870"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__paul_wuerfel_QGW_II_I_1200"><roleName
                           type="title">hern</roleName> Pauln des Würffel, <roleName type="occ"
                           corresp="org__oesterreich-herzogtum">münssmaister</roleName> in
                        Österreich, </rs>und <rs type="person"
                        ref="pe__friedrich_von_aschbach_QGW_II_I_1705">Fridreichs von Aschpach,
                           <roleName type="occ" corresp="org__oesterreich-herzogtum"
                           >lantschreiber</roleName> in Osterreich und <roleName type="occ"
                           corresp="org__wien">urtailschreiber</roleName> ze Wienn</rs> .</rs></rs>
            </p>
         </div>
