            <origDate instant="false">ze Wienne, an sand Elsbeten tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00096_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00096_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="ev__QGW_II_I_96"><rs type="fn" role="issuer"><rs type="person" ref="pe__konrad_chrannest_QGW_II_I_99">Chunrat der Chrannest</rs></rs>
                  <triggerstring n="disp">verpfändet</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__martin_QGW_II_I_102"><roleName type="title">hern</roleName> Merten, <roleName type="occ" corresp="org__wien-st_maria_im_rathaus">Kaplan</roleName> und <roleName type="occ" corresp="org__wien-st_maria_im_rathaus">Verweser</roleName>
                        der Kapelle Unserer Frau in dem Hause, das weiln hern Otten hern Haimen
                        gewesen ist</rs></rs>, für 15 ½ Mark Silber (die Mark zu 72 grossen
                  böhmischen Pfenningen), wofür er seinen Dienern Gewand gekauft habe, und für einen
                  silbernen Becher, den er dem Pfarrer von S. Stephan gegeben habe, <rs type="fn" role="other"><triggerstring n="fn">mit seiner Grundherren Hand</triggerstring>, <rs type="org" ref="org__wien-st_lazarus_siechenhaus">der siehen dacz sand
                        Lazers</rs></rs>, 12 sh. dn. Burgrecht auf des vorgenannten h. Merten Haus,
                  gelegen vor dem Schottenthore, das weiln Seifrides des Legrer gewesen ist, von dem
                  man 25 dn. Grundrecht nach S. Lazar dient, und <rs type="fn" role="other"><triggerstring n="fn">mit seines Grundherrn Hand</triggerstring>, <rs type="person" ref="pe__ludwig_QGW_II_I_96"><roleName type="title"><add>Grundherrn</add></roleName> <roleName type="title">hern</roleName> Ludweiges, des alten <roleName type="occ" corresp="org__oesterreich-herzogtum">forstmaisters</roleName></rs></rs>,
                  2 lb dn. Burgrecht auf Ulriches haus des Gundleins, das da leit auh vor
                  Schottentor auf der Alsse enzwischen Hainreichen dem Slaher und Fridrichen, dem
                  pinter , von dem man 12 dn. zu Grundrecht dient.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_96">Siegler: <rs type="person" ref="pe__konrad_chrannest_QGW_II_I_99">1. der Aussteller</rs>, <rs type="org" ref="org__wien-st_lazarus_siechenhaus">2. <add>Grundherren</add></rs>, <rs type="person" ref="pe__ludwig_QGW_II_I_96">3. die Grundherren</rs>, und <rs type="person" ref="pe__mauritius_von_den_schotten_QGW_II_I_112">4. <roleName type="occ" corresp="org__wien-schotten">Abt</roleName> Mariz von den
                     Schotten</rs>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>