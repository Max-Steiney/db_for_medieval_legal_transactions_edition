                  <rs type="fn" role="other"><triggerstring n="fn">in Gegenwart</triggerstring>
                     <rs type="person" ref="pe__georg_von_nikolsburg_QGW_II_I_1010"><roleName type="title">hern</roleName> Jörgens von Nicolspurkch, des <roleName type="occ" corresp="org__wien">rates der stat zu Wienne</roleName></rs>, und <rs type="person" ref="pe__paul_holzkaeufel_QGW_II_I_1010"><roleName type="title">hern</roleName> Pauln des Holzkouffel, <roleName type="occ" corresp="org__wien">judenrichter</roleName> daselbs</rs></rs>,
