                  <rs type="fn" role="issuer"><rs type="person" ref="pe__anna_QGW_II_I_989">Anna,
                           <roleName type="kin" corresp="pe__heinrich_wuerfel_QGW_II_I_1049"><add>housvrowe</add></roleName>
                        <rs type="person" ref="pe__heinrich_wuerfel_QGW_II_I_1049">Hainreichs housvrowe des
                           Würfel</rs></rs></rs>, <triggerstring n="disp">beurkundet</triggerstring>,
                     <triggerstring n="disp">dass sie über die Verwaltung der Güter</triggerstring> ihres
                     <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_QGW_II_I_989"><roleName type="kin" corresp="pe__anna_QGW_II_I_989">Sohnes</roleName>
