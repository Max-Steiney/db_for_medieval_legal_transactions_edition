            <date when="13950724">1395 VII 24</date>
            <origDate instant="false">ze Wienn, an sand Jacobs abend in dem
            snit.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01308_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01308_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1308"><rs type="fn" role="issuer"><rs type="person" ref="pe__konrad_rokk_QGW_II_I_1031">Chunrat der Rokk <roleName type="occ" corresp="org__wien"><add>rat</add></roleName></rs> und <rs type="person" ref="pe__peter_guenzburger_QGW_II_I_1235">Peter der
                        Gunzpurger, den man nennet den Schönaicher, baid des <roleName type="occ" corresp="org__wien">rats</roleName> der stat zu Wienn</rs></rs>,
                     <triggerstring n="disp">beurkunden als vom Rathe beauftragte tailer die
                     Gütertheilung</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn"><add>beauftragt
                        vom</add></triggerstring>
                     <rs type="org" ref="org__wien"><add>rat der stat zu Wienn</add></rs></rs>, um
                  welche <rs type="fn" role="recipient"><rs type="person" ref="pe__anna_QGW_II_I_1308"><roleName type="title">frau</roleName> Ann, <rs type="person" ref="pe__christian_goczchirch_QGW_II_I_1308">Christeins des
                           Goczchirchs</rs>
                        <roleName type="kin" corresp="pe__christian_goczchirch_QGW_II_I_1308">hausfrau</roleName>
                        <roleName type="rep" corresp="pe__anastasia_QGW_II_I_1308_a"><add>für</add></roleName>
                        <roleName type="rep" corresp="pe__tylman_QGW_II_I_1308"><add>für</add></roleName><roleName type="kin" corresp="pe__konrad_feger_QGW_II_I_1308"><add>chinder</add></roleName><roleName type="kin" corresp="pe__anastasia_QGW_II_I_1308_b"><add>chinder</add></roleName>
                     </rs>, und ir <rs type="person" ref="pe__dorothea_QGW_II_I_1308"><roleName type="kin" corresp="pe__anna_QGW_II_I_1308">swester</roleName>
                        <roleName type="title">frau</roleName> Dorothe, Lienharts <roleName type="kin" corresp="pe__leonhard_haiden_QGW_II_I_1308">hausfrau</roleName>
                        <rs type="person" ref="pe__leonhard_haiden_QGW_II_I_1308"><add>Lienharts</add> des Haidns</rs>
                        <roleName type="rep" corresp="pe__anastasia_QGW_II_I_1308_a"><add>für</add></roleName>
                        <roleName type="rep" corresp="pe__tylman_QGW_II_I_1308"><add>für</add></roleName><roleName type="kin" corresp="pe__konrad_feger_QGW_II_I_1308"><add>chinder</add></roleName><roleName type="kin" corresp="pe__anastasia_QGW_II_I_1308_b"><add>chinder</add></roleName>
                     </rs></rs> , für sich und <rs type="person" ref="pe__anastasia_QGW_II_I_1308_a">ihre unmündigen <roleName type="kin" corresp="pe__anna_QGW_II_I_1308">Geschwister</roleName>
                     <roleName type="kin" corresp="pe__dorothea_QGW_II_I_1308"><add>Geschwister</add></roleName> Anastasien <roleName type="kin" corresp="pe__konrad_feger_QGW_II_I_1308"><add>chinder</add></roleName><roleName type="kin" corresp="pe__anastasia_QGW_II_I_1308_b"><add>chinder</add></roleName></rs>
                  und <rs type="person" ref="pe__tylman_QGW_II_I_1308">Tylmann <roleName type="kin" corresp="pe__anna_QGW_II_I_1308"><add>Geschwister</add></roleName>
                     <roleName type="kin" corresp="pe__dorothea_QGW_II_I_1308"><add>Geschwister</add></roleName><roleName type="kin" corresp="pe__konrad_feger_QGW_II_I_1308"><add>chinder</add></roleName><roleName type="kin" corresp="pe__anastasia_QGW_II_I_1308_b"><add>chinder</add></roleName></rs>,
                  alle <rs type="person" ref="pe__konrad_feger_QGW_II_I_1308">Chunrats des Feger
                        <roleName type="dead"><add>got genade</add></roleName></rs> chinder bei
                  seiner <rs type="person" ref="pe__anastasia_QGW_II_I_1308_b"><roleName type="kin" corresp="pe__konrad_feger_QGW_II_I_1308">hausfraun</roleName> Anastasien,
                     den baiden <roleName type="dead">got genade</roleName></rs>
                  <triggerstring n="disp">angesucht hatten</triggerstring>. Sie <triggerstring n="disp">theilen</triggerstring> das Haus, gelegen an dem Harmarcht ze Wienn, das weilnt
                  der Schönaicherin gewesen ist, zenechst Jorgen haus von Nicolspurg, <rs type="fn" role="other"><triggerstring n="fn">nach rat</triggerstring> der zwaier werichmann,
                        <rs type="person" ref="pe__johann_maurer_von_wienerherberg"><roleName type="title">maister</roleName> Hannsen, des <roleName type="prof">maurer</roleName> von Wiennerherwerg <roleName type="occ" corresp="org__wien"><add>werichmann</add></roleName></rs>, und <rs type="person" ref="pe__dietrich_zimmermann_QGW_II_I_1572"><roleName type="title">maister</roleName> Dietreich, des <roleName type="prof">zimermans</roleName>
                        <roleName type="occ" corresp="org__wien"><add>werichmann</add></roleName></rs></rs>, zwischen Anastasia und Tilmann.
                  Der Letztere erhält zu seinem Theile Stadel und Garten, gelegen in der Hierspeunt
                  gegen des pischofs garten von Freising uber. Dorothen der Haidnin fallen zwei
                  Weingärten, ainer gelegen ze Obern Sufring zenechst der chirchen und haisset der
                  Westerwurger, und der ander an dem Haunsperg ze Su/efring und haisset der Vacz,
                  Annen der Goczchirchin 200 lb dn. zu.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1308"><rs type="fn" role="witness">Besiegelt von
                     den <rs type="person" ref="pe__konrad_rokk_QGW_II_I_1031"><add>Ausstellern</add></rs>
                     <rs type="person" ref="pe__peter_guenzburger_QGW_II_I_1235">Ausstellern</rs></rs>.</rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>