            <origDate instant="false">ze Wienn, des nasten mantags nach sand Jörgen tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01030_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01030_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="ev__QGW_II_I_1030"><rs type="fn" role="issuer"><rs type="person" ref="pe__wolfhard_pob_QGW_II_I_1011">Wolfhard der Pob, <roleName type="occ" corresp="org__wien">statrichter</roleName> ze Wienn</rs></rs>,
                     <triggerstring n="disp">beurkundet, dass vor ihm in der
                     Bürgerschranne</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="pe__simon_vivianz_QGW_II_I_1030">Simon der
                        Vivianz, <rs type="person" ref="pe__johann_von_tierna_QGW_II_I_1018"><roleName type="title">hern</roleName> Jannsen</rs>
                        <roleName type="occ" corresp="pe__johann_von_tierna_QGW_II_I_1018">schaffer</roleName>
                        von Tierna, <roleName type="rep" corresp="pe__johann_von_tierna_QGW_II_I_1018">an seines
                           Herrn Statt</roleName>
                     </rs><triggerstring n="fn">mit Vorsprechen</triggerstring></rs> auf das haus, das
                  weilnt Seifrids von Paz/zz/zau, des goldsmids, gewesen ist, gelegen under den
                  Goltsmiden gegen sand Stephan über ze Wienn, zenast dem haus, das weiln Eberhards,
                  des goltsmids, ist gewesen , um 3 lb dn. gelts <triggerstring n="disp">versessens
                     purkrechts und die darauf ertheilten zwispil geklagt habe</triggerstring>. Er gibt
                  dem <rs type="fn" role="recipient"><rs type="person" ref="pe__simon_vivianz_QGW_II_I_1030">Kläger </rs></rs>
                  <rs type="person" ref="pe__johann_praunsperger_QGW_II_I_1030">Jannsen von Praunsperk <roleName type="rep" corresp="pe__wolfhard_pob_QGW_II_I_1011"><add>Vorsprech</add></roleName></rs>
                  und <rs type="person" ref="pe__johann_von_feldsberg_QGW_II_I_1030">Jannsen von Veltzperg, di
                     zwen <roleName type="rep" corresp="pe__wolfhard_pob_QGW_II_I_1011">vorsprechen</roleName></rs>, als recht poten mit und <triggerstring n="disp">macht ihn <add>gewaltig</add></triggerstring> nach deren Aussage an seines Herrn
                  Statt des Hauses gewaltig.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1030"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="pe__wolfhard_pob_QGW_II_I_1011">Aussteller</rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>