               <rs type="event" ref="ev__QGW_II_I_426"><rs type="fn" role="issuer"><rs type="person" ref="pe__jakob_tumminch_QGW_II_I_426_a">Jacob der Tumminch</rs>, <rs type="person" ref="pe__christine_QGW_II_I_426">Christein, seine
                           <roleName type="kin" corresp="pe__jakob_tumminch_QGW_II_I_426_a">Hausfrau</roleName></rs>, und <rs type="person" ref="pe__jakob_tumminch_QGW_II_I_426_b">Jacob der Tumminch, sein<roleName type="kin" corresp="pe__jakob_tumminch_QGW_II_I_426_a">Sohn</roleName></rs></rs>, <triggerstring n="disp"> verzichten mit gesammter
                     Hand</triggerstring> und <rs type="fn" role="other"><triggerstring n="fn">mit
                        Handen</triggerstring><rs type="person" ref="pe__johann_poll_QGW_II_I_850">
                        ihres <roleName type="title">Grundherrn </roleName><roleName type="title">hern</roleName> Jansen des Pollen</rs></rs>
                  <rs type="fn" role="recipient">gegen <rs type="person" ref="pe__heinrich_ledrer_QGW_II_I_426">Hainreichen, dem <roleName type="prof">ledrer</roleName>
                        <roleName type="kin" corresp="pe__meinhard_QGW_II_I_426"><add>sun</add></roleName>,<rs type="person" ref="pe__meinhard_QGW_II_I_426"> Meinharts sun <roleName type="dead">saelig</roleName></rs></rs>, und dessen <rs type="person" ref="pe__kunigunde_QGW_II_I_426"><roleName type="kin" corresp="pe__heinrich_ledrer_QGW_II_I_426">Frau</roleName> Chunigunden,
                           <roleName type="kin" corresp="pe__hainusche_tummnich_QGW_II_I_426">Witwe</roleName> nach <rs type="person" ref="pe__hainusche_tummnich_QGW_II_I_426">Jakobs <roleName type="dead">verstorbenem</roleName>
                           <roleName type="kin" corresp="pe__jakob_tumminch_QGW_II_I_426_a">Bruder</roleName> Hainusche</rs></rs></rs>, auf die Brandstatt eines
                  Hauses, gelegen in dem Geraeut vor Stubentor ze Wienne<rs type="event" ref="ev__QGW_II_I_426_men_1">
                     zenaechst Stephans haus von Medlich, von der man jährlich 4 dn. zu Grundrecht
                     dient, sowie auf alles andere Gut, welches Hanusch der genannten Kunigunde
                     hinterlassen hatte</rs></rs>. </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_426"><rs type="fn" role="witness">Besiegelt mit
