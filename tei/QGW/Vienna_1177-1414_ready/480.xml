                  von der Schaebnicz</rs></rs></rs>, <triggerstring n="disp">beurkunden</triggerstring>,
              <rs type="event" ref="NULL">dass sie und <rs type="person" ref="pe__andreas_hauser_QGW_II_I_375">Andre der Hauser, <roleName type="occ" corresp="pe__albrecht_herzog_von_oesterreich_QGW_II_I_596">chamermaister</roleName>
                <rs type="person" ref="pe__albrecht_herzog_von_oesterreich_QGW_II_I_596"><roleName type="occ" corresp="org__oesterreich-herzogtum">Herzog</roleName> Albrechts</rs></rs>, sich an <rs type="person" ref="pe__heinrich_oeler_QGW_II_I_771"><roleName type="title">hern</roleName>
                Hainreichen den O/eler</rs> und <rs type="person" ref="pe__haunold_schuchler_QGW_II_I_170"><roleName type="title">hern</roleName>
                Haunolten den Schuchler</rs>
              <triggerstring n="disp">mit der Bitte gewendet haben, das </triggerstring>von ihren <rs type="person" ref="pe__jakob_pfaffstetter_QGW_II_I_438"><roleName type="dead">verstorbenen</roleName>
                <roleName type="kin" corresp="pe__margarethe_QGW_II_I_480">Eltern</roleName>
                <roleName type="kin" corresp="pe__anna_QGW_II_I_480"><add>Eltern</add></roleName>
                Jacob dem Phaffsteter</rs> und <rs type="person" ref="pe__elisabeth_QGW_II_I_480">seiner <roleName type="kin" corresp="pe__jakob_pfaffstetter_QGW_II_I_438">Hausfrau</roleName> Elspet <roleName type="dead"><add>verstorbenen</add>
                  <roleName type="kin" corresp="pe__margarethe_QGW_II_I_480"><add>Eltern</add></roleName>
                  <roleName type="kin" corresp="pe__anna_QGW_II_I_480"><add>Eltern</add></roleName></roleName></rs>
              <triggerstring n="disp">hinterlassene Erbgut zwischen ihnen zu
            theilen</triggerstring>.</rs></rs>
