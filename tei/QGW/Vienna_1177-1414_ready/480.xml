          <rs type="event" ref="ev__QGW_II_I_480"><rs type="fn" role="issuer"><rs type="person" ref="pe__jakob_loeffler_QGW_II_I_505">Jacob der Löffler, <roleName type="occ" corresp="org__wien">purger</roleName> ze Wienn</rs>, <rs type="person" ref="pe__margarethe_QGW_II_I_480">Margret, seine <roleName type="kin" corresp="pe__jakob_loeffler_QGW_II_I_505">Hausfrau</roleName></rs>, und ihre <rs type="person" ref="pe__anna_QGW_II_I_480"><roleName type="kin" corresp="pe__margarethe_QGW_II_I_480">Schwester</roleName> Anna, <roleName type="kin" corresp="pe__johann_von_der_schemnitz_QGW_II_I_394"><add>hausvrow</add></roleName>
