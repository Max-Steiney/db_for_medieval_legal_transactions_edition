                        daselbens der <rs type="person" ref="pe__beatrix_von_zollern_nuernberg_QGW_II_I_1048"><roleName type="title">hochgeporn</roleName>
                           <roleName type="title">fürstin</roleName>
                           <roleName type="title">fraun</roleName> Beatricis von Nürnberkch, <rs type="person" ref="pe__albrecht_herzog_von_oesterreich_QGW_II_I_1020"><roleName type="occ" corresp="org__oesterreich-herzogtum">herzog</roleName> Albrechts</rs>
                           <roleName type="kin" corresp="pe__albrecht_herzog_von_oesterreich_QGW_II_I_1020">witiben</roleName></rs></rs>,</rs> ein Haus, <rs type="event" ref="ev__QGW_II_I_1494_men_1">welches Andre und Margret mit gesammter Hand gekauft hatten</rs>,
