               <rs type="event" ref="ev__QGW_II_I_1494"><rs type="fn" role="issuer"><rs type="person" ref="pe__margarethe_QGW_II_I_1494">Margret, <roleName type="kin" corresp="pe__andreas_pierbaumer_QGW_II_I_1494"><add>witib</add></roleName>
