            <placeName>Passau</placeName>
            <date when="14110412">1411 IV 12</date>
            <origDate instant="false">Geben ze Passau an dem heiligen Ostertag, anno domini etc.
               undecimo.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01859_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01859_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1859"><rs type="fn" role="issuer"><rs type="person" ref="pe__georg_von_passau_QGW_II_I_1292">Bischof Jorg ze
                        Passau</rs></rs>
                  <triggerstring n="disp">schreibt</triggerstring>
                  <rs type="fn" role="recipient">den Gechäftherren seines Chorherrn und Officials
                     Lienhart Schauer<rs type="person" ref="pe__paul_geir_QGW_II_I_1406"><add>Pauln
                           dem Geyr</add>
                        <roleName type="occ" corresp="org__wien"><add>rats</add></roleName>,<roleName type="rep" corresp="pe__leonhard_schaur_QGW_II_I_1242"><add>Geschäftsherr</add></roleName></rs>
                     <rs type="person" ref="pe__wolfgang_purkchartsperger_QGW_II_I_1560"><add>Wolfgangen dem Purkcharczperger, baid des</add><roleName type="rep" corresp="pe__leonhard_schaur_QGW_II_I_1242"><add>Geschäftsherr</add></roleName>
                        <roleName type="occ" corresp="org__wien">rats</roleName> der stat ze
                        Wienn,</rs> und <rs type="person" ref="pe__heinrich_starkch_StB_I_62"><add>Hainreichen dem Starkchen</add><roleName type="rep" corresp="pe__leonhard_schaur_QGW_II_I_1242"><add>Geschäftsherr</add></roleName></rs>,</rs> dass er auf die Nachricht
                  hin, dieser habe kein Testament hinterlassen, den <rs type="fn" role="recipient"><rs type="person" ref="pe__andreas_von_grillenperg_QGW_II_I_1859">Official
                        Andren den Grillenperger</rs></rs>
                  <triggerstring n="disp">beauftragt habe,</triggerstring> den ganzen Nachlass des
                  Verstorbenen zu übernehmen. Da er aber nun anders berichtet worden war, so
                     <triggerstring n="disp">nimmt er diese Verfügung zurück und bittet
                     sie</triggerstring>, was Schaur ihm und seinem Gotteshause geschafft habe, dem
                  genannten Official auszufolgen.</rs>
            </p></div><div type="nota"><p>Adresse aussen.</p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>