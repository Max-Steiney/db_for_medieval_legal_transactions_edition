               <rs type="event" ref="ev__QGW_II_I_1650"><rs type="fn" role="issuer"><rs type="person" ref="pe__stephan_QGW_II_I_1650">Stephan, <roleName type="occ" corresp="org__stetten-pfarre">pharrer</roleName> in sand Ulreichs
                        pharrkirchen ze Stetten</rs>, </rs><triggerstring n="disp">bestätigt</triggerstring>, dass <rs type="fn" role="recipient"><rs type="person" ref="pe__ulrich_greif_QGW_II_I_1650">Ulrich <roleName type="dead">selig</roleName>, der erst <roleName type="occ" corresp="org__stetten-pfarre">pharrer</roleName> derselben
                        pharrkirchen</rs>, <rs type="person" ref="pe__martin_QGW_II_I_1650"><roleName type="title">her</roleName> Mert <roleName type="dead">selig</roleName>, sein <roleName type="kin" corresp="pe__ulrich_greif_QGW_II_I_1650">vetter</roleName>, der ander
                           <roleName type="occ" corresp="org__stetten-pfarre">pharrer</roleName></rs>, und der <rs type="person" ref="pe__greiffe_QGW_II_I_1650">Greiff, sein <roleName type="kin" corresp="pe__ulrich_greif_QGW_II_I_1650">vater</roleName><roleName type="dead"><add>selig</add></roleName></rs>, und <rs type="person" ref="pe__petra_QGW_II_I_1650">Peters, sein <roleName type="kin" corresp="pe__ulrich_greif_QGW_II_I_1650">muter</roleName><roleName type="dead"><add>selig</add></roleName></rs>, und <rs type="person" ref="pe__johann_greiffe_QGW_II_I_1650">Hanns der Greiff, sein <roleName type="kin" corresp="pe__ulrich_greif_QGW_II_I_1650">vetter</roleName><roleName type="dead"><add>selig</add></roleName></rs>,
                     und <rs type="person" ref="pe__kunigunde_QGW_II_I_1650">Chunigund, sein
                           <roleName type="kin" corresp="pe__johann_greiffe_QGW_II_I_1650">hausfrau</roleName>, den allen <roleName type="dead">got
                           gnedig</roleName> sei</rs></rs> , 4 ½ Joch Aecker, der zwai jeuch gelegen
                  sind in Stettnerveld bei dem Prünnlein gegen Sebarn über und die dritthalb jeuch
                  sint gelegen ze Hainprunn , der Pfarrkirche zu einem Jahrtage <triggerstring n="disp">geschafft haben</triggerstring>, und <triggerstring n="disp">verpflichtet sich zur
                     Abhaltung</triggerstring> desselben am nächsten Sonntag nach sant Siman und sant
                  Judas tag, der. heiligen zwelifpoten.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1650"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="pe__stephan_QGW_II_I_1650">Ausstellers</rs> und <rs type="person" ref="pe__andreas_rammler_QGW_II_I_1650">Andre des Rammler, <roleName type="occ" corresp="org__wien">burger</roleName> und ainer des
                        gesworn <roleName type="occ" corresp="org__korneuburg">rats</roleName> ze
                        Neunburg markchalben</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>