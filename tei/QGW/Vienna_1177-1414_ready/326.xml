            <origDate instant="false">ze Wienne, an dem Ebenweichtage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00326_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00326_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="ev__QGW_II_I_326"><rs type="fn" role="issuer"><rs type="person" ref="pe__schaul_QGW_II_I_326">Schaul der Jude, <roleName type="kin" corresp="pe__zeisl_QGW_II_I_326"><add>sun</add></roleName>
                        <rs type="person" ref="pe__zeisl_QGW_II_I_326">Zeisleins sun ze
                        Wienne</rs></rs>, und <rs type="person" ref="pe__istier_QGW_II_I_326">Istier, seine <roleName type="kin" corresp="pe__schaul_QGW_II_I_326">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen mit
                     gesammter Hand</triggerstring> und <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="pe__ortolf_jan_QGW_II_I_326"><roleName type="title">Grundherrn</roleName><roleName type="title">hern</roleName> Ortolfs des
                        Janen</rs></rs>, ihre hofstat weingarten, deu da leit vor Stubentor in dem
                  Geraeut zenaehst Stephan, dem ledrer von Medlich , <rs type="event" ref="ev__QGW_II_I_326_men_1">von
                     der man jährlich dient 4 dn. zu Grundrecht</rs> und <rs type="event" ref="ev__QGW_II_I_326_men_2">der Swaemlinne 2 lb dn. zu Burgrecht</rs>, um 28 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__trautmann_lederer_QGW_II_I_384">Trautman, dem <roleName type="prof">ledrer</roleName></rs>, und seiner <rs type="person" ref="pe__margarethe_QGW_II_I_297"><roleName type="kin" corresp="pe__trautmann_lederer_QGW_II_I_384">Hausfrau</roleName>
                        Margreten</rs></rs>. Sie <triggerstring n="disp">übermitteln</triggerstring> dem
                  Käufer den Brief, der ihnen ze einem scherm übergeben war von den sichen dacz dem
                  Chlagpaum, und daran hangt irs haus insigel und des egenanten gruntherren insigil
                  und des <rs type="person" ref="pe__albrecht_von_hohenberg_II_QGW_II_I_216"><roleName type="title">edeln herrn</roleName> insigil <roleName type="title">graf</roleName> Albrechts von Hohenberch, <roleName type="occ" corresp="org__wien-st_stephan">pharrer</roleName> dacz sand Stephan ze
                     Wienne</rs>, und <rs type="person" ref="pe__haunold_schuchler_QGW_II_I_170"><roleName type="title">hern</roleName> Haunolts insigil des
                  Schühler</rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_326"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="pe__ortolf_jan_QGW_II_I_326">Grundherrn</rs>, 2. <rs type="person" ref="pe__martin_QGW_II_I_326"><roleName type="title">hern</roleName> Merten, <roleName type="occ" corresp="org__wien">judenrichter</roleName> ze Wienne</rs></rs>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>