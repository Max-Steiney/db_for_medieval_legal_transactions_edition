               <rs type="event" ref="ev__QGW_II_I_174"><rs type="fn" role="issuer"><rs type="person" ref="pe__peter_schlosser_QGW_II_I_155">Peter, der <roleName type="prof">slosser</roleName></rs></rs>, <triggerstring n="disp">gibt</triggerstring>
