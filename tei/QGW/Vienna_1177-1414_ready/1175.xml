                           sundersiechen gemain daselbens</rs></rs></rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Einwilligung</triggerstring> ihres
                        <rs type="person" ref="pe__herbert_QGW_II_I_1175"><roleName type="occ" corresp="org__wien-st_lazarus_siechenhaus">Vogtes</roleName> Herwarts in
