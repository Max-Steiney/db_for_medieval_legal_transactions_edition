            <origDate instant="false">ze Wienn, des sampstags in der andern ganzen Vastwochen.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00402_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00402_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="ev__QGW_II_I_402"><rs type="fn" role="issuer"><rs type="person" ref="pe__berthold_spil_QGW_II_I_402">Perchtolt <roleName type="kin" corresp="pe__ulrich_spil_von_moedling_QGW_II_I_402"><add>sun</add></roleName>, <rs type="person" ref="pe__ulrich_spil_von_moedling_QGW_II_I_402">Ulreichs sun des Spils
                           von Medlich, <roleName type="dead">dem got
                     genad</roleName></rs></rs></rs>, <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__benedikt_QGW_II_I_191"><roleName type="title">hern</roleName> Benedicten, <roleName type="occ" corresp="org__wien-schotten">amman</roleName> und <roleName type="occ" corresp="org__wien-schotten">phleger</roleName> der Schotten gut ze
                        Wienn</rs></rs>, für sich und seine unmündige <rs type="person" ref="pe__margarethe_QGW_II_I_402a">Schwester junchvrown Margreten</rs> zwei
                  Tagwerke Wiesen, gelegen ze Aichau, zenaehst der vrowen wisen von sant Nichla, von
                  denen man jährlich 6 dn. zu Grundrecht dient, um 5 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__stephan_strobein_QGW_II_I_1086"><roleName type="title">hern </roleName>Stephan dem Strobein, <roleName type="occ" corresp="org__wien">purger</roleName> ze
                  Wienn</rs></rs>. <rs type="fn" role="other">Als <triggerstring n="fn">Schirm gegen
                        jede Ansprache</triggerstring> setzen sich der <rs type="person" ref="pe__berthold_spil_QGW_II_I_402">Aussteller</rs>, <rs type="person" ref="pe__meinhard_wascher_QGW_II_I_304">Meinhart der Waser von Medlich</rs>,
                        <rs type="person" ref="pe__margarethe_QGW_II_I_402b">Margret, seine
                           <roleName type="kin" corresp="pe__meinhard_wascher_QGW_II_I_304">Hausfrau</roleName></rs>, <rs type="person" ref="pe__konrad_naeslein_QGW_II_I_402">Chunrat der Naesel</rs> und <rs type="person" ref="pe__katharina_QGW_II_I_402">Katrei, seine <roleName type="kin" corresp="pe__konrad_naeslein_QGW_II_I_402">Hausfrau</roleName></rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_402"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="pe__benedikt_QGW_II_I_191"><roleName type="title">hern</roleName> Benedicts</rs>, 2. <rs type="person" ref="pe__ulrich_churtzman_QGW_II_I_294"><roleName type="title">hern</roleName> Ulreichs des Churtzmans, <roleName type="occ" corresp="org__wien">purger</roleName> ze Wienn</rs></rs>.</rs>
            </p></div><div type="nota"><p>Indorsat: Uber wis ze Aichau von dem Zundlein. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>