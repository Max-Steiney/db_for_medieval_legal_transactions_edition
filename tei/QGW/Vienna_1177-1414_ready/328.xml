         <div type="abstract" resp="ks">
            <p>
               <rs type="event" ref="ev__QGW_II_I_328"><rs type="fn" role="issuer"><rs type="person"
                        ref="pe__dietmar_QGW_II_I_328"><roleName type="title"
                        >Pruder</roleName>Dietmar, <roleName type="occ"
                           corresp="org__wien-augustiner_eremiten">prior</roleName></rs>, und die
                        <rs type="org" ref="org__wien-augustiner_eremiten">pru/eder gemain sand
                        Augustins orden ze Wienne</rs></rs>
                  <triggerstring n="disp">bestätigen</triggerstring>, von <rs type="fn" role="recipient"
                        ><rs type="person" ref="pe__elisabeth_QGW_II_I_386"><roleName type="title"
                           >Frau</roleName> Elspeten der Urbetzin </rs></rs>
                  <rs type="fn" role="other"><triggerstring n="fn">für das Seelenheil</triggerstring>
                     ihres <rs type="person" ref="pe__dietrich_urbetsch_QGW_II_I_950"><roleName
                           type="dead">verstorbenen</roleName><roleName type="kin"
                           corresp="pe__elisabeth_QGW_II_I_386">Mannes</roleName> Dietreiches des
                        Urbetzen</rs></rs> 10 lb dn. <triggerstring n="disp">als Legat erhalten zu
                     haben</triggerstring>, und <triggerstring n="disp">verpflichten sich</triggerstring> zur
                  Abhaltung eines Jahrtages des nächsten eritages noch sand Gorgen tag.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_I_328"><rs type="fn" role="witness">Besiegelt von
                        <rs type="person" ref="pe__dietmar_QGW_II_I_328">Prior</rs> und <rs
                        type="org" ref="org__wien-augustiner_eremiten">Convent</rs></rs>.</rs></p>
