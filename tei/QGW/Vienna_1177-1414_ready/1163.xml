            <origDate instant="false">ze Wienn, an dem achten tage nach Unser Fraun tag, als sie geparn
               warde.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01163_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01163_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1163"><rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_toemgel_QGW_II_I_1163">Ulreich der Tömgel, <roleName type="occ" corresp="org__wien">purger</roleName> ze Wienn</rs>, und
                        <rs type="person" ref="pe__lucia_QGW_II_I_1163">Lucei, seine <roleName type="kin" corresp="pe__ulrich_toemgel_QGW_II_I_1163">Hausfrau</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__michael_geukramer_QGW_II_I_1137"><roleName type="title">hern</roleName> Michels des Geuchramer, <roleName type="occ" corresp="org__wien">purgermaister</roleName> und <roleName type="occ" corresp="org__oesterreich-herzogtum" select="pl__wien">münzmeister</roleName></rs>, und des
                        <rs type="org" ref="org__wien">rates gemain der stat ze Wienn</rs></rs> ihr
                  Zuhaus, gelegen in der Suningerstrasse ze Wienn an ainem tail zenechst ihrem Hause
                  und an dem andern tail zenechst der Poschinne haus, von welchem, Haus und Zuhaus
                  man hinz den Deutschenherren ze Wienn 3 lb dn. Burgrecht dient, mitsambt dem
                  grossen cheler darunder unter Regelung der Rechts und Dienstverhältnisse um 26 lb
                  dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__otto_purgercheufl_QGW_II_I_1163">Otten, dem <roleName type="prof">purgercheuffl</roleName> ze Wienn</rs>, und seiner <rs type="person" ref="pe__kunigunde_QGW_II_I_1163"><roleName type="kin" corresp="pe__otto_purgercheufl_QGW_II_I_1163">Hausfrau</roleName>
                  Kunigunden</rs></rs>.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1163"><rs type="fn" role="witness">Besiegelt : 1.
                     mit dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs>, 2. mit dem
                     Siegel des <rs type="person" ref="pe__georg_von_nikolsburg_QGW_II_I_1010">Wiener <roleName type="occ" corresp="org__wien">Bürgers</roleName> Jörgen von
                        Nicolspurg</rs></rs>.</rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>