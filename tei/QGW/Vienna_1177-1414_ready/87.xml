                     <triggerstring n="fn">ausgesprochenen Vergleich</triggerstring></rs>
                  <rs type="fn" role="recipient">für <rs type="person" ref="pe__kunigunde_QGW_II_I_87">sich</rs> und <rs type="person" ref="pe__niklas_strutzel_QGW_II_I_87">ihren <roleName type="kin" corresp="pe__kunigunde_QGW_II_I_87">Sohn</roleName> Nichlas</rs></rs>
