            <date when="14030418">1403 IV 18</date>
            <origDate instant="false">ze Wienn, des nechsten mitichen nach Ostern.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01534_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01534_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_I_1534"><rs type="fn" role="issuer"><rs type="person" ref="pe__margarethe_chranvogelin_QGW_II_I_1129">Margret, <roleName type="kin" corresp="pe__philipp_chranvogel_QGW_II_I_1129"><add>witib</add></roleName>
                        <rs type="person" ref="pe__philipp_chranvogel_QGW_II_I_1129">Philips <roleName type="dead">witib</roleName> des Chranvogel</rs></rs>,</rs>
                  <triggerstring n="disp">gibt</triggerstring>
                  <rs type="fn" role="recipient">ihrem <rs type="person" ref="pe__jakob_chranvogel_QGW_II_I_1468"><roleName type="kin" corresp="pe__margarethe_chranvogelin_QGW_II_I_1129">Sohne</roleName> Jacoben dem Chranvogel</rs></rs>
                  <triggerstring n="disp">für seinen vaeterleichen und müterleichen
                  erbtail</triggerstring> die nachbenannten Güter: von erst das haus, gelegen in der
                  Mu/ensserstrass ze Wienn, hinders und vorders, zenechst Wolfharts haus von der
                  Sche/abnicz, geleich halbs, und das haus, gelegen vor Schottentor und den garten
                  und die hofstat weingarten daran, ganz und gar, und einen weingarten, gelegen an
                  der Hochenwart, und einen weingarten, gelegen an der Weissenleitten, und vierdhalb
                  hundert lb dn ., wein für 200 lb dn. und für die anderthalbhundert phunt
                  kaufmanschaft, und darzu alle die geltschuld, die man ihr bis auf den heutigen Tag
                  schuldig bleibt.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1534"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln ihres <rs type="person" ref="pe__kolomann_chranvogel_QGW_II_I_1468"><roleName type="kin" corresp="pe__margarethe_chranvogelin_QGW_II_I_1129">Sohnes</roleName>
                        Cholmans des Chranvogels</rs> und der <rs type="person" ref="pe__paul_wuerfel_QGW_II_I_1200">Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Pauln des Würffels</rs> und <rs type="person" ref="pe__konrad_spaet_QGW_II_I_1534">
                        <roleName type="occ" corresp="org__wien"><add>Bürger</add></roleName>
                        Chunrats des Spe/aten, den man auch nennet den Wochner</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>