            <origDate instant="false">ze Wienne, an Unser Fraun abende zu der Schidung.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01214_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01214_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><!-- Korrekturhinweis "Warum hat pe__thomas_payr_QGW_II_I_1214 ein Quellenkürzel" - Zur Unterscheidung von "Thomas Payr" in 1057/58--><p><rs type="event" ref="ev__QGW_II_I_1214"><rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_reindl_QGW_II_I_1214">Ulreich der Reindl, der <roleName type="prof">fleischhakcher</roleName>, <roleName type="occ" corresp="org__wien">purger</roleName> ze Wienne</rs>, <rs type="person" ref="pe__katharina_QGW_II_I_1213">Kathrei, seine <roleName type="kin" corresp="pe__ulrich_reindl_QGW_II_I_1214">Hausfrau</roleName></rs>, und <rs type="person" ref="pe__thomas_reindl_QGW_II_I_1214">Thoman, sein <roleName type="kin" corresp="pe__ulrich_reindl_QGW_II_I_1214">Sohn</roleName>
                        <roleName type="kin" corresp="pe__kunigunde_QGW_II_I_1213"><add>Sohn</add></roleName> aus seiner früheren Ehe mit <rs type="person" ref="pe__kunigunde_QGW_II_I_1213">Chunigunden</rs></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring> mit gesammter Hand und <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__michael_geukramer_QGW_II_I_1137"><roleName type="title">hern</roleName> Michels des Geuchramer, <roleName type="occ" corresp="org__wien">purgermaister</roleName> und <roleName type="occ" corresp="org__oesterreich-herzogtum" select="pl__wien">münzmaister</roleName></rs>, und des <rs type="org" ref="org__wien">rats
                        gemain der stat ze Wienn</rs></rs> ihre Fleischbank, deren eine Hälfte das
                  Ehepaar erarbeitet hatte und <rs type="event" ref="ev__QGW_II_I_1214_men_1">deren andere Hälfte dem
                     Thomas und seinen <rs type="person" ref="pe__andreas_QGW_II_I_1214"><roleName type="kin" corresp="pe__thomas_reindl_QGW_II_I_1214">Geschwistern</roleName>
                        Andren</rs> und <rs type="person" ref="pe__katharina_QGW_II_I_1214"><roleName type="kin" corresp="pe__thomas_reindl_QGW_II_I_1214"><add>Geschwistern</add></roleName> Kathrein</rs> in rechter Theilung
                     gegen den <rs type="person" ref="pe__niklas_QGW_II_I_1214"><roleName type="kin" corresp="pe__kunigunde_QGW_II_I_1213">Bruder</roleName> seiner Mutter
                        Niclasen des Churzen Simans sun, des fleischhakcher, <roleName type="dead">den got gnad</roleName></rs>, zugefallen und ihm dann von seinen
                     Geschwistern anerstorben war</rs>, gelegen under den Fleischpenkchen auf der
                  Möring bei dem Liechtensteg ze Wienn, an ainem tail zenechst Jannsen fleischpankch
                  des Stadels und an dem andern tail zenegst Thomans fleischpankch des Phanzagels ,
                  um 100 lb dn. dem <rs type="fn" role="recipient"><rs type="person" ref="pe__thomas_payr_QGW_II_I_1214">Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Thoman dem Payr</rs></rs>.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1214"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="pe__stephan_leitner_QGW_II_I_1012">Wiener <roleName type="occ" corresp="org__wien">Bürgers</roleName>
                        <roleName type="title">hern</roleName> Stephans des
               Leitner</rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>