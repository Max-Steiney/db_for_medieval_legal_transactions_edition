            <placeName>Wien</placeName>
            <date when="14010428">1401 IV 28</date>
            <origDate instant="false">Geben ze Wienn nach Christi gepurd 1400 jar darnach in dem 1. jar, des
               nachsten phinztags nach sand Jorgen tag. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01488_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01488_v.jpg"/></surface></facsimile><!-- evtl beide Streitparteien als recipient --><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_I_1488"><rs type="fn" role="issuer"><rs type="person" ref="pe__berthold_lang_QGW_II_I_1488">Perchtold der Lang, <roleName type="occ" corresp="org__wien">burgermaister</roleName></rs>, und der
                        <rs type="org" ref="org__wien">rat gemain der stat ze Wienn</rs></rs>
                  <triggerstring n="disp">beurkunden, dass</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="pe__johann_sachs_QGW_II_I_1488"><roleName type="title">maister</roleName> Hanns der Sachs, der <roleName type="prof">maier</roleName>, <roleName type="rep" corresp="pe__anna_QGW_II_I_1488_b"><add>anstatt</add></roleName></rs>
                     <triggerstring n="fn"><add>geklagt habe</add></triggerstring>
                  </rs> an seiner <rs type="person" ref="pe__anna_QGW_II_I_1488_b"><roleName type="kin" corresp="pe__johann_sachs_QGW_II_I_1488">hausfraun</roleName> stat Annen, <rs type="person" ref="pe__ulrich_schrannschreiber_QGW_II_I_1488">Ulreichs
                           <roleName type="dead">seligen</roleName> des <roleName type="occ" corresp="org__wien">schrannschreiber</roleName></rs>
                     <roleName type="kin" corresp="pe__ulrich_schrannschreiber_QGW_II_I_1488">tochter</roleName>
                     <roleName type="kin" corresp="pe__anna_QGW_II_I_1488_a"><add>tochter</add></roleName> pei <rs type="person" ref="pe__anna_QGW_II_I_1488_a"><roleName type="title">fraun</roleName>
                        Annen, seiner <roleName type="kin" corresp="pe__ulrich_schrannschreiber_QGW_II_I_1488">hausfraun</roleName></rs></rs>, ihnen <triggerstring n="disp">geklagt und
                     vorgelegt habe</triggerstring>, <rs type="event" ref="ev__QGW_II_I_1488_men_1">wie dieselbe frau
                     Ann, sein swiger, zwei Weingärten, die von dem Vater seiner Frau herrührten,
                     unverchumert, unvermacht und unverschafft hinterlassen habe, ainer gelegen ze
                     Paungarten in der Wegleng und der ander gelegen in der Maur an dem
                     Kadolsperig,</rs> seine Frau also der nächste Erbe sei. <triggerstring n="disp">Dem entgegen habe</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn"><add>hincz</add></triggerstring>
                     <rs type="person" ref="pe__niklas_bogner_von_nikolsburg_QGW_II_I_1488">Niklas, der <roleName type="prof">pogner</roleName> von Nikolspurg,
                           <roleName type="rep" corresp="pe__barbara_QGW_II_I_1488">an<add>statt</add></roleName></rs></rs> seiner <rs type="person" ref="pe__barbara_QGW_II_I_1488"><roleName type="kin" corresp="pe__niklas_bogner_von_nikolsburg_QGW_II_I_1488">hausfraun</roleName> Barbaren, auch der egenanten Annen <roleName type="kin" corresp="pe__anna_QGW_II_I_1488_a">tochter</roleName>
                     <roleName type="kin" corresp="pe__michael_seld_QGW_II_I_1488"><add>tochter</add></roleName>
                     pei <rs type="person" ref="pe__michael_seld_QGW_II_I_1488">irem andern <roleName type="kin" corresp="pe__anna_QGW_II_I_1488_a">wirt</roleName> Micheln <roleName type="dead">seligen</roleName> dem Selden</rs>,</rs>
                  <triggerstring n="disp">nachgewiesen</triggerstring>, <rs type="event" ref="ev__QGW_II_I_1488_men_2">dass
                     er laut eines Gerichtsbriefes den Weingarten an dem Kadolsperg dem maister
                     Hannsen dem Sachsen und dessen Hausfrau Annen durch Gerichtsspruch anerlangt
                     und anbehabt habe, und dass an der gwer des andern Weingartens Michel der Seld,
                     seiner Hausfrau rechter Vater, im Grundbuch geschrieben erscheine</rs>. Der
                  Rath, vor den der Streit von beiden Theilen gebracht worden war, <triggerstring n="disp">entscheidet</triggerstring>, dass der Weingarten zu Baumgarten an die
                  Kinder und Erben Michels des Selden fallen solle, hinsichtlich des andern
                  Weingartens aber solle es, seind der vorgenant maister Hanns der Sachs das recht
                  umb denselben von dem perigmaister gesuecht und genomen hat, pei dem gerichtbrif
                  genzleich beleiben, den der egenant maister Niklas, der pogner, und sein hausfrau
                  Barbara darumb habent.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1488"><rs type="fn" role="witness">Besiegelt mit
                     der <rs type="org" ref="org__wien">stat ze Wienn</rs> klainem anhangundem
                     insigil.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>