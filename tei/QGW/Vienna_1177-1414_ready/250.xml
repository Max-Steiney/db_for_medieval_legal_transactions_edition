               <rs type="event" ref="ev__QGW_II_I_250"><rs type="fn" role="issuer"><rs type="person" ref="pe__leopold_QGW_II_I_250"><roleName type="title">Pru/eder</roleName>
                        Leutolt, <roleName type="occ" corresp="org__wien-augustiner_eremiten">prior</roleName> datz den Augustinern ze Wienne</rs>, und <rs type="org" ref="org__wien-augustiner_eremiten">der convent gemain desselben
                        chlosters</rs></rs>
                  <triggerstring n="disp">verpflichten sich</triggerstring>, für das Pfund Wiener
                  Pfenninge geltes purchrechtes, das <rs type="fn" role="recipient"><rs type="person" ref="pe__konrad_fuetrer_QGW_II_I_250">Chunrat, der
                        fu/etrer</rs></rs>, dem Kloster nach pruder Ru/egers Tod gegeben hat, das da
                  leit auf Fridreichs weingarten, Wolfharts pru/eder, des pekchen auf der Widem, und
                  der da leit ausserhalben der Widem zenachst Ru/edleins Adlots weingarten , nach
                  dem Ableben des Bruders Ruger für Konrad und <rs type="person" ref="pe__adelheid_QGW_II_I_250">seine <roleName type="kin" corresp="pe__konrad_fuetrer_QGW_II_I_250">Hausfrau</roleName> Alhaiten, der
                        <roleName type="dead">got genade</roleName></rs>, <triggerstring n="disp">einen
                     Jahrtag</triggerstring> des naechsten mittichens vor sant Merteins tage
                     <triggerstring n="disp">zu begehen</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_250"><rs type="fn" role="witness">Besiegelt von
                        <rs type="person" ref="pe__leopold_QGW_II_I_250">Prior</rs> und <rs type="org" ref="org__wien-augustiner_eremiten">Convent</rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>