      <text>
            <body>
                  <div type="abstract" resp="ks">
                        <p><rs type="event" ref="ev__QGW_II_I_144"><rs type="fn" role="issuer"><rs
                                                type="person" ref="pe__martin_QGW_II_I_102">Mert,
                                                  <roleName type="occ"
                                                  corresp="org__wien-st_maria_im_rathaus"
                                                  >Kaplan</roleName> und <roleName type="occ"
                                                  corresp="org__wien-st_maria_im_rathaus"
                                                  >Verweser</roleName> der Kapelle Unser Vrowen in
                                                dem hause, das weiln hern Otten Enhaim gewesen
                                                ist</rs></rs>, <triggerstring n="disp"
                                          >verkauft</triggerstring>
                                    <rs type="fn" role="other"><triggerstring n="fn">mit
                                                Handen</triggerstring> seines <rs type="person"
                                                ref="pe__otto_schreiber_QGW_II_I_144"><roleName
                                                  type="occ" corresp="org__penzing-st_jakob"
                                                  >Bergmeisters</roleName> Otten des Schreiber von
                                                Pentzingen</rs></rs> seines rechten Kaufgutes ½ Joch
                                    Weingarten, der do leit ze Praitense an dem Altenperge, zenaest
                                    den Heiligen Gaester stathalben, von dem man jährlich 60 dn. für
                                    Bergrecht und Zehent, 3 dn. zu Voitrecht dient, um 17 Mark
                                    Silber, ie zwen und sibenzig grosser pehemischer phenning für
                                    die march, an <rs type="fn" role="recipient"><rs type="person"
                                                ref="pe__friedrich_im_steinhaus_QGW_II_I_144"
                                                >Fridreich in dem Steinhaus</rs> und <rs
                                                type="person" ref="pe__reitze_QGW_II_I_144">seine
                                                  <roleName type="kin"
                                                  corresp="pe__friedrich_im_steinhaus_QGW_II_I_144"
                                                  >Frau</roleName> Reitze</rs>.</rs></rs>
                        </p>
                  </div>
                  <div type="seal">
                        <p><rs type="event" ref="ev__QGW_II_I_144"><rs type="fn" role="witness"
                                          >Besiegelt von dem <rs type="person"
                                                ref="pe__martin_QGW_II_I_102">Aussteller</rs> und
                                          dem <rs type="person"
                                                ref="pe__otto_schreiber_QGW_II_I_144"
                                                >Bergmeister</rs>.</rs></rs>
                        </p>
