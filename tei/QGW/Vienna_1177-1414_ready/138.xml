               <rs type="event" ref="ev__QGW_II_I_138"><rs type="fn" role="issuer"><rs type="person" ref="pe__ortolf_chraechsner_QGW_II_I_119">Ortolf der Chraechsner</rs> und
                        <rs type="person" ref="pe__margarethe_QGW_II_I_138">Margret, sein <roleName type="kin" corresp="pe__ortolf_chraechsner_QGW_II_I_119">hausvrowe</roleName></rs></rs>, <triggerstring n="disp">setzen sich und
                     ihre Erben</triggerstring>
                  <rs type="fn" role="recipient">für <rs type="person" ref="pe__margarethe_QGW_II_I_118"><roleName type="title">vron</roleName>
                        Margreten, <roleName type="kin" corresp="pe__heinrich_mogan_QGW_II_I_119"><add>witib</add></roleName>
                        <rs type="person" ref="pe__heinrich_mogan_QGW_II_I_119">Hainreichs <roleName type="dead">witib</roleName> des Mogan</rs></rs>, und für <rs type="person" ref="pe__wendel_QGW_II_I_138"><roleName type="title">vron</roleName> Wenteln, <roleName type="kin" corresp="pe__ulrich_QGW_II_I_138"><add>witiben</add></roleName>
                        <rs type="person" ref="pe__ulrich_QGW_II_I_138">U/olreichs <roleName type="dead">witiben</roleName>, <rs type="person" ref="pe__nagel_QGW_II_I_138">des Nagels</rs>
                           <roleName type="kin" corresp="pe__nagel_QGW_II_I_138">bru/oder</roleName></rs></rs>, <rs type="person" ref="pe__siegfried_minnganch_QGW_II_I_192"><roleName type="title">hern</roleName> Seifriden dem Minnganch</rs> und seiner <rs type="person" ref="pe__katharina_QGW_II_I_192"><roleName type="kin" corresp="pe__siegfried_minnganch_QGW_II_I_192">Hausfrau</roleName>
                        Katrein</rs></rs>
                  <triggerstring n="disp">zu Bürgen</triggerstring> über zwei Drittel des Weingartens, der
                  da leit ze Grinzingen und haisset der Scherge, des dreu viertail sint, den Herr
                  Seifried von den genannten Frauen gekauft hat.</rs>
