            <origDate instant="false">ze Wienn, des nechsten eritags nach sand Veits tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01431_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01431_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1431"><rs type="fn" role="issuer"><rs type="person" ref="pe__konrad_rampersdorfer_QGW_II_I_1107">Chu/eenrat der Ramppersdorfer
                           <roleName type="occ" corresp="org__wien"><add>rat</add></roleName>
                        <roleName type="rep" corresp="org__wien"><add>vom Rathe bestellte
                              Theiler</add></roleName></rs> und <rs type="person" ref="pe__johann_ziernast_QGW_II_I_1371">Hanns der Ziernast, paid des <roleName type="occ" corresp="org__wien">rats</roleName> der stat ze Wienn <roleName type="rep" corresp="org__wien"><add>vom Rathe bestellte
                           Theiler</add></roleName></rs></rs>, <triggerstring n="disp">beurkunden,
                     dass</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__hermann_von_eslarn_ii_QGW_II_I_1185">Herman von Eslarn <roleName type="kin" corresp="pe__hermann_von_eslarn_QGW_II_I_1185"><add>Kind</add></roleName></rs> und <rs type="person" ref="pe__niklas_von_eslarn_v_QGW_II_I_1185">Niclas von Eslarn, sein <roleName type="kin" corresp="pe__hermann_von_eslarn_ii_QGW_II_I_1185">brueder</roleName>, baid <rs type="person" ref="pe__hermann_von_eslarn_QGW_II_I_1185"><roleName type="title">hern</roleName> Hermans <add>von Eslarn</add>
                           <roleName type="dead">seligen</roleName></rs>
                        <roleName type="kin" corresp="pe__hermann_von_eslarn_QGW_II_I_1185">kinder</roleName> von
                        Eslarn</rs></rs>, <rs type="org" ref="org__wien">den Rath</rs> um die
                  Theilung des ihnen von ihrem Vater hinterlassenen Gutes <triggerstring n="disp"><add>um Theilung hinterlassenen Gutes</add> gebeten haben</triggerstring>. Als
                  vom Rathe bestellte Theiler <triggerstring n="disp">theilen</triggerstring> sie zuerst
                     <rs type="fn" role="other"><triggerstring n="fn">nach Rath</triggerstring> der zwair
                     werichmann <rs type="person" ref="pe__johann_maurer_von_wienerherberg"><roleName type="occ" corresp="org__wien"><add>werichmann</add></roleName>
                        <roleName type="title">maister</roleName> Hannsen, des <roleName type="prof">maurer</roleName> von Wiennerherwerig</rs>, und <rs type="person" ref="pe__peter_zimmermann_QGW_II_I_1538"><roleName type="occ" corresp="org__wien"><add>werichmann</add></roleName>
                        <roleName type="title">maister</roleName> Peter, des <roleName type="prof">zimermans</roleName></rs></rs>, das haus, gelegen in der Münzerstrass ze
                  Wienn an dem Ekk gegen sand Margreten kappellen über zenechst Hannsen haus des
                  Zinkken , unter beide Brüder, dann erhält Niklas ein Joch Weingarten ze
                  Chlaitzing, ein halbes Joch Weingarten ze Grinzing in dem Gereut, ein Joch
                  Weingarten ze Dornpach, ein Joch Weingarten ze Penzing, einen Centner Unschlitt
                  geltes auf zwain fleischpenkchen bei sand Michel, einen Acker ze Welfa/echsing,
                  einen Krautgarten ze Simoning und ein halbes Joch Weingarten ze Otakchrinn,
                  Hermann aber zwei Joch Weingarten in dem Mukkental, Haus und Stadel vor Chernertor
                  auf der Wydem, 11 lb 55 dn. geltes auf behaustem gut und auf weingerten.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1431"><rs type="fn" role="witness">Besiegelt von
                     den <rs type="person" ref="pe__konrad_rampersdorfer_QGW_II_I_1107">Ausstellern</rs>
                     <rs type="person" ref="pe__johann_ziernast_QGW_II_I_1371"><add>Ausstellern</add></rs></rs>.</rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>