         <div type="abstract">
            <p>
               <rs type="event" ref="ev__QGW_II_II_1950"><rs type="fn" role="issuer"><rs type="person" ref="pe__heinrich_scheppach_QGW_II_I_1544">Hainreich Schepach,
                           <roleName type="occ" corresp="org__wien">burger</roleName> ze
                        Wienn</rs>, und <rs type="person" ref="pe__anna_QGW_II_II_1950">Anna, sein
                           <roleName type="kin" corresp="pe__heinrich_scheppach_QGW_II_I_1544">hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__andreas_muldorffer_QGW_II_II_1950">Andres des
                        Muldorffer ze We/aring, <roleName type="occ" corresp="org__michaelbeuern-benediktiner">pergmaister</roleName> der
                        geistleichen herren von Peurn</rs>,</rs> ein Viertel Weingarten, gelegen in
                  dem Gottschalichsperg, zenegst des prunnhu/eter von Hof weingarten, von dem man 30
                  dn. für Bergrecht, 3 Ort zu Voitrecht dient, <rs type="fn" role="recipient"><rs type="person" ref="pe__michael_QGW_II_II_1930"><roleName type="title">hern</roleName> Micheln, <roleName type="occ" corresp="org__wien-st_maria_im_rathaus-altar_jodocus">capplan</roleName><roleName type="occ" corresp="org__wien-st_maria_im_rathaus-altar_st_leonhard"><add>capplan</add></roleName> und <roleName type="occ" corresp="org__wien-st_maria_im_rathaus-altar_jodocus">verweser</roleName><roleName type="occ" corresp="org__wien-st_maria_im_rathaus-altar_st_leonhard"><add>verweser</add></roleName> sand Lienharts und sand Josten altar,
                        gelegen in hern Otten und Haimen seligen cappelln bei der purger
                        Rathaus</rs> , zu diesem Altare</rs> um 10 lb dn., die herkommen von den 126
                  lb dn., die auf Wilhalms des Slechten seligen haus gelegen sind gewesen.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_1950"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="pe__heinrich_scheppach_QGW_II_I_1544">Ausstellers</rs> und <rs type="person" ref="pe__georg_grunnpekch_QGW_II_I_1304">Jorgen des Grunpekchen, des
                           <roleName type="occ" corresp="org__wien">rats</roleName> der stat ze
                        Wienn</rs>.</rs></rs>
            </p>
