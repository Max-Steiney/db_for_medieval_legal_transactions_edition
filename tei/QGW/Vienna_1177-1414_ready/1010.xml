            <origDate instant="false">ze Wienne, des nächsten freitags nach sand Giligen tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01010_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01010_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="ev__QGW_II_I_1010"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_QGW_II_I_1010">Jans, <rs type="person" ref="pe__niklas_hofvaszieher_QGW_II_I_1010">Nichlas <roleName type="dead">seligen</roleName>, des <roleName type="prof">hofvasziecher</roleName></rs>, <roleName type="kin" corresp="pe__niklas_hofvaszieher_QGW_II_I_1010">sun</roleName></rs>,
                     und <rs type="person" ref="pe__christian_QGW_II_I_1010">Christan, sein
                           <roleName type="kin" corresp="pe__johann_QGW_II_I_1010">Vetter</roleName></rs></rs>, <triggerstring n="disp">stellen <add>einen
                        Schuldbrief aus</add></triggerstring> dem <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_von_harrenstein_QGW_II_I_1010">Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Jannsen von
                        Harrenstain</rs> und seiner <rs type="person" ref="pe__christine_QGW_II_I_1010"><roleName type="kin" corresp="pe__johann_von_harrenstein_QGW_II_I_1010">Hausfrau</roleName>
                     Christein</rs></rs> einen Schuldbrief über 28 lb dn. aus und <triggerstring n="disp">verpfänden</triggerstring> ihm dafür <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="pe__paul_holzkaeufel_QGW_II_I_1010"><roleName type="occ" corresp="org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Pauln des Holzchauffels</rs> und des
                        <rs type="org" ref="org__wien">rats gemain der stat ze Wienn</rs></rs> das
                  Haus, <rs type="event" ref="ev__QGW_II_I_1010_men_1">das dem Jannsen von seinem <rs type="person" ref="pe__niklas_hofvaszieher_QGW_II_I_1010">Vater <roleName type="dead">anerstorben</roleName></rs> war</rs>, gelegen an dem Alten Cholmarkch an
                  dem ekke ze Wienne zenachst Nichlas haus, des schuester, von dem man der chapelln
                  in dem Greutt 5 sh. dn., hinz der pharrchirchen dacz sand Michel ze Wienn 2 lb dn.
                  und swester Elsbeten, conventswester dacz sand Marien Magdalenen vor Schottentor
                  ze Wienne, 3 lb 6 sh. dn. ze purkrecht dient.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1010"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="pe__georg_von_nikolsburg_QGW_II_I_1010">Wiener <roleName type="occ" corresp="org__wien">Bürgers</roleName> Jorgen von
                        Nicolspurkch</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: Der brief leit herinne Hannsen, Niclas sun, des vaszieher. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>