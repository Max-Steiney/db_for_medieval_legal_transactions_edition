                        Elspeten, <roleName type="kin" corresp="pe__ortolf_QGW_II_I_1212">Witwe</roleName> ihres <rs type="person" ref="pe__ortolf_QGW_II_I_1212"><roleName type="kin" corresp="pe__jakob_fuchs_QGW_II_I_1212">Vetters</roleName><roleName type="kin" corresp="pe__christine_QGW_II_I_1212"><add>Vetters</add></roleName>,
