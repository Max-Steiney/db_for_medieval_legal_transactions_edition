                  <rs type="fn" role="issuer"><rs type="person" ref="pe__simon_QGW_II_I_689">Simon,
                           <roleName type="occ" corresp="org__oesterreich-herzogtum">torwertel</roleName> der Herzöge in Oesterreich</rs>, und <rs type="person" ref="pe__elisabeth_QGW_II_I_689">Elsbet, seine <roleName type="kin" corresp="pe__simon_QGW_II_I_689">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
