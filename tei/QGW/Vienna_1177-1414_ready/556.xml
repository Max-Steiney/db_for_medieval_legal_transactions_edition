            <date when="13600809">1360 VIII 09</date>
            <origDate instant="false">ze Wienne, an sande Larenzen abent.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00556_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00556_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="ev__QGW_II_I_556"><rs type="fn" role="issuer"><rs type="person" ref="pe__margarethe_QGW_II_I_556"><roleName type="title">Swester</roleName>
                        Margret, <roleName type="kin" corresp="pe__albrecht_herzog_von_oesterreich_QGW_II_I_596">tochter</roleName>
                        <rs type="person" ref="pe__albrecht_herzog_von_oesterreich_QGW_II_I_596"><roleName type="occ" corresp="org__oesterreich-herzogtum">herzog</roleName> Albrechts <roleName type="dead">seligen</roleName>
                           tochter in Osterreich</rs>, <roleName type="occ" corresp="org__wien-st_jakob_auf_der_huelben">maistrin</roleName></rs>,
                     und der <rs type="org" ref="org__wien-st_jakob_auf_der_huelben">convent gemain
                        der geistleichen vrowen chloster dacz sande Jacob auf der Hülben ze
                        Wienne</rs></rs>
                  <triggerstring n="disp">bestätigen</triggerstring>, dass <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_von_joching_QGW_II_I_556">Jans von
                        Jeuchingen, <roleName type="occ" corresp="org__wien">purger</roleName>
                        ze Wienne</rs>, und seine <rs type="person" ref="pe__elisabeth_QGW_II_I_556"><roleName type="kin" corresp="pe__johann_von_joching_QGW_II_I_556">Hausfrau</roleName> Elsbet</rs></rs> nach dem Gebote Herzog Rudolfs IV.
                  4 lb dn. gelts ewigs purchrechts von ihrem Hause, gelegen hinder der Slachstuben
                  ze Wienne, das weilnt hern Perichtolts des Pollen gewesen ist, dem got gnad,
                  zenachst dem haus, das weilnt Ulreichs des Pollen gewesen ist, und ist das ekhaus,
                  das da get an aim tail hinden gegen dem Chamerhof uber und mit dem andern tail
                  gegen Jacobs haus über, des leinwoter , um 32 lb dn. abgelöst haben.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_556"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="org" ref="org__wien-st_jakob_auf_der_huelben">1. des
                        Conventes</rs>, <rs type="person" ref="pe__peter_kolein_QGW_II_I_556">2.
                           <roleName type="title">hern</roleName> Petreins des Kolein, <roleName type="occ" corresp="org__wien-st_jakob_auf_der_huelben-messe_hermann_von_st_poelten">chaplan</roleName> und <roleName type="occ" corresp="org__wien-st_jakob_auf_der_huelben-messe_hermann_von_st_poelten">Ver weser</roleName> der von <rs type="person" ref="pe__hermann_von_st_poelten_QGW_II_I_61"><roleName type="title">hern</roleName> Herman von Sande Polten</rs> im Kloster gestifteten
                        Messe, welcher von dem Burgrechte 3 lb dn. innegehabt hatte</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>