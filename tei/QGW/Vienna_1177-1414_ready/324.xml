               <rs type="event" ref="ev__QGW_II_I_324"><rs type="fn" role="issuer"><rs type="person" ref="pe__hartwig_QGW_II_I_324">Hertweich, <roleName type="occ" corresp="org__rein-zisterzienser">abt</roleName> ze Reun</rs>, und der
                        <rs type="org" ref="org__rein-zisterzienser">convent daselben</rs></rs>
                  <triggerstring n="disp">beurkunden</triggerstring>, dass sie dem <rs type="fn" role="recipient"><rs type="person" ref="pe__leb_nussdorfer_QGW_II_I_401">Wiener<roleName type="occ" corresp="org__wien">Bürger</roleName> Leon dem
