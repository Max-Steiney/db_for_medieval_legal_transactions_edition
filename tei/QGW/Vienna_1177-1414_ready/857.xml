                     <triggerstring n="fn">mit Vorsprechen</triggerstring></rs>
                  <rs type="fn" role="other"><triggerstring n="fn">gegen</triggerstring>
                     <rs type="person" ref="pe__johann_schindler_QGW_II_I_857">Janns den Schindler</rs></rs>
