                        <roleName type="rep" corresp="pe__schweigmut_QGW_II_I_1183"><add>anstatt</add></roleName>
                        <roleName type="rep" corresp="pe__kunigunde_QGW_II_I_1183"><add>anstatt</add></roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__johann_von_eslarn_QGW_II_I_1020">Hannsen von Eslarn, <roleName type="occ" corresp="org__wien">statrichter</roleName> ze Wienn und
