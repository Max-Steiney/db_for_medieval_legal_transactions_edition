               <rs type="event" ref="ev__QGW_II_I_77"><rs type="fn" role="issuer"><rs type="person" ref="pe__christine_QGW_II_I_77">Christein,<roleName type="kin" corresp="pe__leopold_sluessler_QGW_II_I_77_a"><add>witiwen</add></roleName>
                        <rs type="person" ref="pe__leopold_sluessler_QGW_II_I_77_a"><roleName type="title">hern</roleName> Leupoldes <roleName type="dead">witiwen</roleName> des Sluz/zler</rs></rs>, <rs type="person" ref="pe__leopold_sluessler_QGW_II_I_77_b">Leupolt, ir <roleName type="kin" corresp="pe__christine_QGW_II_I_77"><add>sun</add></roleName>
                        <roleName type="kin" corresp="pe__leopold_sluessler_QGW_II_I_77_a">sun</roleName></rs>, und <rs type="person" ref="pe__margarethe_QGW_II_I_77_a">Margret, dessen <roleName type="kin" corresp="pe__leopold_sluessler_QGW_II_I_77_b">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen mit gesammter
                     Hand</triggerstring> und<rs type="fn" role="other">
                     <triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__johann_QGW_II_I_80">des <roleName type="occ" corresp="org__wien-schotten">Abtes</roleName> Johans dacz den Schotten,
                        als <roleName type="title">Grundherrn</roleName></rs></rs>,<triggerstring n="disp"> aus ehafter Noth </triggerstring><rs type="fn" role="other"><triggerstring n="fn">wegen grosser Schulden</triggerstring>, die sie für ihren <rs type="person" ref="pe__peter_ponhalm_QGW_II_I_77"><roleName type="kin" corresp="pe__christine_QGW_II_I_77">Eidam</roleName>
                        <roleName type="kin" corresp="pe__leopold_sluessler_QGW_II_I_77_b"><add>Eidam</add>
                        </roleName>
                        <roleName type="kin" corresp="pe__margarethe_QGW_II_I_77_a"><add>Eidam</add></roleName>Petren den Ponhalm von Steyre</rs> und <rs type="person" ref="pe__margarethe_QGW_II_I_77_b">seine <roleName type="kin" corresp="pe__peter_ponhalm_QGW_II_I_77">Hausfrau</roleName> Margret</rs>
                     <triggerstring n="fn">gelten sollen</triggerstring></rs>, von ihrem Erbgute einen
                  Baumgarten in der Schottenawe gegenüber dem Tuerngarten, genannt der Sluz/zler,
                  umb 25 lb dn. an 30 dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__otto_giesser_QGW_II_I_77">Otten dem Giez/zz/zer</rs> und <rs type="person" ref="pe__bertha_QGW_II_I_77">Perhte, seiner <roleName type="kin" corresp="pe__otto_giesser_QGW_II_I_77">Hausfrau</roleName></rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_77"><rs type="fn" role="witness">Siegler: <rs type="person" ref="pe__leopold_sluessler_QGW_II_I_77_b">1. Leupolt der
