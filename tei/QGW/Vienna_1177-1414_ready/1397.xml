            <placeName>Wien</placeName>
            <date when="13980626">1398 VI 26</date>
            <origDate instant="false">ze Wienn, des nachsten mittichens nach sand Johanns tag zu
               Sunbenden.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01397_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01397_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1397"><rs type="fn" role="issuer"><rs type="person" ref="pe__jakob_guens_ii_QGW_II_I_1397">Jacob der Günser, <roleName type="occ" corresp="org__wien">purger</roleName> zu Wienn</rs>, und
                        <rs type="person" ref="pe__anna_QGW_II_I_1397">Ann, seine <roleName type="kin" corresp="pe__jakob_guens_ii_QGW_II_I_1397">Hausfrau</roleName></rs></rs>,
                     <triggerstring n="disp">verpfänden</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="pe__heinrich_QGW_II_I_1385"><roleName type="title">Grundherrn</roleName>, des <roleName type="occ" corresp="org__wien-schotten">Schottenabtes</roleName>
                        <roleName type="title">hern</roleName> Hainreichs</rs></rs>, das Haus,
                  gelegen in der Strauchgassen zenägst hern Hertleins haus des Losenstainer, <rs type="event" ref="ev__QGW_II_I_1397_men_1">von dem man den Schotten 81 dn. zu Grundrecht und hern
                     Hannsen, chaplan Unser Fraun altar, gelegen in der pharrchirchen dacz sand
                     Stephan ze Tulln , 4 lb dn. zu Burgrecht dient</rs>, für 69 lb dn., <rs type="event" ref="ev__QGW_II_I_1397_men_2">welche von dem Verkaufe des Hauses, gelegen in der
                     Strauchgassen zenechst dem haus, das weilnt Marcharts seligen des Hausleiter
                     gewesen ist , herrühren</rs>, <rs type="event" ref="ev__QGW_II_I_1397_men_3">das Jacob mit seiner
                        <rs type="person" ref="pe__katharina_QGW_II_I_1397"><roleName type="dead">früheren</roleName>
                        <roleName type="kin" corresp="pe__jakob_guens_ii_QGW_II_I_1397">Frau</roleName>
                        Kathrei</rs> gekauft und nach deren Tod zu Leibgeding innehatte</rs>. Die 69
                  lb dn. sollen nunmehr auf dem erstgenannten Hause zu seinem Leibgeding liegen
                  bleiben, nach seinem Tode aber an seine und der Kathrei nächste Erben
               fallen.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1397"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="pe__jakob_guens_ii_QGW_II_I_1397">Ausstellers</rs> und
                     des <rs type="person" ref="pe__heinrich_QGW_II_I_1385">Grundherrn</rs></rs>.</rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>