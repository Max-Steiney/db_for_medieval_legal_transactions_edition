            <placeName>Wien</placeName>
            <date when="13801212">1380 XII 12</date>
            <origDate instant="false">ze Wienne, an sand Lucen abend, der heiligen
            junchvrowen.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00995_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00995_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="ev__QGW_II_I_995"><rs type="fn" role="issuer"><rs type="person" ref="pe__thomas_raedler_QGW_II_I_1014">Thoman der Redler <roleName type="occ" corresp="org__wien"><add>purger</add></roleName></rs>, <rs type="person" ref="pe__johann_von_st_leonhard_QGW_II_I_995">Janns von Sand Lienhart <roleName type="occ" corresp="org__wien"><add>purger</add></roleName></rs>,
                        <rs type="person" ref="pe__jakob_von_leiss_QGW_II_I_966">Jacob von Leiz/zz/ze <roleName type="occ" corresp="org__wien"><add>purger</add></roleName></rs>
                     und <rs type="person" ref="pe__eberhard_von_neuburg_QGW_II_I_1018">Eberhart von Neunburkch,
                        alle <roleName type="occ" corresp="org__wien">purger ze
                           Wienne</roleName></rs></rs> , <triggerstring n="disp">fällen in dem
                     Streite</triggerstring>
                  <rs type="fn" role="other">
                     <triggerstring n="fn">zwischen</triggerstring> dem <rs type="person" ref="pe__stephan_naezeuger_QGW_II_I_1011"><roleName type="occ" corresp="org__wien">Wiener Bürger</roleName> Stephann dem Nezeuger</rs></rs> und <rs type="fn" role="other"><triggerstring n="fn"><add>zwischen</add></triggerstring>
                     seiner <rs type="person" ref="pe__anna_QGW_II_I_995"><roleName type="kin" corresp="pe__stephan_naezeuger_QGW_II_I_1011">swiger vrown</roleName> Annen<roleName type="kin" corresp="pe__ulrich_helbling_QGW_II_I_773"><add>wittibe</add></roleName></rs></rs>, <rs type="person" ref="pe__ulrich_helbling_QGW_II_I_773"><roleName type="dead">wittibe</roleName> Ulreichs des
                     Helblings</rs> , wegen der 56 lb dn., <rs type="event" ref="ev__QGW_II_I_995_men_1">für welche
                     Anna ihrem Eidam ihren Anspruch und ihr Warterecht an den zwei Weingärten
                     verkauft hatte</rs>, ainer gelegen zu Grinzing, genant der Gern, des ein halbs
                  jeuch ist zenest des pharrer weingarten von Ottenhaim, der da haisset der Scherg,
                  so leit der ander weingarten in dem Mukkental, des anderthalb virtail ist,
                  zenechst Jacobs weingarten des Chettner , <triggerstring n="disp">folgende
                     Entscheidung</triggerstring>: <rs type="fn" role="recipient"><rs type="person" ref="pe__anna_QGW_II_I_995">Anna</rs></rs>, welche den Kauf nicht
                  anerkennen, aber auch die 56 lb dn. nicht zurückgeben will, soll ihren Eidam für
                  die 56 lb dn. <triggerstring n="disp">schadlos halten</triggerstring> mit 14 Fuder und 2
                  Dreiling Wein, <rs type="event" ref="ev__QGW_II_I_995_men_2">die ihr der Rath zu einem Pfande
                     gespent hatte</rs>, <rs type="fn" role="recipient"><rs type="person" ref="pe__stephan_naezeuger_QGW_II_I_1011">Stephan</rs></rs> aber <triggerstring n="disp">die
                     beiden Weingärten zu Leibgeding innehaben</triggerstring>. Nach seinem Tode sollen
                  die Weingärten dahin fallen, wohin sie gehören. Wer den Spruch nicht hält, soll,
                  zum Bau der prukke vor Kernertor 50 lb dn. und jedem der Spruchleute 10 lb dn.
                  zahlen.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_995"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__thomas_raedler_QGW_II_I_1014">Thomans des Redler</rs>
                     und <rs type="person" ref="pe__johann_von_st_leonhard_QGW_II_I_995">Hannsens von Sant
                        Lienhart</rs></rs>. </rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>