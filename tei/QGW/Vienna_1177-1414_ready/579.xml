                  , <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring><rs type="person" ref="pe__johann_urbetsch_QGW_II_I_501"> seines <roleName type="title">Bergherrn</roleName>
