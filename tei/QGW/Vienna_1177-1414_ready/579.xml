               <rs type="event" ref="ev__QGW_II_I_579"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_QGW_II_I_579">Jans, der <roleName type="prof">priester</roleName>,<roleName type="kin" corresp="pe__ruediger_wiersing_QGW_II_I_579"><add>sun</add></roleName><rs type="person" ref="pe__ruediger_wiersing_QGW_II_I_579"> Rugern des
