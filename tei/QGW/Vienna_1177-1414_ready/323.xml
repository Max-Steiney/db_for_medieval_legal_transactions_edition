            <date when="13480815">1348 VIII 15</date>
            <origDate instant="false">ze Wienn, an Unser Vrowen tag ze der schidung.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00323_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00323_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="ev__QGW_II_I_323"><rs type="fn" role="issuer"><rs type="person" ref="pe__berthold_geukramer_QGW_II_I_115">Perchtolt der Geuchramer, <roleName type="occ" corresp="org__wien-st_stephan">chirchmaister</roleName> dacz sand Stephan
                        ze Wienn</rs></rs>, <triggerstring n="disp">widmet</triggerstring> unter Berufung
                  auf sein Geschäft ( als ich der purger prief daruber han mit irem grossen insigel)
                  12 lb dn. purchrechtes, der 5 lb dn. ligent auf des Hainreichs des Wechsleins haus
                  und auf der metgrueb an dem Liechtensteg und 7 lb dn. auf Jansen haus des
                  Tekkendorfer in der Wolzeil , zu einer <rs type="fn" role="recipient"><rs type="org" ref="org__wien-st_stephan-kapelle_st_katharina-altar_st_katharina-messe_geukramer">ewigen Messe, di man
                        taegleich lesen schol in sand Stephanschirchen auf <rs type="org" ref="org__wien-st_stephan-kapelle_st_katharina-altar_st_katharina">sand Kathrein alter pei der
                           Zwelifpoten tu/er</rs></rs></rs> , den er selbst mit seinem Gute
                  gestiftet und erbaut habe, deren Verleihung seinen beiden <rs type="fn" role="recipient"><rs type="person" ref="pe__michael_geukramer_QGW_II_I_323"><roleName type="kin" corresp="pe__berthold_geukramer_QGW_II_I_115">Söhnen</roleName><roleName type="occ" corresp="org__wien-st_stephan-kapelle_st_katharina-altar_st_katharina-messe_geukramer"><add>Lehensherr</add></roleName> Michhel</rs> und <rs type="person" ref="pe__johann_geukramer_QGW_II_I_323"><roleName type="kin" corresp="pe__berthold_geukramer_QGW_II_I_115"><add>Sohn</add></roleName><roleName type="occ" corresp="org__wien-st_stephan-kapelle_st_katharina-altar_st_katharina-messe_geukramer"><add>Lehensherr</add></roleName>Jans</rs></rs> und deren Erben
                  zustehen solle. Er <triggerstring n="disp">widmet</triggerstring> ferner 17 sh. dn.
                  purchrehts, di da ligent auf drin haeusern pei dem Radprunn, davon man den alter
                  beleuchten schol mit oel und mit wachs und auch davon man das messgewant und di
                  altertuecher pessern schol .</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_323"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="pe__berthold_geukramer_QGW_II_I_115">Ausstellers</rs>, 2. <rs type="person" ref="pe__otto_gnaemhertel_QGW_II_I_150"><roleName type="title">hern</roleName> Otten des Gnemhertlein, <roleName type="occ" corresp="org__wien-st_maria_am_gestade">pharrer</roleName> und <roleName type="occ" corresp="org__wien-st_maria_am_gestade">chaplan</roleName>
                        Unser Vrowen auf der Stetten</rs>, 3. <rs type="person" ref="pe__johann_poll_QGW_II_I_850"><roleName type="title">hern</roleName>
                        Jansen des Pollen</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>