        <date when="13490824">1349 VIII 24</date>
        <origDate instant="false">ze Wienne, an sand Bartholomes tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00342_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00342_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
          <rs type="event" ref="ev__QGW_II_I_342"><rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_pukkas_QGW_II_I_951">Ulreich von dem Pukgas</rs></rs>
            <triggerstring n="disp">beurkundet seinen letzten Willen</triggerstring>. Er <triggerstring n="fn">schafft</triggerstring> seinen Weingarten, gelegen ze Grinzing und haisset der
            Scherig, des dreu viertail sind, <triggerstring n="disp">zu einer ewigen Messe</triggerstring>
            in die <rs type="fn" role="recipient"><rs type="org" ref="org__wien-st_maria_im_rathaus">chapelln Unser Vrowen in der purger Rathaus ze Wienne, hern Otten Haimen
                stiftung</rs></rs>,<triggerstring n="impl_rules"> die der Kaplan und Verweser her Jacob
              der Polle im Einvernehmen mit dem Oheim des Ausstellers Jansen dem Minngang einem
              ehrbaren Priester zu verleihen habe</triggerstring>. Ueber sein Haus, das da leit in der
            Vodern Pekchenstrasse ze Wienne zenaehst dem haus, das hern, Jansen des Rogner gewesen
            ist , und 1 ½ Joch Weingarten, der da leit ze Haekkingen und haisset der Twerich,
            verfügt er in der Weise, dass <rs type="fn" role="recipient"><rs type="person" ref="pe__gottfried_lantsidler_QGW_II_I_342">sein <roleName type="kin" corresp="pe__ulrich_pukkas_QGW_II_I_951">Eidam</roleName> Gotfrit der Lantsidler
                von Amberch</rs> und <rs type="person" ref="pe__elisabeth_QGW_II_I_342">dessen
                  <roleName type="kin" corresp="pe__gottfried_lantsidler_QGW_II_I_342">Frau</roleName> Elsbet</rs></rs> beides innehaben sollen <triggerstring n="impl_rules">bis zum Tode der Elsbet</triggerstring>, wogegen sie jährlich den
              Dürftigen<rs type="fn" role="recipient">
              <rs type="org" ref="org__wien-buergerspital">in dem Bürgerspital</rs></rs> 4 ½ lb dn.
            zu einem Mahle und den Priestern daselbst ½ lb dn. <triggerstring n="impl_rules">zur
              Abhaltung eines Jahrtages zu reichen haben</triggerstring>.</rs>
        </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_342"><rs type="fn" role="witness">Besiegelt mit den
              Siegeln: <rs type="person" ref="pe__heinrich_gausrabe_QGW_II_I_789">1. <roleName type="title">hern</roleName> Hainreichs des Gausraben</rs>, <rs type="person" ref="pe__michael_poll_QGW_II_I_440">2. Michels des Pollen</rs>.</rs></rs>
        </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>