            <origDate instant="false">Der brief ist geben ze Wienn nach Christes gepurd 1300 iar darnach in dem 73.
               jar, des nêchsten freitags nach dem heiligen Weihennacht tag. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00823_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00823_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_823">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__johann_schuetzenmeister_QGW_II_I_815">Janns der Schützenmaister</rs></rs>
                  <triggerstring n="disp">bestätigt</triggerstring>, dass er <rs type="fn" role="recipient"><rs type="person" ref="pe__jakob_poll_QGW_II_I_770"><roleName type="title">hern</roleName> Jacoben dem Pollen, <roleName type="occ" corresp="org__wien-st_maria_im_rathaus">chaplan</roleName> der
                        chapellen Unser Frown in dem alten Rathous ze Wienne, hern Ottenhaimen
                        seligen Stiftung</rs></rs>, 14 lb dn. geltes purchrechts auf seinem Hause,
                  gelegen in der Münzerstrasse ze Wienne zenêchst hern Hermans haus von Eslarn und
                  stosset hinden an den Chamerhof, <triggerstring n="disp">verkauft und solange
                     versessen habe</triggerstring>, <rs type="event" ref="ev__QGW_II_I_823_men_1">dass das Haus vor
                     offenem Gerichte in der Bürgerschranne der <rs type="org" ref="org__wien-st_maria_im_rathaus">Kapelle</rs> zugesprochen wurde</rs>.
                     <rs type="event" ref="ev__QGW_II_I_823_men_2">Da Jakob der Poll das Haus, nachdem er es vorher
                     ihm angeboten hatte, <rs type="person" ref="pe__ulrich_zinkk_QGW_II_I_1066a">Ulreichen dem
                        Zinken</rs> und seiner <rs type="person" ref="pe__katharina_QGW_II_I_823"><roleName type="kin" corresp="pe__ulrich_zinkk_QGW_II_I_1066a">Hausfrau</roleName>
                        Katrein</rs> verkauft hat</rs>, so <triggerstring n="disp">verzichtet er auf
                     allen Anspruch</triggerstring> an dasselbe.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_823"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="pe__johann_schuetzenmeister_QGW_II_I_815">Ausstellers</rs>, 2. <rs type="person" ref="pe__johann_von_pergau_QGW_II_I_1130"><roleName type="title">maister</roleName> Johannsen von Pergow,
                        Chorherren ze Paz/zz/zow, <roleName type="occ" corresp="org__passau-dioezese">bischof Albrechts ze Paz/zz/zow official
                           in geistleichen Sachen in Österreich</roleName></rs>, 3 . des<rs type="person" ref="pe__jakob_graf_QGW_II_I_1122">
                        <roleName type="kin" corresp="pe__johann_schuetzenmeister_QGW_II_I_815">Schwagers</roleName> des Ausstellers Jacoben des Grafen</rs>, 4. seines
                        <rs type="person" ref="pe__johann_jan_QGW_II_I_1085"><roleName type="kin" corresp="pe__johann_schuetzenmeister_QGW_II_I_815">Oheims</roleName> Jannsens des
                        Janen</rs></rs>.</rs>
            </p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>