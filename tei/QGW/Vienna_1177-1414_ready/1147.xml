   <text>
      <body>
         <div type="abstract" resp="cs">
            <p><rs type="event" ref="ev__QGW_II_I_1147"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__jakob_schmied_QGW_II_I_1147">Jacob, der <roleName
                           type="prof">smied</roleName> von Fe/andorf</rs></rs>, <triggerstring
                     n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__michael_geukramer_QGW_II_I_1137"><roleName
                           type="title">hern</roleName> Michels des Geuchramer, <roleName type="occ"
                           corresp="org__wien">purgermaister</roleName> und <roleName type="occ"
                           corresp="org__oesterreich-herzogtum" select="pl__wien"
                           >munzmaister</roleName></rs>, und des <rs type="org" ref="org__wien"
                        >rates gemain der stat ze Wienn</rs></rs> 10 sh. dn. ablösbaren geltes
                  purkrechts auf seinem Hause, <rs type="event" ref="ev__QGW_II_I_1047_men_1">das er
                     und seine <rs type="person" ref="pe__brigitta_QGW_II_I_1147"><roleName
                           type="dead">frühere</roleName>
                        <roleName type="kin" corresp="pe__jakob_schmied_QGW_II_I_1147"
                           >Hausfrau</roleName> Preid</rs> miteinander gekauft hatten</rs>, <rs
                     type="event" ref="ev__QGW_II_I_1047_men_2">und das er von jedem Ansprüche der
                     Erben seiner verstorbenen Frau gelöst hatte</rs>, gelegen vor Stubentor ze
                  Wienn zenechst Merten haus des Vingerler, von dem man den geistlichen Frauen dacz
                  sand Jacob auf der Hülben ze Wienn ½ lb dn., dem Wiener Bürger Wolfharten dem
                  Poben ½ lb dn., den geistlichen Frauen hinz sand Niclas vor Stubentor ½ lb dn. zu
                  Burgrecht dient, <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__kaspar_QGW_II_I_1147">Casparn <roleName type="kin"
                           corresp="pe__konrad_semmelzipf_QGW_II_I_1147"><add>unmündigen
                              Kindern</add></roleName></rs> und <rs type="person"
                        ref="pe__barbara_QGW_II_I_1147">Barbaren, den <roleName type="kin"
                           corresp="pe__konrad_semmelzipf_QGW_II_I_1147">unmündigen
                           Kindern</roleName></rs></rs>, <rs type="person"
                     ref="pe__konrad_semmelzipf_QGW_II_I_1147">Chunrads des Semelziphs von
                     Fe/andorf</rs> um 10 lb: dn., <rs type="event" ref="ev__QGW_II_I_1047_men_3"
                     >wovon 8 lb dn. aus dem Erlöse für ein Haus herrühren, das <rs type="person"
                        ref="pe__niklas_schmied_QGW_II_I_1147">Niclasen, dem <roleName type="prof"
                           >smid</roleName></rs>, und semer <rs type="person"
                        ref="pe__agnes_QGW_II_I_1147"><roleName type="kin"
                           corresp="pe__niklas_schmied_QGW_II_I_1147">Hausfrau</roleName>
                        Agnesen</rs> verkauft worden war</rs>.</rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_I_1147"><rs type="fn" role="witness">Besiegelt : 1.
                     mit dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs>, 2. dem
                     Siegel des <rs type="person" ref="pe__pilgrim_snaeczl_QGW_II_I_1015">Wiener
                           <roleName type="occ" corresp="org__wien">Bürgers</roleName>
                        <roleName type="title">hern</roleName> Pilgreims des
                  Sneczlein</rs></rs>.</rs></p>
         </div>
