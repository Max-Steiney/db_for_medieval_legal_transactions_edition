          zwaihundert iar an dem dritten und neunzigisten iar. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00021_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00021_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p><rs type="event" ref="ev__QGW_II_I_21"><rs type="fn" role="issuer"><rs type="person" ref="pe__jakob_QGW_II_I_21_a">Jacob <roleName type="kin" corresp="pe__ernst_QGW_II_I_21_a"><add>sun</add></roleName>
                <roleName type="occ" corresp="org__wien"><add>purger</add></roleName></rs> und
                <rs type="person" ref="pe__heinrich_QGW_II_I_21_a">Hainreich, <rs type="person" ref="pe__ernst_QGW_II_I_21_a"><roleName type="title">hern</roleName> Ernstes</rs>
                <roleName type="kin" corresp="pe__ernst_QGW_II_I_21_a">sun</roleName> und <roleName type="occ" corresp="org__wien">purger</roleName> ze Wienn</rs></rs>,
              <triggerstring n="disp">bezeugen</triggerstring>, <rs type="fn" role="recipient"><add>
                <rs type="person" ref="pe__euphemia_QGW_II_I_21">Offmein</rs><rs type="org" ref="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">samnung von S.
                  Niklas zu Wien</rs></add></rs>
            <rs type="event" ref="NULL">dass sie, und zwar <rs type="fn" role="issuer"><rs type="person" ref="pe__jakob_QGW_II_I_21_a">Jakob nach seiner <rs type="person" ref="pe__gertrud_QGW_II_I_21_c">ersten <roleName type="kin" corresp="pe__jakob_QGW_II_I_21_a">Frau</roleName> Gerdrout <roleName type="dead">Tode</roleName></rs></rs> und <rs type="person" ref="pe__heinrich_QGW_II_I_21_a">Heinrich</rs></rs> mit <rs type="fn" role="other">seiner <rs type="person" ref="pe__gertrud_QGW_II_I_21_d"><roleName type="kin" corresp="pe__heinrich_QGW_II_I_21_a">Frau</roleName> Gerdrout</rs>
                <triggerstring n="fn">verhanchnusse</triggerstring></rs> und beide <rs type="fn" role="other"><triggerstring n="fn">mit</triggerstring> ihrer <rs type="person" ref="pe__elisabeth_QGW_II_I_21"><roleName type="kin" corresp="pe__heinrich_QGW_II_I_21_a">Schwestern</roleName>
                  <roleName type="kin" corresp="pe__jakob_QGW_II_I_21_a"><add>Schwestern</add></roleName> Elspet</rs> und <rs type="person" ref="pe__margarethe_QGW_II_I_21_a">Margret <roleName type="kin" corresp="pe__heinrich_QGW_II_I_21_a"><add>Schwestern</add></roleName>
                  <roleName type="kin" corresp="pe__jakob_QGW_II_I_21_a"><add>Schwestern</add></roleName></rs>, sowie ihrer Erben, und zwar derer
                Jakobs: <rs type="person" ref="pe__jakob_QGW_II_I_21_b"><roleName type="kin" corresp="pe__jakob_QGW_II_I_21_a"><add>Erben</add></roleName> Jacob</rs>, <rs type="person" ref="pe__kunigunde_QGW_II_I_21"><roleName type="kin" corresp="pe__jakob_QGW_II_I_21_a"><add>Erben</add></roleName> Chunegunten</rs>,
                  <rs type="person" ref="pe__margarethe_QGW_II_I_21_b"><roleName type="kin" corresp="pe__jakob_QGW_II_I_21_a"><add>Erben</add></roleName> Margreten</rs> und
                  <rs type="person" ref="pe__gertrud_QGW_II_I_21_a"><roleName type="kin" corresp="pe__jakob_QGW_II_I_21_a"><add>Erben</add></roleName> Gerdrouten</rs>,
                sowie derer Heinrichs: <rs type="person" ref="pe__heinrich_QGW_II_I_21_b"><roleName type="kin" corresp="pe__heinrich_QGW_II_I_21_a"><add>Erben</add></roleName>
                  Heinreichs</rs>, <rs type="person" ref="pe__jakob_QGW_II_I_21_c"><roleName type="kin" corresp="pe__heinrich_QGW_II_I_21_a"><add>Erben</add></roleName>
                  Jacobs</rs>, <rs type="person" ref="pe__ernst_QGW_II_I_21_b"><roleName type="kin" corresp="pe__heinrich_QGW_II_I_21_a"><add>Erben</add></roleName> Ernstes</rs>
                und <rs type="person" ref="pe__dietrich_QGW_II_I_21"><roleName type="kin" corresp="pe__heinrich_QGW_II_I_21_a"><add>Erben</add></roleName>
                Dietreichs</rs>, <rs type="person" ref="pe__katharina_QGW_II_I_21"><roleName type="kin" corresp="pe__heinrich_QGW_II_I_21_a"><add>Erben</add></roleName>
                  Kathrein</rs>, <rs type="person" ref="pe__margarethe_QGW_II_I_21_c"><roleName type="kin" corresp="pe__heinrich_QGW_II_I_21_a"><add>Erben</add></roleName>
                  Margreten</rs> und <rs type="person" ref="pe__gertrud_QGW_II_I_21_b"><roleName type="kin" corresp="pe__heinrich_QGW_II_I_21_a"><add>Erben</add></roleName>
                  Gerdrouten</rs>, <triggerstring n="fn">Zustimmung</triggerstring></rs>, <rs type="fn" role="recipient">der <rs type="person" ref="pe__euphemia_QGW_II_I_21"><roleName type="occ" corresp="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">Aebtissin</roleName>
                  <roleName type="title">vern</roleName> Offmein</rs> und der <rs type="org" ref="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">samnung von S.
                  Niklas zu Wien</rs></rs> eine Gült von 17 sh. dn. auf einem Lehen zu Ebersdorf,
              von dem man ausserdem ze weised an dem heiligen Abend zu Ostern zwei Lammsbäuche im
              Werthe von 24. dn., zwei Käse im Werthe von 6 dn. und 40 Eier dient, um 19 lb und 5
              dn. <triggerstring n="disp">verkauft</triggerstring> haben.</rs></rs>
        </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_21"><rs type="fn" role="witness">Siegler: die beiden
                <rs type="person" ref="pe__jakob_QGW_II_I_21_a">Aussteller</rs>
