               <rs type="event" ref="ev__QGW_II_I_1617"><rs type="person" ref="pe__siegfried_rorbekch_QGW_II_I_1617">Seifrid der Rorbekk, <roleName type="occ" corresp="org__wien">burger</roleName> ze Neunburg
                     markthalben</rs>, <triggerstring n="disp">verkauft</triggerstring>
                  <triggerstring n="fn">mit Handen</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="pe__heinrich_falkenberger_StB_I_170">seines <roleName type="title">Grundherrn</roleName> Hainreichs des Valkenperger, <roleName type="occ" corresp="org__klosterneuburg">statrichter</roleName> daselbst</rs>,</rs>
