            <origDate instant="false">ze Wienn, an dem heiligen Auffart abende.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01148_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01148_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1148"><rs type="fn" role="issuer"><rs type="person" ref="pe__peter_kremser_QGW_II_I_1148">Peter der Chremser, der <roleName type="prof">schuster</roleName> ze Wienn</rs>, und <rs type="person" ref="pe__christine_QGW_II_I_1148">Kristein, seine <roleName type="kin" corresp="pe__peter_kremser_QGW_II_I_1148">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">bestätigen</triggerstring>, dass sie <rs type="fn" role="recipient"><rs type="person" ref="pe__georg_wasserknecht_QGW_II_I_1148">Jörgen, <rs type="person" ref="pe__friedrich_wasserknecht_QGW_II_I_1148">Fridreichs <roleName type="dead">seligen</roleName> des Waz/zz/zerchnechts</rs>
                        <roleName type="kin" corresp="pe__friedrich_wasserknecht_QGW_II_I_1148">bruder
                           sun</roleName>, der noch zu seinen beschaiden jarn nicht chomen
                     ist</rs></rs> , 7 lb dn. schulden, welche aus dem Erlöse für ein Haus, gelegen
                  in der Kernerstrasse ze Wienn, das an seiner Statt <rs type="person" ref="pe__heinrich_QGW_II_I_1148">Hainreichen <roleName type="kin" corresp="pe__ulrich_von_muenster_QGW_II_I_1148"><add>kindern</add></roleName></rs> und <rs type="person" ref="pe__anna_QGW_II_I_1148">Annen <roleName type="kin" corresp="pe__ulrich_von_muenster_QGW_II_I_1148"><add>kindern</add></roleName></rs>, <rs type="person" ref="pe__ulrich_von_muenster_QGW_II_I_1148">Ulreichs kindern von Münzster</rs>,
                  verkauft worden ist, herrühren, und welche den Käufern zu Ebenteuer und Schirm
                  dienen sollen, <triggerstring n="disp">und verpfänden dafür</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__michael_geukramer_QGW_II_I_1137"><roleName type="title">hern</roleName> Michels des Geuchramer, <roleName type="occ" corresp="org__wien">purgermaister</roleName> und <roleName type="occ" corresp="org__oesterreich-herzogtum" select="pl__wien">münzmaister</roleName></rs>, und des <rs type="org" ref="org__wien">rates gemain der stat ze Wienn</rs></rs>
                  ihr Haus, gelegen auf dem Steig bei Stubentor ze
                  Wienn zenechst dem haus, das weilnt der Pymirinne gewesen ist, von dem man den
                  geistlichen Herren dacz den Predigern 4 lb dn. zu Burgrecht dient.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1148"><rs type="fn" role="witness">Besiegelt : 1.
                     mit dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs>, 2. dem
                     Siegel des <rs type="person" ref="pe__ulrich_herwart_QGW_II_I_1098"><roleName type="occ" corresp="org__wien">Stadtschreibers</roleName> Ulreichs des
                     Herwarts</rs></rs>.</rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>