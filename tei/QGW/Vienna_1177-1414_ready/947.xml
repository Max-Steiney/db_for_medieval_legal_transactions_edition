               <rs type="event" ref="ev__QGW_II_I_947"><rs type="fn" role="issuer"><rs type="person" ref="pe__georg_parschenbrunner_QGW_II_I_846">Jorig der Parrssenprunner, <roleName type="occ" corresp="org__frauendorf-pfarre">pharrer</roleName> ze
