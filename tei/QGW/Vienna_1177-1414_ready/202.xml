            <origDate instant="false">ze Wienne, an sande Niclas tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00202_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00202_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="ev__QGW_II_I_202"><rs type="fn" role="issuer"><rs type="person" ref="pe__otaker_QGW_II_I_202">Otacher, <rs type="person" ref="pe__tonigl_QGW_II_I_202">des Tonigleins <roleName type="kin" corresp="pe__otaker_QGW_II_I_202">aidem</roleName>,</rs></rs> und
                        <rs type="person" ref="pe__katharina_QGW_II_I_202">Katrei, seine <roleName type="kin" corresp="pe__otaker_QGW_II_I_202">Hausfrau</roleName>,</rs></rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihrer <rs type="person" ref="pe__vromut_von_kaja_QGW_II_I_199"><roleName type="title">Grundfrau</roleName> Vromu/eden von Cheiawe, <roleName type="occ" corresp="org__tulln-dominikanerinnen">priolinne</roleName> in <rs type="org" ref="org__tulln-dominikanerinnen">Vrowenchloster ze
                           Tulln,</rs></rs></rs> 1 lb dn. <triggerstring n="disp">gelts ewiges
                     purchrechts</triggerstring> auf ihrem Hause, das da leit an der Stiege, und das
                  weilent hern Wilhalms an der Stieg gewesen ist, zenaest Pilgreims haus, des
                  saltzhacher , von dem man jährlich den vrowen von Tulln 12 dn. Grundrecht und 1 lb
                  dn. Burgrecht dient, um 7 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__berthold_poll_QGW_II_I_121"><roleName type="title">hern</roleName>
                        Perichtolten dem Pollen, <roleName type="occ" corresp="org__wien">purgermaister</roleName> ze Wienne,</rs> und <rs type="person" ref="pe__margarethe_QGW_II_I_182">seiner <roleName type="kin" corresp="pe__berthold_poll_QGW_II_I_121">Hausfrau</roleName>
                  Margret.</rs></rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_202"><rs type="fn" role="witness">Besiegelt mit den Siegeln:
                        <rs type="person" ref="pe__otaker_QGW_II_I_202">1. des Ausstellers,</rs>
                     <rs type="person" ref="pe__vromut_von_kaja_QGW_II_I_199">2. der Grundfrau,</rs>
                     <rs type="person" ref="pe__jakob_maeserl_QGW_II_I_121">3. <roleName type="title">hern</roleName> Jacobs des Meserlein.</rs></rs></rs>
            </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. E. XI. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>