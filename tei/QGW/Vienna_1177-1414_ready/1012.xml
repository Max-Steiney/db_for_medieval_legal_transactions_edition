            <date from="99999999" to="99999999"/>
            <origDate instant="false">ze Wienne, des nachsten phinztags nach, sand Matheus tage, des heiligen
               zwelfpoten und evangelisten. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01012_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01012_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1012">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__paul_holzkaeufel_QGW_II_I_1010">Paul der
                        Holzchauffel, <roleName type="occ" corresp="org__wien">purgermaister</roleName></rs> , <rs type="person" ref="pe__stephan_leitner_QGW_II_I_1012">Stephan Leitner, <roleName type="occ" corresp="org__wien-buergerspital">obrister spitalmaister</roleName></rs>, und
                     der <rs type="org" ref="org__wien">rat gemain der stat ze Wienne</rs></rs> ,
                     <triggerstring n="disp">bestätigen</triggerstring>, dass <rs type="fn" role="recipient"><rs type="person" ref="pe__thomas_swaeml_QGW_II_I_1012"><roleName type="title">her</roleName> Thoman der Swemmel , mit ihnen <roleName type="occ" corresp="org__wien">gesworener des rats</roleName></rs></rs>,
                     ihrem <rs type="fn" role="issuer"><rs type="org" ref="org__wien-buergerspital">Spital</rs></rs> folgende Erbgüter <triggerstring n="disp">geschenkt
                     habe</triggerstring>: von erst sein mul, gelegen an der Swechent, . . . und sein
                  zwen weingarten, baide gelegen ze Perchtoltsdorf, ainer in der Gerriet, des ein
                  viertail ist, zenechst Jorgen weingarten des Purniczer, und der ander an dem
                  Hochrain, des auch ein viertail ist, zenechst des bischofs weingarten von Freising
                  . Sie <triggerstring n="disp">verpflichten</triggerstring> sich dagegen,jährlich an
                  Unser Vrawen abende zu der Schidung oder inner acht tagen darnach <triggerstring n="disp">einen Jahrtag zu begehen und den Dürftigen ein Mahl und ein Bad zu
                     geben</triggerstring>, sowie hern Thoman <triggerstring n="disp">jährlich vier Mut
                     Weizen auf der genannten Mühle zu mahlen</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1012"><rs type="fn" role="witness">Besiegelt mit
                     der stat ze <rs type="org" ref="org__wien">Wienne</rs> chlainem und des <rs type="org" ref="org__wien-buergerspital">Spitals</rs>, baiden anhangunden,
                     insigeln.</rs></rs>
            </p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>