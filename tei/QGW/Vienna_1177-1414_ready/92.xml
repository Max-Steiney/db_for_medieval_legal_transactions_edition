            <origDate instant="false">ze Wienne, des naehsten mittichens vor sand Veites
               tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00092_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00092_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="ev__QGW_II_I_92"><rs type="fn" role="issuer"><rs type="person" ref="pe__leubmann_QGW_II_I_92">Leubmann, des <rs type="person" ref="pe__faerlein_QGW_II_I_92">Faerleins</rs>
                        <roleName type="kin" corresp="pe__faerlein_QGW_II_I_92">steufsun</roleName></rs>, und <rs type="person" ref="pe__gertrud_QGW_II_I_92">Gerdraut, seine <roleName type="kin" corresp="pe__leubmann_QGW_II_I_92">Hausfrau</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihrer <rs type="person" ref="pe__kunigunde_QGW_II_I_92"><roleName type="title">Grundfrau</roleName>, <roleName type="title">swester</roleName>
                        Chunigunden, <roleName type="occ" corresp="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">Aebtissin</roleName> von S. Nichlas</rs></rs>, einen Baumgarten, der da
                  leit in der Awe zenaehste Fridrichen dem Swoben und haisset der Junchherre, von
                  dem man 3 sh. dn. dient, ferner <rs type="fn" role="other"><triggerstring n="fn">mit
                        Handen</triggerstring> des <rs type="person" ref="pe__walter_QGW_II_I_92"><roleName type="title">Grundherrn</roleName>
                        <roleName type="title">hern</roleName> Weigandes, des <roleName type="occ" corresp="org__wien-buergerspital">priesters</roleName>, <roleName type="occ" corresp="org__wien-buergerspital">schaffer</roleName> und
                           <roleName type="occ" corresp="org__wien-buergerspital">phleger</roleName>
                        der siehen in der purger Spital ze Wienne</rs></rs> , ein angrenzendes
                  Gärtchen, zunächst hern Jacoben bei dem Prunne, von dem man 34 dn. und 2 Hühner
                  dient, um 24 lb dn. dem <rs type="fn" role="recipient"><rs type="person" ref="pe__jakob_maeserl_QGW_II_I_121">Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName>
                        <roleName type="title">hern</roleName> Jacoben dem Maeserlein</rs> und
                     seiner <rs type="person" ref="pe__katharina_QGW_II_I_148"><roleName type="kin" corresp="pe__jakob_maeserl_QGW_II_I_121">Hausfrau</roleName>
                     Katrein</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_92"><rs type="fn" role="witness">Siegler: <rs type="person" ref="pe__kunigunde_QGW_II_I_92">1. die Grundfrau</rs>, <rs type="person" ref="pe__walter_QGW_II_I_92">2. der Grundherr</rs>.</rs></rs>
