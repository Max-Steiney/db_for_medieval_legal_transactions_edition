            <date when="13890913">1389 IX 13</date>
            <origDate instant="false">ze Wienn, des nächsten mantags nach Unser Fraun tag, als si geborn
               warde.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01178_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01178_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1178"><rs type="fn" role="issuer"><rs type="person" ref="pe__jakob_wolf_QGW_II_I_1178">Jacob der Wolf von Gre/acz, <roleName type="occ" corresp="org__wien">purger</roleName> ze Wienne</rs>,
                     und <rs type="person" ref="pe__dorothea_QGW_II_I_1178">Dorothe, seine
                        Hausfrau</rs></rs>, <triggerstring n="disp">beurkunden</triggerstring>, dass sie
                  dem <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_haslach_QGW_II_I_1178_b"><roleName type="kin" corresp="pe__dorothea_QGW_II_I_1178">Vetter</roleName> der Dorothe Hannsen, <rs type="person" ref="pe__johann_haslach_QGW_II_I_1178_a">Hannsen <roleName type="dead">seligen</roleName>
                           <add>von Haslach</add></rs>
                        <roleName type="kin" corresp="pe__johann_haslach_QGW_II_I_1178_a">sun</roleName> von
                        Haslach</rs>, der innerlands nicht ist</rs>, 25 lb dn. als halben Ertrag für
                  das Haus, gelegen an dem Salzgriez/zz/ze ze Wienne, <rs type="event" ref="ev__QGW_II_I_1178_men_1">das Dorothea für sich und
                  ihren Vetter um 50 lb dn. <rs type="person" ref="pe__dietrich_prenner_QGW_II_I_1178">Dietreichen dem Prenner</rs> verkauft hatte</rs>, ferner 30 lb dn.
                  von des Hauses wegen schulden, gelegen bei dem Rotenturn ze Wienn zenechst des
                  Stuchsen haus, des fleischhaker, das der rat der stat ze Wienn von notdurft wegen,
                  davon dass esvast paufellig worden was, Hainreichen, dem haubner, verkauft hatte.
                  Sie <triggerstring n="disp">verpfänden</triggerstring> dafür <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__michael_geukramer_QGW_II_I_1137"><roleName type="title">hern</roleName> Michels des Geuchramer, <roleName type="occ" corresp="org__wien">purgermaister</roleName> und <roleName type="occ" corresp="org__oesterreich-herzogtum" select="pl__wien">münzmaister</roleName></rs>, und des <rs type="org" ref="org__wien">rates gemain der stat ze Wienn</rs></rs> ihr Haus, gelegen in der
                  Champhlukchen ze Wienn zenechst maister Petreins haus von sand Michel, chorherr
                  dacz Allerheiligen tumchirichen dacz sand Stephan ze Wienn.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1178"><rs type="fn" role="witness">Besiegelt : 1.
                     mit dem Siegel des <rs type="person" ref="pe__jakob_wolf_QGW_II_I_1178">Ausstellers</rs>, 2.
                     mit dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs></rs>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>