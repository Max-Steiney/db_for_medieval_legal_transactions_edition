               <rs type="event" ref="ev__QGW_II_I_1502"><rs type="fn" role="issuer"><rs type="person" ref="pe__hartmann_guertler_QGW_II_I_1502">Hartman, der
                           <roleName type="prof">gürtler</roleName>, <roleName type="occ" corresp="org__wien">purger</roleName> ze Wienn</rs>, und <rs type="person" ref="pe__kunigunde_QGW_II_I_1502">Kunigund, sein <roleName type="kin" corresp="pe__hartmann_guertler_QGW_II_I_1502">hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__paul_wuerfel_QGW_II_I_1200"><roleName type="title">hern</roleName> Pauln des Würffels, <roleName type="occ" corresp="org__wien">purgermaister</roleName></rs>, und des <rs type="org" ref="org__wien">rats gemain der stat ze Wienn</rs></rs> ihr
