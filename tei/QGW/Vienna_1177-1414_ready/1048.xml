            <origDate instant="false">ze Wienn, des nasten sunntags vor sand Tiburcii und sand Valeriani
               tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01048_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01048_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="ev__QGW_II_I_1048"><rs type="fn" role="issuer"><rs type="person" ref="pe__michael_QGW_II_I_1132">Michel, des Pertelmes sun,
                           <roleName type="occ" corresp="pe__beatrix_von_zollern_nuernberg_QGW_II_I_1048">amptman</roleName> in der Schefstrass der <rs type="person" ref="pe__beatrix_von_zollern_nuernberg_QGW_II_I_1048"><roleName type="title">edeln und hochgeborn fraun</roleName>
                           Beatrix von Nürnberk, <roleName type="occ" corresp="org__oesterreich-herzogtum">herzoginn</roleName> ze Österreich</rs></rs>
                  </rs>, <triggerstring n="disp">beurkundet, dass vor ihm in offenem
                     Gerichte</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="pe__martin_reisenperger_ii_QGW_II_I_1048">Mert
                        der Reisenperger, der erbirdigen geistlichen vrowen <roleName type="occ" corresp="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">schaffer</roleName> in sand Niclas chloster var Stubentor ze Wienn , an
                        des Klosters <roleName type="rep" corresp="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">Statt</roleName></rs>
                     <triggerstring n="fn">mit Vorsprechen</triggerstring></rs>
                  <rs type="fn" role="other"><triggerstring n="fn">auf</triggerstring>
                     <rs type="person" ref="pe__anna_wekchlerin_QGW_II_I_1048">Annen</rs> weingarten der
                     Wekchlerinn</rs>, gelegen in der Mitterpeunt var Stubentar ze Wienn, des ein
                  viertail eins jeuchs ist, zenachst Dietreichs weingarten des Swentenbeins , um 3
                  sh. dn. gelts <triggerstring n="disp">versessens purkrechts und die darauf ertheilten
                     zwispil geklagt habe</triggerstring>. Er gibt dem Kläger <rs type="person" ref="pe__johann_praunsperger_QGW_II_I_1030">Jannsen den Praunsperkch <roleName type="rep" corresp="pe__michael_QGW_II_I_1132"><add>vorsprech</add></roleName></rs> und
                     <rs type="person" ref="pe__ulrich_pheffel_QGW_II_I_1048">Ulreichen den Phefflein, die zwen
                        <roleName type="rep" corresp="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">vorsprechen</roleName></rs>, als recht poten mit und <triggerstring n="disp">macht <add>gewaltig</add></triggerstring> nach ihrer Aussage <rs type="fn" role="recipient"><rs type="org" ref="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">das
                        Kloster</rs></rs> des Weingartens gewaltig.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1048"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="pe__michael_QGW_II_I_1132">Aussteller</rs>.</rs></rs></p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>