                        <placeName>Wien</placeName>
                        <date when="13551105">1355 XI 05</date>
                        <origDate instant="false">ze Wienne, des naehsten phincztags vor sant
                              Merteins tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00470_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00470_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
                              <rs type="event" ref="ev__QGW_II_I_470"><rs type="fn" role="issuer"><rs type="person" ref="pe__ortolf_von_apamaea_QGW_II_I_470">Ortolf,
                                                  <roleName type="title">erczpischolf</roleName> von
                                                Appoimea und <roleName type="occ" corresp="org__lassee-pfarre">pharrer</roleName> ze
                                                Lauchssê</rs></rs>, <triggerstring n="disp">bestätigt</triggerstring>, dass er <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_smausser_QGW_II_I_946">Jansen dem
                                                Smauz/zz/zer, <roleName type="occ" corresp="org__wien">purger</roleName> ze
                                                Wienne</rs></rs>, 84 lb dn. schulde und <rs type="event" ref="ev__QGW_II_I_470_men_1">ihm dafür <rs type="fn" role="other"><triggerstring n="fn">mit
                                                  Handen</triggerstring> seines <rs type="person" ref="pe__konrad_QGW_II_I_410">Burgherrn <roleName type="occ" corresp="org__heiligenkreuz-zisterzienser">apts</roleName> Chunrats vom Heiligen
                                                  Chreutz</rs></rs> seinen Hof, gelegen ze
                                          Trebaswinchel, mit sampt der mül, von dem man 4 ½ lb dn.
                                          Burgrecht nach Heiligenkreuz dient, und zwar die
                                          Uebertheuerung über das Geld, das er <rs type="person" ref="pe__raedlein_QGW_II_I_470">Raedlein der
                                                Jüdinne, <rs type="person" ref="pe__haendlein_QGW_II_I_470">Haendleins</rs>
                                                <roleName type="kin" corresp="pe__haendlein_QGW_II_I_470">hausvrowe</roleName></rs>, schulde, zu Pfand
                                          gesetzt habe.</rs> Für dieses Darlehen überlässt Ortolf
                                    seinem Gläubiger für dieses Jahr allen Ertrag des zur Pfarre
                                    Lassee gehörigen Gutes mit Ausnahme des kleinen Zehents ze dorfe
                                    und eines Weingärtchens ze Medlich. Nach der Einnahme dieser
                                    Einkünfte durch den Gläubiger soll Ortolf seiner Schuld ledig
                                    sein und ausserdem die Urkunde zurückerhalten, die Jans von ihm
                                    hat, die da sagt fu/emf phunt geltes über den weingarten,
                                    gelegen ze Engelschalichsdorf an dem Mitterekke und haisset der
                                    Flötzer .</rs>
                        </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_470"><rs type="fn" role="witness">Besiegelt mit den Siegeln: <rs type="person" ref="pe__ortolf_von_apamaea_QGW_II_I_470">1. des
                                                Ausstellers</rs>, <rs type="person" ref="pe__konrad_QGW_II_I_410">2. des Burgherrn</rs>,
                                                <rs type="person" ref="pe__friedrich_von_atzenbrugg_QGW_II_I_470">3.
                                                unsers <roleName type="title">pruders</roleName>
                                                Fridreichs von Atzenprukke</rs>.</rs></rs>
                        </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>