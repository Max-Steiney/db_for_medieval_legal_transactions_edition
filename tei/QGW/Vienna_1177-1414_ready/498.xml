          <rs type="event" ref="ev__QGW_II_I_498"><rs type="fn" role="issuer"><rs type="person" ref="pe__adelheid_QGW_II_I_456"><roleName type="title">Swester</roleName> Alhait von
                Neunburch, <roleName type="occ" corresp="org__wien-st_laurenz_am_alten_fleischmarkt">priorinn</roleName> dacz sand Larenczen chloster ze Wienne</rs>, und <rs type="org" ref="org__wien-st_laurenz_am_alten_fleischmarkt">der convent gemain
                daselbs</rs></rs>
            <triggerstring n="disp">verkaufen</triggerstring>
            <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="pe__johann_smausser_QGW_II_I_946"><roleName type="title">Grundherrn</roleName>
                <roleName type="title">hern</roleName> Jansen des Smauz/zz/zer, <roleName type="occ" corresp="org__wien">statrichter</roleName> ze Wienn</rs></rs>, ½ lb dn. ewigs
            purchrechts auf Leutolts haus, des choler, hinder dem Neunmarcht zenaechst dem haus, das
            weiln Otten des Raschlein gewesen ist , von dem man 15 dn. zu Grundrecht dient, um 4 ½
            lb dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__heinrich_vinkch_QGW_II_I_499">Hainreichen dem Vinchken, <roleName type="occ" corresp="pe__albrecht_herzog_von_oesterreich_QGW_II_I_596">chamrer</roleName>
                <rs type="person" ref="pe__albrecht_herzog_von_oesterreich_QGW_II_I_596">Herzog
                  Albrechts</rs></rs>, und seiner <rs type="person" ref="pe__elisabeth_QGW_II_I_499"><roleName type="kin" corresp="pe__heinrich_vinkch_QGW_II_I_499">Hausfrau</roleName> Elspeten</rs></rs>.</rs>
        </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_498"><rs type="fn" role="witness">Besiegelt mit den
              Siegeln: <rs type="person" ref="pe__adelheid_QGW_II_I_456">1. der Priorin</rs>, <rs type="org" ref="org__wien-st_laurenz_am_alten_fleischmarkt">2. des Convents</rs>,
                <rs type="person" ref="pe__johann_smausser_QGW_II_I_946">3. des
              Grundherrn</rs>.</rs></rs>
