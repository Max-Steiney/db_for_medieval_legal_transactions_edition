         <div type="abstract" resp="ks">
            <p>
               <rs type="event" ref="ev__QGW_II_I_314"><rs type="fn" role="issuer"><rs type="person"
                        ref="pe__friedrich_von_topel_QGW_II_I_301">Fridreich von Topel</rs></rs>
                  <triggerstring n="disp">verpflichtet sich</triggerstring>, <rs type="fn"
                     role="recipient"><rs type="person" ref="pe__friedrich_naezeuger_QGW_II_I_314"
                        >Fridreichen, dem satler, dem Naezeuger</rs></rs>, den Getreidezehent, den
                  er diesem verkauft hatte und der herzogliches Lehen ist, sobald Herzog Albrecht ze
                  Wienne chumt, binnen 14 Tagen zu übergeben.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_I_314"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="person" ref="pe__friedrich_von_topel_QGW_II_I_301">1.
                        des Ausstellers</rs>, <rs type="person"
                        ref="pe__popp_von_hauspach_QGW_II_I_314">2. Poppen von
                  Hauspach</rs>.</rs></rs>
            </p>
