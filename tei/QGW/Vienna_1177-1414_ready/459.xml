            <placeName>Wien</placeName>
            <date when="13541124">1354 XI 24</date>
            <origDate instant="false">ze Wienne, an sant Katrein abent.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00459_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00459_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="ev__QGW_II_I_459"><rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_bei_den_minderbruedern_FRA_II_1316_II_02.1">Ulreich bei den
                        Minnern Pru/edern <roleName type="occ" corresp="org__wien"><add>rates der
                              stat ze Wienne</add></roleName></rs>, <rs type="person" ref="pe__heinrich_wuerfel_QGW_II_I_459">Hainreich der Würffel <roleName type="occ" corresp="org__wien"><add>rates der stat ze
                           Wienne</add></roleName></rs>, <rs type="person" ref="pe__konrad_schoenaicher_QGW_II_I_459">Chunrat der Schönnaicher<roleName type="occ" corresp="org__wien"><add>rates der stat ze
                           Wienne</add></roleName>
                     </rs> und <rs type="person" ref="pe__heinrich_von_der_neisse_QGW_II_I_459">
                        Hainreich von der Neiz/zz/za<roleName type="occ" corresp="org__wien"><add>rates der stat ze Wienne</add></roleName>
                     </rs>, alle vier des rates der stat ze Wienne </rs>, <triggerstring n="disp">beurkunden <add>Schiedspruch</add></triggerstring> den von ihnen im Auftrage des
                  Rathes gefällten Schiedspruch in dem Streite zwischen <rs type="fn" role="other"><rs type="person" ref="pe__bartholomaeus_treter_QGW_II_I_459">Partelme dem
                        Treter</rs>
                     <triggerstring n="fn">einerseits</triggerstring></rs>, <rs type="fn" role="other">
                     <rs type="person" ref="pe__friedrich_schrannschreiber_StB_I_225">Fridreich, dem
                        schrannschreiber <roleName type="rep" corresp="pe__herbert_QGW_II_I_459"><add>an Stelle</add></roleName></rs>, <rs type="person" ref="pe__michael_poll_QGW_II_I_440">Michel dem Pollen<roleName type="rep" corresp="pe__herbert_QGW_II_I_459"><add>an Stelle</add></roleName>
                     </rs>, <rs type="person" ref="pe__johann_pleyein_QGW_II_I_459">Jans dem
                           Pleiein<roleName type="rep" corresp="pe__herbert_QGW_II_I_459"><add>an
                              Stelle</add></roleName>
                     </rs>, an Stelle des <rs type="person" ref="pe__herbert_QGW_II_I_459">unmündigen<roleName type="kin" corresp="pe__johann_QGW_II_I_459"><add>Sohnes</add></roleName> Herbort, Sohnes des <rs type="person" ref="pe__johann_QGW_II_I_459"><roleName type="dead">verstorbenen</roleName>
                           <roleName type="kin" corresp="pe__friedrich_schrannschreiber_StB_I_225">Bruders</roleName> Friedrichs Jansen</rs> aus dessen <rs type="person" ref="pe__katharina_QGW_II_I_459_a"><roleName type="kin" corresp="pe__johann_QGW_II_I_459">Ehe</roleName> mit Katrein <roleName type="dead">selig</roleName>, weiln genant die Progantinne</rs></rs>,
                        <triggerstring n="fn">ander seits</triggerstring></rs> über <rs type="event" ref="ev__QGW_II_I_459_men_1">das Geschäft der <rs type="person" ref="pe__katharina_QGW_II_I_459_b"> Katrei, der <roleName type="dead">ver
                           storbenen</roleName>
                        <roleName type="kin" corresp="pe__bartholomaeus_treter_QGW_II_I_459">Gemahlin</roleName><rs type="person" ref="pe__bartholomaeus_treter_QGW_II_I_459"> Partelmes des Treter</rs>
                        und <roleName type="kin" corresp="pe__herbert_QGW_II_I_459">Schwester</roleName>
                        <rs type="person" ref="pe__herbert_QGW_II_I_459"> Herborts</rs></rs></rs>.
                  Sie bestimmen, dass <rs type="fn" role="recipient">
                     <rs type="person" ref="pe__herbert_QGW_II_I_459">Herbort</rs></rs> 14 Fuder
                  Wein und 65 lb dn., wovon ihm Partelme der Treter bereits 7 Fuder heurigen Weines
                  und 8 lb dn. gegeben habe, erhalten solle, <rs type="fn" role="recipient">dagegen
                     sprechen sie <rs type="person" ref="pe__bartholomaeus_treter_QGW_II_I_459">dem
                        Letzteren</rs> zu</rs> ein halbes Joch Weingarten, gelegen ze Alsse zwischen
                  den Wegen, haisset der Schilter, und achthalb phunt gelts purchrechts ,<rs type="event" ref="ev__QGW_II_I_459_men_2"> welche Katrei für 75 lb dn. gehabt
                     hatte auf dem haus, gelegen an dem Neunmarcht, das weiln der vorgenanten ir
                     muter vrowen Margreten gewesen ist, zenaest Andres haus, des her zogen
                     türchamrer </rs>. Wer den Spruch nicht hält, zahlt dem Herzog 100 lb dn., dem
                  Rathe der Stadt zu Wien 50 lb dn. und dem Bürgerspital 50 lb dn.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_459"><rs type="fn" role="witness">Besiegelt von
                     den <rs type="person" ref="pe__ulrich_bei_den_minderbruedern_FRA_II_1316_II_02.1">Ausstellern</rs>
                     <rs type="person" ref="pe__heinrich_wuerfel_QGW_II_I_459"><add>Ausstellern</add></rs><rs type="person" ref="pe__konrad_schoenaicher_QGW_II_I_459"><add>Ausstellern</add></rs><rs type="person" ref="pe__heinrich_von_der_neisse_QGW_II_I_459"><add>Ausstellern</add></rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>