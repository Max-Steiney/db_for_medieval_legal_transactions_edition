                     <rs type="person" ref="pe__benedikt_QGW_II_I_191"><roleName type="title">hern</roleName> Benedicten, der Schotten <roleName type="occ" corresp="org__wien-schotten">amman</roleName> ze Wienne,</rs></rs> ein
