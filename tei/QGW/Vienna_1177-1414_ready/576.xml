                     und <rs type="person" ref="pe__bertha_QGW_II_I_889">Percht, seine <roleName type="kin" corresp="pe__sieghard_brunner_QGW_II_I_889">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="pe__gerung_chol_QGW_II_I_417"><roleName type="occ" corresp="org__klosterneuburg-augustiner_chorherren">Bergmeisters</roleName>
