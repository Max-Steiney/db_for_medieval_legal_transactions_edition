               <rs type="event" ref="ev__QGW_II_I_267"><rs type="fn" role="issuer"><rs type="person" ref="pe__berthold_gerstenbauch_QGW_II_I_267">Perichtolt der
                        Gerstenpauch</rs> und <rs type="person" ref="pe__elisabeth_QGW_II_I_267">Elsbet, seine <roleName type="kin" corresp="pe__berthold_gerstenbauch_QGW_II_I_267">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">bestätigen</triggerstring>,
                  dass sie die drei Viertel Weingarten, <rs type="event" ref="ev__QGW_II_I_267_men_1">die sie von<rs type="person" ref="pe__heinrich_poltz_QGW_II_I_186"> Hainreich dem Poltz</rs> und seiner
                        <rs type="person" ref="pe__katharina_QGW_II_I_186"><roleName type="kin" corresp="pe__heinrich_poltz_QGW_II_I_186">Hausfrau</roleName>
                        Katrein</rs> gekauft haben, der da leit an dem Nussperge und haisset der
                     Schreiber, zenaehst Leupolts weingarten des Mundoffen, mit Handen des <rs type="person" ref="pe__gerung_chol_QGW_II_I_417"><roleName type="occ" corresp="org__klosterneuburg" select="pl__klosterneuburg">Bergmeisters</roleName>
                        <roleName type="title">hern</roleName> Gerungs,<roleName type="kin" corresp="pe__gerung_chol_QGW_II_I_185"><add>sun</add></roleName>
                        <rs type="person" ref="pe__gerung_chol_QGW_II_I_185"><roleName type="title">hern</roleName> Gerungs sun. des Choln, <roleName type="dead">dem got
                              genade</roleName></rs>, <roleName type="occ" corresp="org__klosterneuburg">amptman</roleName> des chlosters ze
                        Neuenburch</rs>,</rs>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__sieghard_brunner_QGW_II_I_889">ihrem <roleName type="kin" corresp="pe__berthold_gerstenbauch_QGW_II_I_267">Schwager</roleName>
                        <roleName type="kin" corresp="pe__elisabeth_QGW_II_I_267"><add>Schwager</add></roleName> Sigwarten dem Prunner</rs> und <rs type="person" ref="pe__bertha_QGW_II_I_889">seiner <roleName type="kin" corresp="pe__sieghard_brunner_QGW_II_I_889">Hausfrau</roleName>
                        Perichten</rs></rs>
                  <triggerstring n="disp">überlassen haben </triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_267"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="pe__berthold_gerstenbauch_QGW_II_I_267">des Ausstellers</rs>, 2. <rs type="person" ref="pe__gerung_chol_QGW_II_I_417">des Bergmeisters</rs></rs>.</rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>