            <placeName>Wien</placeName>
            <date when="14021220">1402 XII 20</date>
            <origDate instant="false">ze Wienn, an sand Thomans abend, des heiligen
            zwelifpoten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01521_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01521_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_I_1521"><rs type="fn" role="issuer"><rs type="person" ref="pe__stephan_mairl_QGW_II_I_1521">Stephan der Mairl ze Otakchrinn
                        <roleName type="rep" corresp="pe__kunigunde_QGW_II_I_1521"><add>anstatt</add></roleName></rs></rs>
                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__konrad_rampersdorfer_QGW_II_I_1107">Chunrats des Ramperstorffer,
                           <roleName type="occ" corresp="org__klosterneuburg-augustiner_chorherren">amptman</roleName> des <rs type="org" ref="org__klosterneuburg-augustiner_chorherren">klosters ze
                           Neunburkch</rs></rs>,</rs> anstatt <rs type="person" ref="pe__kunigunde_QGW_II_I_1521">seiner <roleName type="kin" corresp="pe__stephan_mairl_QGW_II_I_1521">Schwester</roleName> Kunigunden</rs> ein
               Viertel Joch Weingarten, <rs type="event" ref="ev__QGW_II_I_1521_men_1">das dieser in rechter
                  Erbtheilung zugefallen war,</rs> gelegen ze Otakchring in dem Klain Phenninggelt
               zenechst Niclas weingarten des Inzestorfer, von dem man 7 ½ dn. zu Bergrecht und 3
               Helbling ze foitrecht dient, <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_kilber_QGW_II_I_1521">Hannsen dem Chülber, dem <roleName type="prof">sneider</roleName>
                     ze Wienn, der den
                     Weingarten <roleName type="rep" corresp="pe__katharina_QGW_II_I_1521"><add>für</add></roleName><roleName type="rep" corresp="pe__anna_QGW_II_I_1521"><add>für</add></roleName><roleName type="rep" corresp="pe__stephan_QGW_II_I_1521"><add>für</add></roleName></rs></rs>
               <rs type="fn" role="other"><triggerstring n="fn">seiner</triggerstring>
                  <rs type="person" ref="pe__katharina_QGW_II_I_1521"><roleName type="kin" corresp="pe__johann_kilber_QGW_II_I_1521">Frau</roleName> Kathrein</rs> und ihren
                  unmündigen <rs type="person" ref="pe__anna_QGW_II_I_1521"><roleName type="kin" corresp="pe__katharina_QGW_II_I_1521">Kindern</roleName>
                     <roleName type="kin" corresp="pe__hermann_fridmann_QGW_II_I_1521"><add>Kindern</add></roleName> Annen</rs> und <rs type="person" ref="pe__stephan_QGW_II_I_1521"><roleName type="kin" corresp="pe__katharina_QGW_II_I_1521"><add>Kindern</add></roleName>
                     <roleName type="kin" corresp="pe__hermann_fridmann_QGW_II_I_1521"><add>Kindern</add></roleName> Stephan</rs> aus ihrer <rs type="person" ref="pe__hermann_fridmann_QGW_II_I_1521">
                     <roleName type="dead">früheren</roleName>
                     <roleName type="kin" corresp="pe__katharina_QGW_II_I_1521">Ehe</roleName> mit
                     Hermann Fridmann</rs>
                  <triggerstring n="fn">kauft</triggerstring></rs>, um 15 lb dn., <rs type="event" ref="ev__QGW_II_I_1521_men_2">für welche an dieser Kinder Statt das Haus, gelegen an der Herzogen
                  hof in dem Lederhof ze Wienn, Hannsen dem Matschawer verkauft worden war.</rs>
               <rs type="event" ref="ev__QGW_II_I_1521_men_3">Von den 15 lb dn. fallen 5 lb 5 sh. dn. den Augustinern
                  ze Wienn, 2 lb dn. dem pharrer ze Otakchrinn, 3 sh. dn. den geltern und der Rest
                  den Kindern zu.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1521"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="pe__konrad_rampersdorfer_QGW_II_I_1107">Amtmannes</rs> und des <rs type="person" ref="pe__konrad_innauer_QGW_II_I_1521"><roleName type="occ" corresp="org__wien">Wiener
                           Bürgers</roleName> Chunrats des Innauer</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>