         <div type="abstract">
            <p>
               <rs type="event" ref="ev__QGW_II_II_1976"><rs type="fn" role="issuer"><rs type="person" ref="pe__hotz_StB_I_208">Hocz, der Jud ze Wienn</rs></rs>,
                     <triggerstring n="disp">verkauft</triggerstring> die in <rs type="event" ref="ev__QGW_II_II_1966">Urk. n° 1966</rs> und <rs type="event" ref="ev__QGW_II_II_1971">1971</rs> bezeichnete halbe Wechselbank Hannsen des
                  Rokgen um 20 lb dn. und umb ainen guldein dem <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_aczinger_QGW_II_II_3549">Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Hannsen dem
                        Aczinger</rs>.</rs></rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_1976"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__rudolf_angerfelder_QGW_II_I_1335"><roleName type="title">hern</roleName>
                        Ruedolfs des Angervelder, <roleName type="occ" corresp="org__wien">burgermaister</roleName> ze Wienn und <roleName type="occ" corresp="org__oesterreich-herzogtum">münssmaister</roleName> in
                        Österreich</rs>, und<rs type="person" ref="pe__michael_menschein_QGW_II_I_1218"> <roleName type="title">hern</roleName> Michels des Menschein, des
                        <roleName type="occ" corresp="org__wien">rats</roleName> der stat ze Wienn</rs> .</rs>
               </rs></p>
         </div>
