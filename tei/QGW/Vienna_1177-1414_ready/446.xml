            <origDate instant="false">ze Wienne, an sant Agnesen tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_446_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_446_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="ev__QGW_II_I_446"><rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_wittauer_QGW_II_I_446"><roleName type="title">Bru/eder</roleName> Ulreich der Wittauer, <roleName type="occ" corresp="org__wien-augustiner_eremiten">prior</roleName></rs>, <rs type="person" ref="pe__heinrich_QGW_II_I_446"><roleName type="title">bru/eder</roleName> Heinreich, <roleName type="occ" corresp="org__wien-augustiner_eremiten">subprior</roleName></rs>, und der
                        <rs type="org" ref="org__wien-augustiner_eremiten">convent gemain der
                        gaestleichen bru/eder chloster sande Augustins ordens ze Wienne</rs></rs>
                  <triggerstring n="disp">beurkunden</triggerstring>, dass sie in ihrem Kloster grosse
                  Noth mit den gemachen, die da haissent privet, gehabt und ihre Klagen an Herzog
                  Albrecht und den Rath der Stadt gebracht haben. Von diesem erhielten sie die
                  Erlaubnis, diese heimlichen Gemächer in einem an der Ringmauer zu erbauenden
                  Thurme unterzubringen, hinsichtlich dessen sie nunmehr <rs type="fn" role="other"><triggerstring n="fn">mit Zustimmung</triggerstring>
                     <rs type="person" ref="pe__ulrich_gnaemhertel_QGW_II_I_446"><roleName type="title">bruder</roleName> Ulreichs des Gnaemhaertleins, <roleName type="occ" corresp="org__wien-augustiner_eremiten">obrister
                           provincial</roleName></rs> des Ordens in Oesterreich, Kärnten, Böhmen und
                     Bayern</rs>, <rs type="fn" role="recipient">dem <rs type="person" ref="pe__albrecht_herzog_von_oesterreich_QGW_II_I_596"><roleName type="title">Herzoge</roleName><add>Albrecht</add></rs> und dem <rs type="org" ref="org__wien">Rathe</rs></rs>
                  <triggerstring n="disp">einen Revers ausstellen</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_446"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="pe__ulrich_wittauer_QGW_II_I_446">des
                        Priors</rs>, 2. <rs type="org" ref="org__wien-augustiner_eremiten">des
                        Conventes</rs>, 3. des <rs type="person" ref="pe__ulrich_gnaemhertel_QGW_II_I_446">Provinzials</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>