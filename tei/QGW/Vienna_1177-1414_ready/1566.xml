                     Siegeln 3. des <rs type="person" ref="pe__ulrich_QGW_II_I_1566">Pfarrers von
                        Mödling</rs>, 4. des <rs type="person" ref="pe__jakob_waicz_QGW_II_I_1473">Wiener <roleName type="occ" corresp="org__wien">Bürgers</roleName>
                        Jacobs des Waiczen</rs>.</rs></rs>
