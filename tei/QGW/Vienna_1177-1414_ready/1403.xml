   <text>
      <body>
         <div type="abstract" resp="cs">
            <!-- Organisation ausweisen nötig! -->
            <p><rs type="event" ref="ev__QGW_II_I_1403"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__johann_von_purgstall_QGW_II_I_1026">Hanns, der
                           <roleName type="prof">wachsgiesser</roleName>, <roleName type="occ"
                           corresp="org__wien">purger</roleName> ze Wienne</rs></rs>, <triggerstring
                     n="disp">beurkundet seinen letzten Willen</triggerstring>. <triggerstring n="disp">Er
                     schafft</triggerstring>: 1. 40 lb dn. zu den 60 lb dn., welche seine <rs
                     type="person" ref="pe__katharina_QGW_II_I_1403_a"><roleName type="dead"
                        >verstorbene</roleName>
                     <roleName type="kin" corresp="pe__johann_von_purgstall_QGW_II_I_1026"
                        >Frau</roleName> Kathrei</rs> für ihr Seelenheil geschafft hatte, und zwar:
                  a) 10 lb dn. den <rs type="fn" role="recipient"><rs type="org"
                        ref="org__wien-st_stephan">Chorherren und dem Capitel bei S. Stephan zu
                        einem Jahrtag</rs> b) 10 lb dn. den ächtern, vicarien und gracianern zu
                     einem Jahrtag c) 10 lb dn. zu dem Bau daselbst d) in die Klöster hinz den <rs
                        type="org" ref="org__wien-dominikaner">Predigern</rs> , hinz den <rs
                        type="org" ref="org__wien-augustiner_eremiten">Augustinern</rs> , hinz den
                        <rs type="org" ref="org__wien-minoriten">Minnornprudern</rs> und hinz den
                        <rs type="org" ref="org__wien-karmeliter">Weissenprüdern</rs> je 10 lb dn.
                     zu einem Jahrtag</rs> e) den <rs type="fn" role="recipient"><rs type="org"
                        ref="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">geistlichen
                        Frauen hinz sand Niclas vor Stubentor</rs> und <rs type="org"
                        ref="org__wien-st_agnes_auf_der_himmelpforte"><add>geistlichen
                        Frauen</add>hinz der Himelporten</rs></rs> je 10 lb dn. zu einem Jahrtag 2.
                  14 sh. dn. gelts, die er auf einem Hause in dem Lederhof hat, ze <rs type="fn"
                     role="recipient"><rs type="org" ref="org__wien-st_peter">sand Valteins capellen
                        in sand Peter ze Wienne</rs></rs> zu dem pau 3. seiner <rs type="fn"
                     role="recipient"><rs type="person" ref="pe__dorothea_QGW_II_I_1403"><roleName
                           type="kin" corresp="pe__johann_von_purgstall_QGW_II_I_1026"
                           >Hausfrau</roleName> Dorothen</rs></rs> für ihre Morgengabe 100 lb dn.
                  auf seinem Wachse, ferner sein Gewand, das beste Bettgewand und ein Fuder Wein von
                  dem künftigen Ertrag 4. seinen <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__konrad_QGW_II_I_1403"><roleName type="kin"
                           corresp="pe__johann_von_purgstall_QGW_II_I_1026">unmündigen
                           Vettern</roleName> Chunraten</rs> und <rs type="person"
                        ref="pe__erhard_QGW_II_I_1403">
                        <roleName type="kin" corresp="pe__johann_von_purgstall_QGW_II_I_1026"
                              ><add>Vetter</add></roleName> Erharten</rs>, zu deren <rs
                        type="person" ref="pe__jakob_wachsgiesser_QGW_II_I_1403"><roleName
                           type="rep" corresp="pe__konrad_QGW_II_I_1403">Vormund</roleName>
                        <roleName type="rep" corresp="pe__erhard_QGW_II_I_1403"
                           ><add>Vormund</add></roleName> er seinen <roleName type="kin"
                              corresp="pe__johann_von_purgstall_QGW_II_I_1026">Schwager</roleName>
                        Jacoben, den <roleName type="prof">wachsgiesser</roleName></rs></rs>,
                  bestellt, unter der Bedingung ordentlichen und gehorsamen Verhaltens sein Haus,
                  gelegen an dem Hochenmarcht zenechst Jacobs haus, des gürtler, ½ Joch Weingarten
                  in dem Gotschalichs perig, zwei Viertel Weingarten, gelegen in dem Hungerprunn,
                  vier Fuder Wein, das noch übrige Wachs, das zum Wachse gehörige Geschirr und je
                  ein Bettgewand 5. seiner <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__elisabeth_QGW_II_I_1403"><roleName type="kin"
                           corresp="pe__johann_von_purgstall_QGW_II_I_1026">Muhme</roleName>
                        <roleName type="title">junkfraun</roleName> Elsbeten</rs></rs> 30 lb dn. 6.
                  seinem <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__christian_QGW_II_I_1403"><roleName type="kin"
                           corresp="pe__johann_von_purgstall_QGW_II_I_1026">Vetter</roleName>
                        Kristann</rs></rs> 10 lb dn., seine silbergürtel, ein taschen und ainen
                  beslagen Pasler 7. seinem <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__stephan_schmied_QGW_II_I_1403"><roleName type="friend"
                           corresp="pe__johann_von_purgstall_QGW_II_I_1026">Freunde</roleName>
                        Stephane , dem <roleName type="prof">smid</roleName></rs></rs>, 10 lb dn. 8.
                  seinen beiden <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__katharina_QGW_II_I_1403_b"><roleName type="kin"
                           corresp="pe__johann_von_purgstall_QGW_II_I_1026">Muhmen</roleName>
                        Kathrei</rs> und <rs type="person" ref="pe__anna_QGW_II_I_1403_a"
                           ><add>Muhme</add> Annen</rs></rs> je 10 lb dn. 9. seiner <rs type="fn"
                     role="recipient"><rs type="person" ref="pe__katharina_QGW_II_I_1403_c"
                           ><roleName type="kin" corresp="pe__johann_von_purgstall_QGW_II_I_1026"
                           >Muhme</roleName> Kathrein, Jacobs <roleName type="kin"
                           corresp="pe__jakob_wachsgiesser_QGW_II_I_1403">hausfraun</roleName>, des
                        wachsgiesser</rs></rs> , ein seideins gulter, zwai seideine küss, <rs
                     type="fn" role="recipient"><rs type="person" ref="pe__anna_QGW_II_I_1403_b"
                        >ihrer <roleName type="kin" corresp="pe__jakob_wachsgiesser_QGW_II_I_1403"
                           >Tochter</roleName>
                        <roleName type="kin" corresp="pe__katharina_QGW_II_I_1403_c"
                              ><add>Tochter</add></roleName> Annen</rs></rs> 10 lbdn 10. seinem <rs
                     type="fn" role="recipient"><rs type="person" ref="pe__peter_QGW_II_I_1403"
                           ><roleName type="occ" corresp="pe__johann_von_purgstall_QGW_II_I_1026"
                           >Diener</roleName> Petrein</rs></rs> 5 lb dn. 11. seinen silbernen Kopf
                  zu verkaufen und den Erlös unter die <rs type="fn" role="recipient"><rs type="org"
                        ref="org__wien-buergerspital">Dürftigen in der purger Spital</rs> , in die
                     drei <rs type="org" ref="org__wien-st_johann_in_der_siechenals">siechhäuser
                        hinz sand Johanns</rs>, <rs type="org"
                        ref="org__wien-st_lazarus_siechenhaus"><add>sichhäuser</add> hinz sand
                        Marx</rs> und <rs type="org" ref="org__wien-st_hiob_zum_klagbaum"
                           ><add>sichhäuser</add> hinz dem Chlagpaum und in die Aichorn
                        daselbens</rs>, hinz sand <rs type="org" ref="org__wien-st_hieronymus"
                        >Jeronimus den bekerten vraun und in die zwai selhäuser bei den
                        Predigern</rs> zu vertheilen</rs> 12. <rs type="fn" role="recipient"><rs
                        type="org"
                        ref="org__wien-st_stephan-kapelle_st_erasmus_im_neuen_karner_auf_dem_st_stephansfriedhof"
                        >auf den Karner in die pruderschaft auf sand Stephans freithof</rs></rs> 10
                  lb dn. zu einem Jahrtag 13. ½ Joch Weingarten an dem Alssekk <rs type="fn"
                     role="recipient"><rs type="person" ref="pe__niklas_QGW_II_I_1403">Nicolae, dem
                           <roleName type="kin" corresp="pe__katharina_QGW_II_I_1403_a"
                           >Vetter</roleName> seiner <rs type="person"
                           ref="pe__anna_die_smerberin_QGW_II_I_1403"><roleName type="kin"
                              corresp="pe__johann_von_purgstall_QGW_II_I_1026">früheren
                              Frau</roleName>
                           <roleName type="dead"><add>früheren Frau</add></roleName>, Annen der
                           Smerberinne</rs>
                        <roleName type="kin" corresp="pe__anna_die_smerberin_QGW_II_I_1403"
                           >sun</roleName></rs></rs>, für den Fall, als er Priester werde,
                  andernfalls zur Stiftung einer Messe. Den noch übrigen Theil seines Vermögens
                  schafft er zur Vertheilung an Hausarme. Das <rs type="fn" role="other"><triggerstring
                        n="fn">Geschäft empfiehlt er</triggerstring>
                     <rs type="person" ref="pe__niklas_von_friesach_QGW_II_I_1031"><roleName
                           type="title">hern</roleName> Niclasen von Friesach, <roleName type="occ"
                           corresp="org__wien-st_stephan">vicarii</roleName> dacz sand Stephan
                           <roleName type="rep" corresp="pe__johann_von_purgstall_QGW_II_I_1026"
                              ><add>Geschäftsherr</add></roleName></rs>, <rs type="person"
                        ref="pe__johann_chetner_QGW_II_I_1104">Hannsen dem Ketner <roleName
                           type="rep" corresp="pe__johann_von_purgstall_QGW_II_I_1026"
                              ><add>Geschäftsherr</add></roleName></rs>, <rs type="person"
                        ref="pe__ernst_im_tuerndlein_an_dem_hohenmarkt_QGW_II_I_1403">Ernsten im
                        Türndlein an dem Hochenmarkt <roleName type="rep"
                           corresp="pe__johann_von_purgstall_QGW_II_I_1026"
                           ><add>Geschäftsherr</add></roleName></rs> und seinem <rs type="person"
                        ref="pe__jakob_wachsgiesser_QGW_II_I_1403"><roleName type="kin"
                           corresp="pe__johann_von_purgstall_QGW_II_I_1026">Schwager</roleName>
                        Jacoben, dem <roleName type="prof">wachsgiesser</roleName>
                        <roleName type="rep" corresp="pe__johann_von_purgstall_QGW_II_I_1026"
                              ><add>Geschäftsherr</add></roleName></rs></rs>.</rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_I_1403"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="pe__jakob_dorn_QGW_II_I_1378"><roleName
                           type="occ" corresp="org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Jacobs des Dorn</rs> und des <rs
                        type="person" ref="pe__wilhelm_hansgraf_QGW_II_I_1403"><roleName type="occ"
                           corresp="org__wien">Bürgers</roleName>
                        <roleName type="title">hern</roleName> Wilhalms des
                  Hansgrafen</rs></rs>.</rs></p>
         </div>
