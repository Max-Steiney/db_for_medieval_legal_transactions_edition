            <origDate instant="false">des nêchsten phinztags nach sand Jo/erigen tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00825_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00825_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="ev__QGW_II_I_825"><rs type="fn" role="issuer"><rs type="person" ref="pe__jakob_von_tierna_QGW_II_I_825">Jacob von Tierna, <roleName type="occ" corresp="org__oesterreich-herzogtum">chellermaister</roleName> in
                        Oesterreich und <roleName type="occ" corresp="org__oesterreich-herzogtum" select="pl__wien">münzmaister</roleName> ze Wienne <roleName type="rep" corresp="pe__albrecht_herzog_von_oesterreich_QGW_II_I_1020"><add>an des Herzogs
                              Statt</add></roleName></rs></rs>, <triggerstring n="disp">beurkundet,
                     dass vor ihm <add>in rechtem perchtaiding ze
                     Gumpoltschirihen</add></triggerstring>, als er an des Herzogs Statt in rechtem
                  perchtaiding ze Gumpoltschirihen sass, <rs type="fn" role="other"><rs type="person" ref="pe__jakob_poll_QGW_II_I_770"><roleName type="title">her</roleName>
                        Jacob der Poll, <roleName type="occ" corresp="org__wien-st_maria_im_rathaus">chaplan</roleName> der chapellen Unser Frowen, gelegen in dem alten
                        Rathous ze Wienne, hern Ottenhaiem (!) seligen Stiftung</rs> , <triggerstring n="fn">mit Vorsprechen</triggerstring></rs>
                  <triggerstring n="disp">gefordert habe</triggerstring> die gewer eins weingarten,
                  gelegen ze Gumpoltschirihen pei dem Pru/endlein zenechst der geistleichen frown
                  weingarten in der Sperr dacz der Neunstat, <rs type="event" ref="ev__QGW_II_I_825_men_1">der seiner
                     Kapelle nach dem <rs type="person" ref="pe__simon_QGW_II_I_825"><roleName type="dead">Tode</roleName>
                        <roleName type="title">hern</roleName> Simons, <roleName type="occ" corresp="org__langenwang-pfarre">pharrer</roleName> ze Langenwankch</rs>,
                     entsprechend dem von dessen<rs type="person" ref="pe__konrad_von_wuldesdorf_QGW_II_I_825">
                        <roleName type="kin" corresp="pe__simon_QGW_II_I_825">Oheim</roleName>
                        Chunrad von Wuldestorf, weilent <roleName type="prof">chamerschreiber</roleName></rs>, beurkundeten Testamente ledig geworden
                     sei</rs>. Dementgegen habe gleichfalls auf Grund von Urkunden <rs type="fn" role="other"><rs type="person" ref="pe__heinrich_QGW_II_I_825"><roleName type="title">pruder</roleName> Hainreich, <roleName type="occ" corresp="org__neuberg-zisterzienser">abt</roleName> des chlosters dacz
                        dem Neunperg</rs></rs>, <triggerstring n="fn">Anspruch
                     <add>erhoben</add></triggerstring> auf diesen Weingarten erhoben. Nach Verlesung
                  der Urkunden habe aber der Abt erkannt, dass seine Urkunden nichtig seien, und in
                  Folge dessen <triggerstring n="disp">spricht <add>zu</add></triggerstring> der
                  Kellermeister den Weingarten der <rs type="fn" role="recipient"><rs type="org" ref="org__wien-st_maria_im_rathaus">Rathauskapelle</rs></rs> zu.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_825"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="pe__jakob_von_tierna_QGW_II_I_825">Aussteller</rs>.</rs></rs></p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. ff. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>