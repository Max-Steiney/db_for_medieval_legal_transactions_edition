               <rs type="event" ref="ev__QGW_II_I_295"><rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_zeller_StB_I_39">Ulreich der Zeller, <roleName type="occ" corresp="pe__johanna_von_pfirt_QGW_II_I_304">chuchenmaister</roleName>
                        der <rs type="person" ref="pe__johanna_von_pfirt_QGW_II_I_304"><roleName type="title">herzoginne</roleName> Johanna ze Oesterreich</rs></rs>,
                     und <rs type="person" ref="pe__margarethe_QGW_II_I_295">Margret, seine
                           <roleName type="kin" corresp="pe__ulrich_zeller_StB_I_39">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">geben <add>ze
                        rechter morgengabe</add></triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="pe__leopold_von_hagenberg_QGW_II_I_295"><roleName type="title">Bergherrn</roleName>
                        <roleName type="title">hern</roleName> Leutolts von Hakkenberch</rs></rs>
                  <rs type="fn" role="recipient">ihrem <rs type="person" ref="pe__berthold_poll_QGW_II_I_121"><roleName type="kin" corresp="pe__ulrich_zeller_StB_I_39">Eidam</roleName><roleName type="kin" corresp="pe__margarethe_QGW_II_I_295"><add>Eidam</add></roleName>
                        <roleName type="title">hern</roleName> Perichtolden dem Pollen</rs></rs>
                  zu/e <rs type="person" ref="pe__katharina_QGW_II_I_295">seiner <roleName type="kin" corresp="pe__berthold_poll_QGW_II_I_121">hausvrowen</roleName>
                     <roleName type="title">vron</roleName> Katrein, ihrer <roleName type="kin" corresp="pe__ulrich_zeller_StB_I_39">Tochter</roleName><roleName type="kin" corresp="pe__margarethe_QGW_II_I_295"><add>Tochter</add></roleName></rs>, ze
                  rechter morgengabe nach des landes recht ze Oesterreich ein Joch Weingarten, der
                  da leit ze Nidern Su/efringe an dem Hornsperge und haisset der Minnestain,
                  zenaehst hern Reimprechtes weingarten des Zaunru/eden, da man von dem egenanten
                  weingarten alle iar dient zwen emmer weins ze perchrecht und 2 dn. ze voitrecht
                  .</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_295"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="pe__ulrich_zeller_StB_I_39">des
                        Ausstellers</rs>, 2. <rs type="person" ref="pe__leopold_von_hagenberg_QGW_II_I_295">des Bergherrn</rs>, 3. <rs type="person" ref="pe__konrad_von_regensburg_QGW_II_I_295">Chunrates von
                     Regenspurch</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>