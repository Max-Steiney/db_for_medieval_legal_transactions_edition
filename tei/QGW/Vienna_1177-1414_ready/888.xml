               <rs type="event" ref="ev__QGW_II_I_888"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_von_der_heiligenstadt_QGW_II_I_879">Janns von der Heiligenstat, <roleName type="occ" corresp="org__wien">purger ze Wienne</roleName></rs>,
