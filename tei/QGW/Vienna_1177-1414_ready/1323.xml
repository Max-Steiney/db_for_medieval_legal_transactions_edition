            <origDate instant="false">ze Wienn, an sand Pauls abent, als er bechert wart.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01323_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01323_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1323"><rs type="fn" role="issuer"><rs type="person" ref="pe__andreas_bei_dem_freithof_QGW_II_I_1323">Andre an sand Peters
                        freithof, <roleName type="occ" corresp="org__wien">purger</roleName>
                        ze Wienn, und <roleName type="rep" corresp="pe__johann_posch_QGW_II_I_1076">ausrichter und
                           volfürer des geschäftz</roleName></rs>, so <rs type="person" ref="pe__johann_posch_QGW_II_I_1076"><roleName type="title">her</roleName> Hanns der
                        Posch, <unclear instant="false">weilnt des probsts chaplan</unclear>, an
                     <roleName type="dead">seinen lesten Zeiten</roleName> getan hat</rs></rs>, <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__paul_holzkaeufel_QGW_II_I_1010"><roleName type="title">hern</roleName> Pauln des Holzchäufels, <roleName type="occ" corresp="org__wien">purgermaister</roleName></rs>, und des <rs type="org" ref="org__wien">rates gemain der stat ze Wienn</rs></rs>, ein Haus, gelegen
                  in der Hindern Schulstrass ze Wienn zwischen dem haus, das weilnt Hansen von Veld
                  gewesen ist, und der schul dacz sand Nicla , <rs type="event" ref="ev__QGW_II_I_1323_men_1">von dem
                     man den Deutschenherren zu Wien 1 lb dn. und hern Christan, der von Tyrna
                     chaplan, zu einer ewigen Messe 4 ½ lb dn. zu Burgrecht dient</rs>, um 28 lb dn.
                     <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_waekkinger_QGW_II_I_1323"><roleName type="title">hern</roleName> Hansen dem Wäkkinger, <roleName type="occ" corresp="org__rainbach-pfarre">pharrer</roleName> ze Reinpach</rs>, und
                        <rs type="person" ref="pe__martin_freindorfer_QGW_II_I_1323"><roleName type="title">hern</roleName> Merten dem Freindorfer, <roleName type="occ" corresp="org__jedenspeigen-pfarre">pharrer</roleName> ze
                     Ydungspeuge</rs></rs>.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1323"><rs type="fn" role="witness">Besiegelt mit
                     dem Siegel des <rs type="person" ref="pe__andreas_bei_dem_freithof_QGW_II_I_1323">Ausstellers</rs>, dem <rs type="org" ref="org__wien">städtischen
                        Grundsiegel</rs> und dem Siegel des <rs type="person" ref="pe__ulrich_ekprecht_QGW_II_I_1149">Wiener <roleName type="occ" corresp="org__wien">Bürgers</roleName> Ulreichs des
                  Ekprechts</rs></rs>.</rs></p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>