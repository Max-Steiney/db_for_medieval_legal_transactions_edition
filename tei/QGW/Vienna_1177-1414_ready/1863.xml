   <text>
      <body>
         <div type="abstract" resp="cs">
            <p>
               <rs type="event" ref="ev__QGW_II_I_1863"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__dietrich_von_stetteldorf_QGW_II_I_1863"><roleName
                           type="title">Bru/eder</roleName> Dietreich von Steteldorf, <roleName
                           type="occ" corresp="org__wien-dominikaner">prior</roleName>,</rs> und <rs
                        type="org" ref="org__wien-dominikaner">der convent gemain dacz den Predigern
                        ze Wienn</rs></rs>
                  <triggerstring n="disp">bestätigen</triggerstring>, dass <rs type="fn" role="recipient"
                        ><rs type="person" ref="pe__erhard_schierl_QGW_II_I_1845"><roleName
                           type="title">her</roleName> Erhart der Schierl, <roleName type="occ" corresp="org__wien-st_stephan">korherr</roleName> zu
                        sand Stephan ze Wienn und <roleName type="occ"
                           corresp="org__nappersdorf-pfarre">pharrer</roleName> ze
                           Naperstorf<roleName type="rep"
                           corresp="pe__leonhard_schaur_QGW_II_I_1242"
                           ><add>geschefftherren</add></roleName></rs>, <rs type="person"
                        ref="pe__paul_geir_QGW_II_I_1406"><roleName type="title">her</roleName> Paul
                        der Geyr<roleName type="rep" corresp="pe__leonhard_schaur_QGW_II_I_1242"
                              ><add>geschefftherren</add></roleName></rs>, <rs type="person"
                        ref="pe__wolfgang_purkchartsperger_QGW_II_I_1560"><roleName type="title"
                           >her</roleName> Wolfgang der Purkcharczperger, baid des <roleName
                           type="occ" corresp="org__wien">rats</roleName> der stat ze Wienn<roleName
                           type="rep" corresp="pe__leonhard_schaur_QGW_II_I_1242"
                              ><add>geschefftherren</add></roleName></rs>, und <rs type="person"
                        ref="pe__heinrich_starkch_StB_I_62">Hainreich der Starkch, <roleName type="occ" corresp="org__wien">purger</roleName> daselbs, <roleName
                           type="rep" corresp="pe__leonhard_schaur_QGW_II_I_1242"
                           >geschefftherren</roleName> des geschêfts</rs></rs>, so <rs type="person"
                     ref="pe__leonhard_schaur_QGW_II_I_1242"> weilent .. . <roleName type="title"
                        >her</roleName> Leonhart Schaur, <roleName type="prof"> lerer geistleicher
                        rechten</roleName>
                     <roleName type="dead">seliger</roleName>, </rs>getan hat, ihnen für dessen
                  Seelenheil 31 lb dn. <triggerstring n="disp">gegeben haben</triggerstring>, und
                     <triggerstring n="disp">verpflichten sich</triggerstring> zur Abhaltung eines
                  Jahrtages an dem Sonntage Judica in der Fasten, beziehungsweise acht Tage vor oder
                  nachher.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_I_1863"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person"
                        ref="pe__dietrich_von_stetteldorf_QGW_II_I_1863">Priors</rs> und des <rs
                        type="org" ref="org__wien-dominikaner">Conventes</rs></rs>.</rs>
            </p>
