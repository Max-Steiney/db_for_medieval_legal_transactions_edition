      <text>
            <body>
                  <div type="abstract" resp="lp">
                        <p>
                              <rs type="event" ref="ev__QGW_II_I_199"><rs type="fn" role="issuer"
                                                ><rs type="person"
                                                ref="pe__vromut_von_kaja_QGW_II_I_199"><roleName
                                                  type="title">Swester</roleName> Vromu/et von
                                                Cheiawe, <roleName type="occ"
                                                  corresp="org__tulln-dominikanerinnen"
                                                  >priorinne</roleName></rs>, und <rs type="org"
                                                ref="org__tulln-dominikanerinnen">der convent gemain
                                                der vrowen in dem chloster ze Tullen Prediger
                                                ordens</rs></rs>
                                    <triggerstring n="disp">verkaufen</triggerstring> das Haus, <rs
                                          type="event" ref="ev__QGW_II_I_199_men_1">das ihr <rs
                                                type="person"
                                                ref="pe__heinrich_auf_der_saeule_QGW_II_I_199"
                                                  ><roleName type="occ"
                                                  corresp="org__tulln-dominikanerinnen">Schaffer
                                                </roleName>her Hainreich auf der Seule </rs>um
                                          versessenes Burgrecht in ihre Gewalt gebracht hat</rs>,
                                    das da leit ze Wienne an dem Alten Fleischmarcht an dem eke gen
                                    sande Larenzen chloster uber und das hern Chunrats des Gartner
                                    gewesen ist , auf dem sie 6 lb dn. Geldes Burgrechts haben, um
                                    34 lb dn. <rs type="fn" role="recipient"><rs type="person"
                                                ref="pe__berthold_poll_QGW_II_I_121"><roleName
                                                  type="title">hern</roleName> Pertholten dem
                                                Pollen, <roleName type="occ" corresp="org__wien">purger ze
                                                Wienne</roleName></rs>, und <rs type="person"
                                                ref="pe__margarethe_QGW_II_I_182"><roleName
                                                  type="kin"
                                                  corresp="pe__berthold_poll_QGW_II_I_121">seiner
                                                  Hausfrau</roleName> Margitten</rs></rs>.</rs>
                        </p>
                  </div>
                  <div type="seal">
                        <p><rs type="event" ref="ev__QGW_II_I_199">Das <rs type="fn" role="witness"
                                                ><rs type="person"
                                                ref="pe__vromut_von_kaja_QGW_II_I_199">Siegel der
                                                Priorin</rs> fehlt, das <rs type="org"
                                                ref="org__tulln-dominikanerinnen">des
                                          Convents</rs></rs> anhangend, spitzoval.</rs>
                        </p>
                  </div>
                  <div type="nota">
                        <p>Indorsat: Aufschrift des Magister Theodericus. N. </p>
                  </div>
