               <rs type="event" ref="ev__QGW_II_I_195"><rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_auf_der_donau_QGW_II_I_195">Ulreich auf Tunawe, <roleName type="occ" corresp="org__regensburg">purger</roleName> ze
                        Regenspurch,</rs>
                     <rs type="person" ref="pe__elisabeth_QGW_II_I_195">und Elsepeth, seine
                           <roleName type="kin" corresp="pe__ulrich_auf_der_donau_QGW_II_I_195">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring><rs type="person" ref="pe__ulrich_von_zyrberch_QGW_II_I_195"> ihres <roleName type="title">Bergherrn</roleName> des <roleName type="title">erbern</roleName> gaistlichen mannes <roleName type="title">pruder</roleName> Ulreichs von Zyrberch, <roleName type="occ" corresp="org__wien-deutsche_herren"> hauscomenteuer</roleName> datz dem
                        Deutschenhause ze Wienne</rs></rs> , ihres ledigen Kaufgutes ein Joch
                  Weingarten, der da leit ze Nidern Suffringen und haisset der Heuz/zz/ze zenaehste
                  der Deutschen Herren weingarten, davon man dient alle iar ze rechtem perchrecht in
                  dem lesen 22 dn ., um 40 Mark Silber Wiener Gewichts, je 72 grosse pehemischer
                  phenninge fur ain iglich march, <rs type="fn" role="recipient"><rs type="person" ref="pe__haunold_schuchler_QGW_II_I_170"><roleName type="title">hern</roleName> Haunolten dem Schuheler, <roleName type="occ" corresp="org__wien">purger </roleName>ze Wienne ,</rs>
                     <rs type="person" ref="pe__christine_QGW_II_I_195">und <roleName type="kin" corresp="pe__haunold_schuchler_QGW_II_I_170">seiner Hausfrau</roleName>
                        Christein.</rs></rs>
               </rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_195">Besiegelt mit den Siegeln: <rs type="fn" role="witness"><rs type="person" ref="pe__ulrich_auf_der_donau_QGW_II_I_195">1.
                        des Ausstellers,</rs>
                     <rs type="org" ref="org__wien-deutsche_herren">2. des Deutschen Hauses,</rs>
                     <rs type="person" ref="pe__konrad_seilniker_QGW_II_I_195">3. <roleName type="title">hern</roleName> Chunrats des Seilniker, der Elsbeth <roleName type="kin" corresp="pe__elisabeth_QGW_II_I_195">Oheim</roleName></rs>,
                     <rs type="person" ref="pe__heinrich_lang_QGW_II_I_193"> 4. <roleName type="title">hern</roleName> Hainreichs des Langen.</rs></rs>
               </rs></p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. L. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>