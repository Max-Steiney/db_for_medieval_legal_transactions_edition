                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__thomas_schaffer_QGW_II_I_1253">Tomans des Schaffer ze
                        Gumpolczkirchen, <roleName type="occ" corresp="org__mauerbach-kartaeuser">pergmaister</roleName> der erbern geistleichen herren ze
                        Allerheiligental ze Maurbach, des ordens von Karthus</rs></rs>, <triggerstring n="disp">seines Erbgutes</triggerstring> einen Weingarten, gelegen ze
