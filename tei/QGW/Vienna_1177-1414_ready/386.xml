      <text>
            <body>
                  <div type="abstract" resp="ks">
                        <p>
                              <rs type="event" ref="ev__QGW_II_I_386"><rs type="fn" role="issuer"
                                                ><rs type="person" ref="pe__elisabeth_QGW_II_I_386"
                                                >Elsbet, weiln <roleName type="kin"
                                                      corresp="pe__dietrich_urbetsch_QGW_II_I_950"
                                                  ><add>hausvrowe</add></roleName>
                                                <rs type="person"
                                                      ref="pe__dietrich_urbetsch_QGW_II_I_950"
                                                  ><roleName type="title">hern</roleName> Dietreichs
                                                  hausvrowe des Urbaetschen <roleName type="dead"
                                                  >saeligen</roleName></rs></rs></rs>, <triggerstring
                                          n="disp">verkauft</triggerstring>
                                    <rs type="fn" role="other"><triggerstring n="fn">mit
                                                Einwilligung</triggerstring> ihres <rs type="person"
                                                ref="pe__konrad_urbetsch_QGW_II_I_950"><roleName
                                                  type="kin" corresp="pe__elisabeth_QGW_II_I_386"
                                                  >Sohnes</roleName> Chunrats des Urbaetschen</rs>
                                          und ihrer <rs type="person"
                                                ref="pe__pilgrim_chitzel_QGW_II_I_386"><roleName
                                                  type="kin" corresp="pe__elisabeth_QGW_II_I_386"
                                                  >aidem</roleName>
                                                <roleName type="title">hern</roleName> Pilgreims des
                                                Chitzels, der gesessen ist ze der Neunstat</rs>, und
                                                <rs type="person"
                                                ref="pe__dietrich_flusthart_QGW_II_I_572"><roleName
                                                  type="kin" corresp="pe__elisabeth_QGW_II_I_386"
                                                  ><add>aidem</add></roleName>
                                                <roleName type="title">hern</roleName> Dietreichs
                                                des Flustharts, <roleName type="occ"
                                                  corresp="org__wien">purgermaister</roleName> ze
                                                Wienn</rs></rs> , und <rs type="fn" role="other"
                                                ><triggerstring n="fn">mit Handen</triggerstring> ihrer
                                                <rs type="person" ref="pe__kunigunde_QGW_II_I_456a"
                                                  ><roleName type="title">Grundfrau</roleName>
                                                <roleName type="title">vron</roleName> Chunigunden,
                                                  <roleName type="kin"
                                                  corresp="pe__herbert_auf_der_saeule_QGW_II_I_912"
                                                  ><add>wittibe</add></roleName>
                                                <rs type="person"
                                                  ref="pe__herbert_auf_der_saeule_QGW_II_I_912"
                                                  ><roleName type="title">hern</roleName> Herborts
                                                  <roleName type="dead">wittibe</roleName> auf der
                                                  Saeul</rs></rs></rs>, ein Haus, gelegen an ainem
                                    tail gegen sant Stephans freithof ze Wienn über, das ekkhaus das
                                    weiln gewesen ist Chunrats, des apoteker saelig, und an dem
                                    andern tail leit îz under den Goldsmiden zenaehst vrowen
                                    Elsbeten haus der Straiherinn, voders und hinders , das ihr in
                                    der Bürgerschranne für 10 lb 3 sh. 20 dn. versessenes Burgrecht
                                    und die zwispilde zugesprochen worden war, um an 24 dn.
                                    aindlefthalb phunt Wiener phening gelts purchrechts . . . <rs
                                          type="fn" role="recipient"><rs type="person"
                                                ref="pe__eberhard_eibansprunner_QGW_II_I_386"
                                                >Eberharten dem Eibansprunner</rs>, seiner <rs
                                                type="person" ref="pe__agnes_QGW_II_I_386"><roleName
                                                  type="kin"
                                                  corresp="pe__eberhard_eibansprunner_QGW_II_I_386"
                                                  >Hausfrau</roleName> Agnesen</rs> und <rs
                                                type="person"
                                                ref="pe__friedrich_graesl_QGW_II_I_386">Fridreichen
                                                dem Graeslein</rs></rs>.</rs>
                        </p>
                  </div>
                  <div type="seal">
                        <p><rs type="event" ref="ev__QGW_II_I_386"><rs type="fn" role="witness"
                                          >Besiegelt mit den Siegeln: 1. der <rs type="person"
                                                ref="pe__elisabeth_QGW_II_I_386">Ausstellerin</rs>,
                                          2. der <rs type="person" ref="pe__kunigunde_QGW_II_I_456a"
                                                  ><roleName type="title">Grundfrau</roleName></rs>,
                                          3. des <rs type="person"
                                                ref="pe__konrad_urbetsch_QGW_II_I_950">Sohnes der
                                                Ausstellerin</rs> und 4. <rs type="person"
                                                ref="pe__pilgrim_chitzel_QGW_II_I_386"
                                                  ><add>Eidame</add></rs>, 5. ihrer <rs
                                                type="person"
                                                ref="pe__dietrich_flusthart_QGW_II_I_572"
                                                >Eidame</rs></rs>.</rs>
                        </p>
