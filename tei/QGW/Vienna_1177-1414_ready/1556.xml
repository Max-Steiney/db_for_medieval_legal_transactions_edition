               <rs type="event" ref="ev__QGW_II_I_1556"><rs type="fn" role="issuer"><rs type="person" ref="pe__margarethe_QGW_II_I_1556">Margret, <rs type="person" ref="pe__berthold_lang_QGW_II_I_1488">Perchtolts des Lanngen <roleName type="dead"><add>witib</add></roleName></rs>
                        <roleName type="kin" corresp="pe__berthold_lang_QGW_II_I_1488">witib</roleName>, die nu <rs type="rs" ref="pe__johann_geresteiner_QGW_II_I_1488">Hannsen den
                           Gerolcztenner</rs>
                        <roleName type="kin" corresp="pe__johann_geresteiner_QGW_II_I_1488">eleichen</roleName> genomen hat</rs>,</rs>
                  <triggerstring n="disp">stellt</triggerstring>
                  <rs type="fn" role="recipient">ihrem <rs type="person" ref="pe__johann_geresteiner_QGW_II_I_1488">Manne</rs></rs>
                  <triggerstring n="disp">einen Schuldbrief</triggerstring> über 600 lb dn. <triggerstring n="disp">aus</triggerstring>, <rs type="event" ref="ev__QGW_II_I_1556_men_1">die den geltern
                     gevallen sind an der grossen swern ehaften notgu/elt, in der sie ihr erster
                     Mann gelassen hätte,</rs>
                  <triggerstring n="disp">und verpfändet</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_geresteiner_QGW_II_I_1488">ihm</rs></rs>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="pe__haunold_schuchler_QGW_II_I_1557"><roleName type="occ" corresp="org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Haunolts des Schuchler</rs> und des
                        <rs type="org" ref="org__wien">rats gemain der stat ze Wienn</rs></rs> ihr
                  Haus, an ainem tail gelegen bei Peilertor ze Wienn und an dem andern tail an sand
                  Peters freithof zenechst Jacobs haus des Suez/zz/zen.</rs>
