               <rs type="event" ref="ev__QGW_II_I_1007"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_von_scharfenberg_QGW_II_I_1007"><roleName type="occ" corresp="org__passau-dioezese">Bischof</roleName> Johann von
                     Passau</rs></rs>
                  <triggerstring n="disp">beurkundet</triggerstring>, dass <rs type="fn" role="recipient"><rs type="person" ref="pe__elisabeth_QGW_II_I_1007">Elspet, <rs type="person" ref="pe__pilgrim_straiffinch_ii_QGW_II_I_1007">Pilgreims des Straiffing
                              <roleName type="dead"><add>witib</add></roleName></rs>
                        <roleName type="kin" corresp="pe__pilgrim_straiffinch_ii_QGW_II_I_1007">witibe</roleName>,
                        des <rs type="person" ref="pe__niklas_wuerfel_QGW_II_I_1001"><roleName type="title">ersamen vesten ritter</roleName> Niclas des Würfels</rs>
                        <roleName type="kin" corresp="pe__niklas_wuerfel_QGW_II_I_1001">tochter</roleName></rs></rs> , ihm mit einer Verbriefung Bischof Albrechts von
                  Passau <triggerstring n="disp">bewiesen habe</triggerstring>, <rs type="event" ref="ev__QGW_II_I_1007_men_1">dass ihr <rs type="person" ref="pe__johann_straiffinch_QGW_II_I_1007"><roleName type="kin" corresp="pe__elisabeth_QGW_II_I_1007">sweher</roleName> Hanns
                        der Straiffing</rs> ihr für 600 lb dn. den halben Zehent ze Haimburch <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                        <rs type="person" ref="pe__albrecht_bischof_von_passau_QGW_II_I_1007"><roleName type="occ" corresp="org__passau-dioezese">Bischof</roleName> Albrechts</rs></rs>
                     <triggerstring n="disp">zu rechter Morgengabe verschrieben habe</triggerstring></rs>,
                  und <triggerstring n="disp">bestätigt sie als Lehensherr in diesem
                     Besitze</triggerstring>.</rs>
