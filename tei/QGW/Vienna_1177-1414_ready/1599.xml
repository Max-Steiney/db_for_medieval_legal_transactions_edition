   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_I_1599"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__peter_angerfelder_QGW_II_I_1373">Peter der
                        Angervelder, <roleName type="occ" corresp="org__wien">statrichter</roleName>
                        ze Wienn</rs>,</rs>
                  <triggerstring n="disp">beurkundet, dass vor ihm in der Bürgerschranne</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="pe__salomon_QGW_II_I_1606"
                        >Salman der Jud, <rs type="person" ref="pe__mair_jude_QGW_II_I_1535">maister
                           Maireins</rs>
                        <roleName type="kin" corresp="pe__mair_jude_QGW_II_I_1535">sun</roleName>,
                           <add>anstat</add></rs>
                     <triggerstring n="fn">mit vorsprechen</triggerstring> anstat</rs> der zwaier <rs
                     type="person" ref="pe__hansuezz_QGW_II_I_1599">Jüdinn Hannsuessen, <rs
                        type="person" ref="pe__steuzz_jude_QGW_II_I_1599">Steussen</rs>
                     <roleName type="kin" corresp="pe__steuzz_jude_QGW_II_I_1599"
                     >tochter</roleName></rs>, und <rs type="person" ref="pe__riffka_QGW_II_I_1599"
                     >Riffka, <rs type="person" ref="pe__abraham_QGW_II_I_1599"><roleName
                           type="title">maister</roleName> Abrahams</rs>
                     <roleName type="kin" corresp="pe__abraham_QGW_II_I_1599"
                     >hausfraun</roleName></rs>, der paider ganzen und vollen gewalt er het ze flust
                  und ze gewinn, <rs type="fn" role="other"><triggerstring n="fn">hinz</triggerstring><rs
                        type="person" ref="pe__johann_siedendorfer_QGW_II_I_1600"> Hannsen dem
                        Siedendorfer, dem <roleName type="prof">chürsner</roleName></rs>,</rs> umb
                  40 lb dn ., die er der egenanten Hannsuez/zz/zen gelten solt, und umb 12 lb dn.,
                  die er der egenanten Riffka gelten solt, und umb allen den gesuech, der auf die
                  vorgenanten 52 lb dn. gegangen wer nach des Judenpuchs sag ze Wienn, <triggerstring
                     n="disp">geklagt</triggerstring> und dass er dafür ein verpot als Erster auf des
                  Schuldners Haus, gelegen in der Su/enigerstrass ze Wienn zenechst der padstuben,
                  und als Zweiter auf der vorundhab genommen <triggerstring n="disp">habe</triggerstring>.
                  Er macht <rs type="fn" role="recipient">den <rs type="person"
                        ref="pe__salomon_QGW_II_I_1606">Kläger <roleName type="rep"
                           corresp="pe__hansuezz_QGW_II_I_1599">anstatt</roleName>
                        <roleName type="rep" corresp="pe__riffka_QGW_II_I_1599"
                           ><add>anstatt</add></roleName></rs></rs> der genannten zwaier Jüdinn des
                  Hauses und der fahrenden Habe gewaltig.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_I_1599"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="pe__peter_angerfelder_QGW_II_I_1373"
                     >Aussteller</rs>.</rs></rs></p>
