            <placeName>Wien</placeName>
            <date when="13540920">1354 IX 20</date>
            <origDate instant="false">ze Wienne, an sant Matheus abent, des heiligen zwelifpoten und
               ewangelisten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00457_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00457_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="ev__QGW_II_I_457"><rs type="fn" role="issuer"><rs type="person" ref="pe__heinrich_schuster_QGW_II_I_457">Hainreich der Schuster von Obern
                        Su/efring</rs>, <rs type="person" ref="pe__katharina_QGW_II_I_457">Katrei,
                        seine <roleName type="kin" corresp="pe__heinrich_schuster_QGW_II_I_457">Hausfrau</roleName>,</rs> und <rs type="person" ref="pe__otto_schuster_QGW_II_I_457">Otte, ihr <roleName type="kin" corresp="pe__heinrich_schuster_QGW_II_I_457">Sohn</roleName>
                        <roleName type="kin" corresp="pe__katharina_QGW_II_I_457">
                           <add>Sohn</add></roleName></rs>,</rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="pe__jakob_pfaffstetter_QGW_II_I_438"><roleName type="title">Bergherrn</roleName>
                        <roleName type="title">hern</roleName> Jacobs des Phaffsteter</rs></rs> ein
                  Drittel Joch Weingarten, der da leit ze Obern Su/efring an dem Mitterperg an ainem
                  tail zena/echst Andres weingarten, Ebergers sun, und an dem andern tail zenaechst
                  Ulreichs weingarten des Stolczs , belastet mit 1 Eimer Wein Bergrecht und 1 dn.
                  Voitrecht, um 24 lb dn. <rs type="fn" role="recipient">
                     <rs type="person" ref="pe__walter_sachs_QGW_II_I_457"><roleName type="title">hern</roleName> Walthern dem Sachsen <roleName type="occ" corresp="org__nuernberg"><add>purger</add></roleName></rs> und <rs type="person" ref="pe__heinrich_chraft_QGW_II_I_457"><roleName type="title">hern</roleName> Hainrichen dem Chraft <roleName type="occ" corresp="org__nuernberg"><add>purger</add></roleName></rs>, baid purger
                     ze Nu/erenberch, und <rs type="person" ref="pe__berthold_halbherr_QGW_II_I_457"><roleName type="title">hern</roleName> Perchtolden dem
                           Halbherren<roleName type="occ" corresp="org__augsburg">
                           <add>purger</add></roleName></rs> und <rs type="person" ref="pe__johann_godinne_QGW_II_I_457"><roleName type="title">hern</roleName>
                        Jansen dem Godune <roleName type="occ" corresp="org__augsburg">
                           <add>purger</add></roleName></rs>, baid purger ze Auspurch ,</rs>
                  <triggerstring n="disp">für die <add>gestiftete Messe</add></triggerstring>
                  <rs type="fn" role="recipient">von <rs type="person" ref="pe__heinrich_diener_QGW_II_I_436">Hainreich, weiln<roleName type="occ" corresp="pe__ulrich_haller_QGW_II_I_436"><add>schreiber</add></roleName>
                        <rs type="person" ref="pe__ulrich_haller_QGW_II_I_436"><roleName type="title">hern</roleName> Ulreichs Schreiber des Haller von
                           Nu/erenberch</rs></rs>, letztwillig in <rs type="org" ref="org__wien-st_maria_im_rathaus-messe_heinrich_haller_von_nuernberg">Unser Vrowen chappelln in der purger Rathaus ze Wienne,hern Otten Haim
                        Stiftung saelig, gestiftete Messe</rs>, deren <rs type="person" ref="pe__peter_von_meichsen_QGW_II_I_457"><roleName type="occ" corresp="org__wien-st_maria_im_rathaus-messe_heinrich_haller_von_nuernberg">Verweser</roleName> her Peter von Meichsen ist</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_457"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="person" ref="pe__jakob_pfaffstetter_QGW_II_I_438">1. des
                        Bergherrn</rs>, 2. <rs type="person" ref="pe__heinrich_wuerfel_QGW_II_I_459"><roleName type="title">hern</roleName> Hainreichs des Würfels,</rs> 3.
                        <rs type="person" ref="pe__siegfried_reicholf_QGW_II_I_1242"><roleName type="title">hern</roleName> Seifrits, gesessen an des herzogen
                           stat in der Slagstuben ze Wienne.</rs></rs></rs>
            </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. E. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>