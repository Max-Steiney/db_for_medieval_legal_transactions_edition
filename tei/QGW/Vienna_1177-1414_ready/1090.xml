            <origDate instant="false">ze Wienn, an sand Johanns abende ze Sunnbenden.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01090_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01090_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="ev__QGW_II_I_1090"><rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_rokk_QGW_II_I_1090"><roleName type="title">Bru/eder</roleName> Ulreich der Rokk, <roleName type="occ" corresp="org__wien-dominikaner">prior</roleName></rs> , und <rs type="org" ref="org__wien-dominikaner">der convent gemain der geistleichen
                        herren chloster dacz den Predigern ze Wienn</rs></rs>
                  <triggerstring n="disp">bestätigen</triggerstring>, dass <rs type="fn" role="recipient"><rs type="person" ref="pe__elisabeth_QGW_II_I_1090"><roleName type="title">Frau</roleName> Elspet <roleName type="kin" corresp="pe__kuno_fuetrer_QGW_II_I_1090"><add>witib</add></roleName></rs>, <rs type="person" ref="pe__kuno_fuetrer_QGW_II_I_1090">Chuenn <roleName type="dead">wittib</roleName>, des
                           <roleName type="prof" cert="unknown">fuetrer</roleName></rs></rs>, ihrem
                  Kloster letztwillig einen Weingarten, gelegen ze Gumpolzkirchen und haisset der
                  Aichperger, zenechst der geistleichen herren weingarten von dem Heiligenchreuz,
                     <triggerstring n="disp">vermacht habe</triggerstring>, den sie <rs type="person" ref="pe__bernhard_esenhaimer_QGW_II_I_1090">Pernharten dem E/asenhaimer</rs> um 4 H dn.
                  geltes ewigs purchrechts verkauft haben. Sie <triggerstring n="disp">verpflichten
                     sich</triggerstring>, von diesen 4 lb dn. die Hälfte in die Kammer des Klosters zu
                  geben, für 1 lb dn. inner den nachsten acht tagen nach sand Jacobs tag im snit
                     <triggerstring n="disp">zum Seelenheile der Erblasserin einen Jahrtag zu
                     feiern</triggerstring>, ½ lb dn. für ihre Bruderschaft zum Ankaufe von Fischen an
                  dem Antlasstag zu verwenden und ½ lb dn. unter die Brüder zu vertheilen. Sollten
                  sie die Stiftung nicht ordentlich ausführen, so fällt der Betrag den Dürftigen im
                  <rs type="org" ref="org__wien-buergerspital">Bürgerspitale</rs> zu.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1090"><rs type="fn" role="witness">Besiegelt von
                        <rs type="person" ref="pe__ulrich_rokk_QGW_II_I_1090">Prior</rs> und <rs type="org" ref="org__wien-dominikaner">Convent</rs>.</rs></rs></p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>