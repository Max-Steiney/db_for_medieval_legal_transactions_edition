            <origDate instant="false">ze Wienne, an dem heiligen Ewenweichtage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00423_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00423_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p><rs type="event" ref="ev__QGW_II_I_423">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__niklas_lang_QGW_II_I_423">Niclas der
                        Lange, der <roleName type="prof">fleischhakcher</roleName></rs>, und <rs type="person" ref="pe__katharina_QGW_II_I_423">Katrei, seine <roleName type="kin" corresp="pe__niklas_lang_QGW_II_I_423">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__clemens_QGW_II_I_423">ihres <roleName type="title">Grundherrn</roleName> des <roleName type="occ" corresp="org__wien-schotten">Schottenabtes </roleName>Clemens</rs></rs>
                  ihr Haus, gelegen auf der Renngassen bei den Schotten ze Wienne an ainem tail an
                  dem ekk gegen der chapellen über zenechst dem smit und an dem andern tail zenechst
                  dem haus, das weilent Praentleins, des schilter, gewesen ist, (von dem man den
                  Schotten 72 dn. zu Grundrecht, hern Weichartes erben bei den Minnern brüdern ½ lb
                  dn., den Schotten 2 lb dn. und den geistlichen Frauen bei S. Niklas ½ lb dn. zu
                  Burgrecht dient,) um 38 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__heinrich_vaschang_QGW_II_I_423">Hainrichen dem Vaschange</rs> und <rs type="person" ref="pe__margarethe_QGW_II_I_423"> seiner <roleName type="kin" corresp="pe__heinrich_vaschang_QGW_II_I_423">Hausfrau</roleName> vron
                     Margreten</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_423"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="pe__clemens_QGW_II_I_423">des
                        Grundherrn</rs>, 2. <rs type="person" ref="pe__friedrich_goldschlager_QGW_II_I_423"><roleName type="title">hern</roleName> Fridreichs, des goltslaher,</rs>
                     3. <rs type="person" ref="pe__leopold_von_kamp_QGW_II_I_423"><roleName type="title">hern
                        </roleName>Leupolts von Champpe, <roleName type="occ" corresp="pe__weichart_von_topel_FRA_II_1308_II_25">schreiber</roleName>
                        des <rs type="person" ref="pe__weichart_von_topel_FRA_II_1308_II_25" cert="low"><roleName type="title">erbern herrn</roleName>
                           <roleName type="title">hern</roleName> Weicharts von Toppel, des
                              <roleName type="occ" corresp="org__oesterreich-herzogtum">lantrichter</roleName> in Österreich</rs></rs></rs> .</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>