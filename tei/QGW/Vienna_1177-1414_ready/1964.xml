   <text>
      <body>
         <div type="abstract">
            <p>
               <rs type="event" ref="ev__QGW_II_II_1964"><rs type="fn" role="issuer"><rs type="person" ref="pe__georg_von_zugraben_QGW_II_I_988">Jörg von Zunkgraben,
                        <roleName type="occ" corresp="org__st_veit-pfarre">pfarrer</roleName> dacz Sand Veit auf der Wienn</rs></rs>, <triggerstring n="disp">gibt</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> der <rs type="person" ref="pe__johanna_stuchsin_QGW_II_II_1947"><roleName type="title">Bergfrau</roleName> <roleName type="title">fraun</roleName>
                        Johanna der Stukssin von Trautmanstorff, <roleName type="occ" corresp="org__wien-st_klara">abbttissin</roleName> des fraunklosters dacz
                        sand Claren</rs></rs> , seines Kaufgutes zwei Weingärten, gelegen zu
                  Praitensee in dem Amaispach, deren einer ½ und 1/3 Joch (dient 3 sh. 10 dn. für
                  Bergrecht und Zehent, 5 dn. zu Voitrecht), der andere 3/8 misst (dient 46½ dn. für
                  Bergrecht und Zehent), <rs type="fn" role="recipient"><rs type="org" ref="org__wien-st_stephan">dem Capitel und den Chorherren Allerheiligen
                        tumkirchen dacz sand Stephan</rs></rs> zur Abhaltung eines Jahrtages.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_1964"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="pe__georg_von_zugraben_QGW_II_I_988">Ausstellers</rs> und der <rs type="person" ref="pe__johanna_stuchsin_QGW_II_II_1947">Bergfrau</rs>.</rs></rs></p>
         </div>
