   <text>
      <body>
         <div type="abstract">
            <p>
               <rs type="event" ref="ev__QGW_II_II_1922"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_von_dem_kamp_StB_I_106">Hans vom Kamp, des
                           <roleName type="occ" corresp="org__wien">rats</roleName> der stat zu
                        Wienn,</rs> und <rs type="person" ref="pe__dorothea_QGW_II_II_1922">Dorothe,
                        Chunrats des Grueber <roleName type="kin" corresp="pe__leopold_zichner_QGW_II_II_1922">hausfrau</roleName>, <rs type="person" ref="pe__leopold_zichner_QGW_II_II_1922">Leupolts <roleName type="dead">seligen</roleName> des Zichner</rs>
                        <roleName type="kin" corresp="pe__konrad_gruber_QGW_II_II_1922">tochter</roleName></rs></rs> , <triggerstring n="disp">stellen</triggerstring>
                  <rs type="fn" role="recipient">dem Bürgermeister und Rathe</rs> hinsichtlich der
                  mit dem Grundsiegel bestätigten Urkunde, <rs type="event" ref="NULL">mit der sie
                     das Haus, gelegen auf der Goldsmit, das weilnt Hannsen seligen des Greiffen
                     gewesen ist, zenechst Lienharts haus von Seveld, Mathesen, dem pinter , und
                     seiner Hausfrau Kathrein verkauft haben</rs>, <triggerstring n="disp">einen Revers
                     aus</triggerstring>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_1922"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="pe__ulrich_herwart_QGW_II_I_1098"><roleName type="occ" corresp="org__wien">Stadtschreibers</roleName>
                        Ulreich des Herwarts</rs> und des <rs type="person" ref="pe__wolfhard_pirchner_QGW_II_I_1789">Wiener <roleName type="occ" corresp="org__wien">Bürgers</roleName> Wolfharts des
                  Pirchner</rs>.</rs></rs>
            </p>
         </div>
