               <rs type="event" ref="ev__QGW_II_I_1839"><rs type="fn" role="issuer"><rs type="org" ref="org__bremgarten">Schultheiss und rät ze Bremgarten in
                        unser gnädigen herrschaf von Osterreich landen</rs></rs>
                  <triggerstring n="disp">schreiben</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="org__wien">dem Bürgermeister
                        und Rath der Stadt zu Wien</rs></rs>, dass <rs type="person" ref="pe__heinrich_von_altwis_QGW_II_I_1839">her Heinrich von Altwis, der
                     pfarrer ze Hugstorf</rs>, von tod abgangen ist ze Bolonii, der aber einen hof
                  und ander sin hab ze Wien hat , und dass sein nächster Erbe, ein bei ihrer Stadt
                  gesessener <rs type="person" ref="pe__rudolf_von_altwis_QGW_II_I_1839"><roleName type="prof">Priester</roleName>
                     <roleName type="title">her</roleName> Rudolf von Altwis</rs>, <rs type="person" ref="pe__heinin_noll_QGW_II_I_1839">Heinin Nollen, zeiger dits briefs, zu
                     seinem <roleName type="rep" corresp="pe__heinrich_von_altwis_QGW_II_I_1839">Bevollmächtigten</roleName></rs>
                  <triggerstring n="disp">bestellt habe</triggerstring>, den sie hiemit den Wienern
                     <triggerstring n="disp">empfehlen</triggerstring>.</rs>
