                        Ausstellers</rs>, <rs type="person" ref="pe__jakob_loeffler_QGW_II_I_505">2.
                        des Bergherrn</rs>, <rs type="person" ref="pe__johann_poll_QGW_II_I_850">3.
                           <roleName type="title">hern</roleName> Jansen des Pollen</rs>.</rs></rs>
