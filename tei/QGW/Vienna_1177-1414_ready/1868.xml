                        Wienn,</rs></rs>
                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="pe__albrecht_zetter_QGW_II_I_1577"><roleName type="occ" corresp="org__wien">Bürgermeisters</roleName> <roleName type="title">hern</roleName> Albrechts des
