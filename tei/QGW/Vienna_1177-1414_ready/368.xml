            <origDate instant="false">ze Wienne, an sande Agnesn tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00368_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00368_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="ev__QGW_II_I_368"><rs type="fn" role="issuer"><rs type="person" ref="pe__dietrich_flusthart_QGW_II_I_572">Dietreich der Flusthart, <roleName type="occ" corresp="org__wien">purgermaister</roleName></rs>, und <rs type="org" ref="org__wien">der rat gemain der stat ze Wienne</rs></rs>,
                     <triggerstring n="disp">bestätigen</triggerstring>, dass sie dem <rs type="fn" role="recipient"><rs type="person" ref="pe__niklas_von_ragelsdorf_QGW_II_I_1107">Nichlas von
                        Raechleinstorf</rs></rs> 3 sh. dn. geltes purchrechtes auf seinem Achtel
                  Weingarten, der da leit an dem Nuz/zperg, zenaehst dem weingarten, der gewesen ist
                  hern Hainreichs des Langen saelig , sammt dem versessenen Dienste aufgelassen
                  haben, wogegen er dem Spital gegeben hat das phunt geltes purchrechts, gelegen auf
                  Jo/erigen weingarten des Sa/euz/zer, gelegen ze Otakchrinn in dem Amaispach, des
                  dreu achttail sint, zenaehst Chu/enraden dem Payr, und der weiln Nichlas, des
                  Weigants aidem, gewesen ist, das <rs type="person" ref="pe__friedrich_von_ragelsdorf_QGW_II_I_793">sein <roleName type="kin" corresp="pe__niklas_von_ragelsdorf_QGW_II_I_1107">bruder</roleName>
                     Fridreich von Raechleinstorf <roleName type="dead">saelig</roleName></rs> mit
                  demselben rechten zu dem Spital geschafft hat .</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_368"><rs type="fn" role="witness">Besiegelt mit
                     des <rs type="org" ref="org__wien-buergerspital">Spitals anhangundem
                        insigil</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. p. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>