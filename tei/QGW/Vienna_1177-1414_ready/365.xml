            <placeName>Wien</placeName>
            <date when="13501209">1350 XII 09</date>
            <origDate instant="false">ze Wienne, des phinztags nach sant Nichlas
            tage.</origDate></creation></profileDesc></teiHeader><facsimile/><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="ev__QGW_II_I_365"><rs type="fn" role="issuer"><rs type="person" ref="pe__dietrich_flusthart_QGW_II_I_572">Dietreich der Flusthart, <roleName type="occ" corresp="org__wien">purgermaister</roleName></rs>, und <rs type="org" ref="org__wien">der rate gemaine der stat ze Wienne</rs></rs>
                  <triggerstring n="disp">verkaufen</triggerstring> für 120 lb dn. von den 400 lb 3 sh. 20
                  dn., <rs type="event" ref="ev__QGW_II_I_365_men_1">die der<rs type="person" ref="pe__heinrich_oeler_QGW_II_I_771">
                        <roleName type="occ" corresp="org__wien-buergerspital">Spitalmeister</roleName> Hainreich der Oeler</rs> dem Spitale in rechten
                     ehaften nöten geliehen hatte</rs>, dem genannten <rs type="fn" role="recipient"><rs type="person" ref="pe__heinrich_oeler_QGW_II_I_771">Spitalmeister</rs>
                     und seiner<rs type="person" ref="pe__margarethe_QGW_II_I_365">
                        <roleName type="kin" corresp="pe__heinrich_oeler_QGW_II_I_771">Hausfrau</roleName> Margreten</rs></rs> 12 lb dn. geltes purchrechtes,
                  die das Spital gehabt hat auf dem gewantcheller, der da leit an dem Hohenmarchte
                  under den geweihten Lauben ze Wienn zenaehst dem gewantcheller, der Lambers im
                  Strôhof gewesen ist, und auf dem Saithaus darauf , <rs type="event" ref="ev__QGW_II_I_365_men_2">mit
                     allem Nutzen, wie sie <rs type="person" ref="pe__martin_von_st_poelten_QGW_II_I_365">
                           Mert,<roleName type="kin" corresp="pe__hermann_von_st_poelten_QGW_II_I_118"><add>sun</add></roleName>
                        <rs type="person" ref="pe__hermann_von_st_poelten_QGW_II_I_118">hern Hermans
                           sun <roleName type="kin" corresp="pe__rudolfine_QGW_II_I_417"><add>ennichel</add></roleName><rs type="person" ref="pe__rudolfine_QGW_II_I_417">der Rudolffinne ennichel von Sant
                              Pölten <roleName type="dead">selig</roleName></rs></rs></rs>, dem
                     Spital geschafft hatte</rs>. Voran gehen diesen 12 lb dn. Burgrecht 10 sh. dn.,
                  die man alle iar davon dient den herren ze Maurbach für grundrecht und für
                  purchrecht, 5 sh. dn. Burgrecht hinz sant Johans in der Chaernerstrasse ze Wienne
                  und 2 lb dn. hinz sant Jacob ze Wienn.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_365"><rs type="fn" role="witness">Besiegelt mit
                        <rs type="org" ref="org__wien"> der Stadt chlainem anhangundem</rs> und <rs type="org" ref="org__wien-buergerspital">des Spitals anhangundem
                        insigil</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>