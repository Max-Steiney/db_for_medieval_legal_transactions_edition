               <rs type="event" ref="ev__QGW_II_I_994"><rs type="fn" role="issuer"><rs type="person" ref="pe__niklas_prechtel_QGW_II_I_994">Niclos der Prechtel</rs> und <rs type="person" ref="pe__eisal_QGW_II_I_994">Eisal, seine <roleName type="kin" corresp="pe__niklas_prechtel_QGW_II_I_994">Hausfrau</roleName></rs></rs> , <triggerstring n="disp">verkaufen</triggerstring><rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihrer <rs type="person" ref="pe__kunigunde_von_grinzing_QGW_II_I_777"><roleName type="title">Grundfrau</roleName>
