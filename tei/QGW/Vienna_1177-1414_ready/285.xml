               <rs type="event" ref="ev__QGW_II_I_285"><rs type="fn" role="issuer"><rs type="person" ref="pe__anna_QGW_II_I_285">Anne <roleName type="kin" corresp="pe__kunigunde_QGW_II_I_285"><add>Schwester</add></roleName>
                        <roleName type="kin" corresp="pe__dankward_QGW_II_I_285"><add>Schwester</add></roleName></rs> und <rs type="person" ref="pe__kunigunde_QGW_II_I_285">Chunigunt, ir <roleName type="kin" corresp="pe__anna_QGW_II_I_285">swester</roleName> von Neusedlicz
                           <roleName type="kin" corresp="pe__dankward_QGW_II_I_285"><add>Schwester</add></roleName></rs>, <rs type="person" ref="pe__dankward_QGW_II_I_285"><roleName type="title">maister</roleName>
                        Danchquartz swestern, <roleName type="dead">dem got
                     gnade</roleName></rs></rs> , <triggerstring n="disp">stellen</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__peter_golein_QGW_II_I_285"><roleName type="title">hern</roleName>
                        Petrein dem Golein, <roleName type="occ" corresp="org__wien">purger</roleName> ze Wienne</rs></rs>, <triggerstring n="disp">einen
                     Schuldbrief</triggerstring> über 16 lb dn. <triggerstring n="disp">aus</triggerstring>,
                  wovon sie einen Theil auf den chrieg, den sie wegen des nachher zu erwähnenden,
                  ihnen von ihrem Bruder angefallenen Weingartens hatten, ausgegeben, den Rest für
                  sich behalten haben. Sie <triggerstring n="disp">verpfänden</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__peter_golein_QGW_II_I_285">ihm</rs></rs> dafür <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__friedrich_von_st_ulrich_QGW_II_I_285">ihres
                           <roleName type="occ" corresp="pe__hagen_von_spielberg_QGW_II_I_118">Bergmeisters</roleName>
                        <roleName type="title">hern</roleName> Fridreiches von Sant
                           Ulreich,<roleName type="occ" corresp="pe__hagen_von_spielberg_QGW_II_I_118"><add>amptman</add></roleName>
                        <rs type="person" ref="pe__hagen_von_spielberg_QGW_II_I_118"><roleName type="title">hern</roleName> Hagens amptman von
                     Spilberch</rs></rs></rs>, ihren Weingarten zenaest hern Pilgreims weingarten,
                  des nadler, an dem Griez/z, bei dem Vrowenek ze Wienne, des ein hofstat ist , . .
                  . davon man alle jar dient in dem lesen 2 dn.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_285"><rs type="fn" role="witness">Besiegelt mit
