            <origDate instant="false">ze Wienn, des nächsten mittichens nach Mittervasten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01117_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01117_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="ev__QGW_II_I_1117"><rs type="fn" role="issuer"><rs type="person" ref="pe__wilhelm_wulzendorfer_QGW_II_I_1117">Wilhalm der
                     Wulzendorfer</rs></rs>
                  <triggerstring n="disp">beurkundet</triggerstring>, dass er das Haus, gelegen vor
                  Widmertor ze Wienn zenechst der padstuben, <rs type="fn" role="other"><triggerstring n="fn">für</triggerstring> sich und seine <rs type="person" ref="pe__georg_QGW_II_I_1117"><roleName type="kin" corresp="pe__wilhelm_wulzendorfer_QGW_II_I_1117">Brüder</roleName> Jörg</rs>, <rs type="person" ref="pe__erasmus_QGW_II_I_1117"><roleName type="kin" corresp="pe__wilhelm_wulzendorfer_QGW_II_I_1117"><add>Bruder</add></roleName>
                        Erasem</rs> und <rs type="person" ref="pe__leopold_QGW_II_I_1117"><roleName type="kin" corresp="pe__wilhelm_wulzendorfer_QGW_II_I_1117"><add>Bruder</add></roleName> Leupolt</rs>, die noch zu iren beschaiden
                     jarn nicht chomen sind</rs>, um 40 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__gottschalk_inprucker_ii_QGW_II_I_1117">Gotschalichen dem
                        lnprukker</rs></rs>
                  <triggerstring n="disp">verkauft habe</triggerstring>, und <triggerstring n="disp">setzt</triggerstring> diesem für die genannten drei Brüder 3 lb dn. gelts, wovon
                  2 lb dn. gelegen sind ze Mitterndorf auf einer mül und das dritt phunt ist gelegen
                  auf einem behausten lehen daselbens, da die zeit Niclas der Lachsendorfer auf
                  gesessen ist, ze ebenteur und ze scherm .</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1117"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="pe__wilhelm_wulzendorfer_QGW_II_I_1117">Ausstellers</rs>, 2. <rs type="person" ref="pe__wolfhard_pob_QGW_II_I_1011">Wolfharts des
                        Poben, <roleName type="occ" corresp="org__wien">statrichter</roleName> ze
                        Wienn</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>