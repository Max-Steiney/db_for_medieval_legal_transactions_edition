               <rs type="event" ref="ev__QGW_II_I_608"><rs type="fn" role="issuer"><rs type="person" ref="pe__niklas_QGW_II_I_608">Niclas, weiln <roleName type="occ" corresp="pe__friedrich_iii_herzog_von_oesterreich_QGW_II_I_853">marstaller</roleName>
                        <rs type="person" ref="pe__friedrich_iii_herzog_von_oesterreich_QGW_II_I_853"><roleName type="occ" corresp="org__oesterreich-herzogtum">herzog</roleName> Fridreichs <roleName type="dead">seligen</roleName>
