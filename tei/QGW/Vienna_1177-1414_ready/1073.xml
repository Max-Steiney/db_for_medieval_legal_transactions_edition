            <date when="13840827">1384 VIII 27</date>
            <origDate instant="false">ze Wienn, des sambstags vor sant Gilgen tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01073_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01073_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="ev__QGW_II_I_1073"><rs type="fn" role="issuer"><rs type="person" ref="pe__paul_holzkaeufel_QGW_II_I_1010">Paul der Holzcha/euffel, <roleName type="occ" corresp="org__wien">purgermaister</roleName></rs>, und der <rs type="org" ref="org__wien">rat gemain der stat ze Wienn</rs></rs>
                  <triggerstring n="disp">beurkunden, dass vor ihnen</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__friedrich_dietram_QGW_II_I_1026"><roleName type="title">her</roleName> Friedreich der Dietram, mit ihnen
                           <roleName type="occ" corresp="org__wien">gesworner des
                        rats</roleName></rs></rs>, <rs type="fn" role="other"><triggerstring n="fn">mit</triggerstring> dem <rs type="person" ref="pe__stephan_auf_dem_brunnen_QGW_II_I_1073"><roleName type="prof">Priester</roleName>
                        <roleName type="title">hern</roleName> Stephann auf dem Prunn von
                        Aspach</rs></rs>, <rs type="fn" role="other"><triggerstring n="fn">mit</triggerstring>
                     <rs type="person" ref="pe__johann_payr_QGW_II_I_1073">Hannsen dem Payr von
                     Dekkendorf</rs></rs> und <rs type="fn" role="other"><triggerstring n="fn">mit</triggerstring>
                     <rs type="person" ref="pe__erhard_von_kematen_QGW_II_I_1073">Erharten von Chemnaten, <rs type="person" ref="pe__johann_swaeml_QGW_II_I_1073">Hansen des Swêmbels</rs>
                        <roleName type="occ" corresp="pe__johann_swaeml_QGW_II_I_1073">locaten</roleName></rs></rs>, <rs type="fn" role="other"><triggerstring n="fn">das Geschäft</triggerstring> seiner <rs type="person" ref="pe__klara_QGW_II_I_1133"><roleName type="kin" corresp="pe__friedrich_dietram_QGW_II_I_1026">Hausfrau</roleName> Chlar, <roleName type="dead">der got genad</roleName></rs></rs>, <triggerstring n="disp"><add>das Geschäft</add> bewiesen habe</triggerstring>. Sie <triggerstring n="disp">hat geschafft</triggerstring>: 1. dass ihr Mann und <rs type="person" ref="pe__paul_ernst_QGW_II_I_1073">ihr <roleName type="kin" corresp="pe__klara_QGW_II_I_1133">Vetter</roleName> Paul Ernst</rs> den
                  Erlös für ihr Haus, gelegen an dem Harmarkcht ze Wienn zenechst der
                  Scho/ennaicherinn haus, für ihr Seelenheil anlegen sollen, dass aber <rs type="fn" role="recipient"><rs type="person" ref="pe__friedrich_dietram_QGW_II_I_1026">ihr
                     Mann</rs></rs> es auf Lebenszeit innehaben solle 2. des Hager chinden, <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_QGW_II_I_1073">Jansen <roleName type="kin" corresp="pe__margarethe_QGW_II_I_1073"><add>Bruder</add></roleName></rs>, <rs type="person" ref="pe__margarethe_QGW_II_I_1073">Margreten <roleName type="kin" corresp="pe__dorothea_QGW_II_I_1073"><add>Schwester</add></roleName></rs>, und <rs type="person" ref="pe__dorothea_QGW_II_I_1073">Dorothen</rs></rs>, ihre zwei Weingärten,
                  baid gelegen ze Gumpoltzchirichen, ainer auf der Jungen Staingrueb zenechst
                  Chu/enrats weingarten des Cheser und der ander bei dem dorf daselbens zenechst
                  Wernharts weingarten des Payrs .</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1073"><rs type="fn" role="witness">Besiegelt mit
                     der <rs type="org" ref="org__wien">Stadt ze Wienn chlainem anhangundem
                        insigil</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>