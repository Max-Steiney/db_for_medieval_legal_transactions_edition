   <text>
      <body>
         <div type="abstract" resp="lp">
            <p>
               <rs type="event" ref="ev__QGW_II_I_337"><rs type="fn" role="issuer"><rs type="person"
                        ref="pe__johann_sohlschneider_QGW_II_I_337">Jans, der <roleName type="prof"
                           >solsneider</roleName>, <roleName type="kin"
                              corresp="pe__marolt_sohlschneider_QGW_II_I_337"><add>aidem</add></roleName><rs type="person"
                           ref="pe__marolt_sohlschneider_QGW_II_I_337">Maroltes aidem , des
                              <roleName type="prof">solsneider</roleName></rs></rs>, und<rs
                        type="person" ref="pe__anna_QGW_II_I_337">Anne, seine <roleName type="kin"
                           corresp="pe__johann_sohlschneider_QGW_II_I_337"
                     >Hausfrau</roleName></rs></rs>, <triggerstring n="disp">bestätigen</triggerstring>,
                  dass sie <rs type="fn" role="other"><triggerstring n="fn">den Streit, den sie
                        mit</triggerstring><rs type="person" ref="pe__katharina_QGW_II_I_337"><roleName
                           type="title">Frau</roleName> Katrein, <roleName type="kin"
                           corresp="pe__gottfried_witz_QGW_II_I_337"><add>wittib</add></roleName><rs
                           type="person" ref="pe__gottfried_witz_QGW_II_I_337"><roleName
                              type="title">hern</roleName> Gotfrides seligen<roleName type="dead"
                              >wittib</roleName> des Witzen</rs></rs></rs>, umb 1 lb dn. geltes
                  purchrechts gehabt haben, das diese auf ihrem Hause in dem Lederhof, das weiln des
                  Hochspranch gewesen ist, zunaest Jansen dem Vedrer gehabt und früher von Frau
                  Perichten, Jacobs hausvrow in dem Lederhof, um 6 lb dn. gekauft hatte, <rs
                     type="fn" role="other"><triggerstring n="fn"><add>den
                        Streit</add>vor</triggerstring><rs type="person" ref="pe__pitrolf_QGW_II_I_337"
                           ><roleName type="title">maister</roleName>Pitrolfen, des pischolf
                           <roleName type="occ" corresp="org__passau-dioezese">amptman</roleName>
                        und <roleName type="occ" corresp="org__passau-dioezese">Verweser</roleName>
                        von Passau</rs></rs>, gebracht haben. Dieser<triggerstring n="disp"
                     >entscheidet</triggerstring> dahin, dass das Burgrecht auf 6 sh. dn.
                  herabgemindert werde, womit sich beide Theile einverstanden erklären.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_I_337"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person"
                        ref="pe__berthold_schuetzenmeister_QGW_II_I_153"><roleName type="title"
                           >obersten Grundherrn</roleName><roleName type="title">hern</roleName>
                        Perichtoltes, des Schutzenmaister sun, <roleName type="occ"
                           corresp="org__wien-buergerspital">spitalmaister</roleName> der purger
                        Spital zu Wienne</rs>, 2. <rs type="person"
                        ref="pe__bernhard_von_ybbs_QGW_II_I_337"><roleName type="title"
                           >hern</roleName> Pernhartes, des <roleName type="occ" corresp="org__wien"
                           >statschreiber</roleName> ze Wienne</rs></rs>.</rs>
            </p>
         </div>
