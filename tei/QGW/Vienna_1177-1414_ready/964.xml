            <date from="99999999" to="99999999"/>
            <origDate instant="false">ze Wienne, des sambztags nach sand Johanns tage ze
            Sunnwenden.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00964_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00964_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_964">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__andreas_chrephel_QGW_II_I_964">Andre der
                        Chrêphel</rs> und <rs type="person" ref="pe__elisabeth_QGW_II_I_964">Elsbet,
                        seine <roleName type="kin" corresp="pe__andreas_chrephel_QGW_II_I_964">Hausfrau</roleName></rs></rs> , <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="recipient"><triggerstring n="fn">mit Handen</triggerstring> ihres
                        <rs type="person" ref="pe__gilg_QGW_II_I_483"><roleName type="title">Grundherrn</roleName>
                        <roleName type="title">bruder</roleName> Giligen, <roleName type="occ" corresp="org__wien-deutsche_herren">comiteur</roleName> dacz dem
                        Deutschenhaus zu Wienne</rs></rs> , ihr Haus mit drei dazu gehörigen Bänken,
                  da man prot und fleisch auf vail hat, gelegen ze Grinzing zenechst Hainreichs haus
                  des To/elrer an ainem tail und an dem andern tail zenechst Stephans haus, des
                  fleischhacher , von dem man den Deutschen Herren 6 dn. zu Grundrecht und 1 lb dn.
                  zu Burgrecht dient, um 13 lb 60 dn. den <rs type="fn" role="recipient"><rs type="person" ref="pe__ulrich_pettziechen_QGW_II_I_1103"><roleName type="occ" corresp="org__wien">Wiener Bürgern</roleName> Ulreichen</rs> und <rs type="person" ref="pe__peter_pettziechen_QGW_II_I_964"><roleName type="occ" corresp="org__wien"><add>Wiener Bürger</add></roleName> Petrein <roleName type="kin" corresp="pe__ulrich_pettziechen_QGW_II_I_1103">gebrüdern</roleName> den
                        Pettziehen</rs></rs>
                  <rs type="fn" role="other"><triggerstring n="fn">zu</triggerstring> dem <rs type="org" ref="org__wien-st_maria_im_rathaus-messe_bettziehen">ewigen Lichte</rs>, das
                     deren <rs type="person" ref="pe__ortolf_pettziechen_QGW_II_I_1253"><roleName type="kin" corresp="pe__ulrich_pettziechen_QGW_II_I_1103">Vater</roleName> Ortolf mit der
                        Pettziehen</rs> in der capellen Unser Vrowen in der purger Rathaus ze Wienne
                     gestiftet hatte</rs>. Sie haben <triggerstring n="disp">zum Ankaufe
                     verwendet</triggerstring> 10 lb dn., für welche 1 lb dn. gelts, das zu dem ewigen
                  Lichte gehörte, von Pauln haus des Holzchaufels, gelegen an dem Chienmarkcht zu
                  Wienne gegen sand Rueprechts chirchen über, <rs type="event" ref="ev__QGW_II_I_964_men_1">das weiln
                     des egenanten Ortolfs und seiner erben gewesen ist , abgelöst worden war</rs>,
                  und 3 lb 60 dn., <rs type="event" ref="ev__QGW_II_I_964_men_2">welche der <rs type="person" ref="pe__jakob_poll_QGW_II_I_770"><roleName type="occ" corresp="org__wien-st_maria_im_rathaus">oberste Kaplan</roleName>
                        <roleName type="title">her</roleName> Jacob der Poll</rs> aus Eigenem
                     beigesteuert hatte</rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_964"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. der <rs type="org" ref="org__wien-deutsche_herren">Deutschen
                        Herren</rs>, 2. <rs type="person" ref="pe__thomas_swaeml_QGW_II_I_1012"><roleName type="title">hern</roleName> Thomans des Swemmbleins, des <roleName type="occ" corresp="org__wien">rats der stat ze Wienne</roleName></rs>,
                     3. <rs type="person" ref="pe__konrad_reicholf_QGW_II_I_1046">Chunrats des
                     Reicholfs</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: a) Aufschrift des Magister Theodericus. 4. b) 1450. 3am unus nomine
               Sigismundus junior Neunburgensis tenet. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>