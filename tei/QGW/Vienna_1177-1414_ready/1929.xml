   <text>
      <body>
         <div type="abstract">
            <p>
               <rs type="event" ref="ev__QGW_II_II_1929"><rs type="fn" role="issuer"><rs type="person" ref="pe__konrad_ernst_QGW_II_II_2048">Chuenrat Ernst</rs></rs>
                  <triggerstring n="disp">gelobt</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="org__wien">der ganzen gemain,
                        reichen und armen, der stat zu Wienn</rs></rs> wegen der venkchnuss, in die
                  ihn Bürgermeister, Richter und Rath von wegen merklicher sach, die er verschuldet
                  hatte, gelegt und aus der sie ihn durch got und vleissiger pet willen wieder
                  geledigt haben, <triggerstring n="disp">Urfehde</triggerstring>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_1929"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="pe__konrad_ernst_QGW_II_II_2048">Ausstellers</rs>, <rs type="person" ref="pe__paul_wuerfel_QGW_II_II_1928">Pauln des Würffl, <roleName type="occ" corresp="org__oesterreich-herzogtum">munssmaister</roleName></rs>, und <rs type="person" ref="pe__andreas_an_dem_st_petersfreithof_QGW_II_II_1929">Andren an sand
                        Peters freithof, <roleName type="occ" corresp="org__oesterreich-herzogtum">chellermaister</roleName> in Österreich</rs>
                  </rs>. </rs></p>
         </div>
