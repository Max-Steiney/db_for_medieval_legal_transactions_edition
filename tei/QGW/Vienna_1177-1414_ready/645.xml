               <rs type="event" ref="ev__QGW_II_I_645"><rs type="fn" role="issuer"><rs type="person" ref="pe__paul_maurer_QGW_II_I_645">Paul der Maurer, gesessen ze
                        Medlikch</rs>, und <rs type="person" ref="pe__mathilde_QGW_II_I_645">Mechthilt, seine <roleName type="kin" corresp="pe__paul_maurer_QGW_II_I_645">Hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__jakob_strasser_QGW_II_I_787">des <roleName type="occ" corresp="org__moedling">Bergmeisters</roleName> Jacobs des
                        Strasser ze Medlikch, <roleName type="occ" corresp="org__moedling">herzoglichen Unterbergmeisters</roleName></rs></rs>, ihres Kaufgutes
                  einen Weingarten, gelegen ze Medlikch bei der Urtail zenächst Otten weingarten von
                  Grinzingen, von dem man dem Herzoge 9 Viertel Wein gibmasse zu Bergrecht und 14 ½
                  dn. stekchenphenning dient, um 45 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__ulrich_von_aspern_QGW_II_I_652">dem <roleName type="prof">Priester</roleName>
                        <roleName type="title">hern</roleName> Ulreichen von Asparn, <roleName type="occ" corresp="org__wien-st_agnes_auf_der_himmelpforte-kapelle_st_katharina">Kaplan</roleName> der von ihm erbauten Katharinenkapelle im
                        Frauenkloster dacz der Himelporten ze Wienne</rs>, zu der <rs type="org" ref="org__wien-st_agnes_auf_der_himmelpforte-kapelle_st_katharina">zweiten
                        von ihm daselbst gestifteten Messe</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_645"><rs type="fn" role="witness">Besiegelt mit
                        <rs type="person" ref="pe__albrecht_schenk_QGW_II_I_599">dem herzoglichen
                        Bergsiegel, das her Albrecht der Schenk, des Herzogs <roleName type="occ" corresp="pe__albrecht_iv_herzog_von_oesterreich_QGW_II_I_1332">oberster
                           Kellermeister</roleName> in Oesterreich, innehat</rs> und mit dem <rs type="person" ref="pe__michael_cholb_QGW_II_I_936">Siegel Michels des
                        Cholben, <roleName type="occ" corresp="org__moedling">judenrichter</roleName> ze Medlikch</rs></rs>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>