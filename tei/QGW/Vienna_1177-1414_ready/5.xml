   <text>
      <body>
         <div type="abstract" resp="ks">
            <p><rs type="event" ref="ev__QGW_II_I_5">* <rs type="event" ref="NULL"><rs type="fn"
                        role="issuer"><rs type="person" ref="pe__seibot_QGW_II_I_5">Siboto,
                              <roleName type="prof">institor</roleName>, <roleName type="occ" corresp="org__wien">civis</roleName> Wiennensis </rs></rs>, hatte
                     einen Hof in Simaninge, genannt Maierhove, den <rs type="fn" role="recipient"
                           ><rs type="org"
                           ref="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen"
                           >Cisterciensernonnen bei S. Nikolaus</rs></rs> ausserhalb der Mauern um
                     72 lb dn. <triggerstring n="disp">verkauft</triggerstring>. </rs>
                  <rs type="person" ref="pe__seibot_QGW_II_I_5"><add>Siboto</add>
                     <roleName type="dead"><add>Tode</add></roleName></rs>
                  <rs type="event" ref="NULL">Nach seinem Tode <triggerstring n="disp"
                        >erhob</triggerstring>
                     <rs type="fn" role="issuer"><rs type="person"
                           ref="pe__ernst_von_als_QGW_II_I_5">Ernestus de Alse, der <roleName
                              type="kin" corresp="pe__gottfried_QGW_II_I_5">Sohn</roleName> des <rs
                              type="person" ref="pe__gottfried_QGW_II_I_5"><roleName type="title"
                                 >Bruders</roleName> Gottfried</rs></rs></rs>, <triggerstring n="disp"
                        >Erbansprüche</triggerstring> und brachte die <rs type="fn" role="other"
                           ><triggerstring n="fn">Streitsache vor</triggerstring>
                        <rs type="person" ref="pe__otto_von_perchtoldsdorf_QGW_II_I_8">Otto de
                           Perihtoldesdorf</rs> und die <rs type="org" ref="org__wien">Wiener
                           Bürger</rs></rs></rs> doch <triggerstring n="disp">verzichtet</triggerstring>
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__ernst_von_als_QGW_II_I_5"
                        >er</rs></rs> gegen Empfang von 10 lb dn. <triggerstring n="disp">für sich und
                     seine Erben auf alle Ansprüche</triggerstring>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_I_5"><rs type="fn" role="witness">Siegler: <rs
                        type="person" ref="pe__otto_von_perchtoldsdorf_QGW_II_I_8">Otto von
                        Perchtoldsdorf</rs> und die <rs type="org" ref="org__wien">Bürger von
                        Wien</rs></rs></rs>
            </p>
         </div>
         <div type="nota">
            <p>Indorsat: gleichzeitig super curiam villicalem in Simaeninge. </p>
         </div>
