            <date when="14111223">1411 XII 23</date>
            <origDate instant="false">Das ist geschehen, do man zalt von Kristi gepurde 1400 jar und darnach in dem
               11. jar, des mitwochen vor Weinachten. </origDate></creation></profileDesc></teiHeader><facsimile/><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1903a"><rs type="fn" role="issuer"><rs type="org" ref="org__passau">Bürgermeister, Richter, Rath und gemainklich die burger
                        der stat zu Passau</rs></rs>
                  <triggerstring n="disp">beurkunden</triggerstring> den von dem<rs type="fn" role="recipient">
                     <rs type="person" ref="pe__georg_von_passau_QGW_II_I_1292"><roleName type="occ" corresp="org__passau-dioezese">Bischof</roleName> Georg von
                        Passau</rs> und <rs type="person" ref="pe__ulrich_probst_QGW_II_I_1903a">Ulrich Brobst,
                        <roleName type="occ" corresp="org__regensburg">kamrer</roleName> zu Regensburg</rs>,</rs>
                  <rs type="fn" role="other"><triggerstring n="disp">zwischen</triggerstring>
                     <rs type="org" ref="org__passau">ihnen</rs> und dem <rs type="person" ref="pe__heinrich_von_bayern_QGW_II_II_3293"><roleName type="occ" corresp="org__bayern-herzogtum">Herzoge</roleName> Heinrich in
                     Bayern</rs></rs>
                  <triggerstring n="disp">vermittelten Vergleich,</triggerstring> dem zufolge die
                  niderlegung des Salzes in Passau für die Unterthanen des Herzogs aufgehoben wird,
                  die in dem Streite Gefangenen gegenseitig freigelassen und alle Streitigkeiten
                  zwischen den Leuten des Herzogs und den Passauern über liegendes oder fahrendes
                  Gut niedergeschlagen werden.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1903a"><rs type="fn" role="witness">Besiegelt mit
