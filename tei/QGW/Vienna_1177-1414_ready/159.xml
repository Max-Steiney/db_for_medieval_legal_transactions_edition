      <text>
            <body>
                  <div type="abstract" resp="lp">
                        <p>
                              <rs type="event" ref="ev__QGW_II_I_159"><rs type="fn" role="issuer"
                                                ><rs type="person"
                                                ref="pe__heinrich_unverzaget_QGW_II_I_159">Hainreich
                                                der Unverzaget</rs> und <rs type="person"
                                                ref="pe__gertrud_QGW_II_I_159">Gedraut, seine
                                                  <roleName type="kin"
                                                  corresp="pe__heinrich_unverzaget_QGW_II_I_159"
                                                  >Hausfrau</roleName></rs></rs>, <triggerstring
                                          n="disp">verkaufen</triggerstring>
                                    <rs type="fn" role="other"><triggerstring n="fn">mit
                                                Handen</triggerstring> ihres <rs type="person"
                                                ref="pe__michael_schoenhelfer_QGW_II_I_320"
                                                  ><roleName type="title">Grundherrn</roleName>
                                                Michels des Scho/enn Helfer, <roleName type="occ"
                                                  corresp="org__wien-st_johann_in_der_siechenals"
                                                  >maister</roleName> des hauses dacz Sand Johans
                                                der Siechen Alsse vor Schottentor</rs>
                                    </rs>, dem <rs type="fn" role="recipient"><rs type="person"
                                                ref="pe__hermann_chuedorfer_QGW_II_I_159"
                                                >geistlichen Manne <roleName type="title"
                                                  corresp="org__deutsche_herren">pruder</roleName>
                                                Hermannen dem Chuedorfer, <roleName type="occ"
                                                  corresp="org__deutsche_herren"
                                                  >comenteur</roleName> dacz dem Deutschenhaus ze
                                                Wienne</rs>, und <rs type="org"
                                                ref="org__deutsche_herren">seiner
                                          Bruderschaft</rs></rs> 2 lb dn. Geldes ewiges Burgrechtes
                                    auf ihrem Hause, das da leit an dem Neuen marchte ze Wienne
                                    zenaechst Hainrichs haus, des pader, von dem man an ainen
                                    helbelinch 20 dn. zu Grundrecht und den Deutschen Herren 1 lb
                                    dn. zu Burgrecht dient, um 20 lb dn.</rs>
                        </p>
                  </div>
                  <div type="seal">
                        <p><rs type="event" ref="ev__QGW_II_I_159"><rs type="fn" role="witness"
                                          >Besiegelt mit dem Siegel von <rs type="org"
                                                ref="org__wien-st_johann_in_der_siechenals">S.
                                                Johannes</rs> und dem des <rs type="person"
                                                ref="pe__reinhard_zaunruede_QGW_II_I_297"><roleName
                                                  type="title">Ritters</roleName>
                                                <roleName type="title">hern</roleName> Reinhartes
                                                des Zaunruden.</rs></rs></rs>
                        </p>
                  </div>
