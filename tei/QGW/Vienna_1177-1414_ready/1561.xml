    <text>
        <body>
            <div type="abstract" resp="kg">
                <p>
                    <rs type="event" ref="ev__QGW_II_I_1561"><rs type="fn" role="issuer"><rs
                                type="person" ref="pe__johann_von_ernstbrunn_QGW_II_I_1466">Hanns
                                von Ernsprunn, <roleName type="occ" corresp="org__klosterneuburg-augustiner_chorherren"
                                    >cho/erherr</roleName> Unser Vraun gotshaus ze Neunburch
                                klosterhalben</rs></rs>, <triggerstring n="disp"
                        >bestätigt</triggerstring>, <rs type="fn" role="recipient">von <rs
                                type="person" ref="pe__katharina_QGW_II_I_1561"><rs type="person"
                                    ref="pe__ulrich_von_fellabrunn_QGW_II_I_1561">Ulreichen
                                    Velenbrunner <roleName type="dead">sa/eligen</roleName></rs>
                                <roleName type="kin"
                                    corresp="pe__ulrich_von_fellabrunn_QGW_II_I_1561"
                                    >tachter</roleName> wegen, junkchfraun Kathrein, die noch nicht
                                vogtpa/erig ist</rs></rs>, 25 lb dn., <rs type="event"
                            ref="ev__QGW_II_I_1561_men_1">welche ihm der genannte Ulreich schuldete
                            und für die ihm ein Haus, gelegen ze Wienn an dem Harmarcht gegen Paul
                            Ernsten padstuben über, verpfändet war</rs>, <triggerstring n="disp"
                            >erhalten zu haben</triggerstring>.</rs>
                </p>
            </div>
            <div type="seal">
                <p><rs type="event" ref="ev__QGW_II_I_1561"><rs type="fn" role="witness">Besiegelt:
                            1. mit dem petschad des <rs type="person"
                                ref="pe__johann_von_ernstbrunn_QGW_II_I_1466">Ausstellers</rs>, da
                            er eigens insigels nicht enhat, und den Siegeln 2. <rs type="person"
                                ref="pe__servatius_tutz_QGW_II_I_1561">Cirvosen des Tu/etzen
                                    <roleName type="occ" corresp="org__klosterneuburg"
                                        ><add>purger ze Neunburch</add></roleName></rs>, 3. <rs
                                type="person" ref="pe__johann_stekch_ii_QGW_II_I_1561">Hannsen des
                                Steckchen, paid <roleName type="occ" corresp="org__klosterneuburg">purger ze
                                Neunburch</roleName></rs>.</rs></rs>
                </p>
            </div>
            <div type="nota">
                <p><rs type="event" ref="NULL">Indorsat: Ein quittbrief umb XXV tl. von hern Hannsen
                        von Ernsprunn, die im von Petreins haus des Helffants gevalln sind.</rs>
                </p>
            </div>
