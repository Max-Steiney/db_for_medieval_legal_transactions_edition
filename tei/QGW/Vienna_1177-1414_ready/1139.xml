            <origDate instant="false">Der geben ist ze Wienne an sand Angnesen tag, nach Kristi geburd 1300 jar
               darnach in dem 88. jare. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01139_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01139_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1139"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_von_mayerhofen_QGW_II_I_1081"><roleName type="rep" corresp="pe__heinrich_meinhard_von_goerz_und_kirchberg_vi_QGW_II_I_1139"><add>gerhab</add></roleName>
                        <roleName type="rep" corresp="pe__johann_meinhard_von_goerz_und_kirchberg_vii_QGW_II_I_1139"><add>gerhab</add></roleName> Johanns, <roleName type="occ" corresp="org__gurk-dioezese">bischof</roleName> ze Gurk</rs></rs>,
                     <triggerstring n="disp">beurkundet, dass</triggerstring> er als gerhab der <rs type="person" ref="pe__heinrich_meinhard_von_goerz_und_kirchberg_vi_QGW_II_I_1139"><roleName type="title">hochgeborn herrn</roleName>, <roleName type="title">graf</roleName>
                     <rs type="person" ref="pe__heinrich_meinhard_von_goerz_und_kirchberg_vi_QGW_II_I_1139">Hainreichs <add>Meinhart von Göprcz</add></rs> und <rs type="person" ref="pe__johann_meinhard_von_goerz_und_kirchberg_vii_QGW_II_I_1139"><roleName type="title"><add>hochgeborn herrn</add></roleName>
                        <roleName type="title">graf</roleName> Johanns Meinhart von Görcz</rs></rs>,
                  mit <rs type="fn" role="recipient"><rs type="org" ref="org__wien">dem
                        Bürgermeister , dem Richter , dem Rathe und der ganzen gemain der stat ze
                        Wienne</rs></rs> wegen des Geldes, das die Stadt dem Vater seiner Mündel,
                     <rs type="person" ref="pe__meinhard_von_goerz_vi_QGW_II_I_1139"><roleName type="kin" corresp="pe__heinrich_meinhard_von_goerz_und_kirchberg_vi_QGW_II_I_1139"><add>Vater</add></roleName>
                     <roleName type="kin" corresp="pe__johann_meinhard_von_goerz_und_kirchberg_vii_QGW_II_I_1139"><add>Vater</add></roleName>
                     <roleName type="title">graf</roleName> Meinharten von Görcz, <roleName type="dead">sêliger gedêchtnu/esse</roleName></rs>, von dem gewöhnlichen
                  Dienste, den sie den Herren von Görz wegen eines Darlehens von 6000 lbdn. zu
                  reichen hat, schuldig geblieben ist, abgerechnet habe, und bestätigt, dass die
                  Stadt bis Montag vor den nächstvergangenen Weihnachten (1387 December 23) 1050 lb
                  dn. schuldig war, die <triggerstring n="disp">ihm als dem Stellvertreter seiner
                     Mündel ausbezahlt worden sind.</triggerstring></rs></p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>