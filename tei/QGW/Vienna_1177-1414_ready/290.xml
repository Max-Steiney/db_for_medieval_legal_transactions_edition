   <text>
      <body>
         <div type="abstract" resp="lp">
            <p>
               <rs type="event" ref="ev__QGW_II_I_290"><rs type="fn" role="issuer"><rs type="person"
                        ref="pe__dietrich_urbetsch_QGW_II_I_950">Dietreich der Urbaetsch</rs></rs>
                  schafft <rs type="fn" role="other"><triggerstring n="fn">mit</triggerstring>
                     <rs type="person" ref="pe__elisabeth_QGW_II_I_386">seiner <roleName type="kin"
                           corresp="pe__dietrich_urbetsch_QGW_II_I_950">Hausfrau</roleName>
                        Elspet</rs> und seiner Erben <triggerstring n="fn">Willen</triggerstring></rs>,
                  sowie <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__johann_greiffe_QGW_II_I_390">seines <roleName
                           type="title">Grundherrn</roleName> des <roleName type="title"
                           >Ritters</roleName>
                        <roleName type="title">hern</roleName> Jansen des Greiffen</rs></rs>
                  <triggerstring n="disp"><add>schafft zu einer ewigen Messe</add></triggerstring> für <rs
                     type="fn" role="other"><rs type="person"
                        ref="pe__dietrich_urbetsch_QGW_II_I_950">sein</rs>, <rs type="person"
                        ref="pe__elisabeth_QGW_II_I_386">seiner Frau Elsbet</rs> und <rs
                        type="person" ref="pe__petra_QGW_II_I_290">seiner <roleName type="dead"
                           >ersten</roleName>
                        <roleName type="kin" corresp="pe__dietrich_urbetsch_QGW_II_I_950"
                           >Hausfrau</roleName> Petersen, <rs type="person"
                           ref="pe__leubmann_vesmann_QGW_II_I_209">hern Leubmans des V/ez/zmannes
                              <roleName type="dead">saeligen</roleName></rs>
                        <roleName type="kin" corresp="pe__leubmann_vesmann_QGW_II_I_209"
                           >tochter</roleName></rs>, <triggerstring n="fn">Seelenheil</triggerstring></rs>
                  an dreissig siben lb dn. geltes ewiges purchrechtes (auf zwain heusern, auf dem
                  alten Waghaus an dem Harmarkcht, das jetzund Ulreiches des Churtzmannes ist, 6 lb
                  dn., das das naest und das erst purchrecht ist, das man alle iar davon dienen
                  schol nach drin phenning gruntrechtes und nach drin Schilling phenning
                  purchrechtes hinz der pharr hinz sand Stephan . . ., di andern siben sh. dn.
                  purchrechtes . . . auf dem neun Waghaus an dem Harmarkcht gegen des alten
                  Wulfestorfer haus über, das jetzund hern Sighartes des Prunner ist) <rs type="fn"
                     role="recipient">in di chappellen hinz Unser Vrowen dacz hern Otten dem Haimen,
                     das jetzund das Rathaus haisset, auf <rs type="org"
                        ref="org__wien-st_maria_im_rathaus-altar_st_leonhard">sand Lienhartes</rs>
                     und <rs type="org" ref="org__wien-st_maria_im_rathaus-altar_jodocus">sand
                        Jostes alter</rs></rs> zu einer ewigen Messe, <triggerstring n="impl_rules">mit
                     der Bestimmung, dass die Gült hern Jacoben dem Pollen, Kaplan der genannten
                     Kapelle, und nach dessen Ableben dem jeweiligen Bürgermeister geleistet und von
                     diesen dem Priester hern Hainrreichen, beziehungsweise nach dessen Tode einem
                     andern Priester gegeben werden solle</triggerstring>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_I_290"><rs type="fn" role="witness">Besiegelt von:
                        <rs type="person" ref="pe__dietrich_urbetsch_QGW_II_I_950"> 1. dem
                        Aussteller</rs>, <rs type="person" ref="pe__johann_greiffe_QGW_II_I_390">2.
                        dem Grundherrn</rs>, <rs type="person" ref="pe__simon_QGW_II_I_290">3. dem
                           <roleName type="occ" corresp="pe__dietrich_urbetsch_QGW_II_I_950"
                           >Beichtiger</roleName> des Ausstellers <roleName type="title"
                           >hern</roleName> Simon, <roleName type="occ"
                           corresp="org__wien-st_stephan">chormaister</roleName> datz sand Stephan
                        ze Wienne</rs>, <rs type="person"
                        ref="pe__wilhelm_bei_dem_brunnen_QGW_II_I_289">4. dem <roleName type="kin"
                           corresp="pe__dietrich_urbetsch_QGW_II_I_950">Oheim</roleName> des
                        Ausstellers <roleName type="title">hern</roleName> Wilhalm bei dem
                        Prunne</rs>.</rs></rs>
            </p>
         </div>
