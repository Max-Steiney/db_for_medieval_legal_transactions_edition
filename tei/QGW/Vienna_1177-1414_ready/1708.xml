   <text>
      <body>
         <div type="abstract" resp="cs">
            <p>
               <rs type="event" ref="ev__QGW_II_I_1708"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__peter_grueber_QGW_II_I_1708">Peter der
                     Grueber</rs></rs>
                  <triggerstring n="disp">schreibt</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="org__wien">dem Bürgermeister
                        und Rath zu Wien</rs></rs>, <rs type="event" ref="NULL">dass er <rs
                        type="person" ref="pe__peter_grueber_QGW_II_I_1674">seinen <roleName
                           type="kin" corresp="pe__peter_grueber_QGW_II_I_1708">Vetter</roleName>
                        Peter den Grueber, purger ze Wienn,</rs>
                     <triggerstring n="disp">bevollmächtigt habe</triggerstring>, das Haus, gelegen ze
                     Wienn pei der Himelporten, das er von <rs type="person"
                        ref="pe__andreas_schoendl_QGW_II_I_1708">Andree dem Schonndlein</rs> und
                     dessen <rs type="person" ref="pe__margarethe_QGW_II_I_1708"><roleName
                        type="kin" corresp="pe__andreas_schoendl_QGW_II_I_1708">Hausfrau</roleName>
                        Marigreden</rs> um 60 lb dn., wovon 20 lb dn. bezahlt, 40 lb dn. aber auf
                     das Haus in dem Grundbuch vorgemerkt worden waren, gekauft hatte, und von dem
                     er jährlich 2 lb dn. zu dem jartag Niclas von Ofen seligen und 3 lb dn. der
                     genannten fraun Marigreden diente</rs>, <triggerstring n="disp">zu
                     verkaufen</triggerstring>. Da nun das Haus um 46 lb dn. verkauft worden ist, so
                     <triggerstring n="disp">verfügt</triggerstring> er, dass 40 lb dn. bei dem Grundbuche
                  erlegt werden sollen, um das Haus frei zu machen, den Rest aber sein Vetter
                  einnehmen solle.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_I_1708"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="pe__peter_grueber_QGW_II_I_1708"
                     >Aussteller</rs>.</rs></rs></p>
