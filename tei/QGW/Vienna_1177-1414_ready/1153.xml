                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__michael_geukramer_QGW_II_I_1137"><roleName type="title">hern</roleName> Michels des Geuchramer, <roleName type="occ" corresp="org__wien">purgermaister</roleName> und <roleName type="occ" corresp="org__oesterreich-herzogtum" select="pl__wien">münzmaister</roleName></rs>, und des <rs type="org" ref="org__wien">rates gemain der stat ze Wienn</rs></rs> den Antheil, den seine <rs type="person" ref="pe__elisabeth_QGW_II_I_1153"><roleName type="kin" corresp="pe__wolfhard_chramer">Hausfrau</roleName> Elsbet</rs> und <rs type="person" ref="pe__peter_QGW_II_I_1153_b">ihr <roleName type="kin" corresp="pe__elisabeth_QGW_II_I_1153">Bruder</roleName> Petrein</rs> an dem
                  Hause, gelegen in dem Greutt vor Stubentor ze Wienn zenechst Paldweins haus, des
                  ledrer, haben, das <rs type="person" ref="pe__johann_ledrer_QGW_II_I_1153">Jans, der
                        <roleName type="prof">ledrer</roleName></rs>, seinen <rs type="fn" role="recipient"><rs type="person" ref="pe__peter_QGW_II_I_1153_a"><roleName type="kin" corresp="pe__johann_ledrer_QGW_II_I_1153">Kindern</roleName>
                        <roleName type="kin" corresp="pe__konrad_QGW_II_I_1153"><add>Brüdern</add></roleName>Petrein</rs> und <rs type="person" ref="pe__konrad_QGW_II_I_1153"><roleName type="kin" corresp="pe__johann_lederer"><add>Kinder</add></roleName>
                        Chunraten</rs></rs>, <rs type="event" ref="ev__QGW_II_I_1153_men_1">sowie den
                     Geschwisterkindern seiner <rs type="person" ref="pe__katharina_QGW_II_I_1153"><roleName type="dead">früheren</roleName>
                        <roleName type="kin" corresp="pe__wolfhard_chramer">Hausfrau</roleName>
                        Kathrein</rs>, Elsbet und Petrein, geschafft hatte</rs>, um 24 lb dn. den
                  beiden vorgenannten Brüdern.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1153"><rs type="fn" role="witness">Besiegelt : 1.
                     mit dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs>, 2. mit dem
                     Siegel des <rs type="person" ref="pe__stephan_leitner_QGW_II_I_1012">Wiener <roleName type="occ" corresp="org__wien">Bürgers</roleName> Stephans des
                        Leitner</rs></rs></rs>.</p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>