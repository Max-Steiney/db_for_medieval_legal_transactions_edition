            <origDate instant="false">ze Wienn, des nachsten mantags nach sand Ulreichs tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01156_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01156_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1156"><rs type="fn" role="issuer"><rs type="person" ref="pe__rudolf_von_tierna_QGW_II_I_1351">Ruodolf von Tierna, <roleName type="occ" corresp="org__oesterreich-herzogtum">hubmaister</roleName> in
                        Österreich</rs>, <rs type="person" ref="pe__ludwig_von_tierna_QGW_II_I_1351"><roleName type="kin" corresp="pe__rudolf_von_tierna_QGW_II_I_1351"><add>bruder</add></roleName>
                        Ludweig <add>von Tierna</add></rs> und <rs type="person" ref="pe__paul_von_tierna_QGW_II_I_1156">Paul von Tierna, sein <roleName type="kin" corresp="pe__rudolf_von_tierna_QGW_II_I_1351">brüder</roleName></rs></rs>, <triggerstring n="disp">beurkunden</triggerstring>, dass <rs type="person" ref="pe__johann_von_tierna_QGW_II_I_1018">ihr <roleName type="kin" corresp="pe__rudolf_von_tierna_QGW_II_I_1351">Vater</roleName>
                     <roleName type="kin" corresp="pe__ludwig_von_tierna_QGW_II_I_1351"><add>Vater</add></roleName>
                     <roleName type="kin" corresp="pe__paul_von_tierna_QGW_II_I_1156"><add>Vater</add></roleName>
                     <roleName type="title">her</roleName> Hanns von Tierna, weilnt auch <roleName type="occ" corresp="org__oesterreich-herzogtum">hubmaister</roleName> in
                     Österreich, <roleName type="dead">dem got genad</roleName></rs>, <rs type="person" ref="pe__ulrich_zinkk_QGW_II_I_1066a">Ulreichen dem Zinkken, des <roleName type="occ" corresp="org__wien">rates</roleName> der stat ze Wienn</rs>, das
                  haus, das vor alter der Kamerhof gewesen ist, gelegen zwischen der gassen hinder
                  der Slachstuben und der Münzerstrasse ze Wienn , gegeben hat. Da aber diese
                  Vergabung nicht verbrieft worden war, so <triggerstring n="disp">bestätigen</triggerstring> sie das von ihrem Vater abgeschlossene Geschäft <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__michael_geukramer_QGW_II_I_1137"><roleName type="title">hern</roleName> Michels des Geuchramer, <roleName type="occ" corresp="org__wien">purgermaister</roleName> und <roleName type="occ" corresp="org__oesterreich-herzogtum" select="pl__wien">münzmaister</roleName></rs>, und des <rs type="org" ref="org__wien">rates gemain der stat ze Wienn</rs></rs> und <triggerstring n="disp">stellen
                     darüber eine Urkunde aus</triggerstring>.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1156"><rs type="fn" role="witness">Besiegelt : 1.,
                     2., 3. mit den Siegeln der <rs type="person" ref="pe__rudolf_von_tierna_QGW_II_I_1351">Aussteller</rs>
                     <rs type="person" ref="pe__ludwig_von_tierna_QGW_II_I_1351"><add>Aussteller</add></rs>
                     <rs type="person" ref="pe__paul_von_tierna_QGW_II_I_1156"><add>Aussteller</add></rs>, 4. mit
                     dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>