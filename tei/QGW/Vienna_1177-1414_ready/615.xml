                     <triggerstring n="disp">stellen <add>einen Schuldbrieg aus</add></triggerstring>
                  <rs type="fn" role="recipient">dem <rs type="person" ref="pe__konrad_von_stegen_QGW_II_I_1102">Chunraten von Stegen, <roleName type="occ" corresp="org__steyr">purger</roleName> ze Steyr</rs>,
