          <rs type="event" ref="ev__QGW_II_I_225"><rs type="fn" role="issuer"><rs type="person" ref="pe__andreas_von_sparbach_QGW_II_I_225">Andre von Sparbach</rs> und <rs type="person" ref="pe__adelheid_QGW_II_I_225">O/elhait, seine <roleName type="kin" corresp="pe__andreas_von_sparbach_QGW_II_I_225">Hausfrau</roleName></rs>,</rs>
            <triggerstring n="disp">verkaufen</triggerstring>
            <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="pe__ulrich_QGW_II_I_225"><roleName type="title">Bergherrn</roleName>
                <roleName type="title">hern</roleName> Ulreiches, <roleName type="occ" corresp="org__achau-pfarre">pharrer</roleName> datz Aichau</rs></rs>, ein Pfund
            Wiener Pfenninge <triggerstring n="disp">geltes purchrechtes</triggerstring> auf ihrem
            Weingarten, der do leit in dem Hauerveld und haisst der Smogan, zenegst des Lechner
            weingarten, do man alle jar von dient in dem lesen dem egenanten erbern priester hern
            Ulreichen . . . anderthalben emmer wein ze perchrecht und drei helbling ze voitrecht, um
            7 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__haunold_schuchler_QGW_II_I_170"><roleName type="title">hern</roleName>
                Haunolden dem Schuechler, <roleName type="occ" corresp="org__wien">purger</roleName> ze Wienn</rs></rs>.</rs>
