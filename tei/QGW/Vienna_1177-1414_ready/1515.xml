               <rs type="event" ref="ev__QGW_II_I_1515"><rs type="fn" role="issuer"><rs type="person" ref="pe__dorothea_QGW_II_I_1513">Dorothe, <rs type="person" ref="pe__georg_pollnheimer_QGW_II_I_1011"><roleName type="title">hern</roleName>
                           Jo/ergen des Pallnhaimer</rs>
                        <roleName type="kin" corresp="pe__georg_pollnheimer_QGW_II_I_1011">witib</roleName></rs>,</rs>
                  <triggerstring n="disp">stiftet</triggerstring> eine ewige Messe <rs type="fn" role="recipient">auf <rs type="org" ref="org__wien-st_stephan">Unser Fraun altar,
                        gelegen auf dem Lector dacz sand Stephan ze Wienn</rs></rs>, <rs type="fn" role="other"><triggerstring n="fn">deren Lehenschaft sie nach ihrem
                        Tode</triggerstring> ihren <rs type="person" ref="pe__georg_haeusler_QGW_II_I_1515"><roleName type="kin" corresp="pe__dorothea_QGW_II_I_1513">Vettern</roleName> Jorg</rs>, <rs type="person" ref="pe__johann_haeusler_QGW_II_I_1515"><roleName type="kin" corresp="pe__dorothea_QGW_II_I_1513"><add>Vettern</add></roleName>
                        Hanns</rs> und <rs type="person" ref="pe__friedrich_haeusler_QGW_II_I_1515"><roleName type="kin" corresp="pe__dorothea_QGW_II_I_1513"><add>Vettern</add></roleName> Fridreich den Heuslern</rs> und nach deren
                     Ableben dem <rs type="org" ref="org__wien">Rathe der Stadt zu Wien</rs>
                     überträgt</rs>, und zu der sie zwei Weingärten, und zwar 1 ½ Joch, gelegen ze
                  Grinzingen zenêchst des Stainer weingarten, genant die Glokken, und drei Viertel,
                  gelegen in dem Nuspach zenechst dem weingarten, der weilent Pauln des
                  Wagendruz/zz/zl gewesen ist , widmet.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1515"><rs type="fn" role="witness">Besiegelt mit
