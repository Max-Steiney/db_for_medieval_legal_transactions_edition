            <date when="13510303">1351 III 03</date>
            <origDate instant="false">ze Wienne, des phinztags in der ersten vir tagen in der
               Vasten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00372_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00372_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="ev__QGW_II_I_372"><rs type="fn" role="issuer"><rs type="person" ref="pe__niklas_chiener_QGW_II_I_372">Niclas der Chienaer auf der Widem zu
                        Wienne</rs></rs>
                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> seines <rs type="person" ref="pe__bernhard_schenk_QGW_II_I_372"><roleName type="occ" corresp="org__oesterreich-herzogtum">Bergmeisters</roleName>
                        <roleName type="title">hern</roleName> Wernharts des Schenkchen, <roleName type="occ" corresp="org__oesterreich-herzogtum">vorstmaister</roleName>
                        in Österreich</rs></rs>, aus êhafter not wegen der Schulden, die ihm seine
                     <rs type="person" ref="pe__christine_QGW_II_I_372"><roleName type="kin" corresp="pe__niklas_chiener_QGW_II_I_372">Hausfrau</roleName> Christein
                        <roleName type="dead">hinterlassen</roleName></rs> hat, drei Viertel
                  Weingarten, gelegen in dem Aetzleinsperg zenechst Chu/enrats weingarten, des
                  pekchen, do man alle jar von dient hern Wernhart, dem forstmaister in
                  O/esterreich, anderthalben emmer weins ze perchrecht und dritthalben dn. ze
                  voitrecht und vrowen Elsbeten, der Chronpergerinne schaferinne, 12 sh. dn. ze
                  purchrecht , um 13 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__ulrich_seidenswancz_QGW_II_I_372">Ulreichen dem Seidenswantz</rs>,
                     dessen <rs type="person" ref="pe__katharina_QGW_II_I_372_a"><roleName type="kin" corresp="pe__ulrich_seidenswancz_QGW_II_I_372">Hausfrau</roleName> Katrein</rs>, <rs type="person" ref="pe__georg_QGW_II_I_372">Jo/ergen, des <rs type="person" ref="pe__trutschler_QGW_II_I_372">Tru/etschler</rs>
                        <roleName type="kin" corresp="pe__trutschler_QGW_II_I_372">aidem</roleName></rs>, und seinem <rs type="person" ref="pe__niklas_QGW_II_I_372_b"><roleName type="kin" corresp="pe__georg_QGW_II_I_372">Bruder</roleName> Niclasen</rs>.</rs>
                  <rs type="fn" role="other">Der <rs type="person" ref="pe__niklas_chiener_QGW_II_I_372">Aussteller <roleName type="rep" corresp="pe__niklas_chiener_QGW_II_I_372"><add>im
                           Namen</add></roleName><roleName type="rep" corresp="pe__margarethe_QGW_II_I_372"><add>im
                           Namen</add></roleName><roleName type="rep" corresp="pe__ulrich_QGW_II_I_372"><add>im Namen</add></roleName><roleName type="rep" corresp="pe__niklas_QGW_II_I_372_a"><add>im
                           Namen</add></roleName><roleName type="rep" corresp="pe__katharina_QGW_II_I_372_b"><add>im
                        Namen</add></roleName></rs> und <rs type="person" ref="pe__margarethe_QGW_II_I_372">seine <roleName type="kin" corresp="pe__niklas_chiener_QGW_II_I_372">Frau</roleName> Margret
                           <roleName type="rep" corresp="pe__niklas_chiener_QGW_II_I_372"><add>im
                              Namen</add></roleName><roleName type="rep" corresp="pe__margarethe_QGW_II_I_372"><add>im
                           Namen</add></roleName><roleName type="rep" corresp="pe__ulrich_QGW_II_I_372"><add>im Namen</add></roleName><roleName type="rep" corresp="pe__niklas_QGW_II_I_372_a"><add>im
                           Namen</add></roleName><roleName type="rep" corresp="pe__katharina_QGW_II_I_372_b"><add>im
                        Namen</add></roleName></rs><triggerstring n="fn">als Schirm gegen jede
                        Ansprache</triggerstring></rs> setzen sich in eigenem und im Namen der
                  unmündigen <rs type="person" ref="pe__ulrich_QGW_II_I_372"><roleName type="kin" corresp="pe__niklas_chiener_QGW_II_I_372">Kinder</roleName>
                     <roleName type="kin" corresp="pe__christine_QGW_II_I_372"><add>Kinder</add></roleName> aus erster Ehe Ulreich</rs> und <rs type="person" ref="pe__niklas_QGW_II_I_372_a"><roleName type="kin" corresp="pe__niklas_chiener_QGW_II_I_372"><add>Kinder</add></roleName>
                     <roleName type="kin" corresp="pe__christine_QGW_II_I_372"><add>Kinder</add></roleName> Niclas</rs>, sowie der <rs type="person" ref="pe__katharina_QGW_II_I_372_b"><roleName type="kin" corresp="pe__niklas_chiener_QGW_II_I_372">Tochter</roleName>
                     <roleName type="kin" corresp="pe__margarethe_QGW_II_I_372"><add>Tochter</add></roleName> aus zweiter Ehe Katrei</rs> als Schirm gegen
                  jede Ansprache.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_372"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="person" ref="pe__bernhard_schenk_QGW_II_I_372">1. des
                        Bergmeisters</rs>, <rs type="person" ref="pe__jakob_poll_QGW_II_I_511">2.
                           <roleName type="title">hern</roleName> Jacobs des
                  Po/elleins</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. N. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>