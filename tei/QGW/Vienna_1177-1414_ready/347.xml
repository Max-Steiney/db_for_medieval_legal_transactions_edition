               <rs type="event" ref="ev__QGW_II_I_347"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_ratgeb_QGW_II_I_347">Jans der Ratgeb, <roleName type="kin" corresp="pe__friedrich_ratgeb_QGW_II_I_347_a"><add>sun</add></roleName>
                        <rs type="person" ref="pe__friedrich_ratgeb_QGW_II_I_347_a">Fridreichs sun
                           des Ratgeben, <roleName type="dead">dem got genade</roleName></rs></rs>,
                        <rs type="person" ref="pe__friedrich_ratgeb_QGW_II_I_347_b">sein <roleName type="kin" corresp="pe__johann_ratgeb_QGW_II_I_347">Bruder</roleName>
                        Fridreich der Ratgeb</rs> und <rs type="person" ref="pe__elisabeth_QGW_II_I_347">seine <roleName type="kin" corresp="pe__johann_ratgeb_QGW_II_I_347">Hausfrau</roleName>
                     Elspet</rs></rs>
                  <triggerstring n="disp">verkaufen mit gesammter Hand</triggerstring> aus ihrem
                  väterlichen Erbe für 12 lb dn. <rs type="fn" role="recipient">der <rs type="person" ref="pe__katharina_QGW_II_I_404"><roleName type="occ" corresp="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">Aebtissin</roleName> des S. Niklasklosters <roleName type="title">swester</roleName> Katrein der Pentzinne</rs> und <rs type="org" ref="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">dem Convente
                        daselbst</rs></rs> 12 sh. 8 dn. gelts ewigs perchrechts auf mehreren
                  Weingärten, deren Bergherr der Schottenabt ist ( 76 dn. auf der Tuntgru/eb, 45 dn.
                  an dem Goldek, 46 dn. an dem Juns (!), 45 dn. auf dem Griez/zz/ze in der
                  Hierspeunt, 56 dn. an dem Rennweg in den Dwerichenlu/ez/zz/zen).</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_347"><rs type="fn" role="witness">Besiegelt mit
