            <origDate instant="false">ze Wienn, des nechsten freitags vor den Phingsten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01283_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01283_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1283"><rs type="fn" role="issuer"><rs type="person" ref="pe__jakob_maeusl_QGW_II_I_1283">Jacob der Meusel, <roleName type="occ" corresp="org__wien">purger</roleName> ze Wienn</rs>, und
                        <rs type="person" ref="pe__katharina_QGW_II_I_1283">Kathrei, seine <roleName type="kin" corresp="pe__jakob_maeusl_QGW_II_I_1283">Hausfrau</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="pe__rudolf_von_tierna_QGW_II_I_1351"><roleName type="title">Bergherrn</roleName>
                        <roleName type="title">hern</roleName> Rudolfs von Tirna</rs></rs> ihres
                  rechten Kaufgutes ½ Joch Weingarten, gelegen ze Tobling in dem Sauperg zenechst
                  Niclas weingarten des Geuder von Nustorf, <rs type="event" ref="ev__QGW_II_I_1283_men_1">von dem man
                     anderthalb Eimer Wein zu Bergrecht und 3 Helbling zu Voitrecht dient</rs>, um
                  65 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__niklas_zistler_QGW_II_I_1283"><roleName type="title">hern</roleName> Niclasen dem
                        Zistler, <roleName type="occ" corresp="org__wien-st_maria_am_gestade-altar_st_andreas_und_maria_magdalena">kaplan</roleName> sand Andres und sand Maria Magdalen altar, gelegen in
                        der kapellen Unser Vraun auf der Stetten ze Wienn</rs></rs>, <rs type="event" ref="ev__QGW_II_I_1283_men_2">der zu dem Ankaufe das Geld verwendete, für welches
                     achthalb lb dn. von Niclas seligen von Ofen weingarten, gelegen ze Grinzing in
                     den Verlein, abgelöst worden waren</rs>.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1283"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="pe__rudolf_von_tierna_QGW_II_I_1351">Bergherrn</rs> und der Wiener Bürger 2. <rs type="person" ref="pe__stephan_leitner_QGW_II_I_1012"><roleName type="occ" corresp="org__wien"><add>Bürger</add></roleName> Stephans des Leitner</rs>, 3. <rs type="person" ref="pe__friedrich_dietram_QGW_II_I_1026"><roleName type="occ" corresp="org__wien"><add>Bürger</add></roleName> Fridreichs des
                        Dietrams</rs></rs>.</rs></p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>