   <text>
      <body>
         <div type="abstract" resp="lp">
            <p><rs type="event" ref="ev__QGW_II_I_289"><rs type="fn" role="issuer"><rs type="person"
                        ref="pe__dietrich_urbetsch_QGW_II_I_950">Dietreich der Urbaetsch</rs></rs>
                  <triggerstring n="disp">schafft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">gemäss einem
                        <add>Versprechen</add></triggerstring>
                     <rs type="person" ref="pe__gerburg_QGW_II_I_289">seiner <roleName type="dead"
                           >verstorbenen</roleName>
                        <roleName type="kin" corresp="pe__dietrich_urbetsch_QGW_II_I_950"
                           >Mutter</roleName> Gerwirg</rs>
                     <triggerstring n="disp">gegebenen Versprechen</triggerstring></rs>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Willen</triggerstring>
                     <rs type="person" ref="pe__elisabeth_QGW_II_I_386">seiner <roleName type="kin"
                           corresp="pe__dietrich_urbetsch_QGW_II_I_950">Frau</roleName> Elspet</rs>
                     und seiner Erben</rs>, sowie <rs type="fn" role="other"><triggerstring n="fn">mit
                        Handen</triggerstring>
                     <rs type="person" ref="pe__johann_greiffe_QGW_II_I_390">seines <roleName
                           type="title">Grundherrn</roleName> des <roleName type="title"
                           >Ritters</roleName>
                        <roleName type="title">hern</roleName> Jansen des Greifen</rs></rs> 6 lb dn.
                  geltes ewiges purchrechtes ( auf hern Hermannes haus, der Ruedolfinne enenchel von
                  Sand Polten, gelegen an dem Chienmarkcht zenaest hern Hermanns haus des
                  Snaetzleins, da er selber ietzund inne gesessen ist, 4 lb dn ., und auf des
                  Huetstokches haus, des satler in der Wiltwercherstrasse, 2 lb dn.) zu <rs
                     type="fn" role="recipient"><rs type="org"
                        ref="org__wien-st_peter-kapelle_st_valentin-messe_urbetsch">einer ewigen
                        Messe in die Kapelle hinz sand Peter auf sand Valenteins alter</rs></rs>,
                  mit der Bestimmung, dass die Gült <rs type="fn" role="recipient">dem <rs
                        type="person" ref="pe__leb_von_pulkau_QGW_II_I_289"><roleName type="occ"
                           corresp="org__wien-st_peter-kapelle_st_valentin">Kaplan</roleName> der
                        Kapelle <roleName type="title">hern</roleName> Leben von Pulka</rs></rs>
                  geleistet werde, der sie <rs type="fn" role="recipient">dem <rs type="person"
                        ref="pe__niklas_QGW_II_I_289"><roleName type="prof">Priester</roleName>
                        <roleName type="title">hern</roleName> Nicla</rs></rs> weiterzugeben
                  habe.</rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_I_289"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="pe__dietrich_urbetsch_QGW_II_I_950">des
                        Ausstellers</rs>, 2. <rs type="person" ref="pe__johann_greiffe_QGW_II_I_390"
                        >des Grundherrn</rs>, 3. <rs type="person" ref="pe__simon_QGW_II_I_290"
                           ><roleName type="title">hern</roleName> Simons, <roleName type="occ"
                           corresp="org__wien-st_stephan">chormaister</roleName> dacz sand Stephan
                        ze Wienne</rs>, 4. <rs type="person"
                        ref="pe__wilhelm_bei_dem_brunnen_QGW_II_I_289">des <roleName type="kin"
                           corresp="pe__dietrich_urbetsch_QGW_II_I_950">Oheims</roleName> des
                        Ausstellers <roleName type="title">hern</roleName> Wilhalms bei dem
                        Prunne</rs>.</rs></rs></p>
         </div>
