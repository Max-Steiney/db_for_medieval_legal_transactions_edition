                  <triggerstring n="disp">verkaufen mit gesammter Hand</triggerstring> und <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihrer <rs type="person" ref="pe__christine_QGW_II_I_148"><roleName type="title">Grundfrau</roleName>
