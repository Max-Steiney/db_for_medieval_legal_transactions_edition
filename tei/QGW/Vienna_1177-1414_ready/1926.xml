                  <rs type="fn" role="recipient"><rs type="person" ref="pe__rudolf_angerfelder_QGW_II_I_1335">seinem <roleName type="kin" corresp="pe__georg_eninkchl_QGW_II_I_1721">Schwager</roleName> Ruedolfen
