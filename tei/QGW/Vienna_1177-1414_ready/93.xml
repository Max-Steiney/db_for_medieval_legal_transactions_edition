          heiligen junchvroun. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00093_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00093_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p><rs type="event" ref="ev__QGW_II_I_93">
            <rs type="fn" role="issuer"><rs type="person" ref="pe__hartneid_traun_QGW_II_I_93">Haertneit von Traun</rs>, <rs type="person" ref="pe__dietmar_lerwuchel_QGW_II_I_93">Dietmar von Lerbu/ochel</rs>, <rs type="person" ref="pe__albrecht_lauterbergch_QGW_II_I_93">Alber Lauterbergch</rs>, <rs type="person" ref="pe__engelschalich_sluzelberger_QGW_II_I_93">Engelschalich
                Sluz/zelberger</rs>, <rs type="person" ref="pe__dietrich_weissenberg_QGW_II_I_93_b">Dietreich der jung Weiz/zenwerger</rs>, <rs type="person" ref="pe__tiemo_pernawe_QGW_II_I_93">Teim von Pernawe</rs>, <rs type="person" ref="pe__dietrich_oven_QGW_II_I_93">Dietreich Oven</rs></rs>
            <triggerstring n="disp">stellen sich <add>als Bürgen</add></triggerstring>
            <rs type="fn" role="recipient"><rs type="person" ref="pe__anna_QGW_II_I_93">der Anna,<rs type="person" ref="pe__dietrich_weissenberg_QGW_II_I_93_a"> Dietrichs von
