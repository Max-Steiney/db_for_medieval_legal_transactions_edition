            <placeName>Wien</placeName>
            <date when="13980626">1398 VI 26</date>
            <origDate instant="false">ze Wienne, des nechsten mitichens nach sand Johanns tag ze
               Sunnbenden.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01396_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01396_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1396"><rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_ris_QGW_II_I_1368">Ulreich der Rys, des <roleName type="occ" corresp="org__wien">rates</roleName> der stat ze Wienn <roleName type="rep" corresp="pe__ruediger_snuerer_QGW_II_I_1585"><add>Stellvertreter</add></roleName></rs></rs>, <triggerstring n="disp">beurkundet</triggerstring> als Stellvertreter <rs type="person" ref="pe__ruediger_snuerer_QGW_II_I_1585"><roleName type="title"/> Rugers des
                     Snu/erer, <roleName type="occ" corresp="org__wien">statrichter</roleName> ze
                     Wienn</rs>, <triggerstring n="disp">dass vor ihm in der
                     Bürgerschranne</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="pe__johann_turs_QGW_II_I_1245">Hanns Turs, <rs type="person" ref="pe__niklas_wuerfel_QGW_II_I_1001"><roleName type="title">hern</roleName> Niclas des Würfels</rs>
                        <roleName type="occ" corresp="pe__niklas_wuerfel_QGW_II_I_1001">diener</roleName>, als
                           <roleName type="rep" corresp="pe__johann_von_dietreichstokch_QGW_II_I_1028">Bevollmächtigter</roleName> seines <rs type="person" ref="pe__johann_von_dietreichstokch_QGW_II_I_1028"><roleName type="occ" corresp="pe__johann_turs_QGW_II_I_1245">Herrn</roleName>, Hannsen von
                           Dietreichstokch, <roleName type="occ" corresp="org__oesterreich-herzogtum">vorstmaister</roleName> in
                           Österreich</rs></rs>, und <rs type="person" ref="pe__ruediger_snuerer_QGW_II_I_1585"><roleName type="title">hern</roleName> Rugers des Snürer</rs>
                     <triggerstring n="fn">mit Vorsprechen</triggerstring></rs>
                  <rs type="fn" role="other"><triggerstring n="fn">hinz</triggerstring>
                     <rs type="person" ref="pe__rudolf_von_tierna_QGW_II_I_1351"><roleName type="title">hern</roleName> Rudolfen von Tierna</rs> und <rs type="person" ref="pe__ludwig_von_tierna_QGW_II_I_1351">Ludweigen <add>von Tyrna</add>, seinem <roleName type="kin" corresp="pe__rudolf_von_tierna_QGW_II_I_1351">prueder</roleName></rs></rs>,
                     <triggerstring n="disp">geklagt habe</triggerstring> umb 1800 guter roter guldein,
                  die gib und geb sein, <rs type="event" ref="ev__QGW_II_I_1396_men_1">für welche Summe die Genannten
                     hinz . . dem von Wolffurt Bürgschaft geleistet hatten und ihnen deshalb das
                     Tirna'sche grosse Haus, gelegen an dem Liechtensteg und die fleischpenkch und
                     der Lederhof dabei und der marstal gegen demselben haus über verpfändet
                     waren</rs>. Da bei einer zweiten Verhandlung trotz der ausgewiesenen
                  Verständigung die beiden Brüder nicht erschienen, so <triggerstring n="disp">spricht
                        <add>zu</add></triggerstring> Ulreich das Haus mit seinem Zubehör den <rs type="fn" role="recipient">Klägern <rs type="person" ref="pe__johann_turs_QGW_II_I_1245"><add>Hans Turs</add></rs>
                     <add>und</add>
                     <rs type="person" ref="pe__ruediger_snuerer_QGW_II_I_1585"><add>Rugers des
                           Snürer</add></rs></rs> zu.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1396"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="pe__ulrich_ris_QGW_II_I_1368">Aussteller</rs></rs>.</rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>