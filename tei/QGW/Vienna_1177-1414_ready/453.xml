            <placeName>Wien</placeName>
            <date when="13540430">1354 IV 30</date>
            <origDate instant="false">ze Wienne, des naechsten mitichens vor sant Philipps und sant Jacobs
               tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00453_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00453_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="ev__QGW_II_I_453"><rs type="fn" role="issuer"><rs type="person" ref="pe__niklas_wuerfel_QGW_II_I_1001">Nichlas der Würfel, <roleName type="occ" corresp="org__wien">richter</roleName> ze Wienne</rs>,</rs>
                  <triggerstring n="disp">beurkundet</triggerstring>, dass vor ihm in der Bürgerschranne
                     <rs type="fn" role="recipient"><rs type="person" ref="pe__friedrich_QGW_II_I_427">Fridreich, <roleName type="occ" corresp="pe__jakob_poll_QGW_II_I_770"><add>diener</add>
                        </roleName><rs type="person" ref="pe__jakob_poll_QGW_II_I_770"><roleName type="title">hern</roleName> Jacobs diener des Pollen, <roleName type="occ" corresp="org__wien-st_maria_im_rathaus">chapplan</roleName>
                           der Chappellen Unser Vrown in der purger Rathaus ze Wienne, hern Otten
                           Haim Stiftung saelig</rs></rs></rs> , mit Vorsprechen auf Mo/erchleins
                  haus des Juden, Nachmans sun von Salzpurch, das da leit under den Juden ze Wienne
                  und das weiln Höbschleins des Juden gewesen ist, und leit an ainem tail zenaechst
                  Efferleins haus des Juden, Adams aidem, und an dem andern tail zenaechst mit dem
                  ekke an dem gaesslein, das da get an das Judentor, zenaechst hern Jacobs haus des
                  Maeserleins , um 1 dn. Grundrecht und um 3 lb dn. versessenes Burgrecht und um die
                  darauf ertheilten zwispilde geklagt habe. Er gibt dem Kläger <rs type="fn" role="other"><rs type="person" ref="pe__bernhard_zehentner_QGW_II_I_453">Wernharten den Zehentner <roleName type="occ" corresp="org__wien"><add>vorsprechen</add></roleName></rs> und <rs type="person" ref="pe__martin_pirmeider_QGW_II_I_453">Merten, den pyrmeider <roleName type="occ" corresp="org__wien"><add>vorsprechen</add></roleName></rs>, di zwen vorsprechen,
                     als <triggerstring n="fn">Schätzleute</triggerstring></rs> mit und macht ihn nach
                  deren Aussage des Hauses gewaltig.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_453"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="pe__niklas_wuerfel_QGW_II_I_1001">Aussteller</rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>