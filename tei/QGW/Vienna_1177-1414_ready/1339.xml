            <placeName>Wien</placeName>
            <date when="13960622">1396 VI 22</date>
            <origDate instant="false">ze Wienn, des nachsten phinztags vor sand Johanns tag ze
               Sunnebenden.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01339_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01339_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1339"><rs type="fn" role="issuer"><rs type="person" ref="pe__paul_holzkaeufel_QGW_II_I_1010">Paul der Holzkeuffel, <roleName type="occ" corresp="org__wien">purgermaister</roleName></rs>, und der <rs type="org" ref="org__wien">rat gemain der stat ze Wienne</rs></rs>
                  <triggerstring n="disp">beurkunden, dass vor ihnen</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="pe__johann_chetner_QGW_II_I_1104">Hanns der
                        Chettner</rs>
                     <triggerstring n="fn">an ainem tail</triggerstring></rs> die Güter, welche <rs type="person" ref="pe__jakob_chetner_QGW_II_I_1339">Jacob der Chetner, seines <rs type="person" ref="pe__konrad_chetner_QGW_II_I_1339"><roleName type="kin" corresp="pe__johann_chetner_QGW_II_I_1104">Bruders</roleName> Chunrats des
                        Chettner</rs>
                     <roleName type="kin" corresp="pe__konrad_chetner_QGW_II_I_1339">Sohn</roleName></rs>, als
                  Erbe seines <rs type="person" ref="pe__johann_puettreich_QGW_II_I_1079"><roleName type="kin" corresp="pe__jakob_chetner_QGW_II_I_1339">enen</roleName> Hanns des Pu/etreich</rs>,
                  wie es ihm in der Theilung mit <rs type="person" ref="pe__anna_QGW_II_I_1339">Annen, Hannsen <roleName type="kin" corresp="pe__johann_von_eslarn_QGW_II_I_1208">wittiben</roleName>
                     <rs type="person" ref="pe__johann_von_eslarn_QGW_II_I_1208"><add>Hannsen</add> von Eslarn
                           <roleName type="dead"><add>wittiben</add></roleName></rs></rs>,
                  zugefallen war, hinterlassen hatte, beansprucht habe, Wogegen <rs type="fn" role="other"><rs type="person" ref="pe__stephan_frauendorfer_ii_QGW_II_I_1339">Steffan der
                        Fraundorfer an seiner <rs type="person" ref="pe__katharina_QGW_II_I_1339"><roleName type="kin" corresp="pe__stephan_frauendorfer_ii_QGW_II_I_1339">Hausfrau</roleName> Kathrein</rs> und ihrer Geschwister <roleName type="rep" corresp="pe__katharina_QGW_II_I_1337">Statt</roleName></rs>,
                     und <rs type="person" ref="pe__niklas_chamrer_QGW_II_I_1339">Niclas der Chamrer, als Jakobs
                           <roleName type="kin" corresp="pe__jakob_chetner_QGW_II_I_1339">Geschwisterenkel</roleName></rs>
                     <triggerstring n="fn">den gleichen Anspruch erhoben</triggerstring></rs>. Sie
                  sprechen das von <rs type="fn" role="recipient"><rs type="person" ref="pe__jakob_chetner_QGW_II_I_1339">Jakob dem Chettner</rs></rs> hinterlassene
                  fahrende Gut seinen nächsten Erben, das aus der Erbschaft Pütreichs stammende
                  liegende Gut dessen nächsten Erben, das von Jakob etwa erarbeitete Gut zur Hälfte
                     <rs type="fn" role="recipient"><rs type="person" ref="pe__katharina_QGW_II_I_1339">beiden Parteien</rs></rs> zu.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1339"><rs type="fn" role="witness">Besiegelt mit
                     der <rs type="org" ref="org__wien">stat ze Wienn chlainem anhangundem
                        insigel</rs></rs>.</rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>