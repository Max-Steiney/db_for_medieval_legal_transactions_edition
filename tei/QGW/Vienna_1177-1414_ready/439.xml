      <text>
            <body>
                  <div type="abstract" resp="ks">
                        <p>
                              <rs type="event" ref="ev__QGW_II_I_439"><rs type="fn" role="issuer"
                                                ><rs type="person" ref="pe__heinrich_QGW_II_I_439"
                                                >Hainreich, <roleName type="occ"
                                                  corresp="org__wien-st_jakob_auf_der_huelben"
                                                  >chappellan</roleName> dacz sand Jacob ze
                                                Wienne</rs></rs>, <triggerstring n="disp">gibt
                                                <add>nach seinem Tode </add></triggerstring>das Haus,
                                    gelegen vor Chaernertor ze Wienne gegen der purger Spital riztür
                                    über, zenaechst Ludweigs haus, des schuester, da man auch alle
                                    iar von dient in der purger Spital ze Wienn 60 dn. ze gruntrecht
                                    und hinz sand Pangraetzen ze Wienn 1 lb dn ., hinz den
                                    Augustinern ze Wienne 1 lb und hern Stiborii saelig, weiln des
                                    herzogen chuchenmaister, 1 lb und vron Margreten, Chunrats
                                    tochter des Schreiber, 10 sh. dn., alles ze purchrecht, das
                                    weiln gewesen ist Herborts, des Spitals mair, und das er um den
                                    angeführten Dienst gekauft hatte, nach seinem Tode <rs type="fn"
                                          role="recipient"><rs type="org"
                                                ref="org__wien-buergerspital">den Dürftigen im
                                                Spitale</rs></rs>.</rs>
                        </p>
                  </div>
                  <div type="seal">
                        <p><rs type="event" ref="ev__QGW_II_I_439"><rs type="fn" role="witness"
                                          >Besiegelt mit den Siegeln: 1. des <rs type="person"
                                                ref="pe__heinrich_QGW_II_I_439">Ausstellers</rs>, 2.
                                                <rs type="person" ref="pe__ulrich_QGW_II_I_439">des
                                                  <roleName type="title">Priesters</roleName>
                                                <roleName type="title">hern</roleName> Ulreichs,
                                                  <roleName type="occ"
                                                  corresp="org__wien-st_stephan"
                                                  >chormaister</roleName> ze Wienn</rs>, 3. <rs
                                                type="person" ref="pe__johann_QGW_II_I_439"
                                                  ><roleName type="title">hern</roleName> Jansen,
                                                  <roleName type="occ"
                                                  corresp="org__wien-st_maria_am_gestade"
                                                  >chappellan</roleName> der chappelln Unser Vrowen
                                                auf der Stetten ze Wienne</rs>.</rs></rs>
                        </p>
                  </div>
