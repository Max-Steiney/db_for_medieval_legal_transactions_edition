               <rs type="fn" role="issuer"><rs type="person" ref="pe__sigmund_maurbekch_QGW_II_II_1984">Sigmund Maurbekch</rs></rs>
               überschickt <rs type="fn" role="recipient"><rs type="person" ref="pe__rudolf_angerfelder_QGW_II_I_1335">dem <roleName type="occ" corresp="org__wien">Bürgermeister</roleName> Rudolffen dem
