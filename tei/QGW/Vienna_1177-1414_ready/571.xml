               <rs type="event" ref="ev__QGW_II_I_571"><rs type="fn" role="issuer"><rs type="person" ref="pe__martin_QGW_II_I_557">Mert,<roleName type="kin" corresp="pe__johann_von_schaffhausen_QGW_II_I_557"><add>sun</add></roleName>
                        <rs type="person" ref="pe__johann_von_schaffhausen_QGW_II_I_557"><roleName type="title">maister</roleName> Jansen sun von Schêffhausen, <roleName type="dead">dem got genad</roleName></rs></rs>, und <rs type="person" ref="pe__margarethe_QGW_II_I_571">Margret, seine <roleName type="kin" corresp="pe__martin_QGW_II_I_557">Hausfrau</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__haunold_schuchler_QGW_II_I_170">des <roleName type="occ" corresp="org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Haunolts des Schuchler</rs> und <rs type="org" ref="org__wien">des Rathes der Stadt zu Wien</rs></rs> ihr Haus,
                  gelegen in der Wiltwerherstrasse ze Wienne, zenechst hern Ulreichs haus des
                  Pollen, von dem man hern Jacoben dem Pollen und seiner Kapelle 4 lb dn. gelts
                  purchrechts und Hermannen, Hainreichs sun, des statschreiber saelig, 14 sh. gelts
                  purchrechts (ablösbar mit 14 lb dn.) dient, um 150 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__jakob_poll_QGW_II_I_770"><roleName type="title">hern</roleName> Jacoben dem Pollen, <roleName type="occ" corresp="org__wien-st_maria_im_rathaus">chaplan</roleName> der chapellen
                        Unser Vrowen in der purger Rothaus ze Wienne</rs>
                  </rs>. Dieser hat für den Ankauf verwendet 100 lb dn., die vrau Katrei, hern Otten
                  wittib, weiln des Schützenmaister Schreiber selig, zur Kapelle gegeben hatte, 32
                  lb dn., mit denen her Jacob von Eslarn 4 lb dn. gelts purchrechts von seinem
                  Hause, das do leit in sant Peters vreithof ze Wienne, abgelöst hat, 18 lb dn., mit
                  denen Leupolt, Arnolts aidem selig, 2 lb dn. gelts purchrechts von ½ Joch
                  Weingarten, der do haisset der Sturminpeunt und leit ze Obern Suffring, abgelöst
                  hat.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_571"><rs type="fn" role="witness">Besiegelt 1. <rs type="org" ref="org__wien">mit dem Grundsiegel der Stadt</rs>, ferner mit
                     den Siegeln 2. <rs type="person" ref="pe__ortolf_mit_den_gevattern_QGW_II_I_954"><roleName type="title">hern</roleName> Ortolfen mit der Gevatern <roleName type="occ" corresp="org__wien"><add>paid des rats der stat ze
                           Wienne</add></roleName></rs>, 3. <rs type="person" ref="pe__niklas_dratlauf_QGW_II_I_810"><roleName type="title">hern</roleName> Niclas des Drôtlaufs, <roleName type="occ" corresp="org__wien">paid des rats der stat ze Wienne</roleName></rs>, 4.
                        <rs type="person" ref="pe__stephan_raedler_QGW_II_I_571"><roleName type="title">hern</roleName> Steffans des Rädler, <roleName type="occ" corresp="org__wien">purger</roleName> ze
                     Wienne</rs></rs>.</rs>
            </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. B. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>