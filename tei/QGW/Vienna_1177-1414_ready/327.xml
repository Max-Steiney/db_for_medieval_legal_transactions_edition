            <date when="13490101">1349 I 01</date>
            <origDate instant="false">ze Wienne, an dem Ebenbeichtag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00327_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00327_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="ev__QGW_II_I_327"><rs type="fn" role="issuer"><rs type="person" ref="pe__heinrich_QGW_II_I_327"><roleName type="kin" corresp="pe__leopold_von_puchs_QGW_II_I_327"><add>Sohn</add></roleName>
                     Hainreich</rs>, <rs type="person" ref="pe__leopold_QGW_II_I_327"><roleName type="kin" corresp="pe__leopold_von_puchs_QGW_II_I_327"><add>Sohn</add></roleName>
                        Leupolt</rs>, <rs type="person" ref="pe__ulrich_puchs_QGW_II_I_329"><roleName type="kin" corresp="pe__leopold_von_puchs_QGW_II_I_327"><add>Sohn</add></roleName>
                        Ulreich</rs>, <rs type="person" ref="pe__johann_QGW_II_I_327"><roleName type="kin" corresp="pe__leopold_von_puchs_QGW_II_I_327"><add>Sohn</add></roleName>
                        Jans</rs> und <rs type="person" ref="pe__margarethe_QGW_II_I_327"><roleName type="kin" corresp="pe__leopold_von_puchs_QGW_II_I_327"><add>chinder</add></roleName>Margret, </rs>
                     <rs type="person" ref="pe__leopold_von_puchs_QGW_II_I_327"><roleName type="title">hern</roleName>Leupolts chinder von Puchs, <roleName type="dead">dem got
                           genade</roleName></rs></rs>, <triggerstring n="disp">theilen</triggerstring><rs type="fn" role="other"><triggerstring n="fn">im Vereine</triggerstring> mit ihrer <rs type="person" ref="pe__christine_QGW_II_I_327"><roleName type="kin" corresp="pe__heinrich_QGW_II_I_327">Mutter</roleName><roleName type="kin" corresp="pe__leopold_QGW_II_I_327"><add>Mutter</add></roleName><roleName type="kin" corresp="pe__ulrich_puchs_QGW_II_I_329"><add>Mutter</add></roleName><roleName type="kin" corresp="pe__johann_QGW_II_I_327"><add>Mutter</add></roleName><roleName type="kin" corresp="pe__margarethe_QGW_II_I_327"><add>Mutter</add></roleName>
                        <roleName type="title">vrowen</roleName> Christein</rs></rs> das Gut, das
                  ihnen ihr Vater hinterlassen hat. An <rs type="fn" role="recipient"><rs type="person" ref="pe__heinrich_QGW_II_I_327">Heinrich</rs></rs> fällt das
                  Dorf, gehaissen das Weinhaus, gelegen bei Werich, an <rs type="fn" role="recipient"><rs type="person" ref="pe__leopold_QGW_II_I_327">Leupolt</rs></rs> fallen ½ Joch Weingarten, gelegen ze Chlaitzing zenest hern
                  Hainreichs weingarten des Straicher, und 5/4 Joch Weingarten in dem Metzleinsperg
                  zenest Fridreichs weingarten, des wiltpreter, an <rs type="fn" role="recipient"><rs type="person" ref="pe__ulrich_puchs_QGW_II_I_329">Ulreich</rs></rs> ½ Joch
                  Weingarten, gelegen ze Chlaitzing zenest der Erkchlinne weingarten, und ain
                  weingart, gelegen ze Gundramstorf und haisst der Lueschinkch zenest Jacobs
                  weingarten des Mundoffen, und zwo wisen, der aine leit ze Lachsendorf und die
                  ander ze Minkchendorf , an <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_QGW_II_I_327">Jans</rs></rs> 1 Joch Weingarten, gelegen ze
                  Sufring zenest des Hermendleins weingarten, und ½ Joch Weingarten, gelegen ze
                  Praitense, und zwo wisen, der aine leit ze Aichaue, so leit die ander bei des
                  Chriechen holzlein , an <rs type="fn" role="recipient"><rs type="person" ref="pe__margarethe_QGW_II_I_327">Margrete</rs></rs> 4 lb dn. gelts, gelegen
                  dacz Chu/emerleinstorf, und 24. Metzen waitzs gelts samwaitzs, und 1 ½ Joch
                  Weingarten, gelegen in dem Harde zenest dem weingarten, der weilnt hern Hainreichs
                  von Pechlarn gewesen ist . Die <rs type="fn" role="recipient"><rs type="person" ref="pe__christine_QGW_II_I_327">Mutter</rs></rs> erhält ½ Joch Weingarten,
                  gelegen ze Chlaitzing zenest irs swager weingarten Ulreichs des Puchser, und 5/4
                  Joch Weingarten, der do leit an dem Sunnperg zenest Fridreichs weingarten, des
                  alten schranneschreiber. Das Haus aber, gelegen ze Wienne in der Pekchenstrasse
                  zenest Jansen haus von Prukk, fällt allen zu unverschaidenleichen ze geleicher
                  tailung.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_327"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1., 2., 3. der Brüder <rs type="person" ref="pe__heinrich_QGW_II_I_327">Heinrich</rs>, <rs type="person" ref="pe__leopold_QGW_II_I_327">Leopold</rs> und <rs type="person" ref="pe__ulrich_puchs_QGW_II_I_329">Ulreich</rs>, 4. ihres <rs type="person" ref="pe__sieghard_brunner_QGW_II_I_889"><roleName type="kin" corresp="pe__heinrich_QGW_II_I_327">Vetters</roleName><roleName type="kin" corresp="pe__leopold_QGW_II_I_327"><add>Vetter</add></roleName><roleName type="kin" corresp="pe__ulrich_puchs_QGW_II_I_329"><add>Vetter</add></roleName>
                        <roleName type="title">hern</roleName> Sigharts des Prunner</rs>, 5. ihres
                        <rs type="person" ref="pe__ruediger_wenig_QGW_II_I_367"><roleName type="kin" corresp="pe__heinrich_QGW_II_I_327">Oheims</roleName><roleName type="kin" corresp="pe__leopold_QGW_II_I_327"><add>Oheim</add></roleName><roleName type="kin" corresp="pe__ulrich_puchs_QGW_II_I_329"><add>Oheim</add></roleName>
                        Rugers, des <rs type="person" ref="pe__leopold_wenig_QGW_II_I_320">Wenigen
                           Leupolts</rs><roleName type="kin" corresp="pe__leopold_wenig_QGW_II_I_320">sun</roleName></rs>, 6. ihres
                        <rs type="person" ref="pe__heinrich_chrannest_ii_QGW_II_I_856"><roleName type="kin" corresp="pe__heinrich_QGW_II_I_327">Schwagers</roleName><roleName type="kin" corresp="pe__leopold_QGW_II_I_327"><add>Schwager</add></roleName><roleName type="kin" corresp="pe__ulrich_puchs_QGW_II_I_329"><add>Schwager</add></roleName>
                        Hainreichs des Chrannest</rs></rs>.</rs>
            </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. h. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>