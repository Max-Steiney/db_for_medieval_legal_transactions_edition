            <placeName>Wiener Neustadt</placeName>
            <date when="13990216">1399 II 16</date>
            <origDate instant="false">zu der Neunstat, des suntags in den vir tagen, als man singet
               Invocavit.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01418_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01418_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1418"><rs type="fn" role="issuer"><rs type="person" ref="pe__leonhard_haiden_QGW_II_I_1308">Linhart der Haiden <roleName type="occ" corresp="org__wiener_neustadt"><add>burger</add></roleName></rs> und <rs type="person" ref="pe__erhard_haiden_QGW_II_I_1417bis">Erhart der Haiden, sein <roleName type="kin" corresp="pe__leonhard_haiden_QGW_II_I_1308">vetter</roleName>, paid <roleName type="occ" corresp="org__wiener_neustadt">burger</roleName> zu der
                        Neunstat</rs></rs>, <triggerstring n="disp">vergleichen sich mit</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__pilgrim_snaeczl_QGW_II_I_1015"><roleName type="title">hern</roleName> Pilgreim dem Sneczlein</rs></rs>
                  <triggerstring n="disp">über zwei Erbgüter</triggerstring>, das haus, gelegen an dem
                  Fleischmarkcht ze Wienn zenast dem haus, das weilent der geistleichen herren von
                  Gere/aun gebesen ist, und den weingarten, gelegen ze Gumpolczkirchen, genant der
                  Renestaler, <rs type="event" ref="ev__QGW_II_I_1418_men_1">welche ihre <rs type="fn" role="other"><rs type="person" ref="pe__anna_QGW_II_I_1418"><roleName type="kin" corresp="pe__leonhard_haiden_QGW_II_I_1308">Muhme</roleName>
                           <roleName type="kin" corresp="pe__erhard_haiden_QGW_II_I_1417bis"><add>Muhme</add></roleName>
                           <roleName type="title">frau</roleName> Ann, Pilgreims <roleName type="kin" corresp="pe__pilgrim_snaeczl_QGW_II_I_1015">Hausfrau</roleName>, mit der
                           sie <roleName type="kin" corresp="pe__leonhard_haiden_QGW_II_I_1308">geswistreidkind</roleName>
                           <roleName type="kin" corresp="pe__erhard_haiden_QGW_II_I_1417bis"><add>geswistreidkind</add></roleName> waren</rs>, ihrem Manne zu
                        Leibgeding <triggerstring n="fn">hinterlassen hatte</triggerstring></rs></rs>, und
                  hinsichtlich welcher sie nunmehr unter angegebenen Bedingungen <rs type="fn" role="other"><triggerstring n="fn">nach Rath</triggerstring>
                     <rs type="person" ref="pe__johann_rokk_QGW_II_I_1371"><roleName type="title">hern</roleName>
                        Hannsen des Rogken, <roleName type="occ" corresp="org__wien">burgermaister</roleName> ze Wienn</rs>, <rs type="person" ref="pe__jakob_dorn_QGW_II_I_1378">Jacobs des Dorns, des <roleName type="occ" corresp="org__wien">rats</roleName></rs>, und <rs type="person" ref="pe__ulrich_herwart_QGW_II_I_1098">Ulreichs des Herwarts, <roleName type="occ" corresp="org__wien">statschreiber</roleName> ze Wienn</rs></rs>,
                     <triggerstring n="disp">auf alle Erbschaftsrechte und Wartung
                        <add>verzichten</add></triggerstring> zu Gunsten Pilgreims verzichten.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1418"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__leonhard_haiden_QGW_II_I_1308">Linharts</rs> und
                     seines <rs type="person" ref="pe__konrad_rueber_QGW_II_I_1417bis"><roleName type="kin" corresp="pe__leonhard_haiden_QGW_II_I_1308">Schwagers</roleName> Chunrats des Rueber,
                           <roleName type="occ" corresp="org__wiener_neustadt">burger</roleName> zu der Neunstat</rs></rs>.</rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>