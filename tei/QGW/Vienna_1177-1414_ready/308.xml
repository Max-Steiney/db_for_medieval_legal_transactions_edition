               <rs type="event" ref="ev__QGW_II_I_308"><rs type="fn" role="issuer"><rs type="person" ref="pe__niklas_QGW_II_I_308">Niclas, <roleName type="kin" corresp="pe__meinhard_von_enzersdorf_QGW_II_I_308"><add>aidem</add></roleName>
                  <rs type="person" ref="pe__meinhard_von_enzersdorf_QGW_II_I_308">Meinbortz
                           aidem von Engseinsdorf</rs></rs>, und <rs type="person" ref="pe__gertrud_QGW_II_I_308">Gedraut, seine <roleName type="kin" corresp="pe__niklas_QGW_II_I_308">Hausfrau</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihrer <rs type="person" ref="pe__katharina_QGW_II_I_308"><roleName type="title">Grundfrau</roleName>, <roleName type="title">vrovn</roleName> Katrein
                        der Schuttzing</rs></rs>, ihr leibding an dem hof halben der do leit ze
                  Prunn zenost Wolfharten des Reichen hof, von dem man jährlich 3 ½ sh. dn. zu
                  Grundrecht dient, um 24 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__ortolf_QGW_II_I_308">Artolfen, <roleName type="kin" corresp="pe__futrer_auf_der_wieden_QGW_II_I_308"><add>aidem</add></roleName>
                        <rs type="person" ref="pe__futrer_auf_der_wieden_QGW_II_I_308">des fuetrer
                           aidem an der Widem ze Wienn</rs></rs>, und seiner <rs type="person" ref="pe__bertha_QGW_II_I_308"><roleName type="kin" corresp="pe__ortolf_QGW_II_I_308">Hausfrau</roleName>
                        <roleName type="title">vron</roleName> Perichten</rs></rs>. <rs type="fn" role="witness">Da der Aussteller und die Grundfrau des eigenen Siegels
                     entbehren, besiegelt mit den Siegeln: <rs type="person" ref="pe__stephan_chergl_QGW_II_I_308">1. <roleName type="title">hern</roleName> Stephans des Chergleins</rs>, <rs type="person" ref="pe__laurenz_lonholz_QGW_II_I_329">2. <roleName type="title">hern</roleName> Larenzen des Lanholtzen</rs>, <rs type="person" ref="pe__niklas_purkchstaller_QGW_II_I_308">3. <roleName type="title">hern</roleName>
                        Niclas des Purchstaller, <roleName type="title">purchgraf</roleName> zu
                        Liechtenstain</rs>.</rs></rs>
