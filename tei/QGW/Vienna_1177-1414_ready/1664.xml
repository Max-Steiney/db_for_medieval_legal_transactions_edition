                        <rs type="person" ref="pe__jakob_guenser_StB_I_459"><roleName type="title">hern</roleName> Jacoben des Günser, des innern <roleName type="occ" corresp="org__wien">rates</roleName> der stat ze Wienn</rs>.</rs>
