            <origDate instant="false">ze Wienn, an des heiligen Chrauz tag, als es funden ist.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01761_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01761_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1761">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__friedrich_von_hanau_QGW_II_I_1761">Fridreich von Hannau</rs> und
                        <rs type="person" ref="pe__wolfhard_von_hanau_QGW_II_I_1761">Wolfhart von
                        Hannau, sein <roleName type="kin" corresp="pe__friedrich_von_hanau_QGW_II_I_1761">sun</roleName>,</rs></rs>
                  <triggerstring n="disp">verkaufen</triggerstring> ihres rechten freien aigens 48 ½ und
                  1/8 Eimer Wein perkrechts geltes perkmass, dass jeder emmer pring fümf viertail
                  Wienner mass, und 87 dn. geltes voitrechts und stekchenphenning, gelegen auf
                  weingerten an dem Kirichpuechel hinder Medling und im Rottenreis, das sich anhebt
                  an dem weingarten, genant der Saitchauffer, und get hinumb an den Liechtenstain
                  unz an die maur, und das perkrecht auf vier öden weingarten, gelegen daselbens ,
                  um 231 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__thomas_zinnspan_QGW_II_I_1761">Thomann dem Zinespan<roleName type="rep" corresp="pe__stephan_von_staatz_QGW_II_I_1761"><add>ausrichter
                              und volfu/erer</add></roleName>
                     </rs>und <rs type="person" ref="pe__konrad_innauer_QGW_II_I_1521"> Chunraten
                        dem Inauer, <roleName type="rep" corresp="pe__stephan_von_staatz_QGW_II_I_1761">ausrichter und
                           volfu/erer</roleName> des geschefts</rs></rs>, <rs type="event" ref="NULL">so <rs type="person" ref="pe__stephan_von_staatz_QGW_II_I_1761">Stephan von Ste/acz, <roleName type="dead">dem got gnad</roleName></rs>,
                     getan hat, zu<rs type="org" ref="org__wien-st_stephan-altar_allerheiligen-messe_staatz"> der ewigen
                        mess</rs> , die dieser auf Allerheiligen altar dacz sand Stephan ze Wienn ze
                     stiften geschaft hat.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1761"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="person" ref="pe__wolfhard_von_hanau_QGW_II_I_1761">1.</rs>, 2. der <rs type="person" ref="pe__friedrich_von_hanau_QGW_II_I_1761">Aussteller</rs>, 3. <rs type="person" ref="pe__wilhelm_turs_QGW_II_I_1761">ihres guten <roleName type="friend" corresp="pe__friedrich_von_hanau_QGW_II_I_1761">Freundes</roleName>
                        <roleName type="title">hern</roleName> Wilhalms des Tursen, <roleName type="occ" corresp="org__wien-st_stephan">probst</roleName> ze
                        Allerheiligen tumkirichen dacz sand Stephan</rs> ihrer <rs type="person" ref="pe__martin_von_fallbach_QGW_II_I_1761"><roleName type="kin" corresp="pe__friedrich_von_hanau_QGW_II_I_1761">Oheime</roleName> 4.
                           <roleName type="title">hern</roleName> Merten von Valbach</rs> und 5. <rs type="person" ref="pe__leopold_stickelperger_QGW_II_I_1714"><roleName type="kin" corresp="pe__friedrich_von_hanau_QGW_II_I_1761"><add>Oheime</add></roleName>Leutolts des Stikchelperger, herzog
                        Ernsts <roleName type="occ" corresp="pe__ernst_herzog_von_oesterreich_QGW_II_I_1332">kamermaister</roleName>.</rs></rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>