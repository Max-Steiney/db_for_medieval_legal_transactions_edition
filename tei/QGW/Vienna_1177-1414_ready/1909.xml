            <p>
               <rs type="event" ref="ev__QGW_II_II_1909"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_QGW_II_II_1909">Swager Hensel <roleName type="occ" corresp="org__kuttenberg" select="pl__kuttenberg-muenzhof_iglauer_schmiede"><add>münzerschopfen</add></roleName></rs>, <rs type="person" ref="pe__martin_teicher_QGW_II_II_1909">Mertein Teicher <roleName type="occ" corresp="org__kuttenberg" select="pl__kuttenberg-muenzhof_iglauer_schmiede"><add>münzerschopfen</add></roleName></rs>, <rs type="person" ref="pe__johann_greusser_QGW_II_II_1909">Hensel Greusser <roleName type="occ" corresp="org__kuttenberg" select="pl__kuttenberg-muenzhof_iglauer_schmiede"><add>münzerschopfen</add></roleName>,</rs>
                     <rs type="person" ref="pe__wenzel_taepler_QGW_II_II_1909">Wenczlaw Täpler,
                           <roleName type="occ" corresp="org__kuttenberg" select="pl__kuttenberg-muenzhof_iglauer_schmiede">münzerschopfen</roleName> in den Smyden</rs>, dornach <rs type="person" ref="pe__hanmann_alder_QGW_II_II_1909">Heiman Alder <roleName type="occ" corresp="org__kuttenberg" select="pl__kuttenberg-muenzhof_iglauer_schmiede"><add>schopfen in dem
