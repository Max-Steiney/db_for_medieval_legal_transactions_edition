               <rs type="event" ref="ev__QGW_II_I_1572"><rs type="fn" role="issuer"><rs type="person" ref="pe__konrad_hainfelder_QGW_II_I_1572">Chunrat der
                        Hainvelder, <rs type="person" ref="pe__konrad_bierbrauer_QGW_II_I_1572">Chunrats <roleName type="kin" corresp="pe__konrad_hainfelder_QGW_II_I_1572">prueder</roleName>, des
                              <roleName type="prof">pierpreuer</roleName>, dem <roleName type="dead">got gnad</roleName></rs>,</rs> und <rs type="person" ref="pe__dietrich_zimmermann_QGW_II_I_1572">Dietreich, der <roleName type="prof">zimerman</roleName>
                        von Hainveld,
                        ir baider <roleName type="kin" corresp="pe__konrad_bierbrauer_QGW_II_I_1572">vetter</roleName>
                        <roleName type="kin" corresp="pe__konrad_hainfelder_QGW_II_I_1572"><add>vetter</add></roleName></rs>,</rs>
                  <triggerstring n="disp">vergleichen sich</triggerstring>
                  <unclear instant="false"><!-- evtl recipient? --><rs type="fn" role="other">
                        <triggerstring n="fn"><add>vergleichen sich</add> mit</triggerstring>
                        <rs type="person" ref="pe__stephan_pechrer_QGW_II_I_1559">Stephan, dem
                              <roleName type="prof">pechrer</roleName>, <roleName type="occ" corresp="org__wien">purger</roleName> ze Wienn</rs>, und seiner <rs type="person" ref="pe__christine_QGW_II_I_1559"><roleName type="kin" corresp="pe__stephan_pechrer_QGW_II_I_1559">Hausfrau</roleName>
                           Kristein, der <roleName type="kin" corresp="pe__konrad_bierbrauer_QGW_II_I_1572">Witwe</roleName>
                           <rs type="person" ref="pe__konrad_bierbrauer_QGW_II_I_1572">Chunrats, des <roleName type="prof">pierpreuer</roleName>
                              <roleName type="dead">Witwe</roleName></rs></rs>,</rs></unclear>
                  <triggerstring n="disp">und verzichten gegen Empfang</triggerstring> von 60 lb dn. auf
                  ihren Erbanspruch an die Hälfte der von Chunrat und Kristein mit gesammter Hand
                  gekauften Güter, und zwar einer Mühle ze Gumpendorf oben an dem dorf, eines Joches
                  Weingarten, gelegen dabei zenechst dem weingarten, der weilent des Urbetschen ist
                  gewesen, eines Hauses, gelegen in der Weidenstrass ze Wienn zenegst des Hannsen
                  haus von Linz, eines Hauses, gelegen daselbens in der Weidenstrass zenegst des
                  Winnstains haus, und eines Viertels Weingarten, gelegen dacz Sand Veit in den
                  Linnsêkchern.</rs>
