            <origDate instant="false">ze Wienne, an sand Cholmans abend.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00972_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00972_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_972">
                  <rs type="fn" role="issuer"><rs type="person" ref="pe__elisabeth_schemnitzerin_QGW_II_I_972"><roleName type="title">Swester</roleName> Elsbet die Schermiezerinne,
                           <rs type="person" ref="pe__michael_von_der_schemnitz_QGW_II_I_932">Michels <roleName type="dead">seligen</roleName></rs>
                        <roleName type="kin" corresp="pe__michael_von_der_schemnitz_QGW_II_I_932">tochter</roleName> von der Schebnicz , <roleName type="occ" corresp="org__wien-st_jakob_auf_der_huelben">conventswester</roleName> in
                        der geistleichen vrowen chloster dacz sand Jacob auf der Hu/elben ze
                        Wienne</rs></rs> , <triggerstring n="disp">verzichtet</triggerstring> nach dem
                  Gebote Herzog Rudolfs IV. <triggerstring n="disp">aus besonderer Liebe und
                     Freundschaft zu Gunsten</triggerstring><rs type="fn" role="recipient"><rs type="person" ref="pe__johann_von_der_schemnitz_ii_QGW_II_I_932">ihres <roleName type="kin" corresp="pe__elisabeth_schemnitzerin_QGW_II_I_972">Bruders</roleName>, des <roleName type="occ" corresp="org__wien">Wiener Bürgers</roleName> Jannsen
                        von der Schebnicz</rs></rs> , auf die 15 guldein phening, <rs type="event" ref="ev__QGW_II_I_972_men_1">die ihr ihr <rs type="person" ref="pe__michael_von_der_schemnitz_QGW_II_I_932"><roleName type="kin" corresp="pe__elisabeth_schemnitzerin_QGW_II_I_972">Vater</roleName></rs> vermacht und die sie gehabt hatte auf ihres
                     Bruders haus, gelegen an Alten Fleiscbmarcht ze Wienne an ainem tail zenechst
                     Albrechts haus des Tursen und an dem andern tail zenechst der Hofgeberinne haus
                     und stosset an der Heiligenchreuzer hof </rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_972"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der Wiener Bürger: 1. <rs type="person" ref="pe__stephan_nuernberger_QGW_II_I_972"><roleName type="occ" corresp="org__wien"><add>Bürger</add></roleName> Stephans des Nürnberger</rs> und 2. <rs type="person" ref="pe__johann_vorlauf_QGW_II_I_886"><roleName type="occ" corresp="org__wien"><add>Bürger</add></roleName>Jannsen des
                     Vorlaufs</rs>.</rs></rs>
            </p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>