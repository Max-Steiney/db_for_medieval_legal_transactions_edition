                        <rs type="person" ref="pe__thomas_von_poigen_QGW_II_I_1268"><add>Thomas</add> von Peugen
                              <roleName type="dead"><add>witib</add></roleName></rs></rs>, und <rs type="person" ref="pe__andreas_QGW_II_I_1268">Andre, ir <roleName type="kin" corresp="pe__kunigunde_QGW_II_I_1268">sun</roleName></rs></rs>,
