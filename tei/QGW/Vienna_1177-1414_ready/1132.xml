   <text>
      <body>
         <div type="abstract" resp="cs">
            <p><rs type="event" ref="ev__QGW_II_I_1132"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__michael_QGW_II_I_1132">Michel, <roleName type="occ"
                           corresp="pe__beatrix_von_zollern_nuernberg_QGW_II_I_1048"
                           >amptman</roleName> in der Scheffstrass ze Wienn der <rs type="person"
                           ref="pe__beatrix_von_zollern_nuernberg_QGW_II_I_1048"><roleName
                              type="title">hochgeborn fürstinn</roleName>
                           <roleName type="title">frown</roleName> Beatricis von Nu/ernberch,
                              <roleName type="occ" corresp="org__oesterreich-herzogtum"
                              >herzogin</roleName> ze Österreich etc</rs>.</rs></rs>, <triggerstring
                     n="disp">beurkundet, dass vor ihm in offenem Gerichte</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="pe__niklas_hold_QGW_II_I_1093"
                        >Niclas der Hold von Grefendorf</rs>
                     <triggerstring n="fn">mit Vorsprechen</triggerstring>
                  </rs>auf Fridreichs haus, des mauter, gelegen in der Scheffstrass ze Wienn
                  zenechst des Ruez/zz/zin haus, um 29 guldein guter ducaten <triggerstring n="disp"
                     >versessenes Burgrecht und die darauf ertheilten zwispil geklagt
                     habe</triggerstring>. Er <triggerstring n="disp">gibt <add>mit</add></triggerstring> ihm
                     <rs type="person" ref="pe__ulrich_pheffel_QGW_II_I_1048"><roleName type="rep"
                        corresp="pe__michael_QGW_II_I_1132"><add>vorsprech</add></roleName>
                     Ulreichen den Pheffel</rs> und <rs type="person"
                     ref="pe__thomas_marichvelder_QGW_II_I_1132"><roleName type="rep"
                        corresp="pe__michael_QGW_II_I_1132"><add>vorsprech</add></roleName> Thomann
                     den Marichvelder</rs>, die zwen vorsprechen, mit und <triggerstring n="disp"
                     >macht</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__niklas_hold_QGW_II_I_1093">ihn</rs></rs> nach deren Aussage des
                  Hauses <triggerstring n="disp">gewaltig</triggerstring>.</rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_I_1132"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="pe__michael_QGW_II_I_1132"
                  >Aussteller</rs></rs>.</rs></p>
