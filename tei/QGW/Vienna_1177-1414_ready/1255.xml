            <date when="13930206">1393 II 06</date>
            <origDate instant="false">ze Wienn, an sant Dorothe tag, der heiligen junkchfraun.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01255_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01255_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1255"><rs type="fn" role="issuer"><rs type="person" ref="pe__heinrich_puchler_QGW_II_I_1255">Hainreich der
                        Püchler</rs>, <rs type="person" ref="pe__andreas_riener_QGW_II_I_1255">Andre der
                        Riener</rs> und <rs type="person" ref="pe__wolfgang_riener_QGW_II_I_1255">Wolfgankch der
                        Rienher, sein <roleName type="kin" corresp="pe__andreas_riener_QGW_II_I_1255">sun</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="pe__wilhelm_wulzendorfer_QGW_II_I_1117"><roleName type="title">Burgherrn</roleName> Wilhalbem des Wulczendorfer</rs></rs> ihren Hof,
                  gelegen ze Neundorf zenechst Merten hof des Reidekker, 22 Joch Aecker ebenda,
                  einen Weingarten, gelegen enhalb der Haid, des funf gewanten sint, auch zenechst
                  des egenanten Merten weingarten , fünf Tagwerke wismads, gelegen ze Mynkchendorf
                  enhalben des Triesnikch und haisset die Romerin, zehn Tagwerke wismads, gelegen in
                  den Twerichwiesen, und 5 sh. 10 dn. geltes gruntrechts, gelegen ze Neundorf auf
                  weingarten, <rs type="event" ref="ev__QGW_II_I_1255_men_1">von welchem Hofe mit Zubehör man 1 lb dn.
                     zu Burgrecht, 6 Hühner (zu 4 dn.) zu Weihnachten, 8 Käse (zu 4 dn.) zu Ostern,
                     1/2 lb Eier und 10 Metzen vogtfutter an sant Giligen tag dient</rs>, um 100 lb
                  dn. <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_atschpekch_QGW_II_I_1255">Hannsen dem Atschpekchen</rs></rs>.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1255"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="pe__heinrich_puchler_QGW_II_I_1255">Ausstellers</rs>, 2. des <rs type="person" ref="pe__wilhelm_wulzendorfer_QGW_II_I_1117">Burgherrn</rs>, 3. des <rs type="person" ref="pe__niklas_wuerfel_QGW_II_I_1001"><roleName type="title">Ritters</roleName>
                        <roleName type="title">hern</roleName> Niclas des
               Würffels</rs></rs>.</rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>