               <rs type="event" ref="ev__QGW_II_I_828"><rs type="fn" role="issuer"><rs type="person" ref="pe__georg_von_fucha_QGW_II_I_828">Jeorig</rs> und <rs type="person" ref="pe__johann_von_fucha_QGW_II_I_828">Hans, <roleName type="kin" corresp="pe__georg_von_fucha_QGW_II_I_828">gepruder</roleName> von Fuchawe</rs></rs>,
                     <triggerstring n="disp">geloben, keinen Anspruch <add>zu
                     erheben</add></triggerstring> auf den Hof, gelegen ze Swechent zwischen den
                  Wassern, <rs type="event" ref="ev__QGW_II_I_828_men_1">den ihr <rs type="person" ref="pe__jakob_von_fucha_QGW_II_I_828"><roleName type="kin" corresp="pe__georg_von_fucha_QGW_II_I_828">Bruder</roleName> Jacob von Fuchawe</rs> dem <rs type="person" ref="pe__hermann_mulndorf_QGW_II_I_828"><roleName type="prof">Kammerschreiber</roleName> Herman Mulndorf</rs> und seiner
                        <rs type="person" ref="pe__anna_QGW_II_I_828"><roleName type="kin" corresp="pe__hermann_mulndorf_QGW_II_I_828">Hausfrau</roleName> Annen</rs> verkauft
                     hatte</rs>, zu erheben und deswegen auch <triggerstring n="disp">keine Abrechnung
                        <add>zu verlangen</add></triggerstring> von ihren <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_ameisser_QGW_II_I_828"><roleName type="kin" corresp="pe__johann_von_fucha_QGW_II_I_828">Oheimen</roleName>
                        <roleName type="kin" corresp="pe__georg_von_fucha_QGW_II_I_828"><add>Oheim</add></roleName>
                        <roleName type="title">hern</roleName> Hannsen dem Ameisser, dem alten</rs>,
                     und <rs type="person" ref="pe__johann_ameisser_ii_QGW_II_I_828"><roleName type="kin" corresp="pe__georg_von_fucha_QGW_II_I_828"><add>Oheim</add></roleName><roleName type="kin" corresp="pe__johann_von_fucha_QGW_II_I_828"><add>Oheim</add></roleName>
                        Hansen dem jungen Ameisser, seinem <roleName type="kin" corresp="pe__johann_ameisser_QGW_II_I_828">sun</roleName></rs></rs>, zu
                  verlangen.</rs>
