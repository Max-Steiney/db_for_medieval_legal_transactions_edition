            <origDate instant="false">ze Wienn, des nagsten freitags nach sand Jorgen tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01536_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01536_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_I_1536"><rs type="fn" role="issuer"><rs type="person" ref="pe__elisabeth_QGW_II_I_1536_a">Elspet, <roleName type="kin" corresp="pe__paul_lederer_QGW_II_I_1536"><add>hausfrau</add></roleName>
                        <rs type="person" ref="pe__paul_lederer_QGW_II_I_1536">Pauln hausfrau,
                           des <roleName type="prof">ledrer</roleName> von Lengpach</rs></rs>, <rs type="person" ref="pe__gottschalk_weisman_QGW_II_I_1536">Go/eschel der
                        Weisman <roleName type="rep" corresp="pe__agnes_QGW_II_I_1536">anstatt</roleName></rs></rs> seines <rs type="person" ref="pe__agnes_QGW_II_I_1536">noch nicht vogtbaren <roleName type="kin" corresp="pe__gottschalk_weisman_QGW_II_I_1536">Kindes</roleName>
                     Agnesen</rs>, <rs type="fn" role="issuer">und <rs type="person" ref="pe__elisabeth_QGW_II_I_1536_b">Elspet, <roleName type="kin" corresp="pe__jakob_hagen_QGW_II_I_1536"><add>hausfrau</add></roleName>
                        <rs type="person" ref="pe__jakob_hagen_QGW_II_I_1536">Jacob hausfrau des
                           Hagens</rs></rs>,</rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__stephan_reutter_QGW_II_I_1536">Stephans des
                        Reutter, <roleName type="occ" corresp="pe__rudolf_von_wallsee_QGW_II_I_1205">amptman</roleName> des <rs type="person" ref="pe__rudolf_von_wallsee_QGW_II_I_1205"><roleName type="title">edeln herren</roleName>
                           <roleName type="title">hern</roleName> Ruedolfs von Waltsee, <rs type="person" ref="pe__wilhelm_herzog_von_oesterreich_QGW_II_I_1313"><roleName type="occ" corresp="org__oesterreich-herzogtum">herzog</roleName>
                              Wilhalms</rs>
                           <roleName type="occ" corresp="pe__wilhelm_herzog_von_oesterreich_QGW_II_I_1313">hofmeister</roleName></rs>,</rs></rs>
                  <rs type="event" ref="ev__QGW_II_I_1536_men_1">die ihnen von ihrer <rs type="person" ref="pe__katharina_QGW_II_I_1536"><unclear instant="false"><roleName type="kin" corresp="pe__elisabeth_QGW_II_I_1536_a">muemen</roleName>
                           <roleName type="kin" corresp="pe__elisabeth_QGW_II_I_1536_b"><add>muemen</add></roleName>
                           <roleName type="kin" corresp="pe__gottschalk_weisman_QGW_II_I_1536"><add>muemen</add></roleName></unclear>
                        <roleName type="title">fraun</roleName> Kathrein, <roleName type="kin" corresp="pe__johann_trautmann_QGW_II_I_1296"><add>hausfraun</add></roleName>
                        <roleName type="dead"><add>got gnad</add></roleName>
                        <rs type="person" ref="pe__johann_trautmann_QGW_II_I_1296">Hannsen
                           hausfraun des Trautmans, den baiden <roleName type="dead">got
                              gnad</roleName></rs></rs>,</rs> anerstorbene Hälfte eines Weingartens,
                  gelegen ze Medling an dem Silberperig zenagst Merten weingarten von Linz, von dem
                  man hern Ruedolfen von Waltsee 3 dn. ze gruntdinst dient, <rs type="fn" role="recipient"><rs type="person" ref="pe__stephan_trautmann_QGW_II_I_1536">Stephann, des vorgenanten Trautmanns unmündigem <roleName type="kin" corresp="pe__johann_trautmann_QGW_II_I_1296">Sohne</roleName></rs>,</rs>
                  um 7 lb dn., wovon der ersten Elspet 14 sh. dn., der zweiten 3 ½ lb dn. zufallen
                  und 14 sh. dn. für Agnes an ein ander erib oder gu/elt gelegt werden sollen.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1536"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="pe__stephan_reutter_QGW_II_I_1536">Amtmannes</rs> und <rs type="person" ref="pe__peter_angerfelder_QGW_II_I_1373"><roleName type="title">hern</roleName> Petreins des Angervelder, <roleName type="occ" corresp="org__wien">statrichter</roleName> ze
                     Wienn</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsate: a) Bilber, Rudolf Walse VII, b) das ist der brief über den weingarten ze
               Medling, c) Alwerti von Snaitau, d) Albrecht von Snaittach. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>