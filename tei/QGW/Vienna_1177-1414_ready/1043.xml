            <origDate instant="false">ze Wienn, des nechsten eritags vor sand Thomans tag, des heiligen
               zwelifpoten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01043_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01043_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="ev__QGW_II_I_1043"><rs type="fn" role="issuer"><rs type="person" ref="pe__andreas_hoechstel_QGW_II_I_1043">Andre der Höchstel, <roleName type="occ" corresp="org__tulln-dominikanerinnen" select="pl__doebling">amptman</roleName> ze Töblich der erbern geistleichen vrowen ze Tuln
                        Prediger ordens</rs></rs> , <triggerstring n="disp">beurkundet, dass vor ihm in
                     offenem Gerichte</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__lucia_QGW_II_I_1018"><roleName type="title">Frau</roleName> Lucei die Nezeugerinn, <roleName type="occ" corresp="org__wien">purgerin</roleName> ze
                     Wienne</rs></rs> , <rs type="person" ref="pe__johann_naezeuger_ii_QGW_II_I_1018">ihrem
                        <roleName type="kin" corresp="pe__lucia_QGW_II_I_1018">Sohne</roleName>
                     Jansen</rs>
                  <triggerstring n="disp">eine Klage <add>aufgetragen habe</add></triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">hinz</triggerstring> irem gelter <rs type="person" ref="pe__martin_stainer_QGW_II_I_1011">Merten dem Stainer</rs></rs>
                  aufgetragen habe. <rs type="fn" role="other"><rs type="person" ref="pe__johann_naezeuger_ii_QGW_II_I_1018">Janns</rs>
                     <add>mit Vorsprechen</add></rs>
                  <triggerstring n="disp">klagt</triggerstring> hierauf mit Vorsprechen auf ein Merten dem
                  Stainer gehöriges Drittel Weingarten, gelegen ze Töblich an der Mittern Hohenbard
                  zenachst des Sirfeier weingarten, von dem man einen Eimer Wein zu Bergrecht und 1
                  dn. zu Voitrecht dient. Nach Ablauf des Verfahrens <triggerstring n="disp">spricht
                        <add>zu</add></triggerstring> der Amtmann den Weingarten der <rs type="fn" role="recipient"><rs type="person" ref="pe__lucia_QGW_II_I_1018">Klägerin</rs></rs> zu.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1043"><rs type="fn" role="witness">Besiegelt mit
                     dem Siegel des <rs type="person" ref="pe__peter_puhler_von_luenz_QGW_II_I_1043">erbern
                        pergmaister Peter des Puehel, <roleName type="occ" corresp="org__tulln">purger</roleName> ze Tuln, <roleName type="occ" corresp="org__tulln-dominikanerinnen">schaffer und verbeser</roleName>
                        der erbern geistleichen vrown doselbs ze Tuln Prediger Ordens</rs>
                  .</rs></rs>
            </p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>