               <rs type="event" ref="ev__QGW_II_I_165"><rs type="fn" role="issuer"><rs type="person" ref="pe__jakob_chrannest_QGW_II_I_165">Jacob der Chrannest <roleName type="kin" corresp="pe__pilgrim_mundoffen_QGW_II_I_165"><add>aidem</add></roleName>,<rs type="person" ref="pe__pilgrim_mundoffen_QGW_II_I_165">
                           <roleName type="title">hern</roleName> Pilgreimes aidem des
                           Mundoffen</rs>, <roleName type="occ" corresp="org__wien">purger</roleName> ze Wienne</rs>, und <rs type="person" ref="pe__bertha_QGW_II_I_165">Perchte, seine <roleName type="kin" corresp="pe__jakob_chrannest_QGW_II_I_165">Hausfrau</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="pe__konrad_hubmeister_QGW_II_I_207">
                        <roleName type="title">Bergherrn</roleName> des <roleName type="title">Ritters</roleName>
                        <roleName type="title">hern</roleName> Chunrates, des <roleName type="occ" corresp="org__oesterreich-herzogtum">hubmaisters</roleName> in
                        Osterreiche</rs></rs>, ihres Erbgutes ein Joch Weingarten, der da leit an
                  dem Neuenperge zenaechst seines Bruders Weingarten, <rs type="person" ref="pe__dietrich_chrannest_QGW_II_I_319">
                     <roleName type="title">hern</roleName> Dietreiches des Chrannestes, <roleName type="kin" corresp="pe__jakob_chrannest_QGW_II_I_165"><add>Bruder</add></roleName></rs>, von dem man jährlich 30 dn. zu
                  Bergrecht, Voitrecht und Zehent dient, um 82 lb dn. <rs type="fn" role="recipient">den beschaiden leuten <rs type="person" ref="pe__friedrich_bei_dem_steg_QGW_II_I_165">Fridreichen pei dem Stege vor
                        Wydemertor</rs> und <rs type="person" ref="pe__reitze_QGW_II_I_165"><roleName type="title">vron</roleName> Reiczzen, seiner <roleName type="kin" corresp="pe__friedrich_bei_dem_steg_QGW_II_I_165">hausvrowen</roleName></rs>, und <rs type="person" ref="pe__friedrich_koch_QGW_II_I_165"><roleName type="title">maister</roleName> Fridreichen, dem <roleName type="prof">choche</roleName>, seinem<roleName type="kin" corresp="pe__friedrich_bei_dem_steg_QGW_II_I_165">
                     swager</roleName></rs>, und <rs type="person" ref="pe__gertrud_QGW_II_I_165">vron Gedrauten, seiner <roleName type="kin" corresp="pe__friedrich_koch_QGW_II_I_165">hausvrowen</roleName></rs>.</rs>
                  <rs type="event" ref="ev__QGW_II_I_165_men_1">Der Vater Jakobs hatte den
                     Weingarten von <rs type="person" ref="pe__jutta_QGW_II_I_165"><roleName type="title">Frau</roleName> Jeutten der Gotesvelderinne</rs> und ihrem
                        <rs type="person" ref="pe__johann_QGW_II_I_165"><roleName type="kin" corresp="pe__jutta_QGW_II_I_165">Sohne</roleName> Jans</rs> gekauft</rs>
                  .</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_165"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des Ausstellers <rs type="person" ref="pe__jakob_chrannest_QGW_II_I_165"><add>Jakob Chrannest</add></rs>, 2.
                     des Bergherrn <rs type="person" ref="pe__konrad_hubmeister_QGW_II_I_207"><add>Konrad Hubmeister</add></rs>, 3. <rs type="person" ref="pe__jakob_maeserl_QGW_II_I_121"><roleName type="title">hern</roleName>
                        Jacobs des Maeserleins</rs>.</rs></rs>
            </p><p><rs type="event" ref="ev__QGW_II_I_165"><rs type="fn" role="witness">Zeugen: <rs type="person" ref="pe__heinrich_QGW_II_I_165"><roleName type="title">her</roleName> Hainreich, der <roleName type="prof">chuchenmaister</roleName></rs> <rs type="person" ref="pe__konrad_atzgersdorfer_QGW_II_I_165"><roleName type="title">her</roleName> Chunrat der Aetzkestorfer</rs> <rs type="person" ref="pe__heinrich_zukchswert_QGW_II_I_165">Hainrich der Zuchswert</rs> <rs type="person" ref="pe__leopold_bei_dem_valtor_QGW_II_I_165">Leupolt bei dem
                        Valtor</rs> <rs type="person" ref="pe__georg_QGW_II_I_144">Georg, des
                        hubmaisters <roleName type="occ" corresp="pe__konrad_hubmeister_QGW_II_I_207" cert="low">schreiber</roleName></rs> <rs type="person" ref="pe__ruediger_pekche_QGW_II_I_165">Ruger, der pekche</rs> <rs type="person" ref="pe__hartneid_rostauscher_QGW_II_I_165">Haertel, der
                           <roleName type="prof">rostauscher</roleName></rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>