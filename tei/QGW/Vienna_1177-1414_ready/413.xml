      <div type="abstract" resp="lp">
        <p>*<rs type="event" ref="ev__QGW_II_I_413">
            <rs type="fn" role="issuer"><rs type="person"
                ref="pe__ludwig_koenig_von_ungarn_QGW_II_I_838">Ludwig, <roleName type="occ"
                  corresp="org_ungarn">König</roleName> von Ungarn</rs></rs>, <triggerstring n="disp"
              >bestimmt</triggerstring>,<rs type="fn" role="recipient">
              <rs type="org" ref="org__wien"> dass die Fleischhauer aus Wien</rs> und die anderen
              Handelsleute aus dem Gebiete des Herzogs Albrecht bis Oedenburg</rs> keine anderen
            Abgaben, als in villa Chyeagi zur Herstellung der Marienkirche von einem beladenen Wagen
            einen Helbling und in tributo fratrum Cruciferorum de Suprunio von einem Loden oder
            Stück grauen Tuches drei Helblinge zu entrichten haben.</rs>
        </p>
