               tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01443_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01443_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="ev__QGW_II_I_1443"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_spiegler_QGW_II_I_1075">Hanns der Spiegler,
                           <rs type="person" ref="pe__albrecht_iv_herzog_von_oesterreich_QGW_II_I_1332"><roleName type="occ" corresp="org__oesterreich-herzogtum">Herzog</roleName> Albrechts</rs>
                        <roleName type="occ" corresp="pe__albrecht_iv_herzog_von_oesterreich_QGW_II_I_1332">Kellerschreiber</roleName></rs></rs>, <triggerstring n="disp">bestätigt</triggerstring>, dass ihm seine <rs type="fn" role="recipient"><rs type="person" ref="pe__margarethe_QGW_II_I_1443"><roleName type="kin" corresp="pe__johann_spiegler_QGW_II_I_1075">swieger</roleName>
                        <roleName type="title">frau</roleName> Margret, Hannsen <roleName type="kin" corresp="pe__johann_plesberger_QGW_II_I_1443">witib</roleName>
                        <rs type="person" ref="pe__johann_plesberger_QGW_II_I_1443"><add>Hannsen</add> des Plesperger <roleName type="dead"><add>witib</add></roleName></rs></rs></rs>, zu irer <rs type="fn" role="other"><rs type="person" ref="pe__elisabeth_QGW_II_I_1443"><roleName type="kin" corresp="pe__margarethe_QGW_II_I_1443">tochter</roleName>
                        Elspeten, seiner <roleName type="kin" corresp="pe__johann_spiegler_QGW_II_I_1075">Hausfrau</roleName>
                        <roleName type="dead"><add>der auch got gnad</add></roleName></rs>
                     <triggerstring n="fn"><add>Heimsteuer</add></triggerstring></rs>, der auch got gnad,
                  200 lb dn. <triggerstring n="disp">zu Heimsteuer gegeben habe</triggerstring>, wofür er
                     <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="pe__paul_holzkaeufel_QGW_II_I_1010"><roleName type="occ" corresp="org__wien">damaligen Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Paul des Holzche/auffels</rs> und des
                        <rs type="org" ref="org__wien">rates gemain der stat ze Wienn</rs></rs> sein
                  Haus, gelegen an dem Alten Rossmarkcht ze Wienn zenechst dem haus, das weilend
                  Hannsen seligen des Haunzants, des sneider, gewesen ist, <triggerstring n="disp">zu
                     Pfand gesetzt hatte</triggerstring>, mit der Bestimmung, dass er diese 200 lb dn.
                  auf Lebenszeit innehabe, dieselben aber nach seinem Tode an die genannte Frau
                  Margret und ihre Erben <triggerstring n="disp">zurückfallen
               sollen</triggerstring>.</rs></p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_I_1443"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="pe__georg_neuer_QGW_II_I_1195">Wiener <roleName type="occ" corresp="org__wien">Bürgers</roleName> Jörgen des
                        Neuer</rs></rs>.</rs></p></div><div type="nota"><p>Indorsat: II// c Ib. dem Hirssauer. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>