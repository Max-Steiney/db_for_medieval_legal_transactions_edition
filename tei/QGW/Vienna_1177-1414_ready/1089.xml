   <text>
      <body>
         <div type="abstract" resp="cs">
            <p>
               <rs type="event" ref="ev__QGW_II_I_1089"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__diemut_QGW_II_I_1089">Diemuet, Chunrats <roleName
                           type="kin" corresp="pe__konrad_vechter_QGW_II_I_1089"
                        >hausvrow</roleName>, <rs type="person"
                           ref="pe__konrad_vechter_QGW_II_I_1089"><add>Chunrats</add> des vechter ze
                           Wienn</rs></rs></rs> , <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs
                        type="person" ref="pe__ulrich_tumbriczer_QGW_II_I_1082"><roleName
                           type="title">Ritters</roleName>
                        <roleName type="title">hern</roleName> Ulreichs des Tumbriczer, <roleName
                           type="occ" corresp="org__klosterneuburg-augustiner_chorherren"
                           >amptman</roleName> des klosters ze Neunburch</rs></rs> , ihren
                  Weingarten, den ihr <rs type="person" ref="pe__bertha_rokkin_QGW_II_I_1089"
                        ><roleName type="title">frow</roleName> Pericht die Rokkin</rs> gegeben
                  hatte, gelegen an dem obern Spiegl, des dreu ochtail sint, zenechst des Phann
                  weingarten von Ried , von dem man 3 ½ Viertel und ¼ eines Viertels Wein zu
                  Bergrecht und 9 ort zu Voitrecht dient, um 37 ½ lb dn. <rs type="fn"
                     role="recipient"><rs type="person" ref="pe__andreas_vischl_QGW_II_I_1089"
                        >Andren dem Vischlein, dem <roleName type="prof">silberprenner</roleName>,
                           <roleName type="occ" corresp="org__wien">purger</roleName> ze
                        Wienn</rs> , und seiner <rs type="person" ref="pe__anna_QGW_II_I_1089"
                           ><roleName type="kin" corresp="pe__andreas_vischl_QGW_II_I_1089"
                           >Hausfrau</roleName> Annen</rs></rs> . <triggerstring n="disp">Als Bürgen
                     treten <add>ein</add></triggerstring> neben der Ausstellerin ein: <rs type="fn"
                     role="other"><triggerstring n="fn"><add>mit Rathe von</add></triggerstring>
                     <rs type="person" ref="pe__stephan_leitner_QGW_II_I_1012">Stephan der
                        Leitner</rs></rs>, <rs type="fn" role="other"><triggerstring n="fn"><add>mit
                           Rathe von</add></triggerstring>
                     <rs type="person" ref="pe__friedrich_dietram_QGW_II_I_1026">Fridreich der
                        Dietram</rs></rs> und <rs type="fn" role="other"><triggerstring n="fn"><add>mit
                           Rathe von</add></triggerstring>
                     <rs type="person" ref="pe__konrad_rokk_QGW_II_I_1031">Chunrat der
                     Rokk</rs></rs> .</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_I_1089"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der Bürgen <rs type="person"
                        ref="pe__stephan_leitner_QGW_II_I_1012"><add>Leitner</add></rs>
                     <rs type="person" ref="pe__friedrich_dietram_QGW_II_I_1026"
                        ><add>Dietram</add></rs>
                     <rs type="person" ref="pe__konrad_rokk_QGW_II_I_1031"><add>Rokk</add></rs> und
                     des <rs type="person" ref="pe__ulrich_tumbriczer_QGW_II_I_1082"
                     >Amtmanns</rs>.</rs></rs>
            </p>
         </div>
