            <origDate instant="false">zu Wienn, an freitag nach des heiligen Kreucz tag
               invencionis.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03711_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03711_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3711"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_hirss_QGW_II_II_3399">Hanns Hirss, <roleName type="occ" corresp="org__wien">burger</roleName> zu
                     Wienn</rs>,</rs>
                  <triggerstring n="disp">stellt</triggerstring> wegen eines verlorenen Satzzettels <rs type="event" ref="ev__QGW_II_II_3399">über die 246 lb dn., die er Andren dem
                     Schönaich und Hannsen dem Winkchler, Niclasen des Tirmans seligen
                     geschefftleuten, zu hannden Jörgen, seines suns, schuldig ist worden , für die
                     er ihnen sein haus mitsambt der Neuen Melgrub, am Neunmarkt gelegen zenagst dem
                     Meczengadem, versaczt hatte, das er nunmehr neuerdings für denselben Betrag
                     seinen Kindern aus seiner Ehe mit Helen, weilent des egenanten Tirmans seligen
                     hausfraun, verschrieben hat,</rs>
                  <rs type="fn" role="recipient"><rs type="org" ref="org__wien">dem Bürgermeister
                        und Rathe</rs> sowie <rs type="person" ref="pe__jakob_rechwein_QGW_II_II_3242">den <roleName type="occ" corresp="org__wien">Verwesern ihrer Grundbücher</roleName>, Jacob
                        Rechwein, des <roleName type="occ" corresp="org__wien">rats</roleName>,</rs>
                     und <rs type="person" ref="pe__michael_mannersdorffer_QGW_II_III_4064"><roleName type="occ" corresp="org__wien"><add>Verwesern ihrer
                              Grundbücher</add></roleName>Michel Mênestorffer, <roleName type="occ" corresp="org__wien">burger</roleName> zu
                     Wienn</rs>,</rs> welche ihm den neuen Satz trotzdem gefertigt haben, einen
                     <triggerstring n="disp">Revers aus</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3711"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__niklas_purger_QGW_II_III_3758">Niclasen
                        des Purger <roleName type="occ" corresp="org__wien"><add>burgern</add></roleName></rs> und <rs type="person" ref="pe__michael_rutenstokch_QGW_II_II_3307">Micheln des Rutenstokch, baid
                           <roleName type="occ" corresp="org__wien">burger</roleName> zu
                        Wienn</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>