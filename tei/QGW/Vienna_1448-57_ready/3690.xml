   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3690"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__matthias_langenmantl_QGW_II_II_3690">Mathes
                        Lanngenmantl, <roleName type="occ" corresp="org__moedling">burger</roleName>
                        zu Medling</rs>, und <rs type="person" ref="pe__anna_QGW_II_II_3690">Anna,
                        sein <roleName type="kin" corresp="pe__matthias_langenmantl_QGW_II_II_3690"
                           >hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">nehmen</triggerstring>
                  <rs type="fn" role="recipient">von <rs type="person"
                        ref="pe__heinrich_stupper_QGW_II_II_3573"><roleName type="title"
                           >herrn</roleName> Hainreichen Stupper, <roleName type="occ"
                           corresp="org__wien-st_stephan">korherr</roleName> dacz sand Stephan zu
                        Wienn, <roleName type="rep" corresp="pe__johann_acrum_QGW_II_II_3573"
                           >anstat</roleName> und <roleName type="rep"
                           corresp="pe__johann_acrum_QGW_II_II_3573">in nomen</roleName>
                        <rs type="person" ref="pe__johann_acrum_QGW_II_II_3573"><roleName
                              type="title">maister</roleName> Hannsen von Arcum, <roleName
                              type="occ"
                              corresp="org__wien-st_agnes_auf_der_himmelpforte-kapelle_st_katharina-messe_stetten"
                              >caplan</roleName> und <roleName type="occ"
                              corresp="org__wien-st_agnes_auf_der_himmelpforte-kapelle_st_katharina-messe_stetten"
                              >Verweser</roleName> der andern mess, die weilent her Mertt von Steten
                           auf sand Kathrein altar zu der Himelporten gestifft hat</rs></rs> ,</rs>
                  <rs type="fn" role="transactiongood_II"><rs type="place"
                        ref="pl__moedling-immo_15">einen <roleName type="owner"
                           corresp="org__wien-st_agnes_auf_der_himmelpforte-kapelle_st_katharina-messe_stetten"
                           >dazu gehörigen</roleName> Weingarten, <roleName type="topo"
                           corresp="pl__moedling">gelegen daselbs zu Medling</roleName> zenagst <rs
                           type="place" ref="pl__moedling-immo_16"><roleName type="owner"
                              corresp="pe__niklas_zinkk_QGW_II_II_3690">weilent Niclasen des
                              Zingken</roleName> weingarten</rs>
                        <roleName type="topo" corresp="pl__moedling-immo_16"><add>zenagst</add> an
                           ainer seitten</roleName>
                        <roleName type="topo" corresp="pl__moedling-immo_17">und an der andern
                           zenagst</roleName>
                        <rs type="place" ref="pl__moedling-immo_17"><roleName type="owner"
                              corresp="pe__lukas_wiczinger_QGW_II_II_3690"><rs type="person"
                                 ref="pe__lukas_wiczinger_QGW_II_II_3690">Lucasen
                              Wiczinger</rs></roleName> weingarten</rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_I">gegen einen <triggerstring n="fn"
                        >Jahresdienst</triggerstring> von <measure>10 sh. dn.</measure></rs>
                  <triggerstring n="disp">auf Lebenszeit in Bestand</triggerstring>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3690"><rs type="fn" role="witness">Siegler: der
                        <rs type="person" ref="pe__matthias_langenmantl_QGW_II_II_3690"
                        >Aussteller</rs> und <rs type="person"
                        ref="pe__laurenz_von_rust_QGW_II_II_3329">Larencz von Russt, <roleName
                           type="occ" corresp="org__moedling">burger</roleName> zu
                  Medling</rs></rs>.</rs>
            </p>
         </div>
