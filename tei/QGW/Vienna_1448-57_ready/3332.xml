   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__SB_CD_00057"><rs type="fn" role="issuer"><rs type="person"
                        ref="pe__andreas_meichsner_QGW_II_II_3332">Andre Meichsner, der <roleName
                           type="prof">goltsmid</roleName>, <roleName type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs>, und <rs
                        type="person" ref="pe__margarethe_SB_CD_00057">Margret, sein <roleName
                           type="kin" corresp="pe__andreas_meichsner_QGW_II_II_3332"
                           >hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">verkaufen <add>geltes purkrechts</add></triggerstring>
                  <rs type="fn" role="other"><triggerstring n="disp">mit Handen</triggerstring> des <rs
                        type="person" ref="pe__johann_steger_QGW_II_II_3264"><roleName type="title"
                           >edeln</roleName>
                        <roleName type="title">vesten</roleName>
                        <roleName type="title">ritter</roleName>
                        <roleName type="title">hern</roleName> Hannsen des Steger, <roleName
                           type="occ" corresp="org__wien">Bürger-<add>meister</add></roleName> und
                           <roleName type="occ" corresp="org__oesterreich-herzogtum"
                           >Münzmeisters</roleName></rs>, und des <rs type="org" ref="org__wien"
                        >Rathes</rs></rs>
                  <rs type="fn" role="transactiongood_I"><measure>2 lb dn.</measure>
                     <triggerstring n="fn">geltes purkrechts</triggerstring> (ablösbar) auf <rs
                        type="place" ref="pl__wien-immo_kohlmarkt_11"><roleName type="owner"
                           corresp="pe__margarethe_SB_CD_00057"><add>ihrem</add></roleName>
                        <roleName type="owner" corresp="pe__andreas_meichsner_QGW_II_II_3332"
                           >ihrem</roleName> Hause, <roleName type="topo"
                           corresp="pl__wien-kohlmarkt">gelegen am Kolmarkcht</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_kohlmarkt_7">zenagst <add>an
                              aim tail</add></roleName>
                        <rs type="place" ref="pl__wien-immo_kohlmarkt_7"><roleName type="owner"
                              corresp="pe__hartmann_tannauer_QGW_II_II_2649"><rs type="person"
                                 ref="pe__hartmann_tannauer_QGW_II_II_2649">Hartmans
                              Tannauer</rs></roleName> haus</rs> an aim tail, <rs type="event"
                           ref="ev__QGW_II_II_3663"><rs type="fn" role="issuer">von <rs type="place"
                                 ref="pl__wien-immo_kohlmarkt_11">dem</rs> man</rs>
                           <rs type="fn" role="recipient"><rs type="person"
                                 ref="pe__thomas_von_goellersdorf_QGW_II_II_3087"><roleName
                                    type="title">hern</roleName> Thoman von Gelestorf, <roleName
                                    type="occ"
                                    corresp="org__wien-st_stephan-kapelle_st_sigmund_und_st_wolfgang"
                                    >kaplan</roleName> sand Sigmunds und sand Wolfgangs capelln
                                 under dem letter zu sand Steffan</rs>,</rs>
                           <rs type="fn" role="transactiongood_I"><measure>12 sh. dn.</measure>
                              <triggerstring n="fn">zu Burgrecht</triggerstring></rs>
                           <triggerstring n="disp"><add>Burgrecht</add>
                     dient</triggerstring></rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_II">um <measure>20 lb dn.</measure>, <rs
                        type="event" ref="ev__QGW_II_II_3332_men_1"><rs type="fn"
                           role="transactiongood_I">die <measure><add>2 lb dn.</add></measure>
                           <triggerstring n="fn"><add>geltes purkrechts</add></triggerstring></rs>
                        <triggerstring n="disp">emaln gelegen sind</triggerstring>
                        <rs type="fn" role="issuer">auf <rs type="place"
                              ref="pl__wien-immo_scheffstrasse_1"><roleName type="owner"
                                 corresp="pe__klara_SB_CD_00231">Claren, der
                                 prugkmaisterin,</roleName> haus <roleName type="topo"
                                 corresp="pl__wien-scheffstrasse">in der
                              Scheffstrass</roleName></rs>,</rs></rs></rs>
                  <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__niklas_kiliber_SB_CD_00231"><roleName type="title">hern</roleName>
                        Niclasen Kiliber, <roleName type="occ"
                           corresp="org__wien-gottesleichnam_kapelle_vor_dem_werdertor-altar_st_maria-messe_flekch"
                           >Kaplan</roleName>
                        <rs type="event" ref="ev__SB_CD_00057_men_2">der von Ulreich Flekch auf
                           Unser Fraun altar in sand Johanns cappeln vor Werdertor gestifteten
                           Messe</rs></rs>, und <rs type="org"
                        ref="org__wien-gottesleichnam_kapelle_vor_dem_werdertor-altar_st_maria-messe_flekch"
                        >seinen Nachfolgern</rs>.</rs></rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__SB_CD_00057"><rs type="fn" role="witness">Besiegelt mit dem
                        <rs type="org" ref="org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="pe__hartmann_tannauer_QGW_II_II_2649">Wiener
                           <roleName type="occ" corresp="org__wien">Bürgers</roleName>
                        Hartmann Tannauer</rs>.</rs></rs>
            </p>
