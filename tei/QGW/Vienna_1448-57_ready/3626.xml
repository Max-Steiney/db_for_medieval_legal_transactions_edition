        <origDate instant="false">zu Wienn, an sambstag nach sand Pangräczen
        tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03626_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03626_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
          <rs type="event" ref="ev__QGW_II_II_3626"><rs type="fn" role="issuer"><rs type="person" ref="pe__anna_QGW_II_II_3626"><roleName type="title">Swester</roleName> Anna die
                Vösendorfferin, <roleName type="occ" corresp="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">abtessin</roleName> dacz sand Niclas vor Stubentor zu Wienn</rs>, und <rs type="org" ref="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">der
                convent gemain daselbs</rs></rs>
            <triggerstring n="disp">bestätigen, dass</triggerstring>
            <rs type="fn" role="recipient"><rs type="org" ref="org__wien">Bürgermeister und
                Rath</rs></rs> ihnen <rs type="fn" role="transactiongood_II">von den 100 lb dn.,
              welche Anna die Schönhauerin hinterlassen hatte, <measure>50 lb dn.</measure></rs>
            <triggerstring n="disp">gegeben haben</triggerstring>, welche von ihnen an ihren stadl verpaut
            worden sind, <triggerstring n="disp">und verpflichten sich</triggerstring>, wenn Erben
            auftreten, welche ihren berechtigten Anspruch nachweisen können, diese Summe <triggerstring n="disp">wieder zurückzuzahlen</triggerstring>. <triggerstring n="reason"><rs type="event" ref="ev__QGW_II_II_3626_men_1"><rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_pusinger_QGW_II_II_3626">Ulreich Pusinger, der <roleName type="prof">türhuetter</roleName></rs>,</rs>
                <triggerstring n="disp">hatte</triggerstring>
                <rs type="fn" role="transactiongood_I">nämlich sein ganzes Gut</rs>
                <rs type="fn" role="recipient">seiner <rs type="person" ref="pe__anna_QGW_II_II_3626_b"><roleName type="kin" corresp="pe__ulrich_pusinger_QGW_II_II_3626">hausfraun</roleName> Annen der
                    Schönhauerin</rs></rs> mit der Bedingung <triggerstring n="disp">geschafft</triggerstring>, <triggerstring n="impl_rules">dass sie seinen Erben 100 lb
                  dn. ausrichten solt,</triggerstring> wofür ihr Haus in der Lantstrass den
                Klosterfrauen in ihrem gruntpuech versaczt gewesen ist Anna selbst aber war
                gestorben, ohne dies Geschäft auszuführen.</rs></triggerstring></rs>
        </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>