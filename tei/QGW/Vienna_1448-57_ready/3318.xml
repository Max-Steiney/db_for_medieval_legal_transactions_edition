            <placeName>Wien</placeName>
            <date when="14490730">1449 VII 30</date>
            <origDate instant="false">zu Wienn, an mitichen vor sand Stephans tag
               invencionis.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03318_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03318_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3318"><rs type="fn" role="issuer"><rs type="person" ref="pe__erasmus_ponhaimer_QGW_II_II_3289">Erasem Ponhaimer,
                           <roleName type="occ" corresp="org__wien">statrichter</roleName> zu
                        Wienn</rs>,</rs>
                  <triggerstring n="disp">beurkundet, dass vor ihm in der Bürgerschranne</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="pe__johann_han_SB_CD_00617">Hanns Han <roleName type="rep" corresp="pe__niklas_kramhofer_QGW_II_II_3278">anstat <add>des gewalt er
                              hat</add></roleName></rs>
                     <triggerstring n="fn"><add>mit vorsprechen</add></triggerstring></rs>
                  <rs type="person" ref="pe__niklas_kramhofer_QGW_II_II_3278">seines <roleName type="kin" corresp="pe__johann_han_SB_CD_00617">vetern</roleName> Niclasen
                     des Kramhofer, <roleName type="occ" corresp="org__wien">burger</roleName>
                     zu Wienn</rs>, des gewalt er hat, mit vorsprechen <rs type="fn" role="transactiongood_III">auf <rs type="place" ref="pl__wien-immo_ratsgasse_1"><roleName type="owner" corresp="pe__johann_zinngiesser_QGW_II_II_2552"><rs type="person" ref="pe__johann_zinngiesser_QGW_II_II_2552"><roleName type="dead">weilent</roleName> Hannsen, <roleName type="prof">zingiesser</roleName>, des abenteurer von
                           Nurnberg</rs></roleName>, und <roleName type="owner" corresp="pe__barbara_QGW_II_II_2552"><rs type="person" ref="pe__barbara_QGW_II_II_2552">Barbara, seiner <roleName type="kin" corresp="pe__johann_zinngiesser_QGW_II_II_2552">hausfraun</roleName>
                              <roleName type="dead">seligen</roleName></rs></roleName>, haus,
                           <roleName type="topo" corresp="pl__wien-ratsgasse">gelegen in dem
                           Ratgesslein daselbs zu Wienn</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_ratsgasse_2">zunagst</roleName>
                        . . <rs type="place" ref="pl__wien-immo_ratsgasse_2"><roleName type="owner" corresp="pe__johann_hirss_QGW_II_II_3399"><rs type="person" ref="pe__johann_hirss_QGW_II_II_3399">Hirssen, des <roleName type="prof">kramer</roleName></rs>,</roleName> haus</rs></rs>,
                     umb <measure>37 lb dn.</measure> geklagt habe, <rs type="event" ref="ev__QGW_II_II_3318_men_1">die <rs type="fn" role="issuer">von in <rs type="person" ref="pe__johann_zinngiesser_QGW_II_II_2552">baiden</rs><rs type="person" ref="pe__barbara_QGW_II_II_2552"/></rs>
                        <rs type="fn" role="recipient">dem <rs type="person" ref="pe__niklas_kramhofer_QGW_II_II_3278">benannten
                           Kramhofer</rs></rs> noch unbezalt ausstünden an den <rs type="fn" role="transactiongood_II"><measure>66 lb dn.</measure></rs>, so si baide
                        unverschaidenlich im schuldig wern und gelten solten und dafur im <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_ratsgasse_1">das benant ir haus</rs></rs>
                        <triggerstring n="disp">versaczt</triggerstring> wer .</rs></rs>
                  <rs type="fn" role="other"><add>hincz</add>Daraufhin wird <rs type="person" ref="pe__margarethe_QGW_II_II_3318">Margreth, <rs type="person" ref="pe__johann_silberprenner_QGW_II_II_3318">Hannsen, des <roleName type="prof">silberprenner</roleName>, <roleName type="dead">witib</roleName></rs>, <roleName type="kin" corresp="pe__johann_silberprenner_QGW_II_II_3318"><add>witib</add></roleName>
                        <roleName type="occ" corresp="org__wien">mitwonerin</roleName> zu
                        Wienn, als nächste Erbin ihres <roleName type="kin" corresp="pe__johann_zinngiesser_QGW_II_II_2552">Bruders</roleName></rs>
                     <rs type="person" ref="pe__johann_zinngiesser_QGW_II_II_2552"><roleName type="dead"><add>Erbin</add></roleName> Hannsen, zingiesser</rs>,
                     verständigt, während die Erben der Barbara nicht aufzufinden waren.</rs>
                  Margarethe nimmt sich einen bedenkchtag auf den nagsten rechttag. Da sie an
                  demselben nicht erscheint, <triggerstring n="disp">so macht</triggerstring> der Richter
                     <rs type="fn" role="recipient"><rs type="person" ref="pe__niklas_kramhofer_QGW_II_II_3278">Niclasen den Kramhofer</rs></rs>
                  des Hauses <triggerstring n="disp">gewaltig</triggerstring>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>