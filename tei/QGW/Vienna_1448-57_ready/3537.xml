            <placeName>Wien</placeName>
            <date when="14530924">1453 IX 24</date>
            <origDate instant="false">zu Wienn, an montag vor sand Michels
            tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03537_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03537_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3537"><rs type="fn" role="issuer"><rs type="person" ref="pe__stephan_straler_QGW_II_II_3537">Stephan Straler, der
                           <roleName type="prof">maurer</roleName>, gesessen zu dem Seicz</rs>, und
                        <rs type="person" ref="pe__margarethe_QGW_II_II_3537">Margreth, sein
                           <roleName type="kin" corresp="pe__stephan_straler_QGW_II_II_3537">swester</roleName>, <rs type="person" ref="pe__leopold_paur_QGW_II_II_3537">Leupolts des Paurn <roleName type="title_ref" corresp="pl__klosterneuburg">zu</roleName>
                           Klosterneunburg</rs>
                        <roleName type="kin" corresp="pe__leopold_paur_QGW_II_II_3537">hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">verzichten</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951"><roleName type="title">hern</roleName> Niclasen des Teschler, <roleName type="occ" corresp="org__wien">burgermaister</roleName></rs>, und <rs type="org" ref="org__wien">des rats gemain der stat zu Wienn</rs></rs>
                  <rs type="fn" role="transactiongood_II">gegen eine entsprechende Abfindung</rs>
                  <rs type="fn" role="recipient">zu Gunsten <rs type="person" ref="pe__barbara_QGW_II_II_3537"><roleName type="title">fraun</roleName>
                        Barbaren, <rs type="person" ref="pe__martin_pillichdorfer_QGW_II_II_3537">Mertten des Pilichdorffer <roleName type="title_ref" corresp="pl__wien-kaerntnertor">vor</roleName> Kernertor zu Wienn</rs>
                        <roleName type="kin" corresp="pe__martin_pillichdorfer_QGW_II_II_3537">hausfraun</roleName>, die emaln <rs type="person" ref="pe__erhard_straler_QGW_II_II_3537">Erharten Straler , ihren
                              <roleName type="kin" corresp="pe__stephan_straler_QGW_II_II_3537">rechten leiblichen pruder</roleName>
                           <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3537"><add>rechten
                                 leiblichen pruder</add></roleName>
                           <roleName type="dead">seligen</roleName></rs>, auch <roleName type="kin" corresp="pe__erhard_straler_QGW_II_II_3537">elichen</roleName> gehabt
                        hat</rs>,</rs>
                  <rs type="fn" role="transactiongood_I">auf <rs type="place" ref="pl__wien-immo_mietstat_vor_kaerntnertor_3">ein Haus, <roleName type="topo" corresp="pl__wien-mietstat_vor_kaerntnertor">gelegen daselbs
                           vor Kernertor an der Mietstat</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_mietstat_vor_kaerntnertor_4">zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_mietstat_vor_kaerntnertor_4"><roleName type="owner" corresp="pe__ludwig_binder_QGW_II_II_3537">weilent <rs type="person" ref="pe__ludwig_binder_QGW_II_II_3537">Ludweigs, des
                                    <roleName type="prof">pinter</roleName></rs></roleName>,
                           haus</rs>, <rs type="event" ref="ev__QGW_II_II_3537_men_1"><rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_mietstat_vor_kaerntnertor_3">darauf</rs></rs>
                           <rs type="fn" role="recipient"><rs type="person" ref="pe__barbara_QGW_II_II_3537">sie</rs></rs>
                           <rs type="fn" role="transactiongood_II"><measure>100 lb dn.</measure>
                              <triggerstring n="fn">haimsteur</triggerstring></rs>
                           <rs type="fn" role="transactiongood_II">und <measure>100 lb dn.</measure>
                              in <triggerstring n="fn">morgengabweise</triggerstring></rs>
                           <rs type="fn" role="issuer">von <rs type="person" ref="pe__erhard_straler_QGW_II_II_3537">ihrem früheren
                              Manne</rs></rs>
                           <triggerstring n="disp">verschrieben hatte</triggerstring></rs></rs>, welcher
                        <triggerstring n="fn">Morgengabe</triggerstring> sie recht und nagst warttund
                     erben gewesen weren.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3537"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="pe__leonhard_gruenpacher_QGW_II_II_2953">Wiener
                           <roleName type="occ" corresp="org__wien">Bürgers</roleName>
                        Lienharten Grünpacher</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: <rs type="event" ref="NULL">der brief ist zu scherm gelegt worden <rs type="person" ref="pe__johann_zochmann_QGW_II_II_3537">Hannsen Zochmann</rs>
                  und seinen erben von des Erharts Straler hauss wegen an der Mietstat vor
                  Kernertor, das er von Ulreichen Gundloch gekaufft hat am Aschtag (März 2), anno
                  etc. LVIImo.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>