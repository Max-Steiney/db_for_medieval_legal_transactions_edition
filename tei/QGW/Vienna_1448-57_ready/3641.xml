      <text>
            <body>
                  <div type="abstract" resp="kg">
                        <p>
                              <rs type="event" ref="ev__QGW_II_II_3641"><rs type="fn" role="issuer"
                                                ><rs type="person"
                                                ref="pe__michael_geukramer_QGW_II_II_3641">Michel
                                                Geukramer</rs></rs>
                                    <triggerstring n="disp">theilt</triggerstring>
                                    <rs type="fn" role="recipient">dem <rs type="org"
                                                ref="org__wien">Bürgermeister und Rathe der Stadt zu
                                                Wien sowie den Verwesern ihres Grundbuches</rs></rs>
                                    <triggerstring n="disp">mit, dass</triggerstring>
                                    <rs type="event" ref="ev__QGW_II_II_3641_men_2"><rs type="fn"
                                                role="issuer"><rs type="person"
                                                  ref="pe__michael_geukramer_QGW_II_II_3641"
                                                >er</rs></rs>
                                          <triggerstring n="disp">seinen tail und
                                                gerechtikait</triggerstring>, so er mitsambt seinem <rs
                                                type="person"
                                                ref="pe__heinrich_geukramer_QGW_II_II_3586"
                                                  ><roleName type="kin"
                                                  corresp="pe__michael_geukramer_QGW_II_II_3641"
                                                  >bruder</roleName> Hainreichen dem Geukramer</rs>
                                          gehabt hat <rs type="fn" role="transactiongood_I"
                                                  ><triggerstring n="fn"><add>tail</add></triggerstring>
                                                an <rs type="place" ref="pl__wien-immo_kienmarkt_21"
                                                  >dem haus und aller seiner zugehorung, <roleName
                                                  type="topo" corresp="pl__wien-kienmarkt">gelegen
                                                  am Kienmarkt</roleName>
                                                  <roleName type="topo"
                                                  corresp="pl__wien-immo_kienmarkt_20"
                                                  >zenagst</roleName>
                                                  <rs type="place" ref="pl__wien-immo_kienmarkt_20"
                                                  ><roleName type="owner"
                                                  corresp="pe__niklas_naeczeuger_QGW_II_II_3438"
                                                  >Niclasen des Neczeuger</roleName> haus</rs>, <rs
                                                  type="event" ref="ev__QGW_II_II_3641_men_1"><rs
                                                  type="fn" role="transactiongood_I"><rs
                                                  type="place" ref="pl__wien-immo_kienmarkt_21"
                                                  >das</rs></rs>
                                                  <rs type="fn" role="issuer">von <rs type="person"
                                                  ref="pe__hieronymus_geukramer_QGW_II_II_3641"
                                                  >ihrem <roleName type="kin"
                                                  corresp="pe__michael_geukramer_QGW_II_II_3641"
                                                  >vater</roleName>
                                                  <rs type="person"
                                                  ref="pe__heinrich_geukramer_QGW_II_II_3586"
                                                  ><add>vater</add></rs> Jeronim dem Geukramer
                                                  <roleName type="dead">seligen</roleName></rs></rs>
                                                  <triggerstring n="disp">erblich</triggerstring>
                                                  <rs type="fn" role="recipient">an <rs
                                                  type="person"
                                                  ref="pe__michael_geukramer_QGW_II_II_3641"
                                                  >sie</rs>
                                                  <rs type="person"
                                                  ref="pe__heinrich_geukramer_QGW_II_II_3586"
                                                  ><add>sie</add></rs></rs>
                                                  <triggerstring n="disp">komen
                                                  ist</triggerstring></rs></rs>,</rs>
                                          <rs type="fn" role="recipient"><rs type="person"
                                                  ref="pe__heinrich_geukramer_QGW_II_II_3586">seinem
                                                  Bruder</rs></rs>
                                          <triggerstring n="disp">übergeben habe</triggerstring></rs>,
                                          <triggerstring n="disp"><add>übergeben habe </add>und
                                          ersucht</triggerstring> sie, diesem das vorgemelt haus
                                    gannczes <triggerstring n="disp">vertigen zu
                                    wollen</triggerstring>.</rs>
                        </p>
                  </div>
                  <div type="seal">
                        <p><rs type="event" ref="ev__QGW_II_II_3641"><rs type="fn" role="witness"
                                          >Siegler: <rs type="person"
                                                ref="pe__michael_geukramer_QGW_II_II_3641">der
                                                Aussteller</rs> und der <rs type="person"
                                                ref="pe__johann_grimm_QGW_II_II_3641"><roleName
                                                  type="title">edel</roleName> Hanns
                                          Grymm</rs>.</rs></rs>
                        </p>
                  </div>
