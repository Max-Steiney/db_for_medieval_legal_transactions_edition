                  <triggerstring n="disp">nimmt</triggerstring>
                  <rs type="fn" role="recipient">von <rs type="person" ref="pe__johann_oppenweiler_QGW_II_II_2579"><roleName type="title">hern</roleName> Hannsen Oppenweiler von Hailbrunn, <roleName type="occ" corresp="org__ebersdorf-pfarre">pfarrer</roleName> zu Eberstorff,
