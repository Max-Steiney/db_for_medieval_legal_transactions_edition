                  <rs type="fn" role="transactiongood_II"><rs type="place" ref="pl__enzersdorf-immo_1">einen <roleName type="owner" corresp="org__wien-st_stephan-kapelle_st_katharina-altar_st_katharina-messe_hutstokch">zu dieser gehörigen</roleName> Weingarten, <roleName type="topo" corresp="pl__enzersdorf">gelegen zu Entschestorff am Hutlstain</roleName>
                        <roleName type="topo" corresp="pl__enzersdorf-immo_3">zenagst <add>an ainer
                              seitten</add></roleName>
                        <rs type="place" ref="pl__enzersdorf-immo_3"><roleName type="owner" corresp="pe__laurenz_hofkircher_QGW_II_II_3432"><rs type="person" ref="pe__laurenz_hofkircher_QGW_II_II_3432">Larenczen Hofkircher
                                    <roleName type="title_ref" corresp="pl__amstetten">von</roleName> Ambsteten</rs></roleName> weingarten</rs> an
                        ainer seitten <roleName type="topo" corresp="pl__enzersdorf-immo_2">und an
                           der andern zenagst</roleName>
                        <rs type="place" ref="pl__enzersdorf-immo_2"><roleName type="owner" corresp="org__heiligenkreuz-zisterzienser">der
                              Heiligenkreuczer</roleName> weingarten</rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_I">gegen <triggerstring n="fn">jährliche
                        Abgabe</triggerstring> des <measure>dritten Eimers Most</measure> bei der press
                     aus dem grant</rs>
                  <triggerstring n="disp">auf Lebenszeit in Bestand</triggerstring>.</rs>
