            <date when="14540206">1454 II 06</date>
            <origDate instant="false">zu Wienn, an sand Dorothea tag, der heiligen
               junkfraun.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03558_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03558_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3558"><rs type="fn" role="issuer"><rs type="person" ref="pe__wolfgang_haider_QGW_II_II_3558">Wolfgang Haider,
                           <roleName type="title_ref" corresp="pl__wien-scheffstrasse">gesessen</roleName> in der Scheffstrass zu Wienn <roleName type="rep" corresp="pe__wolfgang_haider_QGW_II_II_3558"><add>für</add></roleName>
                        <roleName type="rep" corresp="pe__raphael_haider_QGW_II_II_3558"><add>für</add></roleName>
                        <roleName type="rep" corresp="pe__georg_moltrer_QGW_II_II_3558"><add>für</add></roleName></rs>,</rs>
                  <triggerstring n="disp">verzichtet <add>auf</add>
                     <add>Erbanspruch</add></triggerstring> für sich, <rs type="person" ref="pe__raphael_haider_QGW_II_II_3558">Raphaeln, seinen <roleName type="kin" corresp="pe__wolfgang_haider_QGW_II_II_3558">Sohn</roleName>
                     <roleName type="kin" corresp="pe__elisabeth_QGW_II_II_3558"><add>Sohn</add></roleName> aus erster <rs type="person" ref="pe__elisabeth_QGW_II_II_3558"><roleName type="kin" corresp="pe__wolfgang_haider_QGW_II_II_3558">Ehe</roleName> mit
                        Elspethen, <rs type="person" ref="pe__johann_kurcz_QGW_II_II_3558">Hannsen
                           Kurcz <roleName type="title_ref" corresp="pl__klosterneuburg">zu</roleName> Klosterneunburg <roleName type="dead"><add>seligen</add></roleName></rs> und <rs type="person" ref="pe__anna_QGW_II_II_3558">Annen, seiner <roleName type="kin" corresp="pe__johann_kurcz_QGW_II_II_3558">hausfraun</roleName>
                           <roleName type="dead">seligen</roleName></rs>, <roleName type="kin" corresp="pe__johann_kurcz_QGW_II_II_3558">tochter</roleName>
                        <roleName type="kin" corresp="pe__anna_QGW_II_II_3558">tochter</roleName></rs></rs>, und <rs type="person" ref="pe__georg_moltrer_QGW_II_II_3558">Jörgen den Molter, <rs type="person" ref="pe__michael_moltrer_QGW_II_II_3558">Micheln des Molter <roleName type="dead">seligen</roleName></rs>
                     <roleName type="kin" corresp="pe__michael_moltrer_QGW_II_II_3558">sun</roleName>, die noch nicht vogtper sind</rs>, <rs type="fn" role="recipient">zu Gunsten des <rs type="person" ref="pe__leonhard_lehenholzer_QGW_II_II_3371">Linhart Lehenholczer,
                           <roleName type="occ" corresp="org__heiliges_roemisches_reich">ambtman</roleName> in der Scheffstrass, seines <roleName type="kin" corresp="pe__wolfgang_haider_QGW_II_II_3558">Schwagers</roleName></rs>,</rs>
                  <rs type="fn" role="transactiongood_I">auf den Erbanspruch an <rs type="place" ref="pl__wien-immo_wollzeile_13">das Haus, <roleName type="topo" corresp="pl__wien-wollzeile">zu Wienn in der Wolczeil niden am
                           egk</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_wollzeile_14">gegen
                              <add>über</add></roleName>
                        <rs type="place" ref="pl__wien-immo_wollzeile_14">der Janin haus</rs> über
                           <roleName type="topo" corresp="pl__wien-immo_wollzeile_6">zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_wollzeile_6"><roleName type="owner" corresp="pe__erhard_marbacher_QGW_II_III_4472"><rs type="person" ref="pe__erhard_marbacher_QGW_II_III_4472">Erharts, des <roleName type="prof">smids</roleName></rs></roleName>, haus</rs> gelegen,
                           <rs type="event" ref="ev__QGW_II_II_3525_men_1"><rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_wollzeile_13">das</rs></rs>
                           <rs type="fn" role="issuer"><rs type="person" ref="pe__leonhard_lehenholzer_QGW_II_II_3371">Lehenholczer</rs> und
                                 <rs type="person" ref="pe__agnes_QGW_II_II_3525">seine <roleName type="dead">verstorbene</roleName>
                                 <roleName type="kin" corresp="pe__leonhard_lehenholzer_QGW_II_II_3371">Frau</roleName> Agnes, welche der vorgenannten Anna und Micheln
                                 des Molter <roleName type="kin" corresp="pe__michael_moltrer_QGW_II_II_3558">Schwester</roleName>
                                 <roleName type="kin" corresp="pe__anna_QGW_II_II_3558"><add>Schwester</add></roleName> war</rs></rs>, <triggerstring n="disp">mit gesambter hand gekaufft
                     haben</triggerstring></rs></rs>.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3558"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="pe__wolfgang_haider_QGW_II_II_3558">Ausstellers</rs> und des <rs type="person" ref="pe__thomas_praitenweidacher_QGW_II_II_3462">Wiener <roleName type="occ" corresp="org__wien">Bürgers</roleName> Thoman
                        Praitenweidacher</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>