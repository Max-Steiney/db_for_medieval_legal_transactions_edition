                              <add>des Ehepaares</add></rs></rs>
                        <rs type="fn" role="recipient"><rs type="person" ref="pe__stephan_von_der_leiten_QGW_II_II_3603">ihm</rs> und <rs type="person" ref="pe__wolfgang_von_der_leiten_QGW_II_II_3603">seinem
