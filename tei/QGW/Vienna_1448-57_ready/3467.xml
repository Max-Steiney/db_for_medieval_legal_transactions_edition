            tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03467_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03467_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3467"><rs type="fn" role="issuer"><rs type="person" ref="pe__agnes_QGW_II_II_3467">Agnes, <rs type="person" ref="pe__konrad_guster_QGW_II_II_3467">Conrats, des <roleName type="occ" corresp="org__wien-st_stephan">guster</roleName> zu sannd Stephan zu
                           Wienn <roleName type="dead"><add>witib</add></roleName></rs>, <roleName type="kin" corresp="pe__konrad_guster_QGW_II_II_3467">witib</roleName></rs>,</rs>
                  <triggerstring n="disp">stiftet eine ewige Wochenmesse</triggerstring>
                  <rs type="fn" role="recipient">auf <rs type="org" ref="org__wien-st_stephan-altar_st_paul">sannt Pauls altar in sannt Stephans
                        kirchen</rs>,</rs>
                  <triggerstring n="disp">widmet dazu</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__oswald_reicholf_QGW_II_II_3314"><roleName type="title">hern</roleName> Oswalts Reicholf, <roleName type="occ" corresp="org__wien">burgermaister</roleName></rs>, und <rs type="org" ref="org__wien">des Rathes</rs></rs>
                  <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_kumpfgasse_4"><roleName type="owner" corresp="pe__agnes_QGW_II_II_3467">ihr</roleName> Haus, <roleName type="topo" corresp="pl__wien-kumpfgasse">gelegen in dem
                           Kumphgesslein</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_kumpfgasse_1">zenagst <add>an
                              ainem tail</add></roleName>
                        <rs type="place" ref="pl__wien-immo_kumpfgasse_1"><roleName type="owner" corresp="pe__christian_widhacker_SB_CD_00626"><rs type="person" ref="pe__christian_widhacker_SB_CD_00626"><roleName type="title">hern</roleName> Kristans Widhacker</rs></roleName> haus</rs> an
                        ainem tail <roleName type="topo" corresp="pl__wien-immo_kumpfgasse_5">und an
                           dem andern tail zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_kumpfgasse_5"><roleName type="owner" corresp="pe__martin_guldein_QGW_II_III_3897"><rs type="person" ref="pe__martin_guldein_QGW_II_III_3897">Merten Guldein, des
                                    <roleName type="prof">pucharczt</roleName></rs></roleName>,
                           haus</rs></rs>,</rs>
                  <triggerstring n="disp">und <add>verleiht</add></triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">verleiht die Messe</triggerstring>
                     <rs type="person" ref="pe__leonhard_von_hetzendorf_QGW_II_II_3467"><roleName type="title">maister</roleName> Linharten von Heczendorf, <roleName type="occ" corresp="org__wien-st_stephan">achter</roleName> zu sannt
                        Stephan, <roleName type="prof">briester</roleName> Passauer bistumbs
                           <roleName type="occ" corresp="org__wien-st_stephan-altar_st_paul-messe_guster_agnes"><add>Kaplan</add></roleName></rs>.</rs> Nach dessen Tode fällt die
                  Lehenschaft an Bürgermeister und Rath, welche die Messe dem eltisten maister
                  artisten des stannds in der herczogen Collegii pei den Predigern, der kain goczgab
                  hab und [ 339] binnen Jahresfrist Priester werden will, beziehungsweise dem
                  Nächstältesten verleihen sollen. Von dem Hause sollen für statsteur, ansleg,
                  zirken, wachten und ander mitleidung an die Stadt jährlich 3 lb dn. entrichtet
                  werden.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3467"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs>, ferner den
                     Siegeln des <rs type="person" ref="pe__wolfgang_herting_QGW_II_II_3362"><roleName type="title">edeln</roleName> Wolfgang Hertting</rs> und des
                        <rs type="person" ref="pe__wolfgang_holnbrunner_QGW_II_II_3079">Wiener
                           <roleName type="occ" corresp="org__wien">Bürgers</roleName>
                        Wolfgang Holnbrunner</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>