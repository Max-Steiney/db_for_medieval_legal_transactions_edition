               <rs type="event" ref="ev__QGW_II_II_3684"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_schreiner_QGW_II_II_3683">Hanns Schreiner, der
                           <roleName type="prof">griffelsmid</roleName>, <roleName type="occ" corresp="org__wien">mitpurger</roleName> ze Wienn</rs>, und <rs type="person" ref="pe__barbara_QGW_II_II_3684">Barbara, sein <roleName type="kin" corresp="pe__johann_schreiner_QGW_II_II_3683">hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_st_pankraz_18"><roleName type="owner" corresp="pe__johann_schreiner_QGW_II_II_3683">ihre</roleName>
                        <roleName type="owner" corresp="pe__barbara_QGW_II_II_3684"><add>ihre</add></roleName> prantstat, darauf ain haus gestanden ist,
                           <roleName type="topo" corresp="pl__wien-st_pankraz">gelegen hinder sannd
                           Pangreczen</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_st_pankraz_1">zenagst <add>mit
                              ainer seitten</add></roleName>
                        <rs type="place" ref="pl__wien-immo_st_pankraz_1">dem anderm <roleName type="owner" corresp="pe__barbara_QGW_II_II_3684">ihrem</roleName>
                           <roleName type="owner" corresp="pe__johann_schreiner_QGW_II_II_3683"><add>ihrem</add></roleName> haus, <roleName type="owner" corresp="pe__ulrich_hesler_QGW_II_II_3684">das etwenn Ulreichs Hesler
                              gewesen ist</roleName></rs>, mit ainer seitten <roleName type="topo" corresp="pl__wien-immo_st_pankraz_30">und mit der anndern
                           zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_st_pankraz_30">der Krewssin
                           prantstat</rs>, <rs type="event" ref="ev__SB_CD_00696_men_1">von der man
                           sand Pangreczen kapellen 45 dn. zu Burgrecht dient</rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_II">um <measure>30 lb dn.</measure></rs>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951"><roleName type="title">hern</roleName> Niclasen dem Teschler, <roleName type="occ" corresp="org__wien">burgermaister</roleName> und <roleName type="occ" corresp="org__oesterreich-herzogtum">münssmaister</roleName></rs>, und
                        <rs type="org" ref="org__wien">dem rat der stat ze Wienn</rs>, die der
                     egenanten prantstat selber recht gruntherren seind.</rs></rs>
