   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3678"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__wilhelm_von_puchheim_QGW_II_II_3678_b">Wihalm von
                        Puchaim <roleName type="occ" corresp="org__wien-st_stephan-kapelle_st_andreas"
                           ><add>Lehensherr</add></roleName></rs></rs>
                  <triggerstring n="disp">gibt seine Einwilligung dazu, <add>verkauft und</add>
                     <add>gekauft hat</add></triggerstring> dass <rs type="fn" role="recipient"><rs
                        type="person" ref="pe__johann_schach_QGW_II_II_3678"><roleName type="title"
                           >her</roleName> Hanns Schach <roleName type="title_ref"
                           corresp="pl__st_poelten">von</roleName> Sand Pölten, <roleName type="occ"
                           corresp="org__wien-st_stephan-kapelle_st_andreas">kaplan</roleName>
                        <rs type="event" ref="ev__QGW_II_II_3678_men_3"><rs type="fn"
                              role="transactiongood_I"><rs type="org"
                                 ref="org__wien-st_stephan-kapelle_st_andreas">sand Anndres
                                 kapellen</rs>,</rs> die <rs type="fn" role="issuer"><rs
                                 type="person" ref="pe__wilhelm_von_puchheim_QGW_II_II_3678_a">sein
                                    <roleName type="kin"
                                    corresp="pe__wilhelm_von_puchheim_QGW_II_II_3678_b"
                                    >vater</roleName>, <roleName type="title">her</roleName> Wilhalm
                                 von Puchaim, <roleName type="dead">seliger
                                 gedechtnuss</roleName></rs>,</rs>
                           <rs type="fn" role="recipient">in <rs type="org"
                                 ref="org__wien-st_stephan">sand Stephans tumbkirchen ze
                              Wienn</rs></rs>
                           <triggerstring n="disp">gestifft hat</triggerstring></rs></rs>,</rs> deren
                  Lehensherr er ist, <rs type="event" ref="ev__QGW_II_II_3678_men_1"><rs type="fn"
                        role="issuer"><rs type="person" ref="pe__johann_schach_QGW_II_II_3678"
                              ><roleName type="occ"
                              corresp="org__wien-st_stephan-kapelle_st_andreas"
                              ><add>kaplan</add></roleName></rs></rs>
                     <rs type="fn" role="transactiongood_I"><rs type="place"
                           ref="pl__wien-immo_schulhof_3" cert="high">ein <roleName type="owner"
                              corresp="org__wien-st_stephan-kapelle_st_andreas">zu der Kapelle
                              gestiftetes</roleName> Haus, <roleName type="topo"
                              corresp="pl__wien-judengasse">am Judenplacz zu Wienn
                              gelegen</roleName>
                           <roleName type="topo" corresp="pl__wien-immo_schulhof_4" cert="high"
                              >zenagst</roleName>
                           <rs type="place" ref="pl__wien-immo_schulhof_4" cert="high"><roleName
                                 type="owner" corresp="pe__erhard_poeschendorffer_QGW_II_II_3563"
                                 >Erharts Pöschendorffer</roleName> haus</rs></rs>,</rs>
                     <rs type="fn" role="recipient"><rs type="person"
                           ref="pe__paul_galhaimer_QGW_II_II_3678">Pauln Galhaimer, dem <roleName
                              type="prof">vilczhuter</roleName></rs>,</rs>
                     <triggerstring n="disp">verkauft</triggerstring></rs>
                  <rs type="event" ref="ev__QGW_II_II_3678_men_2">und <rs type="fn" role="recipient"
                           ><rs type="person" ref="pe__johann_schach_QGW_II_II_3678"><roleName
                              type="occ" corresp="org__wien-st_stephan-kapelle_st_andreas"
                                 ><add>kaplan</add></roleName></rs></rs>
                     <rs type="fn" role="transactiongood_II">für den Erlös</rs>
                     <rs type="fn" role="transactiongood_I"><rs type="place"
                           ref="pl__wien-immo_kumpfgasse_5">ein anderes Haus, <roleName type="topo"
                              corresp="pl__wien-kumpfgasse">im Kumphgesslein
                              <add>gelegen</add></roleName>
                           <roleName type="topo" corresp="pl__wien-immo_kumpfgasse_2"
                              >hinder</roleName>
                           <rs type="place" ref="pl__wien-immo_kumpfgasse_2">der Neunperger hof</rs>
                           <roleName type="topo" corresp="pl__wien-immo_kumpfgasse_4"
                              >zwischen</roleName>
                           <rs type="place" ref="pl__wien-immo_kumpfgasse_4"><roleName type="owner"
                                 corresp="pe__agnes_QGW_II_II_3467">der alten gustrin</roleName>
                              <add>heusern</add></rs>
                           <roleName type="topo" corresp="pl__wien-immo_kumpfgasse_3">und
                                 <add>zwischen</add></roleName>
                           <rs type="place" ref="pl__wien-immo_kumpfgasse_3"><roleName type="owner"
                                 corresp="pe__matthias_salczer_QGW_II_II_2595">Matthesen, des
                                 salczer</roleName>, heusern</rs> gelegen</rs>,</rs>
                     <triggerstring n="disp">gekauft hat</triggerstring>.</rs></rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3678"><rs type="fn" role="witness">Siegler: der
                        <rs type="person" ref="pe__wolfgang_herting_QGW_II_II_3362"><roleName
                           type="title">edel</roleName> Wolfgang der Hertting</rs> und der <rs
                        type="person" ref="pe__erhard_poeschendorffer_QGW_II_II_3563">Wiener
                           <roleName type="occ" corresp="org__wien">Bürger</roleName> Erhart
                        Pöschendorffer</rs>.</rs></rs>
            </p>
         </div>
         <div type="nota">
            <p>Indorsat: hern Wilhalms von Puchhaim brief und gunst von des hauss wegen, das zu sand
               Andres cappellen gehört hat . </p>
         </div>
