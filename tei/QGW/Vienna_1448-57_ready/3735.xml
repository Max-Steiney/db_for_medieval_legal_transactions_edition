        <origDate instant="false">zu Wienn, an montag vor sand Michels tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03735_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03735_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
          <rs type="event" ref="ev__QGW_II_II_3735"><rs type="fn" role="issuer"><rs type="person" ref="pe__georg_von_ror_QGW_II_II_3714">Jörg von Ror, der <roleName type="prof">fleischakcher</roleName>, <roleName type="occ" corresp="org__wien">mitburger</roleName> zu Wienn, anstat <rs type="person" ref="pe__barbara_QGW_II_II_3735">Barbaren, <rs type="person" ref="pe__simon_heuss_QGW_II_II_3735">Simons Heussen, seines <roleName type="kin" corresp="pe__georg_von_ror_QGW_II_II_3714">swehers</roleName>
                    <roleName type="dead">seligen</roleName></rs>
                  <roleName type="kin" corresp="pe__simon_heuss_QGW_II_II_3735">tochter</roleName>,
                  die noch nicht vogtper ist</rs></rs>, und <rs type="person" ref="pe__katharina_QGW_II_II_3735">Kathrei, seine <roleName type="kin" corresp="pe__georg_von_ror_QGW_II_II_3714">hausfrau</roleName></rs>,</rs>
            <triggerstring n="disp">verkaufen</triggerstring>
            <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
              <rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951"><roleName type="title">hern</roleName> Niclasen des Teschler, <roleName type="occ" corresp="org__wien">burgermaister</roleName> und <roleName type="occ" corresp="org__oesterreich-herzogtum">münssmaister</roleName></rs>, und <rs type="org" ref="org__wien">des Rathes</rs></rs>
            <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_dominikaner_9">zwen drittail, <roleName type="owner" corresp="pe__barbara_QGW_II_II_3735"><add>zwen drittail, welche die beiden
                    Schwestern an dem Hause haben</add></roleName>
                <roleName type="owner" corresp="pe__katharina_QGW_II_II_3735">zwen drittail, welche
                  die beiden Schwestern an dem Hause haben</roleName>, <roleName type="topo" corresp="pl__wien-dominikaner">gelegen gegen den Predigern über</roleName> zenagst
                  <rs type="place" ref="pl__wien-immo_dominikaner_5"><roleName type="owner" corresp="pe__jakob_oeczestorffer_QGW_II_II_3735"><rs type="person" ref="pe__jakob_oeczestorffer_QGW_II_II_3735">Jacoben
                    Öczestorffer</rs></roleName> haus</rs>
                <roleName type="topo" corresp="pl__wien-immo_dominikaner_5"><add>zenagst</add> an
                  aim tail</roleName>, <rs type="event" ref="ev__QGW_II_II_3735_men_1"><rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_dominikaner_9">das</rs></rs>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__barbara_QGW_II_II_3735"><add>ihnen</add></rs>
                    <rs type="person" ref="pe__katharina_QGW_II_II_3735">ihnen</rs> und <rs type="person" ref="pe__dorothea_QGW_II_II_3735">ihrer <roleName type="kin" corresp="pe__katharina_QGW_II_II_3735">Schwester</roleName>
                      <roleName type="kin" corresp="pe__barbara_QGW_II_II_3735"><add>Schwester</add></roleName> Dorothe, <rs type="person" ref="pe__paul_von_ror_QGW_II_II_3735">Pauln von Ror, eines <roleName type="kin" corresp="pe__georg_von_ror_QGW_II_II_3714">Bruders</roleName>
                        des Jörg</rs>, <roleName type="kin" corresp="pe__paul_von_ror_QGW_II_II_3735">hausfraun</roleName></rs>,</rs>
                  <rs type="fn" role="issuer">von <rs type="person" ref="pe__simon_heuss_QGW_II_II_3735">ihrem <roleName type="kin" corresp="pe__dorothea_QGW_II_II_3735">Vater</roleName>
                      <roleName type="kin" corresp="pe__barbara_QGW_II_II_3735"><add>Vater</add></roleName>
                      <roleName type="kin" corresp="pe__katharina_QGW_II_II_3735"><add>Vater</add></roleName></rs></rs>
                  <triggerstring n="disp">angeerbt</triggerstring> und <rs type="fn" role="other">von <rs type="person" ref="pe__jakob_rechwein_QGW_II_II_3242">Jacoben Rechwein
                        <roleName type="occ" corresp="org__wien"><add>rats</add></roleName></rs> und
                      <rs type="person" ref="pe__johann_malchinger_QGW_II_II_3524">Hannsen
                      Malchinger, baid des <roleName type="occ" corresp="org__wien">rats</roleName></rs>, <triggerstring n="fn">die darczu von dem rat geschafft
                      gewesen sein, mitsambt der stat gesworn werchmannen</triggerstring></rs>
                  <unclear instant="false"><triggerstring n="impl_rules">umb <measure>300 lb dn.</measure> gescheczt
                      ist worden</triggerstring></unclear></rs></rs>,</rs>
            <rs type="fn" role="transactiongood_II">um <measure>200 lb dn.</measure></rs>
            <rs type="fn" role="recipient">dem genannten <rs type="person" ref="pe__paul_von_ror_QGW_II_II_3735">Pauln von Ror, dem <roleName type="prof">fleischakcher</roleName>, <roleName type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs>, und <rs type="person" ref="pe__dorothea_QGW_II_II_3735">Dorothen, seiner <roleName type="kin" corresp="pe__paul_von_ror_QGW_II_II_3735">hausfraun</roleName></rs>.</rs></rs>
        </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3735"><rs type="fn" role="witness">Besiegelt mit dem
                <rs type="org" ref="org__wien">städtischen Grundsiegel</rs> und dem Siegel des <rs type="person" ref="pe__christoph_oeczestorffer_QGW_II_II_3245">Wiener <roleName type="occ" corresp="org__wien">Bürgers</roleName> Kristoff
              Öczestorffer</rs>.</rs></rs>
        </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>