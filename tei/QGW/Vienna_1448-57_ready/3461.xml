               <rs type="event" ref="ev__SB_CD_01775"><rs type="fn" role="issuer"><rs type="person" ref="pe__thomas_egkenperger_QGW_II_II_3455">Thoman
                        Egkenperger, <roleName type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs>,</rs>
                  <triggerstring n="disp">beurkundet, dass <add>haimsteur zugebracht</add>
                     <add>morgengab versprochen</add></triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__katharina_QGW_II_II_3461">seine <roleName type="kin" corresp="pe__thomas_egkenperger_QGW_II_II_3455">Hausfrau</roleName>
                        Kathrei, <rs type="person" ref="pe__erhard_gibing_QGW_II_II_3461">Erharts
                           des Gibing <roleName type="dead">seligen</roleName></rs>
                        <roleName type="kin" corresp="pe__erhard_gibing_QGW_II_II_3461">tochter</roleName></rs>,</rs> ihm <rs type="fn" role="transactiongood_II"><measure>200 lb dn.</measure> zu rechter <triggerstring n="fn">haimsteur</triggerstring> zugebracht,</rs> er ihr dagegen <rs type="fn" role="transactiongood_II"><measure>300 lb dn.</measure> zu rechter <triggerstring n="fn">morgengab</triggerstring></rs> versprochen habe, <triggerstring n="disp">und setzt</triggerstring> ihr dafür <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__oswald_reicholf_QGW_II_II_3314"><roleName type="title">hern</roleName> Oswalten Reicholfs, <roleName type="occ" corresp="org__wien">burgermaister</roleName></rs>, und <rs type="org" ref="org__wien">des Rathes</rs></rs>
                  <rs type="fn" role="transactiongood_I">seine zwai heuser, baide <rs type="place" ref="pl__wien-immo_roterturm_11"><roleName type="topo" corresp="pl__wien-roterturm">gelegen bei dem Rotenturm</roleName>, ains,
                           <roleName type="owner" corresp="pe__thomas_egkenperger_QGW_II_II_3455"><add>seine</add></roleName> darinn er jecz selbs sitzt, <roleName type="topo" corresp="pl__wien-immo_roterturm_13">zenagst <add>an aim
                              tail</add></roleName>
                        <rs type="place" ref="pl__wien-immo_roterturm_13"><roleName type="owner" corresp="pe__ladislaus_QGW_II_II_3461">kunig Lasslaws</roleName>
                           kasten</rs> an aim tail <roleName type="topo" corresp="pl__wien-immo_roterturm_14">und an dem andern zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_roterturm_14"><roleName type="owner" corresp="pe__konrad_reiff_SB_CD_00226">Conrats Reiffen</roleName>
                           haus</rs></rs>, <rs type="place" ref="pl__wien-immo_roterturm_12"><roleName type="topo" corresp="pl__wien-roterturm"><add>gelegen bei dem
                              Rotenturm</add></roleName> und das ander <roleName type="owner" corresp="pe__thomas_egkenperger_QGW_II_II_3455"><add>seine</add></roleName> ist <roleName type="topo" corresp="pl__wien-immo_roterturm_11" cert="high">da entgegen über am egk
                           gelegen</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_roterturm_15">zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_roterturm_15"><roleName type="owner" corresp="pe__konrad_taler_QGW_II_II_3461"><rs type="person" ref="pe__konrad_taler_QGW_II_II_3461">Chunczen Taler, des <roleName type="prof">leinbater</roleName></rs></roleName>, [337]
                           haus</rs></rs>,</rs>
                  <triggerstring n="disp">zu ainem rechten furphant</triggerstring>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>