                           <roleName type="topo" corresp="pl__wien-immo_stubentor_geraeut_vor_6"><add>gegen</add> über gelegen</roleName></rs>,</rs>
                     <rs type="fn" role="recipient">ihrem <rs type="person" ref="pe__georg_silberprenner_QGW_II_II_3721"><roleName type="occ" corresp="org__wien">Mitbürger</roleName> Jorgen, <roleName type="prof" cert="unknown">silberprenner</roleName></rs>,</rs>
