                  <triggerstring n="disp">an</triggerstring>
                  <rs type="fn" role="recipient">den <rs type="org" ref="org__wien">Bürgermeister,
                        Richter, Rath, die Genannten und burger gemainklich zu Wienn</rs>.</rs>
                  <rs type="event" ref="ev__QGW_II_II_3697_men_1"><rs type="fn" role="transactiongood_I"><rs type="event" ref="ev__QGW_II_II_3697_men_2"><rs type="fn" role="recipient"><rs type="person" ref="pe__johann_sachs_QGW_II_II_3697">Hanns Sachs <roleName type="title_ref" corresp="pl__sterzing">von</roleName>
