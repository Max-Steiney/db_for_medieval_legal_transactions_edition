                           <triggerstring n="disp">habe</triggerstring> seinerzeit <rs type="fn" role="other"><triggerstring n="disp">gegen</triggerstring> den <rs type="person" ref="pe__georg_talhaimer_QGW_II_II_3559">Wiener
                                    <roleName type="occ" corresp="org__wien">Bürger</roleName>
                                 Jörgen Talhaimer</rs> und andere Erben des Erasm Ponhaimer</rs>
                           <rs type="fn" role="issuer">vor <rs type="person" ref="pe__erasmus_ponhaimer_QGW_II_II_3289">Letzterem als <roleName type="occ" corresp="org__wien">Stadtrichter</roleName></rs></rs>
                           <triggerstring n="disp">gewisse Rechte erlangt</triggerstring></rs>,
                        welche</rs> nach seinem Tode <rs type="fn" role="issuer"><rs type="person" ref="pe__agnes_QGW_II_II_3697">die <roleName type="kin" corresp="pe__johann_sachs_QGW_II_II_3697">Witwe</roleName>
                        Angnes</rs></rs>
                     <rs type="fn" role="recipient">dem <rs type="person" ref="pe__erhard_pernauer_QGW_II_II_3697">Erhart Pernauer</rs></rs>
                     <triggerstring n="disp">übergeben hatte</triggerstring>.</rs> Er <triggerstring n="disp">empfiehlt</triggerstring> ihnen <rs type="fn" role="other"><triggerstring n="fn"><add>empfiehlt</add></triggerstring>
                     <rs type="person" ref="pe__erhard_pernauer_QGW_II_II_3697">den
                        Letztgenannten</rs></rs>, der sich in dieser Angelegenheit nach Wien begeben
                  wolle, <triggerstring n="disp">und ersucht</triggerstring> sie, den Talhaimer sowie die
                  anderen Erben Ponhaimers <triggerstring n="disp">zu veranlassen, dass sie seinem
                     Rechtsanspruche Genüge leisten und ihn verrer unklaghaft
                  machen</triggerstring>.</rs>
