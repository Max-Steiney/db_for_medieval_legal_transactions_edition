   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3334"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__johann_henusch_QGW_II_II_3334">Hanns He/anusch von
                        Kranstat, <roleName type="occ"
                           corresp="org__wien-st_peter-altar_st_maria-messe_elsarn"
                           >caplan</roleName> der ewigen mess, so die von Eslorn auf Unser Fraun
                        altar in sand Peters cappeln gestifft habent</rs>,</rs>
                  <triggerstring n="disp">gibt <add>geltes purkrechts</add></triggerstring>
                  <rs type="fn" role="recipient">dem <rs type="person"
                        ref="pe__matthias_angerfelder_QGW_II_II_3334">Mathes Angervelder</rs></rs>
                  <rs type="fn" role="transactiongood_II"><measure>3 lb dn.</measure>
                     <triggerstring n="fn">geltes purkrechts</triggerstring>, <rs type="event"
                        ref="ev__QGW_II_II_3334_men_1">die <rs type="fn" role="transactiongood_I"
                                 ><measure><add>3 lb dn.</add></measure>
                           <triggerstring n="fn"><add>geltes purkrechts</add></triggerstring></rs> er
                           <triggerstring n="disp">laut</triggerstring> eines unter seinem <rs type="fn"
                           role="recipient"><rs type="person"
                              ref="pe__magnus_simikcher_QGW_II_II_3334"><roleName type="occ"
                                 corresp="org__wien-st_peter-altar_st_maria-messe_elsarn"
                                    >Vorgänger<add>Kaplan</add></roleName> Magnus
                           Simikcher</rs></rs>
                        <triggerstring n="disp">verlorenen Burgrechtsbriefes</triggerstring>
                        <rs type="fn" role="issuer">auf <rs type="place"
                              ref="pl__wien-immo_wiltwerkerstrasse_9"><roleName type="owner"
                                 corresp="pe__matthias_angerfelder_QGW_II_II_3334"
                                 >Angerfelders</roleName> Haus <roleName type="topo"
                                 corresp="pl__wien-wiltwerkerstrasse">in der
                                 Wiltwerherstrass</roleName>
                              <roleName type="topo" corresp="pl__wien-immo_wiltwerkerstrasse_2"
                                 >zenagst</roleName>
                              <rs type="place" ref="pl__wien-immo_wiltwerkerstrasse_2">der Zingken
                                 haus</rs></rs></rs>
                        <triggerstring n="disp">gehabt hatte</triggerstring></rs>,</rs>
                  <rs type="fn" role="transactiongood_I">um <measure>24 lb dn.</measure> abzulösen,
                        <rs type="event" ref="ev__QGW_II_II_3334_men_2"><rs type="fn"
                           role="transactiongood_II">die<measure><add>24 lb dn.</add></measure></rs>
                        <rs type="fn" role="recipient">er</rs> wiederum <rs type="fn" role="issuer"
                           >auf <rs type="place" ref="pl__wien-immo_unter_den_sattlern_1"><roleName
                                 type="owner" corresp="pe__konrad_phuntimaschen_QGW_II_II_3088"
                                 >Kunraten Phuntimaschen</roleName> halbes haus, <roleName
                                 type="topo" corresp="pl__wien-unter_den_sattlern">undern Satlern
                                 gelegen</roleName></rs>,</rs>
                        <triggerstring n="disp">für die Messe anlegt</triggerstring></rs>.</rs></rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3334"><rs type="fn" role="witness">Siegler: <rs
                        type="person" ref="pe__johann_von_eslarn_QGW_II_II_3334">Hanns von Eslorn,
                           <roleName type="occ" corresp="org__wien">burger</roleName> zu
                        Wienn, als <roleName type="occ" corresp="org__wien-st_peter-altar_st_maria-messe_elsarn"
                           >Lehensherr</roleName> der Messe</rs>.</rs></rs>
            </p>
         </div>
