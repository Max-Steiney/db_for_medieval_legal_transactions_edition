   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3679"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__niklas_teschler_QGW_II_II_2951">Niclas Teschler,
                           <roleName type="occ" corresp="org__wien">burgermaister</roleName> und
                           <roleName type="occ" corresp="org__oesterreich-herzogtum"
                           >münssmaister</roleName></rs>, und <rs type="org" ref="org__wien">der
                        rate gemain der stat zu Wienn</rs></rs>
                  <triggerstring n="disp">beurkunden</triggerstring>, dass <rs type="fn" role="other"><rs
                        type="person" ref="pe__anna_QGW_II_II_3679">Anna, <rs type="person"
                           ref="pe__johann_fischer_QGW_II_II_3679">Hannsen, <roleName type="prof"
                              >vischer</roleName></rs>, <roleName type="kin"
                           corresp="pe__johann_fischer_QGW_II_II_3679">hausfrau</roleName>,
                           <roleName type="rep" corresp="pe__anna_QGW_II_II_3679">für</roleName>
                        <roleName type="rep" corresp="pe__margarethe_SB_CD_00627"
                           ><add>für</add></roleName> sich und <rs type="person"
                           ref="pe__margarethe_SB_CD_00627">ihre unmündige <roleName type="kin"
                              corresp="pe__anna_QGW_II_II_3679">Schwester</roleName>
                        Margreth</rs></rs>
                     <triggerstring n="fn"><add>mit Vorsprechen</add></triggerstring></rs>
                  <triggerstring n="disp">Anspruch an</triggerstring>
                  <rs type="fn" role="transactiongood_III">die <rs type="event" ref="NULL">von <rs
                           type="person" ref="pe__peter_hofpinter_QGW_II_II_3679">ihrem <roleName
                              type="kin" corresp="pe__anna_QGW_II_II_3679">een</roleName>
                           <roleName type="kin" corresp="pe__margarethe_SB_CD_00627"
                              ><add>een</add></roleName> Peter, <roleName type="prof"
                              >hofpinter</roleName></rs>, <triggerstring n="disp"
                           >hinterlassene</triggerstring> fahrende Habe, beraitschafft, pett,
                        pettgewant, werchzeug, beraite vas, zarch, taufeln, podem und raiff,</rs>
                     die wol <measure>200 lb dn.</measure> wert gewesen wern,</rs>
                  <triggerstring n="disp">erhoben und</triggerstring> sich darüber <triggerstring n="disp"
                     >beklagt habe</triggerstring>, dass <rs type="fn" role="other"><triggerstring n="fn"
                           ><add>hincz</add></triggerstring>
                     <rs type="person" ref="pe__heinrich_hederler_QGW_II_II_3679">Hainreich
                        Hederler, ir <roleName type="kin" corresp="pe__margarethe_SB_CD_00627"
                           >swager</roleName>
                        <roleName type="kin" corresp="pe__anna_QGW_II_II_3679"
                           ><add>swager</add></roleName></rs>, und <rs type="person"
                        ref="pe__agnes_QGW_II_II_3679">Agnes, sein <roleName type="kin"
                           corresp="pe__heinrich_hederler_QGW_II_II_3679">hausfrau</roleName>, ir
                           <roleName type="kin" corresp="pe__anna_QGW_II_II_3679">mum</roleName>
                        <roleName type="kin" corresp="pe__margarethe_SB_CD_00627"
                           ><add>mum</add></roleName></rs>,</rs> sich derselben allein unterwunden
                  haben, obwohl <rs type="person" ref="pe__margarethe_QGW_II_II_3679">ihre <roleName
                        type="dead">verstorbene</roleName>
                     <roleName type="kin" corresp="pe__margarethe_SB_CD_00627">Mutter</roleName>
                     <roleName type="kin" corresp="pe__anna_QGW_II_II_3679"
                        ><add>Mutter</add></roleName>
                     <roleName type="kin" corresp="pe__peter_hofpinter_QGW_II_II_3679"
                           ><add>tochter</add></roleName> Margreth, <rs type="person"
                        ref="pe__erhard_smidpekch_QGW_II_II_3043">Erharts des Smidpekchen</rs>
                     <roleName type="kin" corresp="pe__erhard_smidpekch_QGW_II_II_3043"
                        >hausfrau</roleName> selige</rs>, und <rs type="person"
                     ref="pe__agnes_QGW_II_II_3679">die egenant Agnes die Hederlerinn zwo <roleName
                        type="kin" corresp="pe__margarethe_QGW_II_II_3679">rechtt
                        swestern</roleName> mit einander und des obgenanten hofpinter leipplich
                        <roleName type="kin" corresp="pe__peter_hofpinter_QGW_II_II_3679"
                        >tochter</roleName> gewesen wern</rs>. Der Rath <triggerstring n="disp"
                     >entscheidet</triggerstring>: <triggerstring n="reason">Seid Margreth, Erharts
                     Smidpekchen hausfrau, vor irem vater Peter, dem hofpinter, mit tod ist abgangen
                     und den val seines varunden guts nicht erlebt hat, darumb so sei dasselb varund
                     gut, so Peter, der hofpinter, gehabt und hinder sein gelassen hat</triggerstring>,
                     <triggerstring n="disp">rechtlichen gevallen und geerbt</triggerstring>
                  <rs type="fn" role="recipient">auf <rs type="person"
                        ref="pe__agnes_QGW_II_II_3679">die egenant Agnesen Hederlerinn, sein
                        tochter</rs>.</rs></rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3679"><rs type="fn" role="witness">Besiegelt mit
                     ihrem clainem anhangundem <rs type="org" ref="org__wien"
                  >statinsigl</rs>.</rs></rs>
            </p>
