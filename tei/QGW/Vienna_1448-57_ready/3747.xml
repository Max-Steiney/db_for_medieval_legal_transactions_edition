               <rs type="event" ref="ev__QGW_II_II_3747"><rs type="fn" role="issuer"><rs type="person" ref="pe__peter_stettner_QGW_II_II_3747">Peter Stettner,
                           <roleName type="title_ref" corresp="pl__nussdorf">gesessen zu</roleName>
                        Nustorf</rs>, und <rs type="person" ref="pe__katharina_QGW_II_II_3747">Kathrei, sein <roleName type="kin" corresp="pe__peter_stettner_QGW_II_II_3747">hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">nehmen</triggerstring>
                  <rs type="fn" role="recipient">von <rs type="person" ref="pe__johann_goldner_QGW_II_II_3237"><roleName type="title">Meister</roleName> Hannsen Goldner, <roleName type="occ" corresp="org__wien-st_philipp_und_st_jakob_kapelle">obrister
