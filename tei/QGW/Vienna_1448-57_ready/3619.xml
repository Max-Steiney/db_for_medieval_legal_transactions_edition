   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3619"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__kaspar_von_tettnang_QGW_II_II_3619">Caspar von
                        Tettnang, <roleName type="occ" corresp="org__wien-universitaet"
                           >rector</roleName></rs>, <rs type="org" ref="org__wien-universitaet">die
                        lerer, maister und Studenten gemain der Universitet der hochwirdigen schul
                        hie zu Wienn</rs>,</rs>
                  <rs type="event" ref="ev__QGW_II_II_3619_men_1"><rs type="fn" role="recipient"><rs
                           type="org" ref="org__wien-universitaet">welche</rs></rs>
                     <triggerstring n="reason">zu gemainem nucz der Universitet und zu ainer behaltnuss
                        und venknuss der Studenten, die zu zeiten verhandeln oder sich
                        vergessen</triggerstring>, <rs type="fn" role="transactiongood_I"><rs
                           type="place" ref="pl__wien-immo_dominikaner_gasse_bei_1">ain haus,
                              <roleName type="topo" corresp="pl__wien-dominikaner_gasse_bei">auf dem
                              Steig am egk gegen den Predigern über gelegen</roleName>
                           <roleName type="topo" corresp="pl__wien-immo_dominikaner_gasse_bei_5"
                              >zenagst</roleName>
                           <rs type="place" ref="pl__wien-immo_dominikaner_gasse_bei_5">dem haus,
                              das zu der Permaninn mess gehoret</rs></rs>,</rs>
                     <rs type="fn" role="issuer">von <rs type="person"
                           ref="pe__elisabeth_QGW_II_II_3619"><roleName type="title"
                              >fraun</roleName> Elsbeten, <rs type="person"
                              ref="pe__ulrich_pretrer_QGW_II_II_3619">Ulreichs Pretrer <roleName
                                 type="dead">witiben</roleName></rs>
                           <roleName type="kin" corresp="pe__ulrich_pretrer_QGW_II_II_3619"
                                 ><add>witiben</add></roleName></rs>,</rs>
                     <triggerstring n="disp">gekaufft haben</triggerstring>,</rs>
                  <triggerstring n="disp">geloben</triggerstring>, <rs type="fn" role="transactiongood_I"
                     >von diesem Hause</rs>
                  <rs type="fn" role="recipient"><rs type="org" ref="org__wien">der Stadt</rs></rs>
                  <rs type="fn" role="transactiongood_I"><triggerstring n="fn">jährlich</triggerstring>
                     <triggerstring n="impl_rules">an sand Michels tag</triggerstring>
                     <measure>60 dn.</measure>
                     <triggerstring n="fn">gruntdinsts</triggerstring></rs>
                  <triggerstring n="disp"><add>jährlich</add>
                     <add>gruntdinsts</add> für alle schaczsteur und mitleidung zu
                     reichen</triggerstring> und darinn nur solh inleut halden zu wollen, die der Schul
                  freihait niessen und prauchen und darinn kain handl treiben in keiner weis.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3619"><rs type="fn" role="witness">Besiegelt mit
                     der <rs type="org" ref="org__wien-universitaet">Universitet klainem anhangundem
                        insigl</rs>.</rs></rs>
            </p>
