   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3437"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__johann_tebner_QGW_II_II_3437"><roleName type="title"
                           >Pruder</roleName> Hanns Tebner <roleName type="title_ref"
                           corresp="pl__wien">von</roleName> Wienn, <roleName type="occ"
                           corresp="org__wien-dominikaner">prior</roleName> des klosters dacz den
                        Predigern zu Wienn</rs>, und <rs type="org" ref="org__wien-dominikaner">der
                        convent gemain daselbs</rs></rs>
                  <triggerstring n="disp">beurkunden</triggerstring>, <rs type="event"
                     ref="ev__QGW_II_II_3437_men_1">dass <rs type="fn" role="issuer"><rs
                           type="person" ref="pe__michael_stadl_SB_CD_00055">Michel Stadel,
                              <roleName type="prof">fleischhacker</roleName></rs>,</rs>
                     <rs type="fn" role="recipient"><rs type="org" ref="org__wien-dominikaner"
                           >ihnen</rs></rs> zur <triggerstring n="disp">Stiftung eines
                        Jahrtages</triggerstring>
                     <rs type="fn" role="transactiongood_I"><rs type="place"
                           ref="pl__wien-immo_werd_1"><roleName type="owner"
                              corresp="pe__michael_stadl_SB_CD_00055">sein</roleName> Haus <roleName
                              type="topo" corresp="pl__wien-werd">im Werd</roleName></rs></rs>
                     <triggerstring n="disp">geschafft habe</triggerstring>, das man ihnen aber nicht
                     vertigen wollte,</rs>
                  <rs type="event" ref="ev__QGW_II_II_3437_men_2">weshalb <rs type="fn"
                        role="issuer"><rs type="person" ref="pe__konrad_pilgrim_QGW_II_II_3285"
                           >Conrat Pilgreim <roleName type="rep"
                              corresp="pe__michael_stadl_SB_CD_00055"
                              ><add>geschefftleut</add></roleName>
                           <roleName type="occ" corresp="org__wien"
                           ><add>burger</add></roleName></rs>, <rs type="person"
                           ref="pe__peter_von_asslabing_QGW_II_II_3285">Peter von Aslabing <roleName
                              type="rep" corresp="pe__michael_stadl_SB_CD_00055"
                                 ><add>geschefftleut</add></roleName>
                           <roleName type="occ" corresp="org__wien"
                           ><add>burger</add></roleName></rs>, <rs type="person"
                           ref="pe__stephan_kufuesser_QGW_II_II_3285">Steffan Kufusser <roleName
                              type="rep" corresp="pe__michael_stadl_SB_CD_00055"
                                 ><add>geschefftleut</add></roleName>
                           <roleName type="occ" corresp="org__wien"
                           ><add>burger</add></roleName></rs> und <rs type="person"
                           ref="pe__kaspar_kemnater_QGW_II_II_3285">Kaspar Kembnater, <roleName
                              type="occ" corresp="org__wien">burger</roleName> zu Wienn, des <rs
                              type="person" ref="pe__michael_stadl_SB_CD_00055">egenanten Stadel
                                 <roleName type="dead">seligen</roleName></rs>
                           <roleName type="rep" corresp="pe__michael_stadl_SB_CD_00055"
                              >geschefftleut</roleName></rs>,</rs>
                     <rs type="fn" role="transactiongood_I"><rs type="place"
                           ref="pl__wien-immo_werd_1">es</rs></rs>
                     <rs type="fn" role="transactiongood_II">um <measure>44 lb dn.</measure></rs>
                     <triggerstring n="disp">verkauft</triggerstring></rs>
                  <unclear instant="false"><rs type="fn" role="recipient"><rs type="person"
                           ref="pe__konrad_pilgrim_QGW_II_II_3285"><add>Conrat Pilgreim</add>
                           <roleName type="rep" corresp="pe__michael_stadl_SB_CD_00055"
                                 ><add>geschefftleut</add></roleName>
                           <roleName type="occ" corresp="org__wien"
                           ><add>burger</add></roleName></rs>, <rs type="person"
                           ref="pe__peter_von_asslabing_QGW_II_II_3285"><add>Peter von
                              Aslabing</add>
                           <roleName type="rep" corresp="pe__michael_stadl_SB_CD_00055"
                                 ><add>geschefftleut</add></roleName>
                           <roleName type="occ" corresp="org__wien"
                           ><add>burger</add></roleName></rs>, <rs type="person"
                           ref="pe__stephan_kufuesser_QGW_II_II_3285"><add>Steffan Kufusser</add>
                           <roleName type="rep" corresp="pe__michael_stadl_SB_CD_00055"
                                 ><add>geschefftleut</add></roleName>
                           <roleName type="occ" corresp="org__wien"
                           ><add>burger</add></roleName></rs>
                        <add>und</add>
                        <rs type="person" ref="pe__kaspar_kemnater_QGW_II_II_3285"><add>Kaspar
                              Kembnater,</add>
                           <roleName type="occ" corresp="org__wien"><add>burger</add></roleName>
                           <add>zu Wienn, des</add>
                           <rs type="person" ref="pe__michael_stadl_SB_CD_00055"><add>egenanten
                                 Stadel</add>
                              <roleName type="dead"><add>seligen</add></roleName></rs>
                           <roleName type="rep" corresp="pe__michael_stadl_SB_CD_00055"
                                 ><add>geschefftleut</add></roleName></rs></rs></unclear> und ihnen
                  diesen <triggerstring n="disp">Betrag übergeben haben. Sie verpflichten sich dagegen,
                     den Jahrtag</triggerstring> an sand Blasien tag oder aber inner den nagsten
                  achttagen vor oder inner den nagsten achttagen darnach <triggerstring n="disp">zu
                     begehen</triggerstring>.</rs>
            </p>
