   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3312"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__johann_steger_QGW_II_II_3264">Hanns Steger, <roleName
                           type="title">ritter</roleName>, <roleName type="occ" corresp="org__wien"
                           >burgermaister</roleName> und <roleName type="occ"
                           corresp="org__oesterreich-herzogtum">münsmaister</roleName></rs>, und <rs
                        type="org" ref="org__wien">der rat gemain der stat ze Wienn</rs></rs>
                  <triggerstring n="disp">beurkunden, dass</triggerstring>
                  <rs type="fn" role="other"><rs type="person"
                        ref="pe__jakob_von_eslarn_QGW_II_II_3312">Jacob von Eslorn, <roleName
                           type="title_ref" corresp="pl__wien-werd">gesessen</roleName> im Werd
                           <roleName type="kin" corresp="pe__thomas_olm_QGW_II_II_3315"
                           cert="medium"><add>rechte geswistreid enenkchel</add></roleName>
                        <roleName type="kin" corresp="pe__elisabeth_QGW_II_II_3313" cert="medium"
                              ><add>rechte geswistreid enenkchel</add></roleName></rs>, <triggerstring
                        n="fn"><add>vorgebracht habe</add></triggerstring></rs> ihnen <triggerstring
                     n="disp">vorgebracht habe</triggerstring>, <rs type="fn"
                     role="transactiongood_III">wie dass <rs type="place"
                        ref="pl__wien-immo_weihenburg_6"><roleName type="owner"
                           corresp="pe__thomas_olm_QGW_II_II_3315"><rs type="person"
                              ref="pe__thomas_olm_QGW_II_II_3315">Thoman Olm, sein <roleName
                                 type="kin" corresp="pe__jakob_von_eslarn_QGW_II_II_3312"
                                 >vetter</roleName>
                              <roleName type="dead"><add>tod</add></roleName></rs></roleName>, ain
                        haus, <roleName type="topo" corresp="pl__wien-weihenburg">in der Weihenpurgk
                           hie gelegen</roleName>, gehabt und hinder im gelassen hiet, darumb er und
                           <roleName type="owner" corresp="pe__elisabeth_QGW_II_II_3315"><rs
                              type="person" ref="pe__elisabeth_QGW_II_II_3315">Elspet, sein
                                 <roleName type="kin" corresp="pe__thomas_olm_QGW_II_II_3315"
                                 >hausfrau</roleName>
                              <roleName type="dead"><add>tod</add></roleName></rs>, mit gesambter
                           hannd nucz und gewer stunden</roleName>, die baide mit tod verschaiden
                        wern</rs>.</rs> Da Jacob, <rs type="person"
                     ref="pe__magdalena_QGW_II_II_3312"><roleName type="title">frau</roleName>
                     Magdalen, <rs type="person" ref="pe__christian_wagenhelbling_QGW_II_II_3312"
                           ><roleName type="dead">weilent</roleName> des Wagenhelbling</rs>
                     <roleName type="kin" corresp="pe__christian_wagenhelbling_QGW_II_II_3312"
                        >hausfrau</roleName>
                     <roleName type="kin" corresp="pe__katharina_QGW_II_II_3312"
                        ><add>swester</add></roleName><roleName type="kin"
                        corresp="pe__jakob_von_eslarn_QGW_II_II_3312"><add>swester</add></roleName>
                     <roleName type="kin" corresp="pe__thomas_olm_QGW_II_II_3315" cert="medium"
                           ><add>rechte geswistreid enenkchel</add></roleName>
                     <roleName type="kin" corresp="pe__elisabeth_QGW_II_II_3313" cert="medium"
                           ><add>rechte geswistreid enenkchel</add></roleName></rs>, und <rs
                     type="person" ref="pe__katharina_QGW_II_II_3312">Kathrei, sein <roleName
                        type="kin" corresp="pe__magdalena_QGW_II_II_3312"
                        >swester</roleName><roleName type="kin"
                        corresp="pe__jakob_von_eslarn_QGW_II_II_3312"><add>swester</add></roleName>,
                        <roleName type="kin" corresp="pe__thomas_olm_QGW_II_II_3315" cert="medium"
                        >rechte geswistreid enenkchel</roleName>
                     <roleName type="kin" corresp="pe__elisabeth_QGW_II_II_3313" cert="medium"
                           ><add>rechte geswistreid enenkchel</add></roleName></rs> mit einander
                  gewesen wern, erhebt er Anspruch auf die Hälfte des bezeichneten Hauses. Die
                  andere Hälfte <rs type="fn" role="other"><triggerstring n="fn"
                        >beanspruchen</triggerstring>
                     <rs type="person" ref="pe__barbara_QGW_II_II_3312"><roleName type="title"
                           >frau</roleName> Barbara, <rs type="person"
                           ref="pe__wolfgang_reispekch_QGW_II_II_3312">Wolfgangs Reispekchen</rs>
                        <roleName type="kin" corresp="pe__wolfgang_reispekch_QGW_II_II_3312"
                           >hausfrau</roleName></rs>, und <rs type="person"
                        ref="pe__anna_QGW_II_II_3312">Anna, ir <roleName type="kin"
                           corresp="pe__barbara_QGW_II_II_3312">swester</roleName>, <rs
                           type="person" ref="pe__martin_knoll_QGW_II_II_3312">Merten Knolln, des
                              <roleName type="prof">sneider</roleName></rs>, <roleName type="kin"
                           corresp="pe__martin_knoll_QGW_II_II_3312">hausfrau</roleName></rs>,</rs>
                  da ihr <rs type="person" ref="pe__martin_kaiser_QGW_II_II_3312"><roleName
                        type="dead">verstorbener</roleName>
                     <roleName type="kin" corresp="pe__barbara_QGW_II_II_3312">Vater</roleName>
                     <roleName type="kin" corresp="pe__anna_QGW_II_II_3312"
                        ><add>Vater</add></roleName> Mert Kaiser, der <roleName type="prof"
                        cert="high">stekchenkleuber</roleName>, und der egenant Olm <roleName
                        type="kin" corresp="pe__thomas_olm_QGW_II_II_3315">rechte
                        geswistreidkinder</roleName> mit einander gewesen wern</rs>. <rs type="fn"
                     role="other"><triggerstring n="fn">Ihnen gegenüber</triggerstring> tritt <rs
                        type="person" ref="pe__niklas_sturm_QGW_II_II_3315"><roleName type="title"
                           >her</roleName> Niclas Sturm, <roleName type="occ"
                           corresp="org__grossenzersdorf-pfarre">pharrer</roleName> zu Grossen
                        Enczestorff, <roleName type="rep" corresp="pe__anna_QGW_II_II_3315"
                              ><add>anstat</add></roleName>
                        <roleName type="rep" corresp="pe__katharina_QGW_II_II_3315"
                              ><add>anstat</add></roleName>
                        <roleName type="rep" corresp="pe__niklas_sturm_QGW_II_II_3315"
                           >anstat</roleName> sein selbs</rs>,</rs>
                  <rs type="person" ref="pe__anna_QGW_II_II_3315">Annen, seiner <roleName type="kin"
                        corresp="pe__niklas_sturm_QGW_II_II_3315">swester</roleName>, <rs
                        type="person" ref="pe__simon_pauchdreml_QGW_II_II_3315">Simons des
                        Pauchdremel <roleName type="dead">witiben</roleName></rs>
                     <roleName type="kin" corresp="pe__simon_pauchdreml_QGW_II_II_3315"
                           ><add>witiben</add></roleName><roleName type="kin"
                        corresp="pe__thomas_olm_QGW_II_II_3315"><add>rechte
                        geswistreidkinder</add></roleName></rs>, und <rs type="person"
                     ref="pe__katharina_QGW_II_II_3315">Kathrein, <rs type="person"
                        ref="pe__stephan_brunner_QGW_II_II_3315">Stephans des Prunner <roleName
                           type="dead">witiben</roleName>
                        <roleName type="title_ref" corresp="pl__muehlleitten">zu</roleName>
                        Mulleiten</rs>, <roleName type="kin"
                        corresp="pe__stephan_brunner_QGW_II_II_3315"><add>witiben</add></roleName>
                     seiner <roleName type="kin" corresp="pe__niklas_sturm_QGW_II_II_3315"
                        >mumen</roleName><roleName type="kin"
                        corresp="pe__thomas_olm_QGW_II_II_3315"><add>rechte
                        geswistreidkinder</add></roleName></rs>, mit dem Nachweise auf, dass er,
                  seine Schwester und seine Muhme mit dem egenannten Thoman Olm rechte
                  geswistreidkinder gewesen und ainer sippt nehender gefreundt wern, denn die
                  obgenannten klager. Bürgermeister und Rath entscheiden zu ihren Gunsten
                     <triggerstring n="disp">und sprechen</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__katharina_QGW_II_II_3315">ihnen</rs>
                     <rs type="person" ref="pe__anna_QGW_II_II_3315"><add>ihnen</add></rs>
                     <rs type="person" ref="pe__niklas_sturm_QGW_II_II_3315"
                     ><add>ihnen</add></rs></rs> das halbe Haus <triggerstring n="disp">unter Wahrung
                     der von etwa noch auftauchenden näheren Erben zu erhebenden Ansprüche
                     zu</triggerstring>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3312"><rs type="fn" role="witness">Besiegelt mit
                     ihrem klainem anhangundem <rs type="org" ref="org__wien"
                  >statinsigl</rs></rs>.</rs>
            </p>
