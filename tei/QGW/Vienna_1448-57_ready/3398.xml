    <body>
      <div type="abstract" resp="kg">
        <p><rs type="event" ref="ev__QGW_II_II_3398"><rs type="fn" role="issuer"><rs type="person"
                ref="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270">König Friedrich
              IV.</rs></rs>
            <triggerstring n="disp">befiehlt</triggerstring>
            <rs type="fn" role="recipient">dem <rs type="org" ref="org__wien">Bürgermeister und
                Rathe zu Wien</rs>,</rs>
            <rs type="fn" role="other"><triggerstring n="fn"><add>mit Vorsprechen</add></triggerstring>
              <rs type="person" ref="pe__johann_vom_graben_QGW_II_II_3398">seinem Wiener <roleName
                  type="occ" corresp="org_wien"
                  select="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270">Bürger</roleName>
                Hannsen vom Graben</rs></rs>
            <triggerstring n="disp">hinsichtlich der Ansprüche</triggerstring>, die er <rs type="fn"
              role="transactiongood_III">von <rs type="place" ref="pl__wien-immo_lichtensteg_1">ains
                grunts und seiner zugehörung wegen, <roleName type="owner"
                  corresp="pe__johann_vom_graben_QGW_II_II_3398">sein behausung</roleName>,
                  <roleName type="topo" corresp="pl__wien-lichtensteg">an dem Liechtensteg daselbs
                  zu Wienn gelegen</roleName></rs>, beru/orend</rs>, <rs type="fn" role="other"
                ><triggerstring n="fn"><add>hincz</add> zu</triggerstring>
              <rs type="person" ref="pe__peter_obrecht_QGW_II_II_3398">Peteria Obrecht</rs></rs> ze
            haben mainet, <triggerstring n="disp">furderleich recht ergeen zu lassen</triggerstring>.</rs>
        </p>
      </div>
      <div type="nota">
        <p>Von anderer Hand: commissio domini regis propria. </p>
      </div>
