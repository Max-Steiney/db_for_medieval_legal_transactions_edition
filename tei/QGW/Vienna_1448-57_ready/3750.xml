               <rs type="event" ref="ev__QGW_II_II_3750"><rs type="fn" role="issuer"><rs type="person" ref="pe__wolfgang_phanhaimer_QGW_II_II_3736">Wolfgang
                        Phannhaimer, der <roleName type="prof">rostauscher</roleName>, <roleName type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs>,
                     und <rs type="person" ref="pe__elisabeth_QGW_II_II_3736">Elspeth, sein
                           <roleName type="kin" corresp="pe__wolfgang_phanhaimer_QGW_II_II_3736">hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">stellen</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__michael_praunsperger_QGW_II_II_3274">Micheln Praunsperger,
                           <roleName type="prof">riemer</roleName>, <roleName type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs>, und <rs type="person" ref="pe__margarethe_QGW_II_II_3274">Margreten, seiner
                           <roleName type="kin" corresp="pe__michael_praunsperger_QGW_II_II_3274">hausfraun</roleName>, <rs type="person" ref="pe__erhard_neunkircher_QGW_II_II_3274">Erharts Neunkirchner, des
                              <roleName type="prof">glokengiesser</roleName>
                           <roleName type="dead">seligen</roleName></rs>, <roleName type="kin" corresp="pe__erhard_neunkircher_QGW_II_II_3274">tochter</roleName></rs>,</rs> einen <triggerstring n="disp">Schuldbrief
                        <add>aus</add></triggerstring>
                  <rs type="fn" role="transactiongood_II">über <measure>130 lb dn.</measure> aus,
                        <rs type="event" ref="ev__QGW_II_II_3274">der 100 lb dn. die benant Margret
                        ihrem Manne zugebracht und 30 lb dn. er ihr daentgegen gelobt hat zu geben,
                        die emaln auf seinem haus in der Riemergassen verschriben und darnach bei
                        der stat gruntpuch gelegen gewesen sind</rs>,</rs> treffen eine genaue
                  Vereinbarung über die Form der Rückzahlung <triggerstring n="disp">und
                     setzen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__jakob_starch_QGW_II_II_3557"><roleName type="title">hern</roleName> Jacoben Starchen, <roleName type="occ" corresp="org__wien">burgermaister</roleName></rs>, und <rs type="org" ref="org__wien">des Rathes</rs></rs>
                  <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_st_jakob_auf_der_huelben_2"><roleName type="owner" corresp="pe__wolfgang_phanhaimer_QGW_II_II_3736">ihr</roleName>
                        <roleName type="owner" corresp="pe__elisabeth_QGW_II_II_3736"><add>ihr</add></roleName> Haus, <roleName type="topo" corresp="pl__wien-st_jakob_auf_der_huelben-freithof">gelegen zenagst sand
                           Jacobs freithoftor mit ainer seitten</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_st_jakob_auf_der_huelben_3">und
                           mit dem andern zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_st_jakob_auf_der_huelben_3">dem haus,
                           genant der Erich</rs></rs>,</rs>
                  <triggerstring n="disp">zu ainem rechten fürphandt</triggerstring>.</rs>
