            <placeName>Wien</placeName>
            <date when="14570906">1457 IX 06</date>
            <origDate instant="false">Geben zu Wienn an eritag vor Unser Lieben Fraun tag der
               Gepurd, nach Kristi geburde 1400 und in dem 57. jar, unnser reich, des Hungrischen
               etc. im achzehenten und des Behemischen im virden jaren. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03730_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03730_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p><rs type="event" ref="ev__QGW_II_II_3730"><rs type="fn" role="issuer"><rs type="person" ref="pe__ladislaus_QGW_II_II_3461">König Lasslaw</rs></rs>
                  <triggerstring n="disp">ertheilt</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">unter ausdrücklicher Anerkennung
                        der</triggerstring>
                     <rs type="org" ref="org__wien">den Wiener Bürgern</rs>
                     <triggerstring n="fn">von seinen Vorfahren verbrieften Testierfreiheit durch merer
                        sicherhait willen</triggerstring></rs>
                  <rs type="fn" role="recipient">dem <rs type="person" ref="pe__simon_poetel_QGW_II_II_2412">Siman Pötl, seinem <roleName type="occ" corresp="org__wien">burger</roleName> zu
                     Wienn</rs>,</rs> die <triggerstring n="disp">Erlaubnis</triggerstring>, dass er
                     <triggerstring n="impl_rules">seiner geslosser, heuser, leut, güter, gult, zehent
                     und alle anndre seine güter, die er jecz hiet oder hinfur gewinnet, wie die
                     genant sein, nichts ausgenomen, es sei aigen, lehen, purkhrecht oder varend
                     gut, mit gesuntem leib oder an seinem todpet nach seinem willen ledicleich und
                     freileich mag schaffen, machen, fügen und geben zu kirchen, klostern, spitalen,
                     seiner hausfraun, freunten, dienern oder anndern, den er es gunnen wil und
                     wirdet</triggerstring>.</rs>
            </p></div><div type="nota"><p>Unter dem Buge links eigenhändige Unterschrift: Ladislaus Rex manu propria. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>