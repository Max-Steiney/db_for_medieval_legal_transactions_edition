               <rs type="event" ref="ev__QGW_II_II_3543"><rs type="fn" role="issuer"><rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951">Niclas Teschler,
                           <roleName type="occ" corresp="org__wien">burgermaister</roleName></rs>,
                     und <rs type="org" ref="org__wien">der rate der stat zu Wienn</rs></rs>
                  <rs type="fn" role="other"><triggerstring n="fn">empfehlen</triggerstring>
                     <rs type="person" ref="pe__barbara_QGW_II_II_3543">Barbara, die <roleName type="kin" corresp="pe__jakob_duerr_QGW_II_II_3543">Tochter</roleName>
                        des <rs type="person" ref="pe__jakob_duerr_QGW_II_II_3543"><roleName type="dead">verstorbenen</roleName>
                           <roleName type="prof">Lebzelters</roleName> Jacob Dürr</rs></rs></rs>
                  <rs type="fn" role="recipient">dem <rs type="person" ref="pe__andreas_diener_QGW_II_II_3543">Andreen Diener, <roleName type="prof">leczelter</roleName>, ihrem <roleName type="occ" corresp="org__wien">mitburger</roleName></rs>, also dass er mitsambt <rs type="person" ref="pe__anna_QGW_II_II_3543"><roleName type="title">fraun</roleName> Annen, des egenanten Dürren <roleName type="kin" corresp="pe__jakob_duerr_QGW_II_II_3543">witiben</roleName></rs>,</rs>
                  <triggerstring n="disp"><add>empfehlen</add> desselben</triggerstring> Dürren
                     <triggerstring n="disp">geschefft und geltschult ausrichten und die
                     benanten</triggerstring> Barbaren <triggerstring n="disp">mit irm leib und gut
                     innhaben, ziehen und verwesen soll</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3543"><rs type="fn" role="witness">Besiegelt mit
