   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3399"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__johann_hirss_QGW_II_II_3399">Johann Hirss, <roleName type="occ" corresp="org__wien">burger</roleName> zu
                     Wienn</rs>,</rs>
                  <triggerstring n="disp">stellt</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__andreas_schoenaicher_QGW_II_II_3399">Andreen Schonaich <roleName type="occ" corresp="org__wien"><add>burger</add></roleName>
                        <roleName type="rep" corresp="pe__niklas_tirman_QGW_II_II_3399"
                              ><add>geschefftleuten</add></roleName>
                        <roleName type="rep" corresp="pe__georg_tirman_QGW_II_II_3399"><add>anstat
                              und zu hannden</add></roleName></rs> und <rs type="person"
                        ref="pe__johann_winkchler_QGW_II_II_3128">Hannsen Winkler, auch <roleName type="occ" corresp="org__wien">burger</roleName> zu Wienn, <rs
                           type="person" ref="pe__niklas_tirman_QGW_II_II_3399">Niclasen Tirman, des
                              <roleName type="prof">eisner</roleName>, seines <roleName type="kin"
                              corresp="pe__johann_hirss_QGW_II_II_3399">vorvordern</roleName>
                           <roleName type="dead">seligen</roleName></rs>
                        <roleName type="rep" corresp="pe__niklas_tirman_QGW_II_II_3399"
                           >geschefftleuten</roleName>, <roleName type="rep"
                           corresp="pe__georg_tirman_QGW_II_II_3399">anstat und zu
                           hannden</roleName></rs></rs>
                  <rs type="person" ref="pe__georg_tirman_QGW_II_II_3399">Jorigen, desselben Tirmans
                        <roleName type="kin" corresp="pe__niklas_tirman_QGW_II_II_3399"
                        >sun</roleName>, der noch nicht vogtber</rs>
                  <rs type="event" ref="ev__QGW_II_II_3399_men_1">
                     <rs type="fn" role="other"><rs type="person"
                           ref="pe__georg_tirman_QGW_II_II_3399"><add>der</add></rs><triggerstring
                           n="fn"><add>empholichen ist</add></triggerstring></rs> und <rs type="fn"
                        role="recipient"><rs type="person" ref="pe__johann_hirss_QGW_II_II_3399"
                           >ihm</rs></rs>
                     <rs type="fn" role="issuer">von <rs type="org" ref="org__wien">Bürgermeister
                           und Rath</rs></rs>
                     <triggerstring n="disp">mit seinem leib und gut innzuhaben empholichen
                        ist</triggerstring>,</rs>
                  <triggerstring n="disp">einen Schuldbrief</triggerstring>
                  <rs type="fn" role="transactiongood_II">über <measure>246 lb dn. der swarczen
                        münss</measure></rs>
                  <triggerstring n="disp">aus</triggerstring>. Auf diesen Betrag ist das gesammte Gut des
                  Knaben geschätzt worden, <rs type="event" ref="ev__QGW_II_II_3399_men_2">das <rs
                        type="fn" role="recipient"><rs type="person"
                           ref="pe__georg_tirman_QGW_II_II_3399">ihm</rs></rs>
                     <rs type="fn" role="other"><triggerstring n="fn">gegen</triggerstring>
                        <rs type="person" ref="pe__helena_QGW_II_II_3399">seine <roleName type="kin"
                              corresp="pe__georg_tirman_QGW_II_II_3399">Mutter</roleName>
                              Helena,<roleName type="kin" corresp="pe__johann_hirss_QGW_II_II_3399"
                                 ><add>zur Ehe</add></roleName></rs> welche Hirss <rs type="fn"
                           role="other">von <rs type="person"
                              ref="pe__thomas_gerhard_QGW_II_II_3338">Thoman Sibenburger, <roleName
                                 type="prof">goltsmid</roleName></rs>, und <rs type="person"
                              ref="pe__georg_epishauser_QGW_II_II_3353">Jorgen Eppishauser</rs>
                           <triggerstring n="fn">als zu dem Geschäfte von Bürgermeister und Rath
                              Verordneten</triggerstring></rs> zur Ehe genommen hatte,</rs>
                     <triggerstring n="disp">zugefallen war</triggerstring>.</rs> Hirss verpflichtet sich
                  zur ordentlichen Verpflegung und Erziehung seines Stiefsohnes, sowie zur
                  Rückerstattung des Geldes bei Eintritt der Mündigkeit <triggerstring n="disp">und
                     setzt</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__konrad_hoelczler_QGW_II_II_3350"><roleName
                           type="title">hern</roleName> Conrads Holczler, <roleName type="occ"
                           corresp="org__wien">burgermaister</roleName></rs>, und <rs type="org"
                        ref="org__wien">des Rathes</rs></rs>
                  <rs type="fn" role="transactiongood_I"><rs type="place"
                        ref="pl__wien-immo_neuer_markt_3"><roleName type="owner"
                           corresp="pe__johann_hirss_QGW_II_II_3399">sein</roleName> Haus mitsambt
                        der Neuen Melbgrub, <roleName type="topo" corresp="pl__wien-neuer_markt">an
                           dem Neuenmarkcht gelegen</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_neuer_markt_4"
                           >zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_neuer_markt_4">der stat
                        Meczengadem</rs></rs></rs>, <triggerstring n="disp">zu ainem rechten
                     furphant</triggerstring>.</rs>
            </p>
