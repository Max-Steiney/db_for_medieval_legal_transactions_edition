   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3401"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__konrad_hoelczler_QGW_II_II_3350">Kunrat Holczler,
                           <roleName type="occ" corresp="org__wien">burgermaister</roleName></rs>,
                     und <rs type="org" ref="org__wien">der rat der stat zu Wienn</rs></rs>
                  <triggerstring n="disp">beurkunden, dass</triggerstring>
                  <rs type="event" ref="ev__QGW_II_II_3401_men_1"><rs type="fn" role="issuer"><rs
                           type="person" ref="pe__johann_kieler_SB_CD_00620">Hanns Kieler, ihr
                              <roleName type="occ" corresp="org__wien"
                           >mitburger</roleName></rs>,</rs>
                     <unclear instant="false"><rs type="fn" role="transactiongood_I"><rs
                              type="person" ref="pe__erasmus_kieler_QGW_II_II_3401">seinen
                              unmündigen <roleName type="kin"
                                 corresp="pe__johann_kieler_SB_CD_00620">Sohn</roleName>
                           Erasem</rs></rs></unclear>
                     <rs type="fn" role="recipient"><rs type="person" ref="pe__barbara_SB_CD_00620"
                           >seiner <roleName type="kin" corresp="pe__johann_kieler_SB_CD_00620"
                              >Hausfrau</roleName> Barbaren, die jecz <rs type="person"
                              ref="pe__johann_kanstorffer_QGW_II_II_3401">Hannsen Kanstorffer,
                                 <roleName type="occ" corresp="org__oesterreich-herzogtum"
                                 >kellermaister</roleName> in Österreich, ihren mitgesworn des
                                 <roleName type="occ" corresp="org__wien">rats</roleName></rs>,
                              <roleName type="kin" corresp="pe__johann_kanstorffer_QGW_II_II_3401"
                              >elichen</roleName> hat</rs>,</rs>
                     <triggerstring n="disp">empfohlen habe</triggerstring>,</rs>
                  <triggerstring n="disp">und empfehlen</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__barbara_SB_CD_00620"
                        >Beiden</rs>
                     <rs type="person" ref="pe__johann_kanstorffer_QGW_II_II_3401"
                        ><add>Beiden</add></rs></rs>
                  <unclear instant="false"><rs type="fn" role="transactiongood_I">den <rs
                           type="person" ref="pe__erasmus_kieler_QGW_II_II_3401"
                     >Knaben</rs></rs></unclear>
                  <triggerstring n="disp">in gerhabweise</triggerstring>
                  <triggerstring n="reason">auch wegen <rs type="place"
                        ref="pl__wien-immo_kaerntnerstrasse_12">eines Hauses, <roleName type="topo"
                           corresp="pl__wien-kaerntnerstrasse">in der Kernerstrass oben am
                           egk</roleName> [324] <roleName type="topo"
                           corresp="pl__wien-kaerntnertor">pei Kernertor</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_kaerntnerstrasse_4"
                           >zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_kaerntnerstrasse_4"><roleName
                              type="owner" corresp="pe__leonhard_floederl_QGW_II_II_3238"><rs
                                 type="person" ref="pe__leonhard_floederl_QGW_II_II_3238">Lienharts
                                 Flöderleins</rs></roleName> haus</rs> gelegen, <rs type="event"
                           ref="ev__QGW_II_II_3401_men_2"><rs type="fn" role="transactiongood_I"><rs
                                 type="place" ref="pl__wien-immo_kaerntnerstrasse_12">das <roleName
                                    type="owner" corresp="pe__johann_kieler_SB_CD_00620">des
                                    egenanten Hannsen Kieler gewesen</roleName></rs></rs><rs
                              type="fn" role="issuer"><rs type="person"
                                 ref="pe__johann_kieler_SB_CD_00620"><add>er</add></rs></rs> und <rs
                              type="fn" role="recipient"><rs type="person"
                                 ref="pe__erasmus_kieler_QGW_II_II_3401">dem egenanten seinem
                                 sun</rs></rs>
                           <triggerstring n="disp">geschafft hat</triggerstring></rs></rs>. <rs
                        type="event" ref="ev__QGW_II_II_3401_men_3"><rs type="fn" role="issuer"><rs
                              type="person" ref="pe__johann_kanstorffer_QGW_II_II_3401"
                                 >Kanstorffer<roleName type="rep"
                                 corresp="pe__erasmus_kieler_QGW_II_II_3401"
                                 ><add>anstatt</add></roleName></rs> und <rs type="person"
                              ref="pe__barbara_SB_CD_00620">seine Frau<roleName type="rep"
                                 corresp="pe__erasmus_kieler_QGW_II_II_3401"
                                 ><add>anstatt</add></roleName></rs></rs> haben <rs type="fn"
                           role="transactiongood_I"><rs type="place"
                              ref="pl__wien-immo_kaerntnerstrasse_12">es</rs></rs> anstatt des
                        Knaben <rs type="fn" role="recipient"><rs type="org"
                              ref="org__altenburg-benediktiner">dem Abt und Convent zu
                              Altenburg</rs></rs>
                        <rs type="fn" role="transactiongood_II">um <measure>340 lb
                           dn.</measure></rs>
                        <triggerstring n="disp">verkauft</triggerstring>, wovon 50 lb dn. der Barbara
                        gehören, <rs type="event" ref="ev__QGW_II_II_3404">während 290 lb dn. für
                           den Knaben auf ihrem Hause, in der Weihenpurg gelegen, das der von
                           Altenburg gewesen ist, angelegt werden
                  sollen</rs>.</rs></triggerstring></rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3401"><rs type="fn" role="witness">Besiegelt mit
                        <rs type="org" ref="org__wien">der Stadt klainem anhangundem
                     insigh</rs></rs></rs>
            </p>
