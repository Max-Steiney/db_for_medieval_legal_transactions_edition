                  hat</roleName></rs>,</rs>
            <triggerstring n="disp">zurückzufordern</triggerstring> und ihn <rs type="fn" role="other">dem
              Wiener Bürger <rs type="person" ref="pe__andreas_schoenprugker_QGW_II_II_3376">Andreen
                Schönprugker</rs>
