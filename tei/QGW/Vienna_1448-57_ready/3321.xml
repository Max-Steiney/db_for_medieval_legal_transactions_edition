   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3321"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__heinrich_wenndtnhaimer_QGW_II_II_3321">Hainreich
                        Wenndtnhaimer, <roleName type="title_ref" corresp="pl__kierling">gesessen
                           zu</roleName> Kirichling</rs>, und <rs type="person"
                        ref="pe__margarethe_QGW_II_II_3321">Margret, sein <roleName type="kin"
                           corresp="pe__heinrich_wenndtnhaimer_QGW_II_II_3321"
                        >hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="disp">mit Handen</triggerstring> des <rs
                        type="person" ref="pe__niklas_stengel_QGW_II_II_3321">Niclasen Stenngl,
                           <roleName type="occ" corresp="pe__leonhard_von_layming_QGW_II_II_3321"
                           >ambtman</roleName>
                        <rs type="person" ref="pe__leonhard_von_layming_QGW_II_II_3321"><roleName
                              type="title">hern</roleName> Leonharden, <roleName type="occ"
                              corresp="org__passau-dioezese">bischoven</roleName> zu
                        Passau</rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_I"><rs type="place"
                        ref="pl__kierling-irnveld-immo_1">eine Wiese, <roleName type="topo"
                           corresp="pl__kierling-irnveld">gelegen am Irnveld</roleName>
                        <roleName type="topo" corresp="pl__kierling-irnveld-immo_2"
                           >zunagst</roleName>
                        <rs type="place" ref="pl__kierling-irnveld-immo_2"><roleName type="owner"
                              corresp="pe__niklas_zwingendorfer_QGW_II_II_3321"><rs type="person"
                                 ref="pe__niklas_zwingendorfer_QGW_II_II_3321">Niclasen des
                                 Zwingendorffer</rs></roleName> wisen</rs>, <rs type="event"
                           ref="ev__QGW_II_II_3321_men_1"><rs type="fn" role="issuer">von <rs
                                 type="place" ref="pl__kierling-irnveld-immo_1">der</rs> man</rs>
                           <rs type="fn" role="recipient"><rs type="org" ref="org__passau-dioezese"
                                 >dem Bisthume</rs></rs>
                           <rs type="fn" role="transactiongood_I"><measure>23 dn. der schwarzen
                                 Münze</measure>
                              <triggerstring n="fn">zu Grunddienst</triggerstring></rs>
                           <triggerstring n="disp"><add>Grunddienst</add>
                     dient</triggerstring></rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_II">und <measure>40 lb dn.</measure>
                     <rs type="event" ref="ev__QGW_II_II_3321_men_2"><triggerstring n="disp">aus dem
                           Erlöse</triggerstring>
                        <rs type="fn" role="transactiongood_I">für <rs type="place"
                              ref="pl__hernals-immo_3">einen Weingarten, <roleName type="topo"
                                 corresp="pl__hernals">gelegen im Nidernveld zu Herren
                                 Allss</roleName>, der zu der <rs type="event"
                                 ref="ev__QGW_II_II_3321_men_3"><rs type="fn" role="issuer">von dem
                                       <rs type="person" ref="pe__stephan_wirsing_QGW_II_II_3321"
                                       >edeln Stephan Wirsing</rs></rs>
                                 <rs type="fn" role="recipient">auf <rs type="org"
                                       ref="org__wien-st_stephan-altar_dreikoenige">der heiligen
                                       Dreier Kunig altar dacz sand Stephans kirchen</rs></rs>
                                 <triggerstring n="disp">gestifteten Messe</triggerstring></rs></rs></rs>
                        <rs type="fn" role="issuer"><rs type="org"
                              ref="org__wien-st_stephan-altar_dreikoenige-messe_wirsing_stephan"
                              >gehört hatte</rs></rs></rs>,</rs>
                  <rs type="fn" role="recipient">dem <rs type="person"
                        ref="pe__johann_vorster_QGW_II_II_3321"><roleName type="title"
                           >maister</roleName> Hannsen Vorsster von Mistlbach, <roleName type="occ"
                           corresp="org__wien-st_stephan-altar_dreikoenige-messe_wirsing_stephan"
                           >Kaplan</roleName> dieser Messe</rs>, mit der Bestimmung, dass die
                     verkaufte Wiese für ewige Zeiten <rs type="org"
                        ref="org__wien-st_stephan-altar_dreikoenige-messe_wirsing_stephan">bei
                        derselben</rs> verbleiben solle</rs>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3321"><rs type="fn" role="witness">Siegler: <rs
                        type="person" ref="pe__konrad_perbmhaubt_QGW_II_II_3295">Connrat Perbmhaupt,
                           <roleName type="occ" corresp="org__klosterneuburg">burger</roleName> zu
                        Closterneunburg</rs>, und <rs type="person"
                        ref="pe__johann_waiczhover_QGW_II_II_3321">Hanns Waiczhover, der jünger,
                        statschreiber zu Kloster Neunburg</rs>.</rs></rs>
            </p>
