            <placeName>Hernals</placeName>
            <date when="14490608">1449 VI 08</date>
            <origDate instant="false">zu Herren Alls, an dem suntag der heiligen Drivaltigkait
            tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03307_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03307_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3307"><rs type="fn" role="issuer"><rs type="person" ref="pe__jakob_ebersperger_QGW_II_II_3307">Jacob Ebersperger,
                        der geistlichen fraun zu sand Niclas vor Stubentor zu Wienn <roleName type="occ" corresp="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen" select="pl__hernals">pergmaister</roleName> zu Herren Alls</rs>,</rs>
                  <triggerstring n="disp">beurkundet, dass vor ihm in offenem Gerichte</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="pe__michael_rutenstokch_QGW_II_II_3307"><roleName type="title">maister</roleName> Michel Rutenstokch, der <roleName type="prof">maler</roleName>, <roleName type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs>, <triggerstring n="fn">mit
                        vorsprechen</triggerstring></rs>
                  <rs type="fn" role="other"><triggerstring n="fn">auf <add>hincz</add></triggerstring>
                     <rs type="person" ref="pe__anna_QGW_II_II_3307"><roleName type="title">fraun</roleName> Annen, <rs type="person" ref="pe__peter_schuessler_QGW_II_II_3307">Petern, des <roleName type="prof">schüssler</roleName>
                           <roleName type="dead">Got genad</roleName></rs>, <roleName type="kin" corresp="pe__peter_schuessler_QGW_II_II_3307">hausfraun</roleName>, den
                        baiden <roleName type="dead">Got genad</roleName>, die <rs type="person" ref="pe__stephan_prugkner_QGW_II_II_3307"><roleName type="dead">emaln</roleName> Stephan, <roleName type="prof">wachsgiesser</roleName>, den Prugkner</rs> auch <roleName type="kin" corresp="pe__stephan_prugkner_QGW_II_II_3307">elichen</roleName> gehabt
                        hat</rs>,</rs>
                  <rs type="fn" role="transactiongood_III">zwen <rs type="place" ref="pl__hernals-immo_eselhart_1">weingerten, baid <roleName type="topo" corresp="pl__hernals-eselhart">gelegen in dem Eselhart</roleName>
                           (<measure>½ Joch</measure>
                        <roleName type="topo" corresp="pl__hernals-immo_eselhart_2">zunagst</roleName>
                        <rs type="place" ref="pl__hernals-immo_eselhart_2"><roleName type="owner" corresp="pe__niklas_muenzer_QGW_II_II_3307"><rs type="person" ref="pe__niklas_muenzer_QGW_II_II_3307">Niclasen, des <roleName type="prof">münsser</roleName></rs></roleName>, weingarten</rs>
                        <rs type="event" ref="ev__QGW_II_II_3307_men_1"><rs type="fn" role="issuer"><rs type="place" ref="pl__hernals-immo_eselhart_1"><add>von beiden</add></rs></rs>
                           <triggerstring n="disp"><add>gebührt</add></triggerstring>
                           <rs type="fn" role="recipient"><rs type="org" ref="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen"><add>den geistlichen Frauen zu St. Niklas</add></rs></rs>
                           <triggerstring n="disp"><add>ein</add>
                              <add>Grunddienst von jährlich</add></triggerstring>
                           <rs type="fn" role="transactiongood_I"><measure><add>45
                                 dn.</add></measure>
                              <triggerstring n="fn"><add>Grunddienst</add></triggerstring></rs></rs></rs>,
                        <rs type="place" ref="pl__hernals-immo_eselhart_4"><measure>½ Joch</measure>
                        <roleName type="topo" corresp="pl__hernals-immo_eselhart_3">zunagst</roleName>
                        <rs type="place" ref="pl__hernals-immo_eselhart_3">der Augustiner
                           weingarten</rs>
                        <roleName type="topo" corresp="pl__hernals-eselhart"><add>gelegen in dem
                              Eselhart</add></roleName>, <rs type="event" ref="ev__QGW_II_II_3307_men_2"><rs type="fn" role="issuer"><rs type="place" ref="pl__hernals-immo_eselhart_4">von
                                 beiden</rs></rs>
                           <triggerstring n="disp">gebührt</triggerstring>
                           <rs type="fn" role="recipient"><rs type="org" ref="org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">den
                                 geistlichen Frauen zu St. Niklas</rs></rs>
                           <triggerstring n="disp">ein Grunddienst von jährlich</triggerstring>
                           <rs type="fn" role="transactiongood_I"><measure>45 dn.</measure>
                              <triggerstring n="fn"><add>Grunddienst</add></triggerstring></rs></rs></rs>)</rs> mit der Begründung
                     <triggerstring n="disp">geklagt habe</triggerstring>, <rs type="event" ref="ev__QGW_II_II_3307_men_3">dass sein Schwager Peter, schüssler, <rs type="event" ref="ev__QGW_II_II_3307_men_3">der für die
                        Frau eine Geldschuld bezahlt hatte,</rs> ihm sein Anrecht an die Weingärten
                     übertragen habe.</rs> Da <rs type="fn" role="other"><triggerstring n="fn"><add>hincz</add></triggerstring> die <rs type="person" ref="pe__dorothea_QGW_II_II_3307"><roleName type="kin" corresp="pe__anna_QGW_II_II_3307">nächste Erbin</roleName> der
                        Verstorbenen, Jungfrau Dorothe</rs>,</rs> einen Einspruch nicht erhebt und
                  auch die von Peter, schüssler, ausgelegte Summe nicht erstattet, so <triggerstring n="disp">macht</triggerstring> er <rs type="fn" role="recipient"><rs type="person" ref="pe__michael_rutenstokch_QGW_II_II_3307">den Kläger</rs></rs> der
                  Weingärten <triggerstring n="disp">gewaltig</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3307"><rs type="fn" role="witness">Siegler: <rs type="person" ref="pe__simon_von_eslarn_QGW_II_II_3263">Simon von Eslarn
                           <roleName type="occ" corresp="org__wien"><add>burger</add></roleName></rs> und <rs type="person" ref="pe__johann_ravensburger_QGW_II_II_3264">Hanns der Ravenspurger,
                           <roleName type="occ" corresp="org__wien">urtailschreiber</roleName>, baid
                           <roleName type="occ" corresp="org__wien">burger</roleName> zu
                        Wienn</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: gericht zum puch, Michel Rutnstokh. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>