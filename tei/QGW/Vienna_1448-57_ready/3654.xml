                        Rathaus zu Wienn, hern [381] Otten und Haymen stifftung</rs>,</rs>
                  <rs type="fn" role="transactiongood_II"><rs type="place" ref="pl__hernals-immo_4">½ Joch Weingarten, <roleName type="topo" corresp="pl__hernals">gelegen zu
                           Herrenalss hinder dem dorff in den Langen halben jeuchen</roleName>
                        zenagst <rs type="place" ref="pl__hernals-immo_5"><roleName type="owner" corresp="pe__johann_wuechster_QGW_II_II_3654"><rs type="person" ref="pe__johann_wuechster_QGW_II_II_3654">Hannsen Wüchster, des
                                    <roleName type="prof">münsser</roleName></rs></roleName>,
                           weingarten</rs>
                        <roleName type="topo" corresp="pl__hernals-immo_5"><add>zenagst</add> an aim
                           tail</roleName>
                        <roleName type="topo" corresp="pl__hernals-immo_6">und an dem andern
                           zenagst</roleName>
                        <rs type="place" ref="pl__hernals-immo_6"><roleName type="owner" corresp="pe__andreas_payr_QGW_II_II_3654"><rs type="person" ref="pe__andreas_payr_QGW_II_II_3654">Andres des
                                 Payr</rs></roleName> weingarten</rs>, <rs type="event" ref="ev__QGW_II_II_3654_men_1"><rs type="fn" role="issuer">von <rs type="place" ref="pl__hernals-immo_4">dem</rs> man</rs>
                           <rs type="fn" role="recipient"><rs type="org" ref="org__hernals-st_bartholomaeus">dem pharrer zu sand Bertelme zu
                                 Herrenalss</rs></rs>
                           <rs type="fn" role="transactiongood_I"><measure>2 dn.</measure>
                              <triggerstring n="fn">zu Grunddienst</triggerstring></rs>
                           <triggerstring n="disp"><add>Grunddienst</add>
                     dient</triggerstring></rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_I">gegen <triggerstring n="fn">jährliche
                        Leistung</triggerstring> des <measure>vierten Eimers Most</measure> bei der
                     press aus dem grant</rs>
                  <triggerstring n="disp">auf</triggerstring> ihrer Drei <triggerstring n="disp">Lebenszeit
                     in Bestand</triggerstring>.</rs>
