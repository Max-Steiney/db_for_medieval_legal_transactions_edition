                        Herrenalss</rs>, <rs type="person" ref="pe__katharina_QGW_II_II_3654">Kathrei, sein <roleName type="kin" corresp="pe__jakob_tragenwein_QGW_II_II_3654">hausfrau</roleName></rs>,
