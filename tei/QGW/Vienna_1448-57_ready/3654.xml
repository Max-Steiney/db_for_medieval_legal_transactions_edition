                  <triggerstring n="disp">nehmen</triggerstring>
                  <rs type="fn" role="recipient">von <rs type="person" ref="pe__heinrich_senftleben_QGW_II_II_3263"><roleName type="title">hern</roleName> Hainreichen Senfftleben, <roleName type="occ" corresp="org__breslau-dioezese">techant</roleName> und <roleName type="occ" corresp="org__breslau-dioezese">tumbherr</roleName> zu
