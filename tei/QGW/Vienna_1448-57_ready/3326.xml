      <text>
            <body>
                  <div type="abstract" resp="kg">
                        <p><rs type="event" ref="ev__QGW_II_II_3326"><rs type="fn" role="issuer"><rs
                                                type="person"
                                                ref="pe__niklas_von_feldsberg_QGW_II_II_3326">Niclas
                                                von Velczperg, <roleName type="occ"
                                                  corresp="org__wien-st_stephan-altar_st_veit-messe_neukum"
                                                  ><add>Kaplan</add></roleName>
                                                <roleName type="occ"
                                                  corresp="org__wien-st_stephan-altar_allerseelen-messe_kurcz_anna"
                                                  >Kaplan</roleName> des Neukum mess auf sand Veits
                                                altar zu sand Stephan und <rs type="event"
                                                  ref="ev__QGW_II_II_3326_men_1">der <triggerstring
                                                  n="disp">mess</triggerstring>, die <rs type="fn"
                                                  role="issuer"><rs type="person"
                                                  ref="pe__anna_QGW_II_II_3326"><roleName
                                                  type="dead" cert="high">weilent</roleName>
                                                  <roleName type="title">frau</roleName> Anna, <rs
                                                  type="person" ref="pe__paul_kurcz_QGW_II_II_3326"
                                                  >Pauln des Kurczen</rs>
                                                  <roleName type="kin"
                                                  corresp="pe__paul_kurcz_QGW_II_II_3326"
                                                  >hausfrau</roleName></rs>,</rs>
                                                  <rs type="fn" role="recipient">auf <rs type="org"
                                                  ref="org__wien-st_stephan-altar_allerseelen"
                                                  >Allerseelen altar daselbst</rs></rs>
                                                  <triggerstring n="disp">zu stifften geschafft
                                                  hat</triggerstring></rs></rs>,</rs>
                                    <triggerstring n="disp">verpflichtet sich</triggerstring> für sich und
                                    seine Nachfolger, <unclear instant="false"><rs type="fn"
                                                role="other"><triggerstring n="fn">von dem
                                                  Ertrage</triggerstring> der zu der Stiftung gehörigen
                                                Weingärten und von <rs type="place"
                                                  ref="pl__wien-immo_traubottenstrasse_1">dem Hause
                                                  <roleName type="topo"
                                                  corresp="pl__wien-traubottenstrasse">in der
                                                  Traubottenstrass niden am eck gegen der
                                                  Rinkchmauer uber</roleName>
                                                  <roleName type="topo"
                                                  corresp="pl__wien-immo_traubottenstrasse_2"
                                                  >zenagst <add>gelegen</add></roleName>
                                                  <rs type="place"
                                                  ref="pl__wien-immo_traubottenstrasse_2">des
                                                  Grubmesser haus gelegen, das der Schotten grund
                                                  ist</rs>, und <rs type="event"
                                                  ref="ev__QGW_II_II_3326_men_2"><rs type="fn"
                                                  role="transactiongood_I"><rs type="place"
                                                  ref="pl__wien-immo_traubottenstrasse_1"
                                                  >das</rs></rs>
                                                  <rs type="fn" role="recipient"><rs type="person"
                                                  ref="pe__niklas_von_feldsberg_QGW_II_II_3326"
                                                  >er</rs></rs>
                                                  <rs type="fn" role="issuer">von <rs type="person"
                                                  ref="pe__heinrich_groecz_QGW_II_II_3326"
                                                  >Hainreichen Grotzen, dem <roleName type="prof"
                                                  >münsser</roleName></rs>, und <rs type="person"
                                                  ref="pe__magdalena_QGW_II_II_3326">Magdalen,
                                                  seiner, <roleName type="kin"
                                                  corresp="pe__heinrich_groecz_QGW_II_II_3326"
                                                  >hausfraun</roleName></rs>,</rs>
                                                  <rs type="fn" role="transactiongood_II">um
                                                  <measure>55 lb dn.</measure></rs>
                                                  <triggerstring n="disp">gekauft
                                                  hatte</triggerstring></rs></rs>,</rs></unclear>
                                    <triggerstring n="disp">in Allem mit der Stadt zu
                                          leiden</triggerstring>.</rs>
                        </p>
                  </div>
                  <div type="seal">
                        <p><rs type="event" ref="ev__QGW_II_II_3326"><rs type="fn" role="witness"
                                          >Besiegelt mit den Siegeln <rs type="person"
                                                ref="pe__johann_scharfenberger_QGW_II_II_3326"
                                                >Hannsen Scharffenperger, <roleName type="occ" corresp="org__wien"><add>burger</add></roleName>
                                                anbalt in der münss</rs>, und <rs type="person"
                                                ref="pe__johann_puchspaum_QGW_II_II_3038">Hannsen
                                                Pukspaum, baid <roleName type="occ" corresp="org__wien">burger</roleName> zu
                                                Wienn</rs>.</rs></rs>
                        </p>
                  </div>
