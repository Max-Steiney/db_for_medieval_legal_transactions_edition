   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3552"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__niklas_sevelder_QGW_II_II_3552">Niclas Sevelder,
                           <roleName type="occ"
                           corresp="org__wien-st_stephan-altar_st_simon_st_judas-messe_mustrer_johann"
                           >Kaplan</roleName> der <rs type="event" ref="ev__QGW_II_II_3552_men_1"
                              ><rs type="fn" role="issuer">von <rs type="person"
                                 ref="pe__johann_mustrer_QGW_II_II_1941">Hanns dem Mustrer</rs></rs>
                           <rs type="fn" role="recipient">auf <rs type="org"
                                 ref="org__wien-st_stephan-altar_st_simon_st_judas">sand Simons und
                                 sand Judas altar dacz sand Steffan zu Wienn</rs></rs>
                           <triggerstring n="disp">gestifteten Messe</triggerstring></rs></rs>,</rs>
                  <triggerstring n="disp">verlässt</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Einwilligung</triggerstring>
                     <rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951"><roleName
                           type="title">hern</roleName> Niclasen Teschler, <roleName type="occ"
                           corresp="org__wien">burgermaister</roleName>
                        <roleName type="occ" corresp="org__wien-st_stephan-altar_st_simon_st_judas-messe_mustrer_johann"
                              ><add>Lehensherren</add></roleName></rs>, und <rs type="org"
                        ref="org__wien">des Rathes als <roleName type="occ" corresp="org__wien-st_stephan-altar_st_simon_st_judas-messe_mustrer_johann"
                           >Lehensherren</roleName></rs></rs>
                  <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__st_ulrich-immo_3"
                        >einen Weingarten, des siben achtail ist, <roleName type="topo"
                           corresp="pl__st_ulrich">gelegen ausserhalb sand Ulreich in der
                           Kelberspeunt</roleName>
                        <roleName type="topo" corresp="pl__st_ulrich-immo_4">zwischen</roleName>
                        <rs type="place" ref="pl__st_ulrich-immo_4"><roleName type="owner"
                              corresp="pe__heinrich_haiden_QGW_II_II_2564">weilent Hainreichs
                              Haiden</roleName>
                           <add>weingerten</add></rs>
                        <roleName type="topo" corresp="pl__st_ulrich-immo_5">und
                           <add>zwischen</add></roleName>
                        <rs type="place" ref="pl__st_ulrich-immo_5"><roleName type="owner"
                              corresp="pe__niklas_swebel_QGW_II_II_3552"><rs type="person"
                                 ref="pe__niklas_swebel_QGW_II_II_3552">Niclasen
                              Sweblein</rs></roleName> weingerten</rs></rs>, sowie <measure>66 lb 6
                        sh. dn.</measure>, <rs type="event" ref="ev__QGW_II_II_3552_men_2"><rs
                           type="fn" role="transactiongood_II">für welche <measure><add>66 lb 6 sh.
                                 dn.</add></measure></rs>
                        <rs type="fn" role="transactiongood_I"><rs type="place"
                              ref="pl__wien-immo_hohewarte_3">ein gleichfalls von Mustrer gewidmeter
                              Weingarten <roleName type="topo" corresp="pl__wien-hohewarte">an der
                                 Hohenbart</roleName>, den man aber zu derselben mess nicht hat
                              wellen vertigen noch bestetten</rs>,</rs>
                        <rs type="fn" role="issuer"><rs type="person"
                              ref="pe__niklas_sevelder_QGW_II_II_3552"/></rs>
                        <triggerstring n="disp">verkauft worden war</triggerstring></rs>,</rs>
                  <rs type="fn" role="recipient">dem <rs type="person"
                        ref="pe__konrad_oeczestorffer_QGW_II_II_2627">Wiener [358] <roleName type="occ" corresp="org__wien">Bürger</roleName> Conraten
                        Öczestorffer</rs></rs>
                  <rs type="fn" role="transactiongood_II">gegen einen <triggerstring n="fn"
                        >Jahrdienst</triggerstring> von <measure>8 lb dn.</measure></rs>
                  <triggerstring n="disp">auf Lebenszeit in Bestand</triggerstring>. <rs type="event"
                     ref="ev__QGW_II_II_3552a"><rs type="fn" role="issuer"><rs type="person"
                           ref="pe__konrad_oeczestorffer_QGW_II_II_2627">Ötzestorffer</rs></rs>
                     <triggerstring n="disp">verpfändet</triggerstring>
                     <rs type="fn" role="recipient"><rs type="person"
                           ref="pe__niklas_sevelder_QGW_II_II_3552"/></rs> dafür <rs type="fn"
                        role="transactiongood_I"><triggerstring n="fn">die Ueberteuerung</triggerstring>
                        <rs type="place" ref="pl__wien-immo_unter_den_sattlern_2"><roleName
                              type="owner" corresp="pe__konrad_oeczestorffer_QGW_II_II_2627"
                              >seines</roleName> Hauses, <roleName type="topo"
                              corresp="pl__wien-unter_den_sattlern">gelegen undern Satlern zu
                              Wienn</roleName>
                           <roleName type="topo" corresp="pl__wien-immo_unter_den_sattlern_3"
                              >zenagst</roleName>
                           <rs type="place" ref="pl__wien-immo_unter_den_sattlern_3"><roleName
                                 type="owner" corresp="pe__johann_wiczinger_QGW_II_II_3552">Hannsen
                                 des Wiczinger</roleName> haus</rs>, <rs type="event"
                              ref="ev__SB_CD_00237_men_1">uber die 42 lb dn ., die Micheln, Walthern
                              des satler sun, vor darauf verphent sein,</rs>
                           <rs type="event" ref="ev__SB_CD_00237_men_2">und über die 7 lb dn. geltes
                              purkrechts (ablösbar mit 70 lb dn.), die weilent hern Hannsen Vaschang
                              nachmaln darauf verschriben sind,</rs>
                           <rs type="event" ref="ev__SB_CD_00237">und über die 40 lb dn ., die er
                              seinen kindern Micheln und Margreten darnach darauf verpfent hat,</rs>
                           <rs type="event" ref="ev__SB_CD_00241">und über die 2 ½ lb dn. gelts
                              purkrechts (ablösbar mit 20 lb dn.), die weilent hern Hannsen Peyssl,
                              Kaplan der von dem Würffl auf sand Sigmunds und sand Wolfgangs altar
                              dacz sant Steffan zu Wienn, nachmaln darauf verphentt
                        sein</rs></rs>.</rs></rs></rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3552"><rs type="fn" role="witness">Besiegelt mit
                        <rs type="org" ref="org__wien">der Stadt klainem insigl</rs>.</rs></rs>
            </p>
