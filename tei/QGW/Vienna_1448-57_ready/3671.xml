                  <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__grinzing-immo_15">ain virtail weingarten, <roleName type="topo" corresp="pl__grinzing">gelegen daselbs zu Grinczing in dem Reisenperg</roleName>
