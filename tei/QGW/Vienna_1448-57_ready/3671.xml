                        <rs type="place" ref="pl__grinzing-immo_16">des Keshover weingarten</rs>,
                           <rs type="event" ref="ev__QGW_II_II_3671_men_1"><rs type="fn" role="issuer">von <rs type="place" ref="pl__grinzing-immo_15">dem</rs>
                              man</rs>
                           <rs type="fn" role="recipient"><rs type="org" ref="org__klosterneuburg-augustiner_chorherren"/></rs>
                           <rs type="fn" role="transactiongood_I"><measure>2½ virtail
                                 weins</measure>
                              <triggerstring n="fn">ze perkchrecht</triggerstring></rs>
                           <rs type="fn" role="transactiongood_I">und <measure>dreu ort</measure>
                              <triggerstring n="fn">ze voitrecht</triggerstring></rs>
                           <triggerstring n="disp"><add>perkchrecht</add><add>voitrecht</add>
                              dient</triggerstring></rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_II">um <measure>55 lb dn.</measure></rs>
                  <rs type="fn" role="recipient">dem <rs type="person" ref="pe__christian_wissinger_QGW_II_II_3328">Kristan Wissinger, des
