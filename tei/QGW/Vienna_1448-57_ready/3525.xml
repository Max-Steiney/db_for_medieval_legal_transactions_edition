                                                  <add>über</add></roleName>
                                                <rs type="place" ref="pl__wien-immo_wollzeile_14">der Janin haus</rs> über <roleName type="topo" corresp="pl__wien-immo_wollzeile_6">zenagst
                                                  <add>gelegen</add></roleName>
                                                <roleName type="owner" corresp="pe__erhard_marbacher_QGW_II_III_4472"><rs type="person" ref="pe__erhard_marbacher_QGW_II_III_4472">Erharten, des <roleName type="prof">smids</roleName></rs></roleName>, haus gelegen,
                                                  <rs type="event" ref="ev__QGW_II_II_3525_men_1"><rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_wollzeile_13">das</rs></rs>
                                                  <rs type="fn" role="recipient"><rs type="person" ref="pe__leonhard_lehenholzer_QGW_II_II_3371">Lehenholczer</rs> und <rs type="person" ref="pe__agnes_QGW_II_II_3525">seine <roleName type="dead">verstorbene</roleName>
                                                  <roleName type="kin" corresp="pe__leonhard_lehenholzer_QGW_II_II_3371">Hausfrau</roleName> Agnes, des Ausstellers
                                                  <roleName type="kin" corresp="pe__johann_molter_QGW_II_II_3525">Schwester</roleName></rs>,</rs>
                                                  <triggerstring n="disp">mit gesammter Hand gekauft
                                                  hatten</triggerstring></rs></rs>.</rs></rs>
                        </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3525"><rs type="fn" role="witness">Besiegelt mit den Siegeln <rs type="person" ref="pe__niklas_renhart_QGW_II_II_3282">Niclasen
