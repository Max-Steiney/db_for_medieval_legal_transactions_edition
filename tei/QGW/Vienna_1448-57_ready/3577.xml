          <rs type="event" ref="ev__QGW_II_II_3577"><rs type="fn" role="issuer"><rs type="person" ref="pe__stephan_pabenperger_QGW_II_II_3577">Stephan Pabenberger, der <roleName type="prof">gürtler</roleName>, <roleName type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs>, und <rs type="person" ref="pe__ursula_QGW_II_II_3577">Ursula, sein <roleName type="kin" corresp="pe__stephan_pabenperger_QGW_II_II_3577">hausfrau</roleName></rs>,</rs>
            <triggerstring n="disp">verkaufen <add>geltes purkchrechts</add></triggerstring>
            <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
              <rs type="person" ref="pe__martin_QGW_II_II_3213">ihres <roleName type="title">Grundherrn</roleName>, <roleName type="title">hern</roleName> Mertten, <roleName type="occ" corresp="org__wien-schotten">abbt</roleName> Unser Lieben Fraun
                gotshaus dacz den Schotten zu Wienn</rs>,</rs>
            <rs type="fn" role="transactiongood_I"><measure>5 lb dn.</measure>
              <triggerstring n="fn">geltes purkchrechts</triggerstring> (ablösbar) auf <rs type="place" ref="pl__wien-immo_hohe_bruecke_3"><roleName type="owner" corresp="pe__stephan_pabenperger_QGW_II_II_3577">ihrem</roleName>
                <roleName type="owner" corresp="pe__ursula_QGW_II_II_3577"><add>ihrem</add></roleName> Hause, <roleName type="topo" corresp="pl__wien-hohe_bruecke">gelegen auf der Hohenprugk</roleName> zenagst <rs type="place" ref="pl__wien-immo_hohe_bruecke_4">der padstuben</rs>
                <roleName type="topo" corresp="pl__wien-immo_hohe_bruecke_4"><add>zenagst</add> an
                  ainem tail</roleName>, <rs type="event" ref="ev__QGW_II_II_3577_men_1"><rs type="fn" role="issuer">von
                      <rs type="place" ref="pl__wien-immo_hohe_bruecke_3">dem</rs> man</rs>
                  <rs type="fn" role="transactiongood_I"><measure>12 dn.</measure>
                    <triggerstring n="fn">zu Grunddienst</triggerstring></rs>
                  <triggerstring n="disp"><add>Grunddienst</add> dient</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="org__wien-schotten"/></rs></rs></rs>,</rs>
            <rs type="fn" role="transactiongood_II">um <measure>40 lb dn.</measure>, <rs type="event" ref="ev__SB_CD_01104"><triggerstring n="disp">die emaln gelegen gewesen
                  sind</triggerstring>
                <rs type="fn" role="issuer">auf <rs type="place" ref="pl__wien-immo_hohe_bruecke_1"><roleName type="owner" corresp="pe__willibald_groblokch_QGW_II_II_3577">Wiltbolten Groblokch</roleName> und <rs type="person" ref="pe__katharina_SB_CD_01104">seiner <roleName type="kin" corresp="pe__willibald_groblokch_QGW_II_II_3577">hausfraun</roleName></rs>
                    haus, <roleName type="topo" corresp="pl__wien-hohe_bruecke">auch bei der
                      Hohenprugk gelegen</roleName></rs>,</rs> die man damit <triggerstring n="disp">darob geledigt und gelost hat</triggerstring>,</rs></rs>
            <rs type="fn" role="recipient">dem <rs type="person" ref="pe__wolfgang_stadler_QGW_II_II_3557"><roleName type="prof">Priester</roleName>
                <roleName type="title">hern</roleName> Wolfgangen Stadler, <roleName type="occ" corresp="org__wien-st_stephan-altar_st_jakob-messe_korner_niklas">Kaplan</roleName> der von Niclas Korner auf sand Jacobs altar dacz sand Stephan
                zu Wienn gestifteten Messe</rs>, und <rs type="org" ref="org__wien-st_stephan-altar_st_jakob-messe_korner_niklas">seinen
                Nachfolgern</rs>.</rs></rs>
        </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3577"><rs type="fn" role="witness">Besiegelt mit dem
                <rs type="org" ref="org__wien-schotten">Grundsiegel der Schotten</rs> und dem Siegel
              des <rs type="person" ref="pe__ulrich_hirssauer_QGW_II_II_3239">Wiener <roleName type="occ" corresp="org__wien">Stadtschreibers</roleName> Ulreich
              Hirssauer</rs>.</rs></rs>
