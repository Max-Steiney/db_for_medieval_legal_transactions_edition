            <date when="14490313">1449 III 13</date>
            <origDate instant="false">Das ist geschehen an pfincztag vor Oculi in der Vasten, als man zalt nach
               Kristes gepurd 1400 und darnach in dem 49. jare. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03292_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03292_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3292"><rs type="fn" role="issuer"><rs type="person" ref="pe__barbara_QGW_II_II_3292">Barbara, <rs type="person" ref="pe__thomas_peunter_QGW_II_II_3292">Thoman des Peuntner <roleName type="dead">saligs</roleName></rs>
                        <roleName type="kin" corresp="pe__thomas_peunter_QGW_II_II_3292">dochter</roleName> und <rs type="person" ref="pe__veit_elrechinger_QGW_II_II_3292">Veitten Elrechingers <roleName type="dead">wittib</roleName></rs>
                        <roleName type="kin" corresp="pe__veit_elrechinger_QGW_II_II_3292"><add>wittib</add></roleName></rs>, <rs type="person" ref="pe__wilhelm_auer_QGW_II_II_3292">Wilhalm Auer zu Tobel anstat seiner
                        kinder, die er von <rs type="person" ref="pe__ursula_QGW_II_II_3292">seiner
                              <roleName type="kin" corresp="pe__wilhelm_auer_QGW_II_II_3292">Hausfrau</roleName> Ursula, Thoman Peuntner saligs <roleName type="kin" corresp="pe__thomas_peunter_QGW_II_II_3292">dochter</roleName></rs>, hat</rs>, und <rs type="person" ref="pe__georg_eplhauser_QGW_II_II_3292">Jorig Eppelhauser, <roleName type="title_ref" corresp="pl__klosterneuburg-burg_herzoglich">purksässig</roleName> zu Neunburgk, <roleName type="rep" corresp="pe__wilhelm_eplhauser_QGW_II_II_3292">für</roleName> sich,
                        seinen <rs type="person" ref="pe__wilhelm_eplhauser_QGW_II_II_3292"><roleName type="kin" corresp="pe__georg_eplhauser_QGW_II_II_3292">Bruder</roleName> Wilhalm Eppelhauser</rs> und seine anderen
                        Geschwister</rs></rs>
                  <triggerstring n="disp">beurkunden, dass sie sich</triggerstring>
                  <rs type="fn" role="recipient">mit ihrem <rs type="person" ref="pe__benedikt_eitzinger_QGW_II_II_3292"><roleName type="kin" corresp="pe__barbara_QGW_II_II_3292">Stiefvater</roleName>
                        <roleName type="kin" corresp="pe__ursula_QGW_II_II_3292"><add>Stiefvater</add></roleName>
                        <roleName type="kin" corresp="pe__georg_eplhauser_QGW_II_II_3292"><add>Stiefvater</add></roleName>
                        <roleName type="kin" corresp="pe__wilhelm_eplhauser_QGW_II_II_3292"><add>Stiefvater</add></roleName>, dem <roleName type="title">edeln</roleName> Benedicten Eiczinger zu Eiczing</rs>,</rs>
                  <triggerstring n="disp">vollständig ausgeglichen haben</triggerstring>.</rs>
