            <date when="14531207">1453 XII 07</date>
            <origDate instant="false">zu Wienn, an freitag nach sant Niclas
            tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03549_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03549_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3549"><rs type="fn" role="issuer"><rs type="person" ref="pe__margarethe_QGW_II_II_3549">Margreth, <rs type="person" ref="pe__peter_unger_StB_I_171" cert="high">Petern Unger
                              <roleName type="dead">seligen</roleName></rs>
                        <roleName type="kin" corresp="pe__peter_unger_StB_I_171">tochter</roleName>
                        und <rs type="person" ref="pe__niklas_knauss_QGW_II_II_3549">Niclasen Knaus,
                              <roleName type="occ" corresp="org__wien">burger</roleName> zu
                           Wienn</rs>, eliche <roleName type="kin" corresp="pe__niklas_knauss_QGW_II_II_3549">hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">beurkundet</triggerstring>, <rs type="event" ref="ev__QGW_II_II_3549_men_1">dass <rs type="fn" role="recipient"><rs type="person" ref="pe__margarethe_QGW_II_II_3549">sie</rs> und <rs type="person" ref="pe__paul_unger_QGW_II_II_3549">ihr <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3549">Bruder</roleName>
                           Paul</rs></rs>
                     <rs type="fn" role="issuer">von <rs type="person" ref="pe__ursula_QGW_II_II_3549_a">Ursulen, vaterhalben ihrer <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3549"><add>vaterhalben</add> swester</roleName>
                           <roleName type="kin" corresp="pe__paul_unger_QGW_II_II_3549"><add>vaterhalben swester</add></roleName>, weilent auch Petern des
                           Unger <roleName type="kin" corresp="pe__peter_unger_StB_I_171">tochter</roleName>
                           <roleName type="dead">seligen</roleName></rs>,</rs>
                     <rs type="fn" role="transactiongood_I"><measure>120 lb dn.</measure></rs>
                     <triggerstring n="disp">geerbt haben</triggerstring>,</rs>
                  <rs type="event" ref="ev__QGW_II_II_3549_men_2">welche <measure><add>120 lb
                           dn.</add></measure>
                     <rs type="fn" role="issuer"><rs type="person" ref="pe__michael_rothut_QGW_II_II_3549">ihr <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3549">steuffater</roleName>
                           <roleName type="kin" corresp="pe__paul_unger_QGW_II_II_3549"><add>steuffater</add></roleName> Michel Rothut <roleName type="dead">seliger</roleName></rs></rs> für sie <triggerstring n="disp">eingenommen und</triggerstring>
                     <rs type="fn" role="transactiongood_I">auf <rs type="place" ref="pl__wien-immo_haarmarkt_13"><roleName type="owner" corresp="pe__michael_rothut_QGW_II_II_3549">seinem</roleName> Hause,
                           genant zum Stern, <roleName type="topo" corresp="pl__wien-haarmarkt">gelegen am Harmarkcht</roleName>
                           <roleName type="topo" corresp="pl__wien-immo_haarmarkt_14">zenagst</roleName>
                           <rs type="place" ref="pl__wien-immo_haarmarkt_14"><roleName type="owner" corresp="pe__johann_aczinger_QGW_II_II_3549"><rs type="person" ref="pe__johann_aczinger_QGW_II_II_3549">Hannsen
                                 Aczinger</rs></roleName> haus</rs></rs>,</rs> in der stat gruntpuch
                        <rs type="fn" role="recipient"><rs type="person" ref="pe__paul_unger_QGW_II_II_3549"><add>ihnen</add></rs>
                        <rs type="person" ref="pe__margarethe_QGW_II_II_3549"><add>ihnen</add></rs></rs>
                     <triggerstring n="disp">verphendt hat</triggerstring>.</rs>
                  <rs type="event" ref="ev__QGW_II_II_3549_men_3">Da <rs type="fn" role="issuer"><rs type="person" ref="pe__paul_unger_QGW_II_II_3549">Paul <roleName type="dead">gestorben</roleName></rs></rs>
                     <triggerstring n="disp"><add>gestorben</add> ist</triggerstring>, so sei <rs type="fn" role="transactiongood_I">der gesammte Betrag <measure><add>120 lb
                              dn.</add></measure></rs>
                     <triggerstring n="disp">an</triggerstring>
                     <rs type="fn" role="recipient"><rs type="person" ref="pe__margarethe_QGW_II_II_3549">sie</rs></rs>
                     <triggerstring n="disp">gefallen</triggerstring>,</rs>
                  <triggerstring n="disp">und</triggerstring> sie <triggerstring n="disp">bestätigt</triggerstring>, dass <rs type="fn" role="recipient"><rs type="person" ref="pe__erhard_mistelbekcher_QGW_II_II_3549">Erhart Mistelbekcher,
                           <roleName type="occ" corresp="org__wien">purger</roleName> zu
                        Wienn, auch ihr <roleName type="kin" corresp="pe__ursula_QGW_II_II_3549_a">steuffater</roleName></rs>, und <rs type="person" ref="pe__ursula_QGW_II_II_3549_b"><roleName type="title">frau</roleName>
                        Ursula, sein <roleName type="kin" corresp="pe__erhard_mistelbekcher_QGW_II_II_3549">hausfrau</roleName>,
                        ihre <roleName type="kin" corresp="pe__ursula_QGW_II_II_3549_a">rechtte
                           muter</roleName></rs>,</rs> ihr <rs type="fn" role="transactiongood_II">denselben <measure><add>120 lb dn.</add></measure></rs>
                  <triggerstring n="disp">entrichtet haben</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3549"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__wolfgang_holnbrunner_QGW_II_II_3079">Wolfgangs Hollenbrunner <roleName type="occ" corresp="org__wien"><add>burger</add></roleName></rs> und <rs type="person" ref="pe__georg_von_nikolsburg_QGW_II_II_2373">Jörgen von Nicolspurg, baid
                           <roleName type="occ" corresp="org__wien">burger</roleName> zu
                        Wienn</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: quittung per Peter Unger kinder de causa 120 lb dn. nach laut aussag im
               statpuch zu Wienn. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>