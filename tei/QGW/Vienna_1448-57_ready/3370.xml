                  <rs type="person" ref="pe__ursula_QGW_II_II_3370">Ursulen, seiner <roleName type="kin" corresp="pe__georg_plesser_QGW_II_II_3370">hausfraun</roleName></rs>, und <rs type="person" ref="pe__johann_valich_QGW_II_II_3370">Hannsen Walich, irs <roleName type="kin" corresp="pe__ursula_QGW_II_II_3370">bruder</roleName></rs>, <rs type="fn" role="other"><triggerstring n="fn"><add>hincz</add> zu</triggerstring>
