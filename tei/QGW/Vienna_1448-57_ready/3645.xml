        <date when="14551007">1455 X 07</date>
        <origDate instant="false">Geben zu Salczburg an eritag vor sannd Dionisien tag, anno domini
          etc. quinquagesimo quinto. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03645_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03645_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
          <rs type="event" ref="ev__QGW_II_II_3645"><rs type="fn" role="issuer"><rs type="person" ref="pe__sigmund_QGW_II_II_3475">Sigmund, <roleName type="occ" corresp="org__salerno-erzdioezese">erczbischove</roleName> zu Salczburg</rs>,</rs>
            <triggerstring n="disp">an</triggerstring>
            <rs type="fn" role="recipient"><rs type="org" ref="org__wien">Bürgermeister und Rath der
                Stadt zu Wien</rs>.</rs>
            <triggerstring n="disp">Auf ihre Zuschrift wegen</triggerstring> der <rs type="fn" role="other"><triggerstring n="fn">zwischen</triggerstring>
              <rs type="person" ref="pe__johann_lautterpach_SB_CD_01842"><roleName type="title">maister</roleName> Hannsen Lautterbach</rs></rs>
            <rs type="fn" role="other"><triggerstring n="fn">und <add>zwischen</add></triggerstring>
              <rs type="person" ref="pe__michael_wanck_QGW_II_II_3645">Micheln Wanck, ihrem
                  <roleName type="occ" corresp="org__wien">mitburger</roleName></rs>,</rs>
            <triggerstring n="disp">bestehenden zwitracht</triggerstring> habe er den Ersteren vorgeladen.
            Dieser habe ihm mitgetheilt, dass es ihm jetzt unmöglich sei, selbst nach Wien zu
            kommen, dass <rs type="event" ref="ev__QGW_II_II_3645_men_1"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_lautterpach_SB_CD_01842">er</rs></rs> aber schon vorher <rs type="fn" role="recipient">dem <rs type="person" ref="pe__heinrich_senftleben_QGW_II_II_3263">in Wien <roleName type="title_ref" corresp="pl__wien">lebenden</roleName>
                  <roleName type="title">maister</roleName> Hainrichen Senftleben</rs></rs>
              <triggerstring n="disp">eine Vollmacht zur Austragung der streitigen Angelegenheit
                ertheilt habe</triggerstring></rs>.</rs>
        </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>