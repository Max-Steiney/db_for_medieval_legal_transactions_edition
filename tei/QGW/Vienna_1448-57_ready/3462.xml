            <placeName>Wien</placeName>
            <date when="14520324">1452 III 24</date>
            <origDate instant="false">zu Wienn, an freitag vor dem suntag Judica in der
               Vassten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03462_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03462_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3462"><rs type="fn" role="issuer"><rs type="person" ref="pe__georg_schuchler_QGW_II_II_3272">Jorg Schuchler,
                           <roleName type="occ" corresp="org__wien">statrichter</roleName> zu
                        Wienn</rs>,</rs>
                  <triggerstring n="disp">beurkundet, dass vor ihm in der Bürgerschranne</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="pe__johann_koll_SB_CD_01565"><roleName type="title">her</roleName> Hanns Koll, <roleName type="occ" corresp="org__wien-st_stephan">korherr</roleName> zu sand Stephan zu
                        Wienn, <roleName type="occ" corresp="org__wien-st_philipp_und_st_jakob_kapelle-altar_st_maria">capplan</roleName> und <roleName type="occ" corresp="org__wien-st_philipp_und_st_jakob_kapelle-altar_st_maria">verweser</roleName> Unserr Lieben Fraun altars, gelegen in sand Philipps
                        und sand Jacobs cappellen im Kollnerhof daselbs</rs>, <triggerstring n="fn">mit
                        Vorsprechen</triggerstring></rs> nachgewiesen habe, <rs type="event" ref="ev__QGW_II_II_3462_men_1">wie <rs type="fn" role="issuer">er</rs> einst
                        <rs type="fn" role="transactiongood_III">auf <rs type="place" ref="pl__wien-immo_dominikaner_4"><roleName type="owner" corresp="pe__johann_gruber_QGW_II_II_3462">weilent <rs type="person" ref="pe__johann_gruber_QGW_II_II_3462">Hannsen des Gruber <roleName type="dead"><add>wittiben</add></roleName></rs></roleName> und
                              <roleName type="owner" corresp="pe__margarethe_QGW_II_II_3462"><add>weilent</add>
                              <rs type="person" ref="pe__margarethe_QGW_II_II_3462">Margrethen,
                                 seiner <roleName type="kin" corresp="pe__johann_gruber_QGW_II_II_3462">wittiben</roleName>,
                                 die darnach <rs type="person" ref="pe__andreas_gruber_QGW_II_II_3462">Andren Gruber</rs> auch
                                    <roleName type="kin" corresp="pe__andreas_gruber_QGW_II_II_3462">elichen</roleName> hat gehabt</rs></roleName>, haus, <roleName type="topo" corresp="pl__wien-dominikaner">gelegen bei den Predigern
                              daselbs</roleName> zunagst <rs type="place" ref="pl__wien-immo_dominikaner_5">dem Türndlein</rs>
                           <roleName type="topo" corresp="pl__wien-immo_dominikaner_5"><add>zunagst</add> mit aim tail</roleName></rs>,</rs>
                     <rs type="fn" role="transactiongood_III">umb <measure>4 lb 3 sh. dn.</measure>
                        <triggerstring n="fn"><add>gelts versessens purkrechts</add></triggerstring></rs>
                     <triggerstring n="disp">gelts versessens purkrechts und die darauf ertheilten
                        zwispild geklagt und das darauf mit dem rechten erlangt und behabt
                        hiet</triggerstring>.</rs>
                  <rs type="event" ref="ev__QGW_II_II_3462_men_2">Nun habe <rs type="fn" role="issuer"><rs type="person" ref="pe__johann_koll_SB_CD_01565">der
                           Chorherr</rs></rs>
                     <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_dominikaner_4">das Haus</rs></rs>
                     <rs type="fn" role="other"><triggerstring n="fn">nach Aussage</triggerstring> der <rs type="person" ref="pe__georg_von_nikolsburg_QGW_II_II_2373">Wiener
                              <roleName type="occ" corresp="org__wien">Bürger</roleName>
                           Jorgen von Nicolspurg</rs> und <rs type="person" ref="pe__thomas_praitenweidacher_QGW_II_II_3462"><roleName type="occ" corresp="org__wien"><add>Bürger</add></roleName>
                           Thoman Praitenweidacher</rs></rs>
                     <rs type="fn" role="transactiongood_II">um <measure>80 lb dn.</measure></rs>
                     <triggerstring n="disp">verkauft</triggerstring>, und sei es um diesen Betrag <rs type="fn" role="other"><rs type="person" ref="pe__agnes_QGW_II_II_3462">Agnesen, <rs type="person" ref="pe__wolfgang_winkchler_QGW_II_II_3434">Wolfgangen des Winkler, <roleName type="occ" corresp="org__klosterneuburg">burger</roleName> zu
                              Klosterneunburg</rs>
                           <roleName type="kin" corresp="pe__wolfgang_winkchler_QGW_II_II_3434">hausfraun</roleName>, <rs type="person" ref="pe__thomas_lienfelder_QGW_II_II_3400">Thoman des Lienfelder
                                 <roleName type="dead">seligen</roleName></rs>
                           <roleName type="kin" corresp="pe__thomas_lienfelder_QGW_II_II_3400">tochter</roleName>
                           <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3462"><add>nächsten Erben</add></roleName></rs>, in geschrift und <rs type="person" ref="pe__andreas_schoenprugker_QGW_II_II_3376">Andren
                           Schönprugker, <roleName type="occ" corresp="org__wien">burger</roleName> zu Wienn, <roleName type="rep" corresp="pe__jakob_lienfelder_QGW_II_II_3400">anstat</roleName> und
                           als <roleName type="rep" corresp="pe__jakob_lienfelder_QGW_II_II_3400">gerhaben</roleName>
                           <rs type="person" ref="pe__jakob_lienfelder_QGW_II_II_3400">Jacoben
                              Lienfelder, der benanten <rs type="person" ref="pe__agnes_QGW_II_II_3462"><roleName type="title">fraun</roleName> Agnesen</rs>
                              <roleName type="kin" corresp="pe__agnes_QGW_II_II_3462">bruder</roleName>, der noch ungevogt ist <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3462"><add>nächsten
                                 Erben</add></roleName></rs></rs>, und <rs type="person" ref="pe__katharina_QGW_II_II_3376"><roleName type="title">fraun</roleName> Kathrein, des jeczgenanten Schönprugker <roleName type="kin" corresp="pe__andreas_schoenprugker_QGW_II_II_3376">hausfraun</roleName>, <rs type="person" ref="pe__michael_lienfelder_QGW_II_II_3376">weilent Micheln des
                              Lienfelder, des obgenanten Thomans Lienfelder seligen <roleName type="kin" corresp="pe__thomas_lienfelder_QGW_II_II_3400">bruders</roleName></rs>, <roleName type="kin" corresp="pe__michael_lienfelder_QGW_II_II_3376">tochter</roleName>,
                           als <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3462">nächsten
                              Erben</roleName> ihrer <rs type="person" ref="pe__margarethe_QGW_II_II_3462"><roleName type="dead">verstorbenen</roleName>
                              <roleName type="kin" corresp="pe__agnes_QGW_II_II_3462">Muhme</roleName>
                              <roleName type="kin" corresp="pe__katharina_QGW_II_II_3376"><add>Muhme</add></roleName>
                              <roleName type="kin" corresp="pe__jakob_lienfelder_QGW_II_II_3400"><add>Muhme</add></roleName> Mavgreten der Gruberin</rs></rs>
                        <triggerstring n="fn">angeboten worden</triggerstring>.</rs></rs> Da diese <rs type="fn" role="other"><triggerstring n="fn">laut eines</triggerstring> von <rs type="person" ref="pe__martin_krug_QGW_II_II_3462">dem Klosterneuburger
                           <roleName type="occ" corresp="org__klosterneuburg">Stadtrichter</roleName> Mert Krug</rs>
                     <triggerstring n="fn">eingelangten santpriefs</triggerstring></rs> und nach Aussage
                  des gesworn fronpoten die Lösung verweigern, so <triggerstring n="disp">gestattet er
                     die Fertigung des Verkaufes</triggerstring>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>