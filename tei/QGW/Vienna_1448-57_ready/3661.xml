            <date when="14560221">1456 II 21</date>
            <origDate instant="false">zu Wienn, an sambstag vor dem suntag, daran man singet
               Reminiscere in der Vasten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03661_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03661_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3661"><rs type="fn" role="issuer"><rs type="person" ref="pe__wolfgang_schmied_QGW_II_II_3661">Wolfgang, <roleName type="prof">smid</roleName>
                        <roleName type="title_ref" corresp="pl__grinzing"><add>gesessen
                           zu</add></roleName></rs>, und <rs type="person" ref="pe__paul_hopher_QGW_II_II_3661">Paul Hopher, baid <roleName type="title_ref" corresp="pl__grinzing">gesessen zu</roleName>
                        Grinczing</rs>,</rs>
                  <triggerstring n="disp">nehmen</triggerstring>
                  <rs type="fn" role="recipient">von <rs type="person" ref="pe__heinrich_senftleben_QGW_II_II_3263"><roleName type="title">hern</roleName> Hainreichen Senfftleben, <roleName type="occ" corresp="org__breslau-dioezese">techant</roleName> und <roleName type="occ" corresp="org__breslau-dioezese">tumbherr</roleName> zu
                        Bressla, <roleName type="occ" corresp="org__wien-st_maria_im_rathaus">obrister caplan</roleName> Unser Fraun cappellen, in der burger Rathaus
                        zu Wienn gelegen, hern Otten und Haymen stifftung</rs>,</rs>
                  <rs type="fn" role="transactiongood_II"><rs type="place" ref="pl__grinzing-immo_13">einen Weingarten, genant der Scherg, <roleName type="topo" corresp="pl__grinzing">gelegen im Mugkental</roleName>, des
                        dreu virtail ist, <roleName type="topo" corresp="pl__grinzing-immo_14">zenagst</roleName>
                        <rs type="place" ref="pl__grinzing-immo_14"><roleName type="owner" corresp="pe__ulrich_matzleinsdorfer_QGW_II_II_3362">Ulreichs
                              Meczleinstorffer</roleName> weingarten</rs>, <rs type="event" ref="ev__QGW_II_II_3661_men_1"><rs type="fn" role="issuer">von <rs type="place" ref="pl__grinzing-immo_13">dem</rs> man</rs>
                           <rs type="fn" role="recipient"><rs type="org" ref="org__klosterneuburg-augustiner_chorherren">Unserr Fraun
                                 goczhauss zu Klosterneunburg</rs></rs>
                           <rs type="fn" role="transactiongood_I"><measure>7½ virtail
                                 weins</measure>
                              <triggerstring n="fn">ze perkchrecht</triggerstring></rs> und <rs type="fn" role="transactiongood_I"><measure>2½ dn.</measure>
                              <triggerstring n="fn">zu Voitrecht</triggerstring></rs>
                           <triggerstring n="disp"><add>perkchrecht</add>
                              <add>Voitrecht</add> dient</triggerstring></rs></rs>,</rs>
                  <triggerstring n="disp">auf Lebenszeit in Bestand und verpflichten sich</triggerstring>,
                  dem Kaplan <rs type="fn" role="transactiongood_I">während der ersten sieben Jahre
                     jedes jars den vierden emer most und darnach alle jar von siben emern zwen emer
                     most bei der press aus dem grannt zu reichen</rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3661">Besiegelt mit den Siegeln <rs type="person" ref="pe__ulrich_hirssauer_QGW_II_II_3239">Ulreichs Hirssauer, <roleName type="occ" corresp="org__wien">statschreiber</roleName> zu Wienn</rs>, und
                     <rs type="person" ref="pe__simon_von_eslarn_QGW_II_II_3263">Simons von Eslorn,
                        <roleName type="occ" corresp="org__wien">burger</roleName>
                     daselbs</rs>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>