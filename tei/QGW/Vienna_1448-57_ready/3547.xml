   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__SB_CD_01853"><rs type="fn" role="issuer"><rs type="person"
                        ref="pe__ulrich_parschalch_QGW_II_II_3547">Ulreich Parschalch, der <roleName
                           type="prof">pinter</roleName>, <roleName type="title_ref"
                           corresp="pl__wien-stubentor">gesessen vor</roleName> Stubentor zu
                        Wienn</rs>, und <rs type="person" ref="pe__agnes_QGW_II_II_3547">Agnes, sein
                           <roleName type="kin" corresp="pe__ulrich_parschalch_QGW_II_II_3547"
                           >hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">verkaufen <add>geltes purkrechts</add></triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> hern
                     Niclasen Teschler, burgermaister, und des Rathes</rs>
                  <rs type="fn" role="transactiongood_I"><measure>6 lb dn.</measure>
                     <triggerstring n="fn">geltes purkrechts</triggerstring> (ablösbar um 60 lb dn.) auf
                        <rs type="place" ref="pl__wien-immo_stubentor_12"><roleName type="owner"
                           corresp="pe__ulrich_parschalch_QGW_II_II_3547">ihrem</roleName>
                        <roleName type="owner" corresp="pe__agnes_QGW_II_II_3547"
                           ><add>ihrem</add></roleName> Hause, <roleName type="topo"
                           corresp="pl__wien-stubentor">gelegen daselbs vor Stubentor</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_stubentor_11"
                           >zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_stubentor_11"><roleName type="owner"
                              corresp="pe__martin_verber_QGW_II_II_3389">weilent Merten, des
                              verber</roleName>, haus</rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_II">um <measure>60 lb dn.</measure>, <rs
                        type="event" ref="ev__QGW_II_II_3547_men_1_abloese"><rs type="fn"
                           role="transactiongood_I">die <measure><add>6 lb dn.</add></measure>
                           <triggerstring n="fn"><add>geltes purkrechts</add></triggerstring></rs>
                        <triggerstring n="disp">emaln gelegen gewesen sind</triggerstring>
                        <rs type="fn" role="issuer">auf <rs type="place"
                              ref="pl__wien-immo_unter_den_sattlern_8"><roleName type="owner"
                                 corresp="pe__stephan_vindenstain_QGW_II_II_3547"><rs type="person"
                                    ref="pe__stephan_vindenstain_QGW_II_II_3547">Stephans
                                    Vindenstain, des <roleName type="prof"
                                 >satler</roleName></rs></roleName>, haus</rs>,</rs> die man damit
                        darab <triggerstring n="disp">geledigt und gelost hat</triggerstring>,</rs></rs>
                  <rs type="fn" role="recipient">dem <rs type="person"
                        ref="pe__johann_prenner_QGW_II_II_3547"><roleName type="prof"
                           >Priester</roleName>
                        <roleName type="title">hern</roleName> Hannsen Prenner, <roleName type="occ"
                           corresp="org__wien-st_stephan-kapelle_st_bartholomaeus_st_georg-altar_eltausend_jungfrauen-messe_fuechsel_mauttinger"
                           >caplan</roleName> der <rs type="event" ref="ev__QGW_II_II_3547_men_2"
                           >ewigen <triggerstring n="disp">mess</triggerstring>, die <rs type="fn"
                              role="issuer">weilent <rs type="person"
                                 ref="pe__michael_fuechsel_QGW_II_II_3547">Michel Füchsel</rs> und
                                 <rs type="person" ref="pe__johann_mauttinger_QGW_II_II_3156">Hanns
                                 Mauttinger</rs></rs>
                           <rs type="fn" role="recipient">auf <rs type="org"
                                 ref="org__wien-st_stephan-kapelle_st_bartholomaeus_st_georg-altar_eltausend_jungfrauen"
                                 >der Aindleftausent Maid altar dacz sand Stephan zu Wienn</rs></rs>
                           <triggerstring n="disp">gestifft haben</triggerstring></rs></rs>, zu <rs
                        type="org"
                        ref="org__wien-st_stephan-kapelle_st_bartholomaeus_st_georg-altar_eltausend_jungfrauen-messe_fuechsel_mauttinger"
                        >dieser Messe</rs>.</rs>
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__SB_CD_01853"><rs type="fn" role="witness">Besiegelt mit dem
                     Siegel des <rs type="person" ref="pe__ulrich_parschalch_QGW_II_II_3547"
                        >Ausstellers</rs>, dem <rs type="org" ref="org__wien">städtischen
                        Grundsiegel</rs> und dem Siegel <rs type="person"
                        ref="pe__simon_von_eslarn_QGW_II_II_3263">des Wiener <roleName type="occ" corresp="org__wien">Bürgers</roleName> Simon von
                        Eslorn</rs>.</rs></rs>
            </p>
         </div>
