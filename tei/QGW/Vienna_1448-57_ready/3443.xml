            <origDate instant="false">zu Wienn, an mitichen nach sand Margreten tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03443_a_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03443_a_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3443"><rs type="fn" role="issuer"><rs type="person" ref="pe__pankraz_binder_SB_CD_3443">Pangrecz, <roleName type="prof">pintter</roleName>, <roleName type="title_ref" corresp="pl__grinzing">gesessen zu</roleName> Grinczing</rs>,</rs>
                  <triggerstring n="disp">nimmt</triggerstring>
                  <rs type="fn" role="recipient">von <rs type="person" ref="pe__heinrich_senftleben_QGW_II_II_3263"><roleName type="title">maister</roleName> Hainreichen Senftleben, <roleName type="occ" corresp="org__wien-st_maria_im_rathaus">obristen kapplan</roleName> und
                           <roleName type="occ" corresp="org__wien-st_maria_im_rathaus">verweser</roleName> Unser Fraun kapellen, hern Otten und Haimen
                        stifftung, gelegen in der burger Rathaus</rs>,</rs>
                  <rs type="fn" role="transactiongood_II"><rs type="place" ref="pl__grinzing-immo_1">einen <roleName type="owner" corresp="org__wien-st_maria_im_rathaus">zu der
                           Kapelle gehörigen</roleName> Weingarten, <roleName type="topo" corresp="pl__grinzing">gelegen daselbs [333] zu Grinczing</roleName>, des
                        ain halbs jeuch ist, genant der Hefenstreit, <roleName type="topo" corresp="pl__grinzing-immo_2">zenagst</roleName>
                        <rs type="place" ref="pl__grinzing-immo_2">des von Rosenberg weingarten</rs>
                     </rs>,</rs>
                  <triggerstring n="disp">auf neun Jahre</triggerstring> gegen <triggerstring n="fn">jährliche Leistung</triggerstring> des <measure>vierten Eimers Most</measure> bei
                  der press aus dem grannt <triggerstring n="disp">in Bestand</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3443">Besiegelt mit den Siegeln <rs type="person" ref="pe__ulrich_hirssauer_QGW_II_II_3239">Ulreichs Hirssauer, <roleName type="occ" corresp="org__wien">statschreiber</roleName> zu Wienn</rs>, und
                     <rs type="person" ref="pe__wolfgang_holnbrunner_QGW_II_II_3079">Wolfgangs
                     Holnbrunner, <roleName type="occ" corresp="org__wien">burger</roleName>
                     daselbs</rs>.</rs>
            </p></div><div type="nota"><p>Indorsat: In Christi nomine, amen! Littera Pangracii, doleatoris, super vinea
               Hebenstreit in Grinczing ½ jug. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>