            <date when="14520131">1452 I 31</date>
            <origDate instant="false">zu Wienn, an montag vor Unser Lieben Fraun tag der
               Liechtmess.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03458_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03458_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__SB_CD_00983"><rs type="fn" role="issuer"><rs type="person" ref="pe__georg_notleich_QGW_II_II_3458">Jorg Notleich, der
                           <roleName type="prof">smelczer</roleName>, <roleName type="title_ref" corresp="pl__wien-werdertor">gesessen vor</roleName> Werdertor zu Wienn
                           <roleName type="rep" corresp="pe__georg_notleich_QGW_II_II_3458"><add>für</add></roleName>
                        <roleName type="rep" corresp="pe__wolfgang_notleich_QGW_II_II_3458"><add>für</add></roleName>
                        <roleName type="rep" corresp="pe__barbara_QGW_II_II_3458"><add>für</add></roleName>
                        <roleName type="rep" corresp="pe__johann_notleich_QGW_II_II_3458"><add>für</add></roleName>
                        <roleName type="rep" corresp="pe__sebastian_notleich_QGW_II_II_3458"><add>für</add></roleName></rs>,</rs>
                  <triggerstring n="disp">verkauft <add>geltes purkrechts</add></triggerstring> für sich
                  und seine unmündigen <rs type="person" ref="pe__sebastian_notleich_QGW_II_II_3458"><roleName type="kin" corresp="pe__georg_notleich_QGW_II_II_3458">Kinder</roleName>
                     <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3458"><add>Kinder</add></roleName> Sebastian</rs>, <rs type="person" ref="pe__johann_notleich_QGW_II_II_3458"><roleName type="kin" corresp="pe__georg_notleich_QGW_II_II_3458"><add>Kinder</add></roleName>
                     <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3458"><add>Kinder</add></roleName> Hännslen</rs>, <rs type="person" ref="pe__barbara_QGW_II_II_3458"><roleName type="kin" corresp="pe__georg_notleich_QGW_II_II_3458"><add>Kinder</add></roleName>
                     <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3458"><add>Kinder</add></roleName> Barbaren</rs> und <rs type="person" ref="pe__wolfgang_notleich_QGW_II_II_3458"><roleName type="kin" corresp="pe__georg_notleich_QGW_II_II_3458"><add>Kinder</add></roleName>
                     <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3458"><add>Kinder</add></roleName> Wolfgangen</rs>, aus seiner früheren Ehe mit
                     <rs type="person" ref="pe__margarethe_QGW_II_II_3458">seiner <roleName type="kin" corresp="pe__georg_notleich_QGW_II_II_3458">hausfraun</roleName>
                     Margreten <roleName type="dead">seligen</roleName></rs>, <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__oswald_reicholf_QGW_II_II_3314"><roleName type="title">hern</roleName> Oswalts Reicholf, <roleName type="occ" corresp="org__wien">burgermaister</roleName></rs>, und <rs type="org" ref="org__wien">des Rathes</rs></rs>
                  <rs type="fn" role="transactiongood_I"><measure>3 lb dn.</measure>
                     <triggerstring n="fn">geltes purkrechts</triggerstring> (ablösbar) auf <rs type="place" ref="pl__wien-immo_werdertor_8"><roleName type="owner" corresp="pe__georg_notleich_QGW_II_II_3458">seinem</roleName> Hause, <rs type="event" ref="ev__QGW_II_II_3458_men_1"><rs type="fn" role="transactiongood_II"><rs type="place" ref="pl__wien-immo_werdertor_8">das</rs></rs>
                           <rs type="fn" role="recipient"><rs type="person" ref="pe__georg_notleich_QGW_II_II_3458">er</rs> mit <rs type="person" ref="pe__margarethe_QGW_II_II_3458">seiner ersten
                                    <roleName type="kin" corresp="pe__georg_notleich_QGW_II_II_3458">Frau</roleName></rs></rs>
                           <triggerstring n="disp">gekauft</triggerstring></rs>
                        <rs type="event" ref="ev__SB_CD_00979">und darnach Jörgen von Ernstprunn
                           versaczt hatte</rs>, <roleName type="topo" corresp="pl__wien-werdertor">gelegen vor Werdertor</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_werdertor_6">gegen
                              <add>uber</add></roleName>
                        <rs type="place" ref="pl__wien-immo_werdertor_6"><roleName type="owner" corresp="pe__johann_een_QGW_II_II_3458"><rs type="person" ref="pe__johann_een_QGW_II_II_3458">Hannsen Een, des <roleName type="prof">flöczer</roleName></rs></roleName>, haus</rs> uber
                           <roleName type="topo" corresp="pl__wien-st_johann_vor_werdertor-freihof">zenagst</roleName>
                        <rs type="place" ref="pl__wien-st_johann_vor_werdertor-freihof">dem
                           freithof, der zu sand Johanns capellen daselbs gehoret</rs>
                     </rs>,</rs>
                  <rs type="fn" role="transactiongood_II">um <measure>24 lb dn.</measure>, <rs type="event" ref="ev__QGW_II_II_3458_men_3"><rs type="fn" role="transactiongood_I">die <measure><add>24 lb dn.</add></measure></rs>
                        <triggerstring n="disp">emaln</triggerstring>
                        <rs type="fn" role="issuer">auf <rs type="place" ref="pl__wien-immo_graben_5"><roleName type="owner" corresp="pe__wolfgang_pillichdorfer_QGW_II_II_3458">Wolfgangen von
                                 Pilchdorf</roleName> haus <roleName type="topo" corresp="pl__wien-graben">am Graben</roleName></rs></rs>
                        <triggerstring n="disp">gelegen gewesen und</triggerstring>
                        <rs type="fn" role="recipient">dem <rs type="person" ref="pe__georg_von_ernstbrunn_QGW_II_II_3458">obgenanten Jorgen von
                              Ernstprunn</rs></rs>
                        <triggerstring n="disp">an seiner geltschuld gevallen
                     sind</triggerstring>,</rs></rs>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_trautmann_QGW_II_II_3458"><roleName type="title">hern</roleName> Hannsen Trautman, <roleName type="occ" corresp="org__wien-st_stephan-altar_allerheiligen-messe_staatz">kaplan</roleName>
                        <rs type="org" ref="org__wien-st_stephan-altar_allerheiligen-messe_staatz">der <rs type="event" ref="ev__QGW_II_II_3458_men_4"><triggerstring n="disp">mess</triggerstring>, die <rs type="fn" role="issuer"><rs type="person" ref="pe__heinrich_von_staatz_QGW_II_II_3458">Hainreich, <roleName type="prof">wachsgiesserin</roleName>, <rs type="person" ref="pe__stephan_von_staatz_QGW_II_II_3458">Steffans von Stêcz</rs>
                                    <roleName type="kin" corresp="pe__stephan_von_staatz_QGW_II_II_3458" cert="unknown">tochter</roleName></rs>,</rs>
                              <rs type="fn" role="recipient">auf <rs type="org" ref="org__wien-st_stephan-altar_allerheiligen">Allerheiligen
                                    altar zu sand Steffan zu Wienn</rs></rs>
                              <triggerstring n="disp">gestifft hat</triggerstring></rs></rs></rs>, zu <rs type="org" ref="org__wien-st_stephan-altar_allerheiligen-messe_staatz">dieser Messe</rs>.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__SB_CD_00983"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="pe__wilhelm_mertinger_QGW_II_II_3715">Wiener
                           <roleName type="occ" corresp="org__wien">Bürgers</roleName> Wilhalm
                        Merttinger</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>