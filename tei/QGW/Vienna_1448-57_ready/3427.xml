   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3427"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__magdalena_QGW_II_II_3427"><roleName type="title"
                           >Swester</roleName> Magdalen, <roleName type="occ"
                           corresp="org__wien-st_agnes_auf_der_himmelpforte">priorinn</roleName> des
                        fraunklosters zu der Himelporten zu Wienn</rs>, und <rs type="org"
                        ref="org__wien-st_agnes_auf_der_himmelpforte">der convent gemain
                        daselbs</rs></rs>
                  <triggerstring n="disp">bestätigen</triggerstring>, <rs type="event"
                     ref="ev__QGW_II_II_3427_men_1">dass <rs type="fn" role="issuer"><rs
                           type="person" ref="pe__barbara_SB_CD_00237"><roleName type="title"
                              >frau</roleName> Barbara, <rs type="person"
                              ref="pe__stephan_wirsing_QGW_II_II_3321"><roleName type="title"
                                 >hern</roleName> Stephans des Wirsing <roleName type="dead"
                                    ><add>witib</add></roleName></rs>
                           <roleName type="kin" corresp="pe__stephan_wirsing_QGW_II_II_3321"
                              >witib</roleName>
                           <roleName type="dead">selige</roleName></rs>,</rs>
                     <rs type="fn" role="recipient"><rs type="org"
                           ref="org__wien-st_agnes_auf_der_himmelpforte">ihnen</rs></rs>
                     <rs type="fn" role="transactiongood_I"><rs type="place"
                           ref="pl__wien-immo_lichtensteg_4"><roleName type="owner"
                              corresp="pe__barbara_SB_CD_00237">ihre</roleName> fleischpankch,
                              <roleName type="topo" corresp="pl__wien-lichtensteg">bei dem
                              Liechtensteg gelegen</roleName>, <roleName type="topo"
                              corresp="pl__wien-taschnergasse">und ist die ander von dem ort, als
                              man aus dem Taschnergesslein in den Liechtensteg get</roleName>,
                              <roleName type="topo" corresp="pl__wien-immo_lichtensteg_6">zenagst
                                 <add>an ainem tail</add></roleName>
                           <rs type="place" ref="pl__wien-immo_lichtensteg_6"><roleName type="owner"
                                 corresp="pe__genkerlin_facs_442_TextRegion_1655808542456_646">der
                                 Gengkerlin</roleName> pankch</rs> an ainem tail <roleName
                              type="topo" corresp="pl__wien-immo_lichtensteg_5">und an dem andern
                              zenagst</roleName>
                           <rs type="place" ref="pl__wien-immo_lichtensteg_5"><roleName type="owner"
                                 corresp="pe__heinrich_von_orth_QGW_II_II_3427">weilnt <rs
                                    type="person" ref="pe__heinrich_von_orth_QGW_II_II_3427"
                                    >Hainreichs von Ortt</rs></roleName>
                        fleischpankch</rs></rs></rs>
                     <triggerstring n="disp">zu hau ir sel geschafft</triggerstring>, <rs type="fn"
                        role="other"><rs type="person" ref="pe__konrad_hoelczler_QGW_II_II_3350"
                              ><roleName type="title">her</roleName> Kunrat Holczler, <roleName
                              type="occ" corresp="org__wien">burgermaister</roleName></rs>, und <rs
                           type="org" ref="org__wien">der Rath</rs>
                        <triggerstring n="fn">sie darum in ir gruntbuch nucz und gewer haben schreiben
                           lassen</triggerstring>,</rs></rs>
                  <triggerstring n="disp">und verpflichten sich, für all steur und
                     mitleidung</triggerstring> von dieser Bank jährlich an sand Jorgen tag <rs
                     type="fn" role="recipient">zu <rs type="org" ref="org__wien">der Stadt</rs>
                     Handen</rs>
                  <rs type="fn" role="transactiongood_I"><measure>1 lb dn.</measure></rs>
                  <triggerstring n="disp">zu reichen</triggerstring>.</rs>
            </p>
         </div>
         <div type="nota">
            <p>Abschrift des 18. Jahrhunderts liegt bei.</p>
         </div>
