      <text>
            <body>
                  <div type="abstract" resp="kg">
                        <p>
                              <rs type="event" ref="ev__QGW_II_II_3365"><rs type="fn" role="issuer"
                                                ><rs type="person"
                                                ref="pe__simon_von_leuchtenburg_QGW_II_II_3365"
                                                >Simel von Leuchtenburgk, <roleName type="title_ref" corresp="pl__voettau">herr</roleName> zu
                                                Vetau</rs>,</rs>
                                    <triggerstring n="disp">an</triggerstring>
                                    <rs type="fn" role="recipient"><rs type="org" ref="org__wien"
                                                >Bürgermeister und Rath zu Wien</rs>.</rs>
                                    <rs type="fn" role="other"><rs type="person"
                                                ref="pe__eustachius_neidekar_QGW_II_II_3365">Sein
                                                  <roleName type="occ"
                                                  corresp="pe__simon_von_leuchtenburg_QGW_II_II_3365"
                                                  >Diener</roleName> Eustachius der Neidekar</rs>
                                          <triggerstring n="fn">habe ihm geklagt</triggerstring></rs>,
                                    dass sie ihm ein Haus, des sein mutter rechter erb ist und im
                                    das lediklich uber hat geben, abgesprochen haben. Er <triggerstring
                                          n="disp">fordert</triggerstring> sie auf, diesen unbilligen
                                    Spruch zurückzunehmen und dem Genannten zu seinem Besitze zu
                                    verhelfen, widrigenfalls er im darinnen bei müsst besteenn und
                                    helfen als seinem diener.</rs>
                        </p>
