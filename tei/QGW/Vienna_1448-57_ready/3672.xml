   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3672"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__christian_wissinger_QGW_II_II_3328">Kristan
                        Wissinger, des <roleName type="occ" corresp="org__wien">rats</roleName> der
                        stat ze Wienn</rs>, und <rs type="person" ref="pe__katharina_QGW_II_II_3672"
                        >Kathrei, sein <roleName type="kin"
                           corresp="pe__christian_wissinger_QGW_II_II_3328"
                     >hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__johann_hechtl_QGW_II_II_3480"><roleName type="title"
                           >hern</roleName> Hannsen Hechtl, <roleName type="occ" corresp="org__klosterneuburg-augustiner_chorherren">korherr</roleName>
                        und <roleName type="occ"
                           corresp="org__klosterneuburg-augustiner_chorherren-altar_st_maria"
                           >obristen kellner</roleName> Unser Fraun goczhaus ze
                     Klosterneunburg</rs>,</rs>
                  <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__ottakring-immo_7"
                        >ain virtail und ain halbs sechczehentail weingarten, <roleName type="topo"
                           corresp="pl__ottakring">gelegen bei Ottakrin in dem
                           Starchantsaigen</roleName>
                        <roleName type="topo" corresp="pl__ottakring-immo_6">zenagst <add>an ainem
                              rain</add></roleName>
                        <rs type="place" ref="pl__ottakring-immo_6"><roleName type="owner"
                              corresp="pe__johann_von_eslarn_QGW_II_II_3334">Hannsen von
                              Eslorn</roleName> weingarten</rs> an ainem rain, <rs type="event"
                           ref="ev__QGW_II_II_3672_men_1"><rs type="fn" role="issuer">von <rs
                                 type="place" ref="pl__ottakring-immo_7">dem</rs> man</rs>
                           <rs type="fn" role="recipient"><rs type="org"
                                 ref="org__klosterneuburg-augustiner_chorherren"/></rs>
                           <rs type="fn" role="transactiongood_I"><measure>15 dn.</measure> zu
                                 <triggerstring n="fn">Bergrecht</triggerstring></rs> und <rs type="fn"
                              role="transactiongood_I"><measure>ain halbs ort</measure> ze
                                 <triggerstring n="fn">voitrecht</triggerstring></rs>
                           <triggerstring n="disp"><add>Bergrecht</add>
                              <add>voitrecht</add> dient</triggerstring></rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_II">um <measure>36 lb dn.</measure></rs>
                  <rs type="fn" role="recipient">dem <rs type="person"
                        ref="pe__christian_wissinger_QGW_II_II_3328">egenanten Kristan Wissinger
                           <roleName type="rep" corresp="pe__helena_QGW_II_II_3551"
                              ><add>Geschäftsleuten</add></roleName></rs> und <rs type="person"
                        ref="pe__johann_marchegger_SB_CD_01246">Hannsen Marhegker, <roleName type="occ" corresp="org__wien">burger</roleName> ze Wienn, als
                           <roleName type="rep" corresp="pe__helena_QGW_II_II_3551"
                           >Geschäftsleuten</roleName> der frau Helen, Linharts Neunhofer witib
                        seligen</rs>, <rs type="org"
                        ref="org__wien-st_michael-altar_st_jakob-messe_neunhofer_helena">zu der auf
                        sand Jacobs altar in sand Michels pharrkirchen zu Wienn gestifteten
                        Messe</rs>.</rs></rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3672"><rs type="fn" role="witness">Siegler: <rs
                        type="person" ref="pe__christian_wissinger_QGW_II_II_3328">der
                        Aussteller</rs>, <rs type="person" ref="pe__johann_hechtl_QGW_II_II_3480"
                        >der oberste Kellner</rs> und <rs type="person"
                        ref="pe__ulrich_hirssauer_QGW_II_II_3239">der <roleName type="occ"
                           corresp="org__wien">Stadtschreiber</roleName> Ulreich
                     Hirssauer</rs>.</rs></rs>
            </p>
         </div>
