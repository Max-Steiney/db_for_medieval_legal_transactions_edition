   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3629"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__wolfgang_perbinger_QGW_II_II_3629">Wolfgang
                        Perbinger, der <roleName type="prof">pekch</roleName>, <roleName type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs>,
                     und <rs type="person" ref="pe__dorothea_QGW_II_II_3629">Dorothe, sein <roleName
                           type="kin" corresp="pe__wolfgang_perbinger_QGW_II_II_3629"
                           >hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">stellen <add>aus</add></triggerstring>
                  <rs type="fn" role="recipient">der <rs type="person"
                        ref="pe__magdalena_QGW_II_II_3629">unmündigen <roleName type="title"
                           >junkfraun</roleName> Magdalen, ihrer <roleName type="kin"
                           corresp="pe__wolfgang_perbinger_QGW_II_II_3629">tochter</roleName>
                        <roleName type="kin" corresp="pe__dorothea_QGW_II_II_3629"
                              ><add>tochter</add></roleName></rs>,</rs>
                  <triggerstring n="disp">einen Schuldbrief</triggerstring>
                  <rs type="fn" role="transactiongood_II">über <measure>92 lb dn.</measure>
                     landeswerung in Osterreich, rückzahlbar bei Eintritt der Mündigkeit, aus, <rs
                        type="event" ref="ev__GB_D_facs_754_TextRegion_1658304330269_228"><rs
                           type="fn" role="transactiongood_I">die <measure><add>92 lb
                              dn.</add></measure></rs>
                        <rs type="fn" role="recipient"><rs type="person"
                              ref="pe__magdalena_QGW_II_II_3629">si</rs></rs>
                        <rs type="fn" role="issuer">von <rs type="person"
                              ref="pe__katharina_QGW_II_II_3554">Kathrein, <rs type="person"
                                 ref="pe__sieghard_aiblinger_QGW_II_II_3629">Sigleins Aiblinger, der
                                 egenanten Dorothen <roleName type="kin"
                                    corresp="pe__dorothea_QGW_II_II_3629">bruder</roleName></rs>,
                                 <roleName type="kin"
                                 corresp="pe__sieghard_aiblinger_QGW_II_II_3629">tochter</roleName>,
                              weilent <rs type="person" ref="pe__georg_toller_QGW_II_II_3554">Jörgen
                                 Töller, <roleName type="occ" corresp="org__oesterreich-herzogtum"
                                    select="pl__wien-werd">ambtmans</roleName> im Werd</rs>,
                                 <roleName type="kin" corresp="pe__georg_toller_QGW_II_II_3554"
                                 >hausfraun</roleName>
                              <roleName type="dead">seligen</roleName>, mit der si <roleName
                                 type="kin" corresp="pe__magdalena_QGW_II_II_3629">geswistreid
                                 kind</roleName> gewesen ist</rs>,</rs>
                        <rs type="fn" role="transactiongood_I">an <rs type="place"
                              ref="pl__wien-immo_alter_fleischmarkt_3">dem haus, <roleName
                                 type="topo" corresp="pl__wien-alter_fleischmarkt">am Alten
                                 Fleischmarkcht gelegen</roleName>, das <roleName type="owner"
                                 corresp="pe__leonhard_lehenholzer_QGW_II_II_3371">jecz Linhart
                                 Lehenholczer innhat</roleName></rs>, <triggerstring n="disp">zu irm
                              tail</triggerstring></rs>
                        <triggerstring n="disp">geerbt hat</triggerstring>,</rs></rs>
                  <triggerstring n="disp">und setzen</triggerstring> ihr <rs type="fn" role="other"
                        ><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__johann_meilinger_QGW_II_II_3629">Hannsen Meilinger,
                        künig Lasslawen etc. <roleName type="occ"
                           corresp="pe__ladislaus_QGW_II_II_3461"
                           select="org__oesterreich-herzogtum">ambtschreibern</roleName> in
                        Österreich und seiner künigclichen gnaden grünt vor Kernertor zu Wienn
                           <roleName type="occ" corresp="pe__ladislaus_QGW_II_II_3461"
                           select="pl__wien-kaerntnertor">ambtman</roleName></rs>,</rs>
                  <rs type="fn" role="transactiongood_I"><rs type="place"
                        ref="pl__wien-immo_kaerntnertor_23"><roleName type="owner"
                           corresp="pe__wolfgang_perbinger_QGW_II_II_3629">ihr</roleName>
                        <roleName type="owner" corresp="pe__dorothea_QGW_II_II_3629"
                           ><add>ihr</add></roleName> Haus, <roleName type="topo"
                           corresp="pl__wien-kaerntnertor">gelegen daselbs vor Kernertor</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_kaerntnertor_24">zenagst
                              <add>an aim tail</add></roleName>
                        <rs type="place" ref="pl__wien-immo_kaerntnertor_24"><roleName type="owner"
                              corresp="pe__konrad_klee_QGW_II_II_3629"><rs type="person"
                                 ref="pe__konrad_klee_QGW_II_II_3629">Kunrats Klee, des <roleName
                                    type="prof">pinter</roleName></rs></roleName>, haus</rs> an aim
                        tail, <rs type="event" ref="ev__QGW_II_II_3629_men_2"><rs type="fn"
                              role="issuer">von <rs type="place" ref="pl__wien-immo_kaerntnertor_23"
                                 >dem</rs> man</rs>
                           <rs type="fn" role="recipient"><unclear instant="false"><rs type="org"
                                    ref="org__heiliges_roemisches_reich">in die königliche
                                    Kammer</rs></unclear></rs>
                           <rs type="fn" role="transactiongood_I"><measure>62 dn.</measure>
                              <triggerstring n="fn">zu Grunddienst</triggerstring></rs>
                           <triggerstring n="disp"><add>Grunddienst</add>
                     dient</triggerstring></rs></rs>,</rs>
                  <triggerstring n="disp">zu ainem rechten fürphant</triggerstring>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3629"><rs type="fn" role="witness">Siegler: <rs
                        type="person" ref="pe__johann_meilinger_QGW_II_II_3629">der Amtmann</rs> und
                     der <rs type="person" ref="pe__simon_von_eslarn_QGW_II_II_3263">Wiener
                           <roleName type="occ" corresp="org__wien">Bürger</roleName> Simon
                        von Eslarn</rs>.</rs></rs>
            </p>
         </div>
