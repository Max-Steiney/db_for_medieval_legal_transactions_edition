                           <rs type="fn" role="transactiongood_I"><measure>15 dn.</measure>
                              <triggerstring n="fn">zu Grunddienst</triggerstring></rs>
                           <triggerstring n="disp"><add>zu Grunddienst</add> dient</triggerstring></rs>
                        <rs type="fn" role="recipient"><rs type="org" ref="org__wien-st_stephan-altar_st_maria-messe_auf_der_saeule_johann" cert="high"/><rs type="org" ref="org__wien-st_stephan-altar_st_maria-messe_auf_der_saeule_herbert" cert="high"/></rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_II">um <measure>32 lb dn.</measure></rs>
                  <rs type="fn" role="recipient">dem <rs type="person" ref="pe__christian_wissinger_QGW_II_II_3328">Kristan Wissinger, des
