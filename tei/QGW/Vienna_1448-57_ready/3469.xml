               <rs type="event" ref="ev__QGW_II_II_3469"><rs type="fn" role="issuer"><rs type="person" ref="pe__margarethe_QGW_II_III_4223">Margreth, <rs type="person" ref="pe__leonhard_jamnitzer_QGW_II_III_4223">des Linhart
                           Jämniczer, <roleName type="occ" corresp="org__wiener_neustadt">burger</roleName> zu der Neunstatt</rs>, <roleName type="kin" corresp="pe__leonhard_jamnitzer_QGW_II_III_4223">eeliche
                           hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">theilt</triggerstring>
                  <rs type="fn" role="recipient">dem <rs type="org" ref="org__wien">Bürgermeister,
                        Richter und Rathe zu Wien</rs></rs>
                  <triggerstring n="disp">mit, dass <add>verpflichtet habe</add></triggerstring>
                  <rs type="event" ref="ev__QGW_II_II_3468"><rs type="fn" role="issuer">sie</rs>
                     sich verpflichtet habe, <rs type="fn" role="recipient">dem <rs type="person" ref="pe__johann_schalauczer_QGW_II_II_3414">Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Hannsen
                           Schalauczer</rs></rs>
                     <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_muensserstrasse_12"><roleName type="owner" corresp="pe__margarethe_QGW_II_III_4223">ihr</roleName> zu Wien
                              <roleName type="topo" corresp="pl__wien-muensserstrasse">in der
                              Münczerstrass gelegenes</roleName> Haus</rs></rs>
                     <rs type="fn" role="transactiongood_II">für eine Summe Geldes</rs>
                     <rs type="fn" role="other"><triggerstring n="fn">durch</triggerstring> einen mit <rs type="org" ref="org__wien">dem städtischen Grundsiegel</rs> und dem
                        Siegel <rs type="person" ref="pe__niklas_ottentaler_QGW_II_II_3469">des
                           Neustädter <roleName type="occ" corresp="org__wiener_neustadt">Bürgermeisters</roleName> Niclasen Ottentaler</rs>
                        <triggerstring n="fn">zu besiegelnden geltbrief</triggerstring></rs> zu
                     verseczen,</rs>
                  <triggerstring n="disp">und ersucht</triggerstring> sie, diese Urkunde mit dem
                  städtischen Grundsiegel <triggerstring n="disp">zu besiegeln</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3469"><rs type="fn" role="witness">Siegler: <rs type="person" ref="pe__heinrich_kornmecz_QGW_II_II_3469">Hainrich Kornmess,
                           <roleName type="occ" corresp="org__wiener_neustadt">burger des
                           rates</roleName> zu der Neunstat</rs>, und <rs type="person" ref="pe__leonhard_erngros_QGW_II_II_3468">Linhart Erngros, <roleName type="occ" corresp="org__wiener_neustadt">statschreiber</roleName>
                        daselbst</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>