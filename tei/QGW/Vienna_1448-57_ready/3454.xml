   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3454"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__johann_koll_SB_CD_01565">Hanns Koll, <roleName
                           type="occ" corresp="org__wien-st_stephan">korherr</roleName> dacz sand
                        Stephan zu Wienn, <roleName type="occ"
                           corresp="org__wien-st_philipp_und_st_jakob_kapelle-altar_st_maria"
                           >kaplan</roleName> Unser Fraun altar in sand Philipps und sand Jacobs
                        kappeln in der Kollner hof zu Wienn</rs>,</rs>
                  <triggerstring n="disp">gibt <add>geltes purkrechts</add></triggerstring>
                  <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__christian_widhacker_SB_CD_00626"><roleName type="title"
                           >hern</roleName> Kristan Widhacker</rs></rs>
                  <rs type="fn" role="transactiongood_II"><measure>1 lb dn.</measure>
                     <triggerstring n="fn">geltes purkrechts</triggerstring> von <rs type="place"
                        ref="pl__wien-immo_kumpfgasse_1"><roleName type="owner"
                           corresp="pe__christian_widhacker_SB_CD_00626">seinem</roleName> Hause,
                           <roleName type="topo" corresp="pl__wien-kumpfgasse">in dem
                           Kumphgesslein</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_kumpfgasse_6"
                           >zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_kumpfgasse_6">dem Romhof</rs>
                        gelegen</rs>,</rs>
                  <rs type="fn" role="transactiongood_I">um <measure>8 lb dn.</measure>
                     abzulösen</rs>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3454"><rs type="fn" role="witness">Besiegelt mit
                     dem Siegel des <rs type="person" ref="pe__ulrich_gundloch_QGW_II_II_3454"
                        >Wiener <roleName type="occ" corresp="org__wien">Bürgers</roleName>
                        Ulreichs des Gundloch als <roleName type="occ" corresp="org__wien-st_philipp_und_st_jakob_kapelle-altar_st_maria"
                           >Lehensherrn des Altars</roleName></rs>.</rs></rs>
            </p>
         </div>
         <div type="nota">
            <p>Indorsat: Widhacker haus purkrecht. </p>
