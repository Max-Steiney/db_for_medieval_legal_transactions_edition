                           <roleName type="occ" corresp="pe__ludwig_von_bayern-landshut_QGW_II_II_3433">kellner</roleName></rs>, in beden oder ir jedem besunder, <triggerstring n="reason"><rs type="event" ref="ev__QGW_II_II_3742_men_1"><rs type="fn" role="transactiongood_I">von solicher schuld und gellts wegen</rs>, so
                              <rs type="fn" role="recipient"><rs type="person" ref="pe__wolfgang_winter_SB_CD_00055">Wolfganng Wintter</rs> und
                                 <rs type="person" ref="pe__ulrich_gwichtmacher_QGW_II_II_3742">Ulrich Gwichtmacher, sein <roleName type="kin" corresp="pe__wolfgang_winter_SB_CD_00055">swager</roleName></rs>,</rs>
                           <rs type="fn" role="issuer">von <rs type="person" ref="pe__ludwig_von_bayern-landshut_QGW_II_II_3433">ihm</rs></rs>
                           <triggerstring n="disp">empfangen und innen
                        haben</triggerstring></rs></triggerstring>, <triggerstring n="fn">seinen gwallt geben
                        habe</triggerstring></rs>, <triggerstring n="disp">und ersucht sie, denselben in
                     dieser Angelegenheit hilflich, fürderlich und ratsam zu sein</triggerstring>.</rs>
