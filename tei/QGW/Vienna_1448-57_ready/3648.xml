               <rs type="event" ref="ev__QGW_II_II_3648"><rs type="fn" role="issuer"><rs type="person" ref="pe__barbara_QGW_II_II_3639">Barbara, <roleName type="kin" corresp="pe__wilhelm_eitzinger_QGW_II_II_3419"><add>töchter</add></roleName><roleName type="kin" corresp="pe__dorothea_QGW_II_II_3639"><add>swestern</add></roleName><roleName type="kin" corresp="pe__katharina_QGW_II_II_3639"><add>swestern</add></roleName>
                        <rs type="person" ref="pe__matthias_grasser_QGW_II_II_3578a">Mathesen des
                           Grasser</rs> eleiche <roleName type="kin" corresp="pe__matthias_grasser_QGW_II_II_3578a">hausfrau</roleName></rs>,
                        <rs type="person" ref="pe__dorothea_QGW_II_II_3639">Dorothe <roleName type="kin" corresp="pe__barbara_QGW_II_II_3639"><add>swestern</add></roleName><roleName type="kin" corresp="pe__katharina_QGW_II_II_3639"><add>swestern</add></roleName>
                        <roleName type="kin" corresp="pe__wilhelm_eitzinger_QGW_II_II_3419"><add>töchter</add></roleName></rs> und <rs type="person" ref="pe__katharina_QGW_II_II_3639">Kathrei, ir <roleName type="kin" corresp="pe__barbara_QGW_II_II_3639">swestern</roleName><roleName type="kin" corresp="pe__dorothea_QGW_II_II_3639"><add>swestern</add></roleName>, all drei <rs type="person" ref="pe__wilhelm_eitzinger_QGW_II_II_3419">Wilhalms des Eyczinger
                              <roleName type="dead">seligen</roleName></rs>
                        <roleName type="kin" corresp="pe__wilhelm_eitzinger_QGW_II_II_3419">töchter</roleName></rs>,</rs>
                  <triggerstring n="disp">theilen</triggerstring>
                  <rs type="fn" role="recipient">dem <rs type="org" ref="org__wien">Bürgermeister
                        und Rathe der Stadt zu Wien</rs></rs>
                  <triggerstring n="disp">mit</triggerstring>, dass <rs type="event" ref="ev__QGW_II_II_3648_men_1"><rs type="fn" role="issuer"><rs type="person" ref="pe__dorothea_QGW_II_II_3639">sie</rs>
                        <rs type="person" ref="pe__katharina_QGW_II_II_3639"><add>sie</add></rs>
                        <rs type="person" ref="pe__barbara_QGW_II_II_3639"><add>sie</add></rs></rs>
                     <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_st_johannsstrasse_10">das Haus, <roleName type="topo" corresp="pl__wien-st_johannsstrasse">in sand Johanns strass</roleName>
                           <roleName type="topo" corresp="pl__wien-immo_st_johannsstrasse_11">zenagst</roleName>
                           <rs type="place" ref="pl__wien-immo_st_johannsstrasse_11"><roleName type="owner" corresp="pe__johann_schweinbarther_QGW_II_II_3648">weilent <rs type="person" ref="pe__johann_schweinbarther_QGW_II_II_3648"><roleName type="title">hern</roleName> Hannsen
                                 Sweinbartter</rs></roleName> haus</rs> gelegen, <rs type="event" ref="ev__QGW_II_II_3648_men_2"><rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_st_johannsstrasse_10">das</rs></rs>
                              <rs type="fn" role="recipient"><rs type="person" ref="pe__dorothea_QGW_II_II_3639">ihnen</rs>
                                 <rs type="person" ref="pe__katharina_QGW_II_II_3639"><add>ihnen</add></rs>
                                 <rs type="person" ref="pe__barbara_QGW_II_II_3639"><add>ihnen</add></rs></rs>
                              <rs type="fn" role="issuer">von <rs type="person" ref="pe__konrad_eitzinger_QGW_II_II_3310">ihres Vaters <roleName type="kin" corresp="pe__wilhelm_eitzinger_QGW_II_II_3419">Bruder</roleName>
                                    <roleName type="title">hern</roleName> Conraten dem Eyczinger
                                       <roleName type="dead">seligen</roleName></rs></rs>,
                                 <triggerstring n="disp">ist anerstorben und
                           angeerbt</triggerstring></rs></rs>,</rs>
                     <rs type="fn" role="transactiongood_II">um <measure>58 lb dn.</measure></rs>
                     <rs type="fn" role="recipient"><rs type="person" ref="pe__niklas_ulrichskirchner_QGW_II_II_3648">Niclasen Ulreichskircher,
                           dem <roleName type="prof">tischer</roleName>, <roleName type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs>, und <rs type="person" ref="pe__katharina_QGW_II_II_3648">Kathrein, seiner
                              <roleName type="kin" corresp="pe__niklas_ulrichskirchner_QGW_II_II_3648">hausfraun</roleName></rs>,</rs>
                     <triggerstring n="disp">verkauft haben</triggerstring>,</rs>
                  <triggerstring n="disp">und ersuchen</triggerstring> sie, den <triggerstring n="disp">Kaufbrief</triggerstring> mit ihrem gruntinsigil <triggerstring n="disp">zu
                     besiegeln</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3648"><rs type="fn" role="witness">Siegler: <rs type="person" ref="pe__barbara_QGW_II_II_3639">die Grasserin</rs> und die
