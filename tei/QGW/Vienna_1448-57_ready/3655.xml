               <rs type="event" ref="ev__QGW_II_II_3655"><rs type="fn" role="issuer"><rs type="person" ref="pe__andreas_pueczinger_QGW_II_II_3655">Andre Püczinger,
                           <roleName type="title_ref" corresp="pl__grinzing">gesessen zu</roleName>
                        Grinczing</rs>, und <rs type="person" ref="pe__agnes_QGW_II_II_3655">Agnes,
                        sein <roleName type="kin" corresp="pe__andreas_pueczinger_QGW_II_II_3655">hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">nehmen</triggerstring>
                  <rs type="fn" role="recipient">von <rs type="person" ref="pe__heinrich_senftleben_QGW_II_II_3263"><roleName type="title">hern</roleName> Hainrichen Senftleben, <roleName type="occ" corresp="org__breslau-dioezese">dechant</roleName> und <roleName type="occ" corresp="org__breslau-dioezese">tumbherr</roleName> zu Bresla,
                           <roleName type="occ" corresp="org__wien-st_maria_im_rathaus">obrister
                           caplan</roleName> Unser Fraun kapelln, gelegen in der purger Rathaus zu
                        Wienn, hern Otten und Haymen stifftung</rs>,</rs>
                  <rs type="fn" role="transactiongood_II"><rs type="place" ref="pl__sievering-immo_7">ein Joch Weingarten, genant der Minnstain,
                           <roleName type="topo" corresp="pl__sievering">gelegen zu Nidern
                           Süfring</roleName>
                        <roleName type="topo" corresp="pl__sievering-immo_8">zenagst</roleName>
                        <rs type="place" ref="pl__sievering-immo_8"><roleName type="owner" corresp="org__gaming-kartaeuser">der geistlichen herren von
                              Gêmnikch</roleName> weingarten</rs>, <rs type="event" ref="ev__QGW_II_II_3655_men_1"><rs type="fn" role="issuer">von <rs type="place" ref="pl__sievering-immo_7">dem</rs> man</rs>
                           <rs type="fn" role="recipient">den <rs type="org" ref="org__mauerbach-kartaeuser">geistlichen herren zu
                              Maurbach</rs></rs>
                           <rs type="fn" role="transactiongood_I"><measure>zwei Eimer Most</measure>
                              <triggerstring n="fn">zu Bergrecht</triggerstring></rs> und <rs type="fn" role="transactiongood_I"><measure>2 dn.</measure>
                              <triggerstring n="fn">zu Voitrecht</triggerstring></rs>
                           <triggerstring n="disp"><add>Bergrecht</add>
                              <add>Voitrecht</add> dient</triggerstring></rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_I">gegen <triggerstring n="fn">jährliche
                        Leistung</triggerstring> des <measure>vierten Eimers Most</measure> bei der
                     press aus dem grannt</rs>
                  <triggerstring n="disp">auf Lebenszeit in Bestand</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3655"><rs type="fn" role="witness">Besiegelt mit
