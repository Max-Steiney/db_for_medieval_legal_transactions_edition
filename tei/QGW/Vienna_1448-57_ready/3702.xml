   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3702"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__felicitas_SB_CD_00617">Felicitas, <rs type="person"
                           ref="pe__johann_han_SB_CD_00617">Hannsen des Han von Zabarn <roleName
                              type="dead">seligen</roleName></rs>
                        <roleName type="kin" corresp="pe__johann_han_SB_CD_00617">tochter</roleName>
                        und ycz <rs type="person" ref="pe__johann_gebel_QGW_II_II_3578a">Hannsen des
                           Gebel</rs> eleiche <roleName type="kin"
                           corresp="pe__johann_gebel_QGW_II_II_3578a">hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">ersucht</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn"><add>ersucht</add></triggerstring>
                     <rs type="person" ref="pe__jakob_rechwein_QGW_II_II_3242">Jacoben den Rechwein,
                           <roleName type="occ" corresp="org__wien">bürger</roleName> und
                        ainer des <roleName type="occ" corresp="org__wien">rats</roleName> der stat
                        zu Wienn</rs>, und <rs type="person"
                        ref="pe__michael_mannersdorffer_QGW_II_III_4064">Micheln den Ma/enestorffer,
                        auch <roleName type="occ" corresp="org__wien">bürger</roleName> und
                        ainer der <roleName type="occ" corresp="org__wien">genanten</roleName>
                        daselbs zu Wienn</rs>,</rs>
                  <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__johann_gebel_QGW_II_II_3578a">ihren Mann</rs></rs>
                  <rs type="fn" role="transactiongood_I"><rs type="place"
                        ref="pl__wien-immo_kaerntnerstrasse_34">des haus, <roleName type="topo"
                           corresp="pl__wien-kaerntnerstrasse">gelegen in der
                           Kernerstrass</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_kaerntnerstrasse_35">ainhalben
                           zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_kaerntnerstrasse_35"><roleName
                              type="owner" corresp="pe__erhard_han_QGW_II_II_3702"><rs type="person"
                                 ref="pe__erhard_han_QGW_II_II_3702">Erharten Hann, des eltern, von
                                 Zabarn zu Salczburgk, ihres <roleName type="kin"
                                    corresp="pe__felicitas_SB_CD_00617"
                              >enn</roleName></rs></roleName> haus</rs>
                        <roleName type="topo" corresp="pl__wien-komoediengasse">und anderthalben
                           zenagst</roleName>
                        <rs type="place" ref="pl__wien-komoediengasse">des gesslein zwischen des
                           vorgenanten haus</rs>
                        <roleName type="topo" corresp="pl__wien-immo_kaerntnertor_4">und
                              <add>gegenüber</add></roleName>
                        <rs type="place" ref="pl__wien-immo_kaerntnertor_4"><roleName type="owner"
                              corresp="pe__niklas_swarcz_QGW_II_II_2500">Niclasen Swarcz,
                              schuster</roleName>, haus</rs>, <rs type="event"
                           ref="ev__QGW_II_II_3702_men_1"><rs type="fn" role="transactiongood_I"><rs
                                 type="place" ref="pl__wien-immo_kaerntnerstrasse_34">das</rs></rs>
                           <rs type="fn" role="recipient"><rs type="person"
                                 ref="pe__felicitas_SB_CD_00617">sie</rs></rs>
                           <rs type="fn" role="issuer">von <rs type="person"
                                 ref="pe__johann_han_SB_CD_00617">ihrem Vater</rs></rs>
                           <triggerstring n="disp">geerbt hat</triggerstring></rs></rs>,</rs>
                  <triggerstring n="disp">zu ihr an die gwer als gesambte hanndt in der stat gruntpuch
                     zu schreiben</triggerstring>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3702"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__simon_lempl_QGW_II_II_4131">Simon des
                        Lempplein <roleName type="friend" corresp="pe__felicitas_SB_CD_00617"
                              ><add>freunt</add></roleName>
                        <roleName type="kin" corresp="pe__felicitas_SB_CD_00617"
                           ><add>swäger</add></roleName></rs> und <rs type="person"
                        ref="pe__matthias_viechtenstainer_QGW_II_II_3702">Matheus des
                        Vichtenstainer, ihrer <roleName type="friend"
                           corresp="pe__felicitas_SB_CD_00617">freunt</roleName> und <roleName
                           type="kin" corresp="pe__felicitas_SB_CD_00617"
                     >swäger</roleName></rs>.</rs></rs>
            </p>
         </div>
