                        Wienn</rs>,</rs>
                  <triggerstring n="disp">verkauft <add>gelts purkrechts</add></triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> seines <rs type="person" ref="pe__martin_QGW_II_II_3213"><roleName type="title">Grundherrn</roleName>
                        <roleName type="title">hern</roleName> Mertten, <roleName type="occ" corresp="org__wien-schotten">abbt</roleName> Unser Lieben Fraun gotshaus
                        dacz den Schotten</rs>,</rs>
                  <rs type="fn" role="transactiongood_I"><measure>12 sh. dn.</measure>
                     <triggerstring n="fn">gelts purkrechts (ablösbar)</triggerstring> auf <rs type="place" ref="pl__wien-immo_landstrasse_1"><roleName type="owner" corresp="pe__michael_singer_QGW_II_II_3333">seinem</roleName> Hause,
                           <roleName type="topo" corresp="pl__wien-landstrasse">gelegen in der
                           Lantstrass vor Stubentor</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_landstrasse_2">zenagst <add>an
                              aim tail</add></roleName>
                        <rs type="place" ref="pl__wien-immo_landstrasse_2"><roleName type="owner" corresp="pe__erasmus_leroch_QGW_II_II_3333"><rs type="person" ref="pe__erasmus_leroch_QGW_II_II_3333">Erasem des
                              Leroch</rs></roleName> haus</rs> an aim tail, <rs type="event" ref="ev__QGW_II_II_3333_men_1"><rs type="fn" role="issuer">von <rs type="place" ref="pl__wien-immo_landstrasse_1">dem</rs> man</rs>
                           <rs type="fn" role="transactiongood_I"><measure>½ lb 20 dn.</measure>
                              <triggerstring n="fn">zu Grunddienst</triggerstring></rs>
                           <rs type="fn" role="recipient"><rs type="org" ref="org__wien-schotten"/></rs>
                           <triggerstring n="disp"><add>Grunddienst</add>
                     dient</triggerstring></rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_II">um <measure>12 lb dn.</measure>, <rs type="event" ref="ev__QGW_II_II_3333_men_2"><rs type="fn" role="transactiongood_I"><measure><add>12 sh. dn.</add></measure>
                           <triggerstring n="fn"><add>gelts purkrechts (ablösbar)</add></triggerstring>
                           die</rs>
                        <triggerstring n="disp">emaln</triggerstring>
                        <rs type="fn" role="issuer">auf <rs type="place" ref="pl__wien-immo_kumphlukche_vor_kernertor_4"><roleName type="owner" corresp="pe__simon_nerensnabel_QGW_II_II_3333"><rs type="person" ref="pe__simon_nerensnabel_QGW_II_II_3333">Simons
                                    Nerensnabel</rs></roleName> und <roleName type="owner" corresp="pe__katharina_QGW_II_II_3333"><rs type="person" ref="pe__katharina_QGW_II_II_3333">Kathrein, seiner <roleName type="kin" corresp="pe__simon_nerensnabel_QGW_II_II_3333">hausfraun</roleName></rs></roleName>, haus <roleName type="topo" corresp="pl__wien-kumphlukche_vor_kernertor">vor
                                 Ke/arnertor in der Kumphlukchen, der stat
                           grunt</roleName></rs>,</rs>
                        <triggerstring n="disp">gelegen sind gewesen</triggerstring>
                        <rs type="fn" role="recipient"><rs type="org" ref="org__wien-st_stephan"/></rs>,</rs></rs>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__konrad_lindenvels_QGW_II_II_3333">Conraden Lindenvels, cantor zu
                        sand Stephan,</rs> und <rs type="org" ref="org__wien-st_stephan">seinen
                        Nachfolgern als Verwesern der zur Cantorei gehörigen Messe</rs>.</rs></rs>
