   <text>
      <body>
         <div type="abstract" resp="kg">
            <p><rs type="event" ref="ev__QGW_II_II_3383"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270"
                        >König Friedrich IV.</rs></rs>
                  <triggerstring n="disp">an</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="org__wien">Bürgermeister,
                        Richter und Rath zu Wien</rs>.</rs>
                  <rs type="fn" role="other">Der <rs type="person"
                        ref="pe__jakob_moshaimer_QGW_II_II_3245"><roleName type="prof"
                           >Priester</roleName> Jacob Moshaimer <roleName type="rep"
                           corresp="pe__johann_spannberger_QGW_II_II_3245"
                           ><add>anstatt</add></roleName><roleName type="rep"
                           corresp="pe__stephan_spannberger_QGW_II_II_3383"
                           ><add>anstatt</add></roleName></rs>
                     <triggerstring n="fn">habe ihm vorgebracht</triggerstring>,</rs>
                  <rs type="event" ref="ev__QGW_II_II_3383_men_1">dass <rs type="fn" role="other"
                           ><triggerstring n="fn">mit tod in abwiczen verschaiden sei</triggerstring><rs
                           type="person" ref="pe__elisabeth_QGW_II_II_3383">Elspet,<roleName
                              type="dead"><add>tod</add></roleName>
                           <rs type="person" ref="pe__ulrich_sel_QGW_II_II_3383">Ulreichen des Sêln
                                 <roleName type="dead">wittib</roleName></rs><roleName type="kin"
                              corresp="pe__ulrich_sel_QGW_II_II_3383"
                           ><add>wittib</add></roleName></rs></rs>, in des <rs type="fn"
                        role="issuer"><rs type="person"
                           ref="pe__peter_engelhartsstetter_QGW_II_II_3435">Wiener <roleName type="occ" corresp="org__wien">Bürgers</roleName> Petern des
                           Engelharczsteter <unclear instant="false"><roleName type="rep"
                                 corresp="pe__elisabeth_QGW_II_II_3383"><add>der sie mit ihrer und
                                    ihrer nächsten Freunde Einwilligung in hu/ot gehalten
                                    hatte</add></roleName></unclear></rs>
                     </rs>haus mit tod in abwiczen verschaiden sei, und dieser, der sie mit ihrer
                     und ihrer nächsten Freunde Einwilligung in hu/ot gehalten hatte, <triggerstring
                        n="disp">ein ungeordents und frömbds gesche/afft hab fürbracht und main
                        damit</triggerstring>
                     <rs type="fn" role="recipient"><rs type="person"
                           ref="pe__johann_spannberger_QGW_II_II_3245">seinen <roleName type="kin"
                              corresp="pe__peter_engelhartsstetter_QGW_II_II_3435">swager</roleName>
                           Hannsen Spanberger<roleName type="kin"
                              corresp="pe__elisabeth_QGW_II_II_3383"
                           ><add>Erben</add></roleName></rs> und <rs type="person"
                           ref="pe__stephan_spannberger_QGW_II_II_3383">Stephan Spanberger, dessen
                              <roleName type="kin" corresp="pe__johann_spannberger_QGW_II_II_3245"
                              >Bruder</roleName><roleName type="kin"
                              corresp="pe__elisabeth_QGW_II_II_3383"
                           ><add>Erben</add></roleName></rs>,</rs> als der genannten Frau nächste
                     Erben <triggerstring n="disp">von ihrem Nachlasse zu entseczen und zu
                        weisen</triggerstring>.</rs> Er <triggerstring n="disp">befiehlt</triggerstring>
                  ihnen, den genannten Priester, dem die beiden Brüder ihr Anrecht übertragen haben,
                  und <rs type="fn" role="other"><triggerstring n="fn"><add>hincz</add></triggerstring>
                     <rs type="person" ref="pe__peter_engelhartsstetter_QGW_II_II_3435">den
                        Engelhartsstetter</rs></rs>
                  <triggerstring n="disp">vorzuladen und in der Streitsache nach Recht zu
                     entscheiden</triggerstring>.</rs>
            </p>
         </div>
         <div type="nota">
            <p>Von anderer Hand: commissio domini regis per marsch( alcum) curie. </p>
         </div>
