                  <triggerstring n="disp">bestätigen, dass</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__konrad_phuntimaschen_QGW_II_II_3088">Kunrat Phuntimaschen <roleName type="occ" corresp="org__wien"><add>rats</add></roleName><roleName type="occ" corresp="org__wien"><add>innemer der
