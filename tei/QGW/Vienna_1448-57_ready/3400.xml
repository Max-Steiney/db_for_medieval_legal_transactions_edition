      <body>
         <div type="abstract" resp="kg">
            <p><rs type="event" ref="ev__QGW_II_II_3400"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270"
                        >König Friedrich IV.</rs></rs>
                  <triggerstring n="disp">an</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="org__wien">Bürgermeister und
                        Rath der Stadt zu Wien</rs>.</rs>
                  <unclear instant="false"><rs type="fn" role="transactiongood_III"><rs
                           type="person" ref="pe__jakob_lienfelder_QGW_II_II_3400">Jacob, des
                           Lienvelder <roleName type="kin"
                              corresp="pe__thomas_lienfelder_QGW_II_II_3400"
                        >sun</roleName></rs></rs></unclear>, sei <rs type="fn" role="other">dem <rs
                        type="person" ref="pe__andreas_schoenprugker_QGW_II_II_3376">Wiener
                           <roleName type="occ" corresp="org__wien">Bürger</roleName> Andren
                        Schönprukger <roleName type="rep"
                           corresp="pe__jakob_lienfelder_QGW_II_II_3400"
                           ><add>gerhaben</add></roleName></rs>
                     <triggerstring n="fn">mit seim leib und gut uncz zu seinen vogtpern jarn
                        innzehaben verschriben</triggerstring>,</rs> doch habe <rs type="fn"
                     role="other">der <rs type="person" ref="pe__thomas_lienfelder_QGW_II_II_3400"
                        >Klosterneuburger <roleName type="occ" corresp="org__klosterneuburg"
                           >Bürger</roleName> Thoman Lienvelder <roleName type="dead"
                              ><add>gestorben</add></roleName></rs>
                     <triggerstring n="fn">sich den Knaben</triggerstring> von ihnen und dem Schönprugker
                        <triggerstring n="fn">erbeten</triggerstring>. Da nun Thomas gestorben ist</rs>,
                  so <triggerstring n="disp">befiehlt</triggerstring> er ihnen, <triggerstring n="disp">den
                     Knaben zurückzufordern</triggerstring> und <unclear instant="false"><rs type="fn"
                        role="other">dem <rs type="person"
                           ref="pe__andreas_schoenprugker_QGW_II_II_3376">Schönprugker</rs></rs>
                     <triggerstring n="disp">zu übergeben</triggerstring></unclear>.</rs>
            </p>
         </div>
         <div type="nota">
            <p>Von anderer Hand: commissio domini regis propria. </p>
         </div>
