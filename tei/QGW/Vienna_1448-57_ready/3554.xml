         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3554"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__johann_wilhalm_QGW_II_II_3554">Hanns Wilhalm,
                           <roleName type="title_ref" corresp="pl__haringsee">gesessen zu</roleName>
                        Haringsee, <roleName type="rep" corresp="pe__lucia_QGW_II_II_3554"
                           >anstatt</roleName>
                        <rs type="person" ref="pe__lucia_QGW_II_II_3554">seiner unmündigen <roleName
                              type="kin" corresp="pe__johann_wilhalm_QGW_II_II_3554"
                              >Tochter</roleName> Lucein</rs></rs>, <rs type="person"
                        ref="pe__simon_wilhalm_QGW_II_II_3554">Simon Wilhalm, sein <roleName
                           type="kin" corresp="pe__johann_wilhalm_QGW_II_II_3554"
                        >sun</roleName></rs>, <rs type="person" ref="pe__margarethe_QGW_II_II_3554"
                        >Margreth <roleName type="kin" corresp="pe__johann_wilhalm_QGW_II_II_3554"
                              ><add>tochter</add></roleName>, <rs type="person"
                           ref="pe__andreas_schuster_QGW_II_II_3554">Anderleins, des <roleName
                              type="prof">schuster</roleName>
                           <roleName type="title_ref" corresp="pl__haringsee">zu</roleName>
                           Haringsee</rs>
                        <roleName type="kin" corresp="pe__andreas_schuster_QGW_II_II_3554"
                           >hausfrau</roleName></rs>, <rs type="person"
                        ref="pe__dorothea_QGW_II_II_3554">Dorothe <roleName type="kin"
                           corresp="pe__johann_wilhalm_QGW_II_II_3554"
                        ><add>tochter</add></roleName>, <rs type="person"
                           ref="pe__georg_haimel_QGW_II_II_3554">Jorgen Haimel, des <roleName
                              type="prof">fleischakcher</roleName> daselbs</rs>, <roleName
                           type="kin" corresp="pe__georg_haimel_QGW_II_II_3554"
                        >hausfrau</roleName></rs>, und <rs type="person"
                        ref="pe__barbara_QGW_II_II_3554">Barbara, <rs type="person"
                           ref="pe__johann_meichsner_QGW_II_II_3554">Hannsen Meichsner, des
                              <roleName type="prof">pekchen</roleName>
                           <roleName type="title_ref" corresp="pl__wien">zu</roleName> Wienn</rs>
                        <roleName type="kin" corresp="pe__johann_meichsner_QGW_II_II_3554"
                           >hausfrau</roleName>, sein <roleName type="kin"
                           corresp="pe__johann_wilhalm_QGW_II_II_3554">tochter</roleName></rs>,</rs>
                  <triggerstring n="disp">stellen</triggerstring>
                  <rs type="fn" role="transactiongood_I">hinsichtlich des <rs type="event"
                        ref="NULL">von <rs type="person" ref="pe__katharina_QGW_II_II_3554"
                              ><roleName type="title">frau</roleName> Kathrei, <rs type="person"
                              ref="pe__georg_toller_QGW_II_II_3554">Jörgen des Toller</rs>
                           <roleName type="kin" corresp="pe__georg_toller_QGW_II_II_3554"
                              >hausfrau</roleName>, ihrer <roleName type="kin"
                              corresp="pe__barbara_QGW_II_II_3554">muem</roleName>
                           <roleName type="kin" corresp="pe__dorothea_QGW_II_II_3554"
                                 ><add>muem</add></roleName>
                           <roleName type="kin" corresp="pe__lucia_QGW_II_II_3554"
                              ><add>muem</add></roleName>
                           <roleName type="kin" corresp="pe__simon_wilhalm_QGW_II_II_3554"
                                 ><add>muem</add></roleName>
                           <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3554"
                                 ><add>muem</add></roleName>
                           <roleName type="dead">seligen</roleName></rs>, hinterlassenen Gutes,
                        dessen nächste Erben sie sind</rs>,</rs>
                  <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__ulrich_haringseer_QGW_II_II_3554">Ulreichen Haringseer, dem
                           <roleName type="prof">ledrer</roleName>, <roleName type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs>,</rs>
                  <triggerstring n="disp">eine Vollmacht aus</triggerstring>.</rs>
            </p>
