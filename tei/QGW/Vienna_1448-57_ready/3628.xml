               <rs type="event" ref="ev__QGW_II_II_3628"><rs type="fn" role="issuer"><rs type="person" ref="pe__wolfgang_wotschamel_QGW_II_II_3628">Wolfgang
                        Wotschamel, <roleName type="prof">briester</roleName> Passauer bistumbs
                           <roleName type="occ" corresp="org__wien-st_stephan-messe_pirchvelderin_anna"><add>Kaplan</add></roleName></rs>,</rs> dem <rs type="fn" role="recipient"><rs type="person" ref="pe__konrad_hoelczler_QGW_II_II_3350"><roleName type="title">her</roleName> Conrat Hölczler, <roleName type="occ" corresp="org__wien">burgermaister</roleName></rs>, und <rs type="org" ref="org__wien">der rat der stat zu Wienn</rs></rs>
                  <rs type="fn" role="transactiongood_II">die <rs type="org" ref="org__wien-st_stephan-messe_pirchvelderin_anna">ewig <rs type="event" ref="ev__QGW_II_II_3628_men_1">messe, so weilent <rs type="fn" role="issuer"><rs type="person" ref="pe__anna_QGW_II_II_3628"><roleName type="title">frau</roleName> Anna, <rs type="person" ref="pe__ulrich_pirchvelder_StB_I_172">Ulreichs Pirchvelder
                                       <roleName type="dead">witib</roleName></rs>
                                 <roleName type="kin" corresp="pe__ulrich_pirchvelder_StB_I_172"><add>witib</add></roleName>
                                 <roleName type="dead">selige</roleName></rs>,</rs>
                           <rs type="fn" role="recipient">hincz <rs type="org" ref="org__wien-st_stephan">sand Steffen zu Wienn</rs></rs>
                           <triggerstring n="disp">gestifft hat</triggerstring></rs></rs>,</rs> die in <rs type="fn" role="other"><triggerstring n="disp">mit</triggerstring>
                     <rs type="person" ref="pe__thomas_von_zwettl_QGW_II_II_3628"><roleName type="title">maister</roleName> Thomans von Zwetel, <roleName type="prof">lerer geistlicher rechten</roleName>, <roleName type="occ" corresp="org__wien-st_stephan-messe_pirchvelderin_anna">weilent
                           capplan</roleName> derselben messe <roleName type="dead"><add>abgang</add></roleName></rs>, <triggerstring n="disp">abgang</triggerstring></rs> ledig worden ist, <triggerstring n="disp">verlihen
                     habent, gelobt</triggerstring>, die dazu gehörigen Güter in gutem Stande
                     <triggerstring n="disp">zu erhalten</triggerstring>, wöchentlich vier Messen mit
                  Wissen des gusters <triggerstring n="disp">zu lesen</triggerstring>, diesem jährlich zu
                  Weihnachten 60 dn. zu pitancz zu geben und darüber zu wachen, dass die von der
                  Pirchfelderin zu Pusenperg und zu Sand Veit auf der Wienn gestifteten Jahrtage
                  alle jar an sand Augustins tag begangen werden.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3628"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__johann_hashart_QGW_II_II_3424">Hannsen
                        des Hasharts <roleName type="occ" corresp="org__wien"><add>burger</add></roleName></rs> und <rs type="person" ref="pe__jakob_kaschauer_QGW_II_II_3048">Jacobs Kaschauer, baid <roleName type="occ" corresp="org__wien">burger</roleName> zu
                     Wienn</rs>.</rs></rs>
