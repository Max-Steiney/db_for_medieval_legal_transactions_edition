                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951"><roleName type="title">hern</roleName> Niclasen Teschler, <roleName type="occ" corresp="org__wien">burgermaister</roleName> und <roleName type="occ" corresp="org__oesterreich-herzogtum">munssmaister</roleName></rs>, und
                        <rs type="org" ref="org__wien">des Rathes</rs></rs>
                  <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_st_jakob_auf_der_huelben_2">ein Haus, <roleName type="owner" corresp="pe__elisabeth_QGW_II_II_3619">das der egenanten
