      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3709"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__wolfgang_weissenburger_QGW_II_II_3709">Wolfgang
                        Weissenburger, <roleName type="occ" corresp="org__wien-st_stephan"
                           >achter</roleName> dacz sand Stephan zu Wienn <roleName type="occ"
                           corresp="org__wien-st_hieronymus-messe_stadl_michael"
                           ><add>kaplans</add></roleName>
                        <roleName type="occ" corresp="org__wien-st_koloman-messe_stadl_michael"
                              ><add>kaplans</add></roleName></rs>,</rs> dem <rs type="fn"
                     role="recipient"><rs type="person" ref="pe__stephan_kufuesser_QGW_II_II_3285"
                        >Stephan Küfusser, ainer des <roleName type="occ" corresp="org__wien"
                           >rats</roleName> der stat zu Wienn <roleName type="rep"
                           corresp="pe__michael_stadl_SB_CD_00055"
                           ><add>geschefftleut</add></roleName></rs>, <rs type="person"
                        ref="pe__konrad_pilgrim_QGW_II_II_3285">Connrat Pilgreim <roleName type="occ" corresp="org__wien"><add>burger</add></roleName>
                        <roleName type="rep" corresp="pe__michael_stadl_SB_CD_00055"
                              ><add>geschefftleut</add></roleName></rs> und <rs type="person"
                        ref="pe__kaspar_kemnater_QGW_II_II_3285">Caspar Kembnater, <roleName type="occ" corresp="org__wien">burger</roleName> daselbs, Micheln
                        Stadel, des fleischhakcher seligen <roleName type="rep"
                           corresp="pe__michael_stadl_SB_CD_00055"
                     >geschefftleut</roleName></rs>,</rs>
                  <rs type="fn" role="transactiongood_II"><rs type="org"
                        ref="org__wien-st_hieronymus-messe_stadl_michael">die mit 28 lb dn.
                        jerlicher gült dotierte Messe</rs>
                     <rs type="org" ref="org__wien-st_koloman-messe_stadl_michael"><add>die mit 28
                           lb dn. jerlicher gült dotierte Messe</add></rs>,</rs> welche <rs
                     type="fn" role="other"><triggerstring n="fn">mit abgang</triggerstring>
                     <rs type="person" ref="pe__stephan_seuringer_QGW_II_II_3452"><roleName
                           type="title">hern</roleName> Stephans Seuringer, des ersten <roleName
                           type="occ" corresp="org__wien-st_hieronymus-messe_stadl_michael"
                              ><add>kaplans</add></roleName>
                        <roleName type="occ" corresp="org__wien-st_koloman-messe_stadl_michael"
                           >kaplans</roleName>
                        <roleName type="dead"><add>abgang</add></roleName></rs>,</rs> ledig geworden
                  war, verliehen haben, <triggerstring n="disp">verliehen haben, gelobt</triggerstring>,
                     <triggerstring n="impl_rules">all wochen fünf</triggerstring>
                  <triggerstring n="disp">mess</triggerstring>, <triggerstring n="impl_rules">drei zu sand
                     Kolman am mantag, am mitichen und am freitag, und zwo zu sand Yeronimus, aine
                     am sambstag und aine am suntag</triggerstring>
                  <triggerstring n="disp">zu lesen</triggerstring>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3709"><rs type="fn" role="witness">Besiegelt mit
                     den Sigeln <rs type="person" ref="pe__niklas_purger_QGW_II_III_3758">Niclasen
                        des Purger, <roleName type="occ" corresp="org__wien">purger</roleName>
                        ze Wienn</rs>, und <rs type="person"
                        ref="pe__ulrich_hirssauer_QGW_II_II_3239">Ulreichs Hirssauer, <roleName
                           type="occ" corresp="org__wien">statschreiber</roleName>
                     daselbs</rs>.</rs></rs>
            </p>
