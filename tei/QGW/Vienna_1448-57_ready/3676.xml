                        <roleName type="topo" corresp="pl__wien-immo_st_johannsstrasse_6">zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_st_johannsstrasse_6"><roleName type="owner" corresp="pe__gilg_kunter_QGW_II_II_3676">Giligen,
                              kunter,</roleName> haus</rs> gelegen</rs>,</rs>
                  <rs type="fn" role="transactiongood_II">um <measure>6 lb dn.</measure>
                     abzulösen</rs>
