            <date when="14550312">1455 III 12</date>
            <origDate instant="false">Datum an mitwochen sant Gregorgen tag, anno domini etc.
               quinquagesimo quinto.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03614_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03614_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3614"><rs type="fn" role="issuer"><rs type="org" ref="org__ochsenfurt">Rate der stat zu Ochsenfurt</rs></rs>
                  <triggerstring n="disp">an</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="org__wien">Bürgermeister,
                        Richter und Rath der Stadt zu Wien</rs>.</rs> Ihrer <triggerstring n="disp">Zuschrift von wegen <add>gelts</add>
                     <add>schuldig ist</add></triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn"><add>von wegen</add></triggerstring>
                     <rs type="person" ref="pe__margarethe_QGW_II_II_3614">Margrethen
                     Dürbachin</rs></rs>
                  <rs type="fn" role="transactiongood_III">und <rs type="event" ref="ev__QGW_II_II_3614_men_1"><rs type="fn" role="transactiongood_I">etlichs gelts wegen</rs>, so dann <rs type="fn" role="issuer"><rs type="person" ref="pe__niklas_duerbach_QGW_II_II_3614">Clauss Dürbach, ir <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3614">stifsun</roleName></rs>,</rs>
                        <rs type="fn" role="recipient"><rs type="person" ref="pe__barbara_QGW_II_II_3614">Barbaren, ir <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3614">tochter</roleName>, die
                              jeczunt <rs type="person" ref="pe__ulrich_parschalch_QGW_II_II_3547">Ulrich Parschalich, der <roleName type="prof">pinter</roleName>,
                                 Wiener <roleName type="occ" corresp="org__wien">mitburger</roleName>, bei im
                                       <unclear instant="false"><roleName type="rep" corresp="pe__barbara_QGW_II_II_3614">in pflegnuss
                                       hat</roleName></unclear></rs></rs>,</rs>
                        <triggerstring n="disp">schuldig ist</triggerstring>,</rs></rs> entsprechend haben
                  sie den genannten Klaus vorgeladen, der ihnen erklärte, dass er das Geld erst im
                  nächsten Herbste abstatten könne. Daraufhin haben etliche ihrer Freunde und
                  ratgenossen in gütlickeit betaidingt, dass <rs type="fn" role="other"><rs type="person" ref="pe__niklas_duerbach_QGW_II_II_3614">Claus Dürbach</rs>
                     <triggerstring n="impl_rules">solich gelt an alles vercziehen uff sant Merteins
                        tag nochst kumende</triggerstring> [ 372] <triggerstring n="fn">ausrichten und
                        beczalen sol</triggerstring></rs>.</rs>
            </p></div><div type="nota"><p>Adresse aussen</p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>