            <date when="14490718">1449 VII 18</date>
            <origDate instant="false">zu Wienn, an freitag vor sand Maria Magdalen
            tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03313_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03313_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3313"><rs type="fn" role="issuer"><rs type="person" ref="pe__georg_waldner_QGW_II_II_3276">Jorg Waldner, der
                           <roleName type="prof">kürsner</roleName>, <roleName type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs>, und <rs type="person" ref="pe__anna_QGW_II_II_3276_a">Anna, sein <roleName type="kin" corresp="pe__georg_waldner_QGW_II_II_3276">hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">bestätigen, dass</triggerstring>
                  <rs type="event" ref="ev__QGW_II_II_3313_men_1"><rs type="fn" role="issuer"><rs type="person" ref="pe__niklas_renhart_QGW_II_II_3282">Niclas Renhart
                              <roleName type="rep" corresp="pe__elisabeth_QGW_II_II_3313"><add>geschefftleut</add></roleName>
                           <roleName type="occ" corresp="org__wien"><add>mitburger</add></roleName></rs> und <rs type="person" ref="pe__johann_puchspaum_QGW_II_II_3038">Hanns Pukchspaum, <rs type="person" ref="pe__elisabeth_QGW_II_II_3313"><roleName type="title">fraun</roleName> Elspeten der Ganiczerin <roleName type="dead">seligen</roleName></rs>
                           <roleName type="rep" corresp="pe__elisabeth_QGW_II_II_3313">geschefftleut</roleName>, <roleName type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs>,</rs>
                     <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_roeren_2"><roleName type="owner" corresp="pe__elisabeth_QGW_II_II_3313">derselben Ganiczerin</roleName>
                           haus, <roleName type="topo" corresp="pl__wien-immo_roeren_1">bei
                              der</roleName>
                           <rs type="place" ref="pl__wien-immo_roeren_1">padstuben zu den Rorn</rs>
                           <roleName type="topo" corresp="pl__wien-roeren"><add>zu den Rorn</add>
                              gelegen</roleName></rs>,</rs>
                     <rs type="fn" role="recipient"><rs type="person" ref="pe__andreas_nuesner_QGW_II_II_3313">ihrem <roleName type="kin" corresp="pe__georg_waldner_QGW_II_II_3276">swager</roleName> und
                              <roleName type="kin" corresp="pe__anna_QGW_II_II_3276_a">pruder</roleName> Andren Nüsner <roleName type="dead">seligen</roleName></rs></rs>
                     <triggerstring n="disp">verkauft</triggerstring>, <rs type="fn" role="transactiongood_II">daran bei dessen Lebzeiten <measure>84 lb
                           dn.</measure> eingenommen</rs></rs>
                  <rs type="event" ref="ev__QGW_II_II_3313_men_2">und <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_roeren_2">es</rs></rs> nach dessen Tode <rs type="fn" role="recipient"><rs type="person" ref="pe__anna_QGW_II_II_3276_a">ihnen</rs>
                        <rs type="person" ref="pe__georg_waldner_QGW_II_II_3276"><add>ihnen</add></rs></rs>
                     <triggerstring n="disp">verkauft haben</triggerstring><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_puchspaum_QGW_II_II_3038"><roleName type="rep" corresp="pe__elisabeth_QGW_II_II_3313"><add>geschefftleut</add></roleName></rs><rs type="person" ref="pe__niklas_renhart_QGW_II_II_3282"><roleName type="rep" corresp="pe__elisabeth_QGW_II_II_3313"><add>geschefftleut</add></roleName></rs></rs></rs>, dass sie sich
                  ferner der 84 lb dn., sowie der nach Begleichung der Begräbniskosten und der
                  rückständigen Schatzsteuer auf 27 lb dn. geschätzten fahrenden Habe des
                  Verstorbenen unterwunden haben, <triggerstring n="disp">und verschreiben</triggerstring>
                  <rs type="fn" role="transactiongood_II">für diese <measure>111 lb
                     dn.</measure></rs>
                  <rs type="fn" role="recipient">dem <rs type="org" ref="org__wien">Bürgermeister
                        und Rathe</rs></rs>
                  <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_roeren_2">das genannte Haus</rs></rs>
                  <triggerstring n="disp">in saczes weis</triggerstring>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>