            <date when="14570919">1457 IX 19</date>
            <origDate instant="false">zu Wienn, an montag vor sannd Matheus tag, des heiligen
               zwelfboten und ewangelisten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03733_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03733_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3733"><rs type="fn" role="issuer"><rs type="person" ref="pe__jakob_menhart_QGW_II_II_3733">Jacob Menhart, der
                           <roleName type="prof">fleischakcher</roleName>, <roleName type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs>,
                     und <rs type="person" ref="pe__martha_SB_CD_00998">Martha, sein <roleName type="kin" corresp="pe__jakob_menhart_QGW_II_II_3733">hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">verkaufen <add>geltes purkchrechts</add></triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951"><roleName type="title">hern</roleName> Niclasen Teschler, <roleName type="occ" corresp="org__wien">burgermaister</roleName> und <roleName type="occ" corresp="org__oesterreich-herzogtum">munnssmaister</roleName></rs>, und
                        <rs type="org" ref="org__wien">des Rathes</rs></rs>
                  <rs type="fn" role="transactiongood_I"><measure>12½ lb dn.</measure>
                     <triggerstring n="fn">geltes purkchrechts</triggerstring> (ablösbar) auf <rs type="place" ref="pl__wien-immo_weihenburg_15"><roleName type="owner" corresp="pe__jakob_menhart_QGW_II_II_3733">ihrem</roleName>
                        <roleName type="owner" corresp="pe__martha_SB_CD_00998"><add>ihrem</add></roleName> Hause, <roleName type="topo" corresp="pl__wien-weihenburg">in der Weihenpurgk gelegen</roleName>
                        zenagst <rs type="place" ref="pl__wien-immo_weihenburg_10"><roleName type="owner" corresp="pe__michael_payrl_QGW_II_II_3356"><rs type="person" ref="pe__michael_payrl_QGW_II_II_3356">Micheln Pair,
                                 des <roleName type="prof">tuchpraitter</roleName></rs></roleName>,
                           Ramhof</rs>
                        <roleName type="topo" corresp="pl__wien-immo_weihenburg_10"><add>zenagst</add> an aim tail</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_weihenburg_1">und mit dem
                           andern zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_weihenburg_1"><roleName type="owner" corresp="pe__johann_kanstorffer_QGW_II_II_3401">Hannsen des
                              Kanstorffer</roleName> haus</rs>, <roleName type="topo" corresp="pl__wien-immo_traubottenstrasse_4">und stosset mit dem hinndern tail
                           an</roleName>
                        <rs type="place" ref="pl__wien-immo_traubottenstrasse_4"><roleName type="owner" corresp="pe__johann_haringseer_QGW_II_II_2387">Hannsen
                              Haringseer</roleName> hof und garten</rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_II">umb <measure>100 lb dn.</measure>, <rs type="event" ref="ev__SB_CD_00067">die emaln gelegen gewesen sind auf
                        Anndres Guendorffer haus in der Wiltwerherstrass, die man damit darab
                           <triggerstring n="disp">geledigt und gelöst hat</triggerstring></rs>,</rs>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__georg_schrot_QGW_II_II_3733"><roleName type="title">hern</roleName>
                        Jorgen Schrot, <roleName type="occ" corresp="org__wien-st_peter-altar_zehntausend_ritter_und_eilftausend_maid-messe_chastner">Kaplan</roleName> der von Eberhart Kastner auf Unser Fraun altar zu sand
                        Peter gestifteten Messe</rs>, und <rs type="org" ref="org__wien-st_peter-altar_zehntausend_ritter_und_eilftausend_maid-messe_chastner">seinen Nachfolgern</rs>.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3733"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="pe__andreas_schoenprugker_QGW_II_II_3376">Wiener
                           <roleName type="occ" corresp="org__wien">Bürgers</roleName> Anndre
                        Schonprugkner</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>