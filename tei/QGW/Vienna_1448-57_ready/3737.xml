   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3737"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__ladislaus_QGW_II_II_3461">König Lasslaw</rs></rs>
                  <triggerstring n="disp">befiehlt</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="org__wien">dem Bürgermeister,
                        Richter und Rathe zu Wien</rs>,</rs> die <triggerstring n="disp">gemech und
                     güter</triggerstring>, <rs type="event" ref="ev__QGW_II_II_3737_men_1">so weilent
                        <rs type="fn" role="issuer"><rs type="person"
                           ref="pe__johann_gerst_QGW_II_II_3737">Hanns Gerst, sein <roleName type="occ" corresp="org__wien">burger</roleName> zu Wienn,
                              <roleName type="dead">hinder sein</roleName></rs></rs>
                     <triggerstring n="disp"><add>hinder sein </add>gelassen hat</triggerstring>,</rs>
                  <triggerstring n="disp">noch weiterhin unter Sperre zu halten</triggerstring>, <rs
                     type="fn" role="other"><triggerstring n="fn">durch</triggerstring>
                     <rs type="person" ref="pe__christoph_potinger_QGW_II_II_3473">Cristoffen
                        Pötinger, seinen <roleName type="occ" corresp="pe__ladislaus_QGW_II_II_3461"
                           >anwalt in dem rat</roleName></rs>,</rs> die Grundherren dieser Güter
                  feststellen zu lassen, die zu dem Nachlasse gehörigen Weingärten zu vechsnen, den
                  Erlös für den verkauften Wein aufzubewahren und ihm einen schriftlichen Bericht
                  einzusenden.</rs>
            </p>
         </div>
         <div type="nota">
            <p>Von anderer Hand: commissio domini regis in consilio. </p>
         </div>
