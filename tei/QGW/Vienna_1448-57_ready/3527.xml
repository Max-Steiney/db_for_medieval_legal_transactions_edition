               <rs type="event" ref="ev__QGW_II_II_3527"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_pellendorfer_QGW_II_II_3527">Hanns von
                        Pellndorf</rs></rs>
                  <triggerstring n="disp">verpflichtet</triggerstring> sich und alle nachfolgenden
                  Besitzer seines Hauses, <rs type="fn" role="transactiongood_II">von <rs type="place" ref="pl__wien-immo_hochstrasse_5">dem hoflein, <roleName type="topo" corresp="pl__wien-immo_hochstrasse_4">zwischen</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_hochstrasse_4">seinem
                              <add>Hauses</add></roleName> und <roleName type="topo" corresp="pl__wien-immo_hochstrasse_6"><add>zwischen</add></roleName>
                        <rs type="place" ref="pl__wien-immo_hochstrasse_6">des <roleName type="owner" corresp="pe__johann_prugkner_QGW_II_II_3523"><roleName type="title">edeln</roleName> Hannsen Prugkner</roleName>
                           heusern</rs>
                        <roleName type="topo" corresp="pl__wien-hochstrasse">auf der Hochstrass zu
                           Wienn gelegen</roleName>, das der stat grunt und ettwenn ain gassen
                        gewesen ist und <rs type="event" ref="ev__GB_D_facs_454_TextRegion_1655809707307_1091">das ihm
                           Bürgermeister und Rath laut eines mit der Stadt klainem insigl
                           besiegelten Spruchbriefes zu seinem Hause verwilligt
                  haben</rs></rs></rs>, <rs type="fn" role="recipient"><rs type="org" ref="org__wien">der Stadt</rs></rs>
                  <rs type="fn" role="transactiongood_I"><triggerstring n="impl_rules">jährlich</triggerstring>
                     <measure>12 dn.</measure>
                     <add>gruntdinst</add>
                     <triggerstring n="impl_rules">zu sand Giligen tag</triggerstring></rs>
                  <triggerstring n="disp">zu rechtem gruntdinst zu dienen</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3527"><rs type="fn" role="witness">Siegler: der
