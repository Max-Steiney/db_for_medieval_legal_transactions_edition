   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3366"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__albrecht_von_bayern_QGW_II_II_3366">Albrecht,
                        phallnnczgrave bei Rein, herzog in Bairn und graf zu Voburg etc.</rs>,</rs>
                  <triggerstring n="disp">an</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="org__wien">Bürgermeister und
                        Rath der Stadt zu Wien</rs>.</rs>
                  <rs type="event" ref="ev__QGW_II_II_3366_men_1"><rs type="fn" role="issuer"><rs
                           type="person" ref="pe__heinrich_per_QGW_II_II_3306"><unclear
                              instant="false"><roleName type="occ"
                                 corresp="pe__albrecht_von_bayern_QGW_II_II_3366">Einer der
                                 Seinen</roleName></unclear>, mit namen Heinrich Ber</rs>,</rs>
                     <triggerstring n="disp">habe</triggerstring>
                     <rs type="fn" role="recipient"><rs type="person"
                           ref="pe__albrecht_von_bayern_QGW_II_II_3366">ihm</rs></rs>
                     <triggerstring n="disp">vorgebracht</triggerstring>, dass er <rs type="fn"
                        role="other"><rs type="person" ref="pe__georg_per_QGW_II_II_3379">einen
                              <roleName type="kin" corresp="pe__heinrich_per_QGW_II_II_3306"
                              >Sohn</roleName>, genant Jorg Ber, <unclear instant="false"><roleName
                                 type="friend" corresp="pe__bartholomaeus_atzinger_QGW_II_II_3366"
                                 >bei dem</roleName></unclear>
                           <rs type="person" ref="pe__bartholomaeus_atzinger_QGW_II_II_3366">Wiener
                                 <roleName type="occ" corresp="org__wien">Bürger</roleName>
                              Bartholomeen Aczinger</rs> habe</rs>, <triggerstring n="fn"><add>in das
                              Gefängnis geworfen worden sei</add></triggerstring></rs> der <rs
                        type="fn" role="other"><triggerstring n="fn">auf Geheiss</triggerstring>
                        <rs type="org" ref="org__wien">des Rathes</rs></rs>
                     <triggerstring n="disp">in das Gefängnis geworfen worden sei</triggerstring>.</rs> Da
                  keinerlei Verschulden des Jorg Ber bekannt sei, <triggerstring n="disp"
                     >ersucht</triggerstring> er sie, <rs type="fn" role="other"><rs type="person"
                        ref="pe__georg_per_QGW_II_II_3379">ihn</rs>
                     <triggerstring n="fn"><add>ersucht</add></triggerstring></rs>
                  <triggerstring n="disp">aus der Gefangenschaft zu entlassen</triggerstring>.</rs>
            </p>
         </div>
