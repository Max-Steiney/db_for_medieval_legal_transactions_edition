            <origDate instant="false">zu Klosterneunburg, an sand Veits tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03521_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03521_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3521"><rs type="fn" role="issuer"><rs type="person" ref="pe__simon_im_turn_QGW_II_II_3521">Simon, <roleName type="occ" corresp="org__klosterneuburg-augustiner_chorherren">brobst</roleName> Unser Fraun gotshauss zu Closterneunburg</rs>,</rs>
                  <triggerstring n="disp">theilt</triggerstring>
                  <rs type="fn" role="recipient">dem <rs type="org" ref="org__wien">Bürgermeister,
                        Richter und Rathe zu Wien</rs></rs>
                  <triggerstring n="disp">mit</triggerstring>, dass <rs type="fn" role="other"><rs type="person" ref="pe__johann_duerr_QGW_II_II_3521">seines Gotteshauses
                           <roleName type="occ" corresp="org__klosterneuburg-augustiner_chorherren" select="pl__meidling">hindersess zu</roleName> Meurling, Hanns Dürr</rs>, <triggerstring n="fn"><add>zu ihnen kommen werde</add></triggerstring></rs>
                  <rs type="event" ref="ev__QGW_II_II_3521_men_1">von ettwevil erbtails und guts
                     wegen, so <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_duerr_QGW_II_II_3521">im</rs></rs>
                     <rs type="fn" role="recipient">von <rs type="person" ref="pe__peter_gwerlich_QGW_II_II_3521">Petern Gwerlich, weilent <rs type="person" ref="pe__elisabeth_QGW_II_II_3521">ihrer <roleName type="occ" corresp="org__wien">mitburgerin</roleName>
                              <roleName type="title">fraun</roleName> Elspethen, <rs type="person" ref="pe__ulrich_kreutrer_QGW_II_II_3521">Ulreichs <roleName type="prof" cert="unknown">Kreutrer</roleName>
                                 <roleName type="title_ref" corresp="pl__wien-kumphlukche_vor_kernertor">in</roleName>
                                 Kumphlukchen <roleName type="dead"><add>witiben</add></roleName></rs>
                              <roleName type="kin" corresp="pe__ulrich_kreutrer_QGW_II_II_3521">witiben</roleName>
                              <roleName type="dead">seligen</roleName></rs>, <roleName type="kin" corresp="pe__elisabeth_QGW_II_II_3521">sun</roleName>, seinem
                              <roleName type="kin" corresp="pe__johann_duerr_QGW_II_II_3521">öhem</roleName></rs>,</rs>
                     <triggerstring n="disp">erblichen zugepüret</triggerstring>,</rs>
                  <triggerstring n="disp">zu ihnen kommen werde, und ersucht sie, denselben in dieser
                     Erbsache zu unterstützen</triggerstring>.</rs>
            </p></div><div type="nota"><p>Adresse aussen.</p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>