            <date when="14511129">1451 XI 29</date>
            <origDate instant="false">zu Wienn, an montag sand Anndres abend,
            appostoli.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03455_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03455_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3455"><rs type="fn" role="issuer"><rs type="person" ref="pe__erasmus_ponhaimer_QGW_II_II_3289">Erasem Ponhaimer,
                           <roleName type="occ" corresp="org__wien">statrichter</roleName> zu
                        Wienn</rs>,</rs>
                  <triggerstring n="disp">beurkundet, dass vor ihm in der Bürgerschranne <add>geclagt
                        und das mit dem rechten erlangt und behabt hiet</add></triggerstring>
                  <rs type="fn" role="other">der <rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951">Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Niclas Teschler</rs>
                     <triggerstring n="fn">mit Vorsprechen</triggerstring> nachgewiesen habe,</rs>
                  <rs type="fn" role="transactiongood_III"><rs type="event" ref="ev__QGW_II_II_3042">dass <rs type="fn" role="recipient"><rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951">er</rs></rs> einst <rs type="fn" role="issuer">auf <rs type="person" ref="pe__johann_kamerstorffer_QGW_II_II_3469">Hannsen des
                              Kamerstorffer, des <roleName type="prof">ziegeldekcher</roleName></rs>, und <rs type="person" ref="pe__anna_QGW_II_II_3469">Anna, seiner <roleName type="kin" corresp="pe__johann_kamerstorffer_QGW_II_II_3469">hausfraun</roleName></rs></rs>, <rs type="fn" role="transactiongood_III"><rs type="place" ref="pl__wien-immo_katerlukchen_1"><roleName type="owner" corresp="pe__anna_QGW_II_II_3469"><add>ihr</add></roleName>
                              <roleName type="owner" corresp="pe__johann_kamerstorffer_QGW_II_II_3469"><add>ihr</add></roleName> haus, <roleName type="topo" corresp="pl__wien-katerlukchen">gelegen in der
                                 Katerlukehen</roleName>
                              <roleName type="topo" corresp="pl__wien-immo_katerlukchen_2">zunagst</roleName>
                              <rs type="place" ref="pl__wien-immo_katerlukchen_2"><roleName type="owner" corresp="pe__johann_schechinger_QGW_II_II_3469">weilent <rs type="person" ref="pe__johann_schechinger_QGW_II_II_3469">Hannsen
                                       Schechinger, des <roleName type="prof">ziegeldekcher</roleName></rs></roleName></rs>, haus, umb
                                 <measure>16 lb dn .</measure>, <rs type="event" ref="ev__QGW_II_II_3455_men_1"><rs type="fn" role="transactiongood_II">dafür <measure><add>16 lb dn
                                       .</add></measure></rs>
                                 <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_katerlukchen_1">es</rs></rs>
                                 <rs type="fn" role="recipient"><rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951">im</rs></rs>
                                 <triggerstring n="disp">versaczt wer</triggerstring>
                                 <rs type="fn" role="issuer"><rs type="person" ref="pe__johann_kamerstorffer_QGW_II_II_3469"/><rs type="person" ref="pe__anna_QGW_II_II_3469"/></rs></rs></rs>,</rs>
                        <triggerstring n="disp">geclagt und das mit dem rechten erlangt und behabt
                           hiet</triggerstring> (vgl. Urk. n° 3042).</rs>
                     <rs type="event" ref="ev__QGW_II_II_3455_men_3">Da <rs type="fn" role="issuer"><rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951">er</rs></rs>
                        <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_katerlukchen_1">es</rs></rs> jetzt <rs type="fn" role="other"><triggerstring n="fn">nach Aussage</triggerstring>
                           <rs type="person" ref="pe__stephan_tengk_QGW_II_II_3455">Stephans des
                              Tenkchen, des <roleName type="occ" corresp="org__wien">rats</roleName>
                              der stat zu Wienn</rs>, und <rs type="person" ref="pe__thomas_egkenperger_QGW_II_II_3455">Thomans des Ekkenperger,
                                 <roleName type="occ" corresp="org__wien">burger</roleName>
                              daselbs</rs>,</rs>
                        <rs type="fn" role="transactiongood_II">um <measure>16 lb dn.</measure></rs>
                        <triggerstring n="disp">verkauft</triggerstring></rs>,</rs>
                  <rs type="fn" role="other"><triggerstring n="fn"><add>hincz</add></triggerstring>
                     <rs type="person" ref="pe__anna_QGW_II_II_3469">die vorgenannte Anna</rs> es
                     aber trotz ausgewiesenen Angebotes nicht gelöst hat</rs>, so <triggerstring n="disp">genehmigt</triggerstring> der Richter <triggerstring n="disp">den
                     Verkauf</triggerstring>.</rs>
            </p></div><div type="nota"><p>Indorsat: Teschler grichtbrief und anpotbrief uber Hannsen Kamerstorffer und Annen,
               seiner hausfraun, <rs type="event" ref="ev__GB_D_facs_439_TextRegion_1655804618858_542"><rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_katerlukchen_1">haus, <roleName type="topo" corresp="pl__wien-katerlukchen">in der
                           Katerlukehen gelegen</roleName>, das</rs></rs>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_hutter_QGW_II_II_3455">Hanns Huter, der <roleName type="prof">pirleutgeb</roleName></rs>,</rs>
                  <triggerstring n="disp">kaufft hat</triggerstring><rs type="fn" role="issuer" cert="high"><rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951"/></rs></rs>. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>