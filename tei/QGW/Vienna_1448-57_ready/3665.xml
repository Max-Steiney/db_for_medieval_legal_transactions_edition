               <rs type="event" ref="ev__QGW_II_II_3665"><rs type="fn" role="issuer"><rs type="person" ref="pe__thomas_von_goellersdorf_QGW_II_II_3087"><roleName type="title">Maister</roleName> Thoman von Gelestorf, <roleName type="prof">licenciat geistlicher rechten</roleName>, <roleName type="occ" corresp="org__wien-st_stephan-kapelle_st_sigmund_und_st_wolfgang-messe_wuerfel">kaplan</roleName> der mess, so die Würffel auf sand Sigmunds und sand
                        Wolfgangs altar zu sand Stephan zu Wienn gestifft habent</rs>,</rs>
                  <triggerstring n="disp">beurkundet</triggerstring>, dass <rs type="event" ref="ev__QGW_II_II_3663">Andre Meichsner, der goltsmid, auf seinem haus am
                     Alten Kolmarcht 12 lb dn.,</rs>
                  <rs type="event" ref="ev__QGW_II_II_3664">Niclas Haug auf seinem haus vor
                     Kernertor 26 lb dn.,</rs>
                  <rs type="event" ref="NULL">Kuncz Klee auf seinem haus auf der Juden freithof
                     daselbs 16 lb dn.</rs> und <rs type="event" ref="NULL">Michel Törl auf seinem
                     haus, am Kienmarkcht gelegen, 28 lb dn. in purkchrechtsweise gehabt und in der
                     stat gruntpuch zu Wienn erlegt und damit abgelöst habent,</rs> dass <rs type="fn" role="recipient"><rs type="person" ref="pe__jakob_rechwein_QGW_II_II_3242">Jacob Rechwein, des <roleName type="occ" corresp="org__wien">rats</roleName><roleName type="occ" corresp="org__wien"><add>Verweser der stat
                        gruntpücher</add></roleName></rs>, und <rs type="person" ref="pe__johann_von_eslarn_QGW_II_II_3334">Hanns von Eslorn, <roleName type="occ" corresp="org__wien">burger</roleName> daselbs, paid
                           <roleName type="occ" corresp="org__wien">Verweser der stat
                           gruntpücher</roleName></rs>,</rs> ihm den Gesammtbetrag nach geschefft
                  und haissen des burgermaister und des rats <triggerstring n="disp">ausbezahlt
                     haben</triggerstring>
                  <rs type="event" ref="NULL">und dass er diese Summe mitsambt anderm gelt für die
                     Messe an ain halbs jeuch weingarten am Nusperg, genant der Leinberger, gelegt
                     habe.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3665"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__johann_viregk_SB_CD_01573">Hannsen
                        Viregken <roleName type="occ" corresp="org__wien"><add>burger</add></roleName></rs> und <rs type="person" ref="pe__simon_von_eslarn_QGW_II_II_3263">Simons von Eslorn, baid <roleName type="occ" corresp="org__wien">burger</roleName> ze
                     Wienn</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>