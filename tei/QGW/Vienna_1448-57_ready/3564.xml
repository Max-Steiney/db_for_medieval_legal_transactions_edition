  <text>
    <body>
      <div type="abstract" resp="kg">
        <p><rs type="event" ref="ev__QGW_II_II_3564"><rs type="fn" role="issuer"><rs type="person"
                ref="pe__ladislaus_QGW_II_II_3461">König Lasslaw</rs></rs>
            <triggerstring n="disp">an</triggerstring>
            <rs type="fn" role="recipient"><rs type="org" ref="org__wien">den Bürgermeister, Rath
                und die burger gemainclich zu Wienn</rs>.</rs>
            <rs type="event" ref="ev__QGW_II_II_3564_men_1"><rs type="fn" role="issuer"><rs
                  type="person" ref="pe__johann_von_maires_QGW_II_II_3818"><roleName type="title"
                    >Maister</roleName> Hanns von Meyrs, <roleName type="occ"
                    corresp="org__gars-pfarre">pharrer</roleName> zu Gars, <rs type="person"
                    ref="pe__albrecht_herzog_von_oesterreich_QGW_II_II_3564">Königs Albrecht
                    II.</rs>
                  <roleName type="occ" corresp="pe__albrecht_herzog_von_oesterreich_QGW_II_II_3564"
                    >canczler</roleName></rs>,</rs> habe seinerzeit für sich und seine Erben <rs
                type="fn" role="issuer">von <rs type="org" ref="org__wien">ihnen</rs></rs>
              <rs type="fn" role="transactiongood_I"><measure>100 lb dn.</measure>
                <triggerstring n="fn">jerlicher gült</triggerstring></rs>
              <triggerstring n="disp"><add>jerlicher gült</add> gekauft</triggerstring></rs>
            <rs type="event" ref="ev__QGW_II_II_3564_men_2">und <rs type="fn" role="recipient">der
                  <rs type="person" ref="pe__ulrich_eitzinger_QGW_II_II_3270"><roleName type="title"
                    >edel</roleName> Ulrich Eyczinger von Eyczingen, des Königs <roleName type="occ"
                    corresp="pe__ladislaus_QGW_II_II_3461">Rath</roleName></rs>,</rs> sei mit <rs
                type="fn" role="issuer">den Erben</rs> übereingekommen, dass sie ihm diese Gült <rs
                type="fn" role="transactiongood_I"><measure><add>100 lb dn.</add></measure>
                <triggerstring n="fn"><add>jerlicher gült</add></triggerstring></rs>
              <triggerstring n="disp"><add>jerlicher gült</add> übergeben</triggerstring>, welche
              Uebergabe er bestätigt habe.</rs> Er <triggerstring n="disp">beauftragt</triggerstring> sie
            daher, <triggerstring n="disp">die Gült von nun</triggerstring> an dem Eitzinger und seinen
            Erben <triggerstring n="disp">zu entrichten</triggerstring>.</rs>
        </p>
      </div>
      <div type="nota">
        <p>Links eigenhändige Unterschrift: Ladislaus Rex manu propria. </p>
      </div>
