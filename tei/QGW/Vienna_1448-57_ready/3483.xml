                                 <triggerstring n="fn">zu purkrecht</triggerstring></rs>, <triggerstring n="disp"><add>zu purkrecht</add> dient</triggerstring></rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_II">um eine Summe Geldes</rs>
                  <rs type="fn" role="recipient">dem <rs type="person" ref="pe__oswald_reicholf_QGW_II_II_3314"><roleName type="occ" corresp="org__wien">Bürgermeister</roleName> Oswalten
