  <text>
    <body>
      <div type="abstract" resp="kg">
        <p>
          <rs type="event" ref="ev__SB_CD_00777"><rs type="fn" role="issuer"><rs type="person"
                ref="pe__johann_haringseer_QGW_II_II_2387">Hanns Haringseer, <roleName type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs>,</rs>
            beurkundet, dass ihm <rs type="fn" role="recipient"><rs type="person"
                ref="pe__klara_SB_CD_00777">seine <roleName type="kin"
                  corresp="pe__johann_haringseer_QGW_II_II_2387">Frau</roleName> Clara</rs></rs>
            <rs type="fn" role="transactiongood_II"><measure>200 lb dn.</measure> zu rechter
                <triggerstring n="fn">haimsteur</triggerstring> zugebracht,</rs> er ihr dagegen <rs
              type="fn" role="transactiongood_II"><measure>200 lb dn.</measure> zu rechter
                <triggerstring n="fn">Widerlegung</triggerstring> versprochen habe,</rs>
            <triggerstring n="disp">und verschreibt</triggerstring> ihr für diese 400 lb dn. <rs type="fn"
              role="other"><triggerstring n="fn">mit Handen</triggerstring>
              <rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951">hern Niclasen des Teschler,
                  <roleName type="occ" corresp="org__wien">burgermaister</roleName> und <roleName
                  type="occ" corresp="org__oesterreich-herzogtum" select="pl__wien"
                  >münssmaister</roleName></rs>, <rs type="org" ref="org__wien">und des
              Rathes</rs></rs>
            <rs type="fn" role="transactiongood_I"><triggerstring n="fn">die Ueberteuerung</triggerstring>
              <rs type="place" ref="pl__wien-immo_muensserstrasse_1"><roleName type="owner"
                  corresp="pe__johann_haringseer_QGW_II_II_2387">seines</roleName> Hauses, <roleName
                  type="topo" corresp="pl__wien-muensserstrasse">gelegen in der
                  Münsserstrass</roleName> zenagst <rs type="place"
                  ref="pl__wien-immo_muensserstrasse_3"><roleName type="owner"
                    corresp="pe__konrad_pilgrim_QGW_II_II_3285">Conrats Piligreim</roleName>
                  haus</rs>
                <roleName type="topo" corresp="pl__wien-immo_muensserstrasse_3"><add>zenagst
                  </add>an aim tail</roleName>
                <roleName type="topo" corresp="pl__wien-immo_muensserstrasse_2">und an dem andern
                  zenagst</roleName>
                <rs type="place" ref="pl__wien-immo_muensserstrasse_2"><roleName type="owner"
                    corresp="pe__stephan_gibing_QGW_II_II_3275">Stephans des Gibing</roleName>
                  haus</rs>, über die 80 lb dn. haimsteur und morgengab, die Hannsen Winkchler vor
                darauf verphennt 1 sein.</rs></rs></rs>
        </p>
