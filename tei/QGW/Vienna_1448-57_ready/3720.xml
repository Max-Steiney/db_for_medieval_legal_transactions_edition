            <placeName>Wien</placeName>
            <date when="14570718">1457 VII 18</date>
            <origDate instant="false">zu Wienn, an montag vor sand Marie Magdalen
            tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03720_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03720_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3720"><rs type="fn" role="issuer"><rs type="person" ref="pe__georg_epishauser_QGW_II_II_3353">Jorg Epishauser,
                           <roleName type="occ" corresp="org__wien">statrichter</roleName> zu
                        Wienn</rs>,</rs>
                  <triggerstring n="disp">beurkundet, dass vor ihm in der Bürgerschranne</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="pe__johann_swentenperger_QGW_II_II_3720">Hanns Swentenperger, der
                           <roleName type="prof">stainmecz</roleName>, <roleName type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs>, <triggerstring n="disp">durch sein vorsprechen</triggerstring></rs> nachgewiesen habe, <rs type="fn" role="transactiongood_III"><rs type="event" ref="ev__QGW_II_II_3720_men_1">wie <rs type="fn" role="issuer">er</rs>
                        <rs type="fn" role="transactiongood_II"><rs type="place" ref="pl__wien-immo_katerlukchen_47"><rs type="person" ref="pe__andreas_hueber_QGW_II_I_1209">Andren des Huber, seins
                                 swager seligen</rs>, guts ain haus, <roleName type="topo" corresp="pl__wien-laimgrub_vor_widmertor">gelegen in der Laimgrub
                                 zu Wienn</roleName>
                              <roleName type="topo" corresp="pl__wien-immo_katerlukchen_44">zwischen</roleName>
                              <rs type="place" ref="pl__wien-immo_katerlukchen_44"><roleName type="owner" corresp="pe__wenzel_swalb_widmer_row_546">Wenczlaben des Swalben</roleName>
                                 <add>heusern</add></rs>
                              <roleName type="topo" corresp="pl__wien-immo_katerlukchen_45">und
                                    <add>zwischen</add></roleName>
                              <rs type="place" ref="pl__wien-immo_katerlukchen_45"><roleName type="owner" corresp="pe__wolfgang_ruland_QGW_II_II_3632">. .
                                    des Ruchlands</roleName> heusern</rs></rs>,</rs>
                        <triggerstring n="disp">mit gericht <add>für eine Satzpost</add></triggerstring>
                        <rs type="fn" role="transactiongood_I">für eine <triggerstring n="fn">Satzpost</triggerstring> von <measure>20 lb dn.</measure></rs>
                        <triggerstring n="disp">verpoten und in verhefftung genomen
                        habe</triggerstring>.</rs></rs>
                  <triggerstring n="impl_rules">Auf seine weitere Klage <rs type="fn" role="other"><triggerstring n="fn">wurde</triggerstring>
                        <rs type="person" ref="pe__thomas_huber_QGW_II_II_3720">Thoman dem Huber
                              <roleName type="title_ref" corresp="pl__perchtoldsdorf"><add>gesessen
                                 zu</add></roleName>
                           <roleName type="kin" corresp="pe__andreas_hueber_QGW_II_I_1209"><add>nagsten erben</add></roleName>
                           <roleName type="friend" corresp="pe__andreas_hueber_QGW_II_I_1209"><add>freunds</add></roleName></rs>, <rs type="person" ref="pe__elisabeth_QGW_II_II_3720">Elspethen, <rs type="person" ref="pe__stephan_schoberl_QGW_II_II_3720">Stephans Schoberleins
                                 <roleName type="dead"><add>wittiben</add></roleName></rs>
                           <roleName type="kin" corresp="pe__stephan_schoberl_QGW_II_II_3720">wittiben</roleName>
                           <roleName type="title_ref" corresp="pl__perchtoldsdorf"><add>gesessen
                                 zu</add></roleName>
                           <roleName type="kin" corresp="pe__andreas_hueber_QGW_II_I_1209"><add>nagsten erben</add></roleName>
                           <roleName type="friend" corresp="pe__andreas_hueber_QGW_II_I_1209"><add>freunds</add></roleName></rs>, und <rs type="person" ref="pe__barbara_QGW_II_II_3720">Barbaren, <rs type="person" ref="pe__peter_larenz_QGW_II_II_3720">Petern Larenczen, des <roleName type="prof">pinter</roleName></rs>, <roleName type="kin" corresp="pe__peter_larenz_QGW_II_II_3720">hausfraun</roleName>, allen
                           drein <roleName type="kin" corresp="pe__elisabeth_QGW_II_II_3720">geswistreiden</roleName>
                           <roleName type="kin" corresp="pe__thomas_huber_QGW_II_II_3720"><add>geswistreiden</add></roleName>, <roleName type="title_ref" corresp="pl__perchtoldsdorf">gesessen zu</roleName> Berchtoltstorf
                              <roleName type="kin" corresp="pe__andreas_hueber_QGW_II_I_1209"><add>nagsten erben</add></roleName>
                           <roleName type="friend" corresp="pe__andreas_hueber_QGW_II_I_1209"><add>freunds</add></roleName></rs>, und <rs type="person" ref="pe__anna_QGW_II_II_3720">Anna, irer <roleName type="kin" corresp="pe__elisabeth_QGW_II_II_3720">mumen</roleName>
                           <roleName type="kin" corresp="pe__thomas_huber_QGW_II_II_3720"><add>mumen</add></roleName>
                           <roleName type="kin" corresp="pe__barbara_QGW_II_II_3720"><add>mumen</add></roleName>, des benanten Swentenperger <roleName type="kin" corresp="pe__johann_swentenperger_QGW_II_II_3720">hausfraun</roleName>, als <roleName type="kin" corresp="pe__andreas_hueber_QGW_II_I_1209">nagsten erben</roleName>
                           des obgemelten Andreen Huber, irs <roleName type="friend" corresp="pe__andreas_hueber_QGW_II_I_1209">freunds</roleName></rs>,
                           <triggerstring n="fn">eine Verständigung übermittelt, deren Zustellung durch
                           einen verslossenn, verpetschadten santbrief von dem richter zu
                           Berchtoltstorf und durch den gesworn fronpoten ausgewiesen
                           wird</triggerstring></rs>.</triggerstring>
                  <triggerstring n="reason">Da die Erben zur Verantwortung nicht erschienen
                     sind</triggerstring>, so <triggerstring n="disp">macht</triggerstring> er <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_swentenperger_QGW_II_II_3720">den Kläger</rs></rs> des
                  Hauses <triggerstring n="disp">gewaltig</triggerstring>.</rs>
            </p></div><div type="nota"><p>Indorsat: gericht auf Hannsen Swenttenperger haus in der Luemgrueb. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>