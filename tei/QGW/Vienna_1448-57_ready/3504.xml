      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3504"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__ursula_QGW_II_II_3504">Ursula</rs> und <rs
                        type="person" ref="pe__katharina_QGW_II_II_3504">Katherina, pet
                        Narczendarfferin, <roleName type="occ" corresp="org__duernstein-klarissen"
                           >classterfrauen</roleName> zu Tirnstain und <roleName type="occ"
                           corresp="org__duernstein-klarissen">conventswestern</roleName>
                        daselbs</rs>,</rs>
                  <triggerstring n="disp">bestätigen, dass</triggerstring> ihnen <rs type="fn"
                     role="recipient"><rs type="person" ref="pe__adam_herting_QGW_II_II_3494">ihr
                           <roleName type="kin" corresp="pe__ursula_QGW_II_II_3504"
                           >Schwager</roleName>
                        <roleName type="kin" corresp="pe__katharina_QGW_II_II_3504"
                              ><add>Schwager</add></roleName>, der <roleName type="title"
                           >edel</roleName> und <roleName type="title">weis</roleName> Adam Hertting
                           <roleName type="title_ref" corresp="pl__wien">zu</roleName>
                     Wienn</rs>,</rs>
                  <rs type="fn" role="transactiongood_II"><rs type="event"
                        ref="ev__QGW_II_II_3504_men_1"><rs type="fn" role="recipient">von <rs
                              type="person" ref="pe__katharina_QGW_II_II_3504">ihrem</rs>
                           <rs type="person" ref="pe__ursula_QGW_II_II_3504"
                           ><add>ihrem</add></rs></rs>
                        <triggerstring n="disp">Antheile an dem Nachlasse</triggerstring>
                        <rs type="fn" role="transactiongood_I"><measure><add>10 lb.
                              dn.</add></measure>
                           <triggerstring n="fn"><add>Antheile an dem Nachlasse</add></triggerstring></rs>
                        <rs type="fn" role="issuer"><rs type="person"
                              ref="pe__georg_narczendorfer_QGW_II_II_3504">ihres <roleName
                                 type="kin" corresp="pe__katharina_QGW_II_II_3504"
                                 >Bruders</roleName>
                              <roleName type="kin" corresp="pe__ursula_QGW_II_II_3504"
                                    ><add>Bruders</add></roleName> Jorgen des
                           Narczendarffer</rs></rs>
                        <measure>10 lb. dn.</measure>
                        <triggerstring n="fn"><add>Antheile an dem
                     Nachlasse</add></triggerstring></rs></rs>
                  <triggerstring n="disp">entrichtet habe</triggerstring>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3504"><rs type="fn" role="witness">Besiegelt mit
                     dem Siegel der <rs type="person" ref="pe__anna_QGW_II_II_3504"><roleName
                           type="occ" corresp="org__duernstein-klarissen">Aebtissin</roleName> Anna
                        von Klamm</rs>.</rs></rs>
            </p>
