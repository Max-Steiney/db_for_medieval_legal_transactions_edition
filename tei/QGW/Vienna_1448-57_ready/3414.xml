                  <triggerstring n="disp">an</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="org__wien">Bürgermeister und
                        Rath zu Wien</rs>.</rs>
                  <rs type="fn" role="other"><rs type="person" ref="pe__johann_schalauczer_QGW_II_II_3414">Hanns Schalauczer, sein
                           <roleName type="occ" corresp="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270">kannczlschreiber</roleName></rs>, <triggerstring n="fn">habe</triggerstring>
