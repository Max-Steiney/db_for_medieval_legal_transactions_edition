                  <triggerstring n="disp">an</triggerstring>
                  <rs type="fn" role="recipient">den <rs type="org" ref="org__wien">Bürgermeister
                        und Rath von Wien</rs></rs>. Er <triggerstring n="disp">sendet</triggerstring>
                  ihnen <rs type="event" ref="ev__QGW_II_II_3314"><rs type="event" ref="ev__QGW_II_II_3316">zwei Schreiben Oswald Reicholffs und Peter
                        Hemtalers, seines Schaffers in Wien, (Urk. n° 3314, 3316) wegen der
                        Geweranschreibung an die streitigen drei Haustheile</rs></rs>
                  <triggerstring n="disp">und ersucht</triggerstring> sie, als Grundherren <rs type="fn" role="other"><rs type="person" ref="pe__barbara_QGW_II_II_3270">die
                        Hölczlin</rs>
                     <triggerstring n="fn"><add>zur Räumung</add></triggerstring></rs>
                  <triggerstring n="disp">zur Räumung</triggerstring> der von ihr besetzten Gemächer
                     <triggerstring n="disp">zu veranlassen</triggerstring>, <triggerstring n="reason">da er
                     an die Gewere geschrieben sei und die Steuer zahle</triggerstring>.</rs>
