   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3698"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__konrad_weingartner_QGW_II_II_3698">Gonnrad
                        Weingartner, der kaiserin <unclear instant="false"><roleName type="occ"
                              corresp="pe__eleonora_QGW_II_II_3698">türhütter</roleName></unclear>
                        <roleName type="rep" corresp="pe__friedrich_weingartner_QGW_II_II_3698"
                              ><add>anstat</add></roleName>
                        <roleName type="rep" corresp="pe__paul_weingartner_QGW_II_II_3698"
                              ><add>anstat</add></roleName>
                        <roleName type="rep" corresp="pe__anna_QGW_II_II_3698"
                           ><add>anstat</add></roleName>
                        <roleName type="rep" corresp="pe__niklas_weingartner_QGW_II_II_3698"
                              ><add>anstat</add></roleName></rs>,</rs>
                  <triggerstring n="disp">stellt</triggerstring> anstat <rs type="person"
                     ref="pe__friedrich_weingartner_QGW_II_II_3698">Fridreichs <roleName type="kin"
                        corresp="pe__agnes_QGW_II_II_3698"><add>Kinder</add></roleName>
                     <roleName type="kin" corresp="pe__konrad_weingartner_QGW_II_II_3698"
                           ><add>Kinder</add></roleName></rs>, <rs type="person"
                     ref="pe__paul_weingartner_QGW_II_II_3698">Pauln <roleName type="kin"
                        corresp="pe__agnes_QGW_II_II_3698"><add>Kinder</add></roleName>
                     <roleName type="kin" corresp="pe__konrad_weingartner_QGW_II_II_3698"
                           ><add>Kinder</add></roleName></rs>, <rs type="person"
                     ref="pe__niklas_weingartner_QGW_II_II_3698">Niclasen <roleName type="kin"
                        corresp="pe__agnes_QGW_II_II_3698"><add>Kinder</add></roleName>
                     <roleName type="kin" corresp="pe__konrad_weingartner_QGW_II_II_3698"
                           ><add>Kinder</add></roleName></rs> und <rs type="person"
                     ref="pe__anna_QGW_II_II_3698">Annen, seiner unmündigen <roleName type="kin"
                        corresp="pe__konrad_weingartner_QGW_II_II_3698">Kinder</roleName>
                     <roleName type="kin" corresp="pe__agnes_QGW_II_II_3698"
                        ><add>Kinder</add></roleName>, die er bei <rs type="person"
                        ref="pe__agnes_QGW_II_II_3698">seiner <roleName type="dead" cert="high"
                           >erern</roleName>
                        <roleName type="kin" corresp="pe__konrad_weingartner_QGW_II_II_3698"
                           >hausfraun</roleName> Agnesen, <rs type="person"
                           ref="pe__thomas_von_orth_QGW_II_II_3406">Thomans des Klemmen von Ort, <rs
                              type="person" ref="pe__katharina_QGW_II_II_3698"><roleName type="dead"
                                 cert="high">ettwen</roleName> Kathrein Paulin, der <roleName
                                 type="prof">kramerin</roleName>
                              <roleName type="title_ref" corresp="pl__wien">zu</roleName>
                           Wienn</rs>, <roleName type="kin" corresp="pe__katharina_QGW_II_II_3698"
                              >pruder</roleName>
                           <roleName type="dead">seligen</roleName></rs>, <roleName type="kin"
                           corresp="pe__katharina_QGW_II_II_3698">tochter</roleName></rs>, gehabt
                     hat</rs>, <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__georg_habinger_QGW_II_II_3657">seinen <roleName type="kin"
                           corresp="pe__thomas_von_orth_QGW_II_II_3406">swegern</roleName>, Jörgen
                        Hebinger von Radendorf</rs> und <rs type="person"
                        ref="pe__georg_engelhart_QGW_II_II_3698"><roleName type="kin"
                           corresp="pe__thomas_von_orth_QGW_II_II_3406"
                           ><add>swegern</add></roleName> Jörgen Englhart</rs>,</rs>
                  <rs type="event" ref="ev__QGW_II_II_3698_men_1">von wegen <rs type="fn"
                        role="transactiongood_I">der <measure>100 lb dn.</measure></rs>, die <rs
                        type="fn" role="recipient"><rs type="person"
                           ref="pe__margarethe_QGW_II_II_3657">Margrethen, desselben Hebinger
                              <roleName type="kin" corresp="pe__georg_habinger_QGW_II_II_3657"
                              >hausfraun</roleName></rs>, <rs type="person"
                           ref="pe__georg_engelhart_QGW_II_II_3698">Jörgen Englhart, irn <roleName
                              type="kin" corresp="pe__margarethe_QGW_II_II_3657"
                           >pruder</roleName></rs>, und die egenanten <rs type="person"
                           ref="pe__niklas_weingartner_QGW_II_II_3698">kinder</rs>
                        <rs type="person" ref="pe__paul_weingartner_QGW_II_II_3698"
                              ><add>kinder</add></rs>
                        <rs type="person" ref="pe__friedrich_weingartner_QGW_II_II_3698"
                              ><add>kinder</add></rs>
                        <rs type="person" ref="pe__anna_QGW_II_II_3698"><add>kinder</add></rs></rs>
                     <triggerstring n="disp">sind anerstorben und angeerbt</triggerstring>
                     <rs type="fn" role="issuer">von <rs type="person" ref="pe__anna_SB_CD_01156"
                           >Annen, der egenanten Paulin, kramerin, <roleName type="kin"
                              corresp="pe__katharina_QGW_II_II_3698">tochter</roleName>, weilent
                           Linharts des Lehenholczer <roleName type="kin"
                              corresp="pe__leonhard_lehenholzer_QGW_II_II_3371">hausfraun</roleName>
                           <roleName type="dead">seligen</roleName></rs>,</rs> und von desselben
                     Lehenholczer geschefftleuten zu der stat gruntpuch erlegt sein zu handen
                     derselben Annen seligen nagst erben ,</rs>
                  <triggerstring n="disp">eine Vollmacht aus</triggerstring>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3698"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__stephan_kisling_QGW_II_II_3622">Stephans
                        Kisling <roleName type="occ" corresp="org__wien"
                           ><add>burger</add></roleName></rs> und <rs type="person"
                        ref="pe__ulrich_volkchl_QGW_II_II_3245">Ulreichs Völkchl, baider <roleName
                           type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs>.</rs></rs>
            </p>
         </div>
