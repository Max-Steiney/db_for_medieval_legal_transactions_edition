                                 <roleName type="kin" corresp="pe__paul_narczendorfer_QGW_II_II_3734"><add>Bruder</add></roleName> Jorgen Narczendörffer</rs></rs>
                           <triggerstring n="disp">anerstorben ist</triggerstring></rs></rs>,</rs>
