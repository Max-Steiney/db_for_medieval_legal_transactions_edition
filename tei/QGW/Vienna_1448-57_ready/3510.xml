                           haus</rs>
                        <roleName type="topo" corresp="pl__wien-immo_roterturm_10"><add>zenagst</add> an aim tail</roleName> , <rs type="event" ref="ev__QGW_II_II_3510_men_1"><rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_roterturm_9">das</rs></rs>
