                              <rs type="person" ref="pe__katharina_QGW_II_II_3504"><roleName type="kin" corresp="pe__paul_narczendorfer_QGW_II_II_3734"><add>Geschwistern</add></roleName></rs></rs>
                           <rs type="fn" role="issuer">von <rs type="person" ref="pe__georg_narczendorfer_QGW_II_II_3504">ihrem <roleName type="kin" corresp="pe__ursula_QGW_II_II_3504">Bruder</roleName>
