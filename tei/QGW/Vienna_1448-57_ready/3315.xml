               <rs type="event" ref="ev__QGW_II_II_3315"><rs type="fn" role="issuer"><rs type="person" ref="pe__niklas_sturm_QGW_II_II_3315">Niclas Sturm, <roleName type="occ" corresp="org__grossenzersdorf-pfarre">pharrer</roleName> zu
                        Grossen Enczestorf</rs>, <rs type="person" ref="pe__anna_QGW_II_II_3315">Anna, sein <roleName type="kin" corresp="pe__niklas_sturm_QGW_II_II_3315">swester</roleName>, <rs type="person" ref="pe__simon_pauchdreml_QGW_II_II_3315">Simons Pauchdremel <roleName type="dead">witib</roleName></rs>
                        <roleName type="kin" corresp="pe__simon_pauchdreml_QGW_II_II_3315"><add>witib</add></roleName></rs>, und <rs type="person" ref="pe__katharina_QGW_II_II_3315">Kathrei, <rs type="person" ref="pe__stephan_brunner_QGW_II_II_3315">Stephans Prunner <roleName type="title_ref" corresp="pl__muehlleitten">zu</roleName> Mulleiten
                              <roleName type="dead">witib</roleName></rs>
                        <roleName type="kin" corresp="pe__stephan_brunner_QGW_II_II_3315"><add>witib</add></roleName>, sein <roleName type="kin" corresp="pe__niklas_sturm_QGW_II_II_3315">mum</roleName></rs>,</rs>
                  <triggerstring n="disp">geloben</triggerstring>, <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_weihenburg_6">das halbe Haus, <roleName type="topo" corresp="pl__wien-weihenburg">gelegen in der Weihenpurg zu
                           Wienn</roleName>, das <roleName type="owner" corresp="pe__thomas_olm_QGW_II_II_3315"><rs type="person" ref="pe__thomas_olm_QGW_II_II_3315"><roleName type="dead">weilent</roleName> Thomans Olm, des <roleName type="prof">tuchpraitter</roleName>, ihres <roleName type="friend" corresp="pe__anna_QGW_II_II_3315">freundes</roleName>
                              <roleName type="friend" corresp="pe__katharina_QGW_II_II_3315"><add>freundes</add></roleName>
                              <roleName type="friend" corresp="pe__niklas_sturm_QGW_II_II_3315"><add>freundes</add></roleName></rs></roleName>, und <roleName type="owner" corresp="pe__elisabeth_QGW_II_II_3315"><rs type="person" ref="pe__elisabeth_QGW_II_II_3315">Elspeten, seiner <roleName type="kin" corresp="pe__thomas_olm_QGW_II_II_3315">hausfraun</roleName>
                              <roleName type="dead">seligen</roleName></rs>, gewesen ist</roleName>,
                           <rs type="event" ref="ev__QGW_II_II_3315_men_1"><rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_weihenburg_6">das</rs></rs>
                           <rs type="fn" role="recipient"><rs type="person" ref="pe__anna_QGW_II_II_3315">sie</rs>
                              <rs type="person" ref="pe__katharina_QGW_II_II_3315"><add>sie</add></rs>
                              <rs type="person" ref="pe__niklas_sturm_QGW_II_II_3315"><add>sie</add></rs></rs>
                           <rs type="fn" role="issuer">von <rs type="person" ref="pe__elisabeth_QGW_II_II_3315">diesen</rs>
                              <rs type="person" ref="pe__thomas_olm_QGW_II_II_3315"><add>diesen</add></rs></rs>
                           <triggerstring n="disp">geerbt und mit dem rechten behabt
                           haben</triggerstring></rs></rs>,</rs>
                  <triggerstring n="disp">inner den nagsten acht wochen ainem, der mit der stat zu
                     Wienn davon leiden sol, zu verkaufen</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3315"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="pe__johann_stickelperger_QGW_II_II_3315"><roleName type="title">edeln</roleName> Hannsen Stiklperger</rs> und <rs type="person" ref="pe__wilhelm_braunsdorfer_QGW_II_II_3315"><roleName type="title"><add>edeln</add></roleName> Wilhalm des
                     Praunstorffer</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: hern Niclasen Sturm, pharrer zu Grossen Enczestorff, und swester und mumen
               verschreibung von Thomans Olm halben hauss wegen . </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>