        <origDate instant="false">zu Wienn, an eritag vor Phingsten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03573_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03573_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
          <rs type="event" ref="ev__QGW_II_II_3573"><rs type="fn" role="issuer"><rs type="person" ref="pe__heinrich_stupper_QGW_II_II_3573">Hainreich Stupper, <roleName type="occ" corresp="org__wien-st_stephan">korherr</roleName> dacz sand Stephan zu Wienn
                  <roleName type="occ" corresp="org__wien-st_agnes_auf_der_himmelpforte-kapelle_st_katharina-messe_stetten"><add>Procuratoren</add></roleName>
                <roleName type="rep" corresp="pe__johann_acrum_QGW_II_II_3573"><add>zu
                  Handen</add></roleName></rs>, und <rs type="person" ref="pe__heinrich_hulger_QGW_II_II_3573">Hainreich Hülger von Stamhaim <roleName type="occ" corresp="org__wien-st_agnes_auf_der_himmelpforte-kapelle_st_katharina-messe_stetten"><add>Procuratoren</add></roleName>
                <roleName type="rep" corresp="pe__johann_acrum_QGW_II_II_3573"><add>zu
                  Handen</add></roleName></rs></rs>
            <triggerstring n="disp">bestätigen <add>Messe</add></triggerstring>, dass sie als Procuratoren
              <rs type="fn" role="transactiongood_II"><rs type="org" ref="org__wien-st_agnes_auf_der_himmelpforte-kapelle_st_katharina-messe_stetten">die
                Messe, so her Mert von Steten in sand Kathrein cappellen dacz der Himelporten hie zu
                Wienn gestifft</rs></rs> und <rs type="fn" role="other"><rs type="person" ref="pe__andreas_raser_QGW_II_II_3573"><roleName type="title">maister</roleName>
                Andre Raser, <roleName type="occ" corresp="org__gmunden-pfarre">pharrer</roleName>
                zu Gmunden <roleName type="occ" corresp="org__wien-st_agnes_auf_der_himmelpforte-kapelle_st_katharina-messe_stetten"><add>weilent Kaplan</add></roleName></rs>, <triggerstring n="fn">freiwillig
                aufgegeben hat</triggerstring>, <rs type="fn" role="recipient">von <rs type="org" ref="org__wien">dem Bürgermeister und Rathe der Stadt zu Wien</rs></rs> zu Handen
                <rs type="person" ref="pe__johann_acrum_QGW_II_II_3573"><roleName type="title">maister</roleName> Hannsen Arcum, <roleName type="occ" corresp="org__vatikan" cert="unknown">secretarien cardinalis sancti Angeli</roleName>
                <roleName type="occ" corresp="org__wien-st_agnes_auf_der_himmelpforte-kapelle_st_katharina-messe_stetten"><add>Kaplan</add></roleName></rs>,</rs>
            <triggerstring n="disp">übernommen haben, und stellen diesen den üblichen Revers
              aus</triggerstring>.</rs>
        </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3573">Besiegelt mit den Siegeln <rs type="person" ref="pe__daniel_hohenkircher_QGW_II_II_3573">Danieln des Hohenkircher <roleName type="occ" corresp="org__wien"><add>burger</add></roleName></rs> und <rs type="person" ref="pe__johann_kamrer_QGW_II_II_3276">Hannsen des Kamrer, baider
                <roleName type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs>.</rs>
        </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>