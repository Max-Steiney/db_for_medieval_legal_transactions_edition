      <body>
         <div type="abstract" resp="kg">
            <p><rs type="event" ref="ev__QGW_II_II_3360"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270"
                        >König Friedrich IV.</rs></rs>
                  <triggerstring n="disp">ertheilt</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__bernhard_von_schaumberg_QGW_II_II_3360"><roleName type="title"
                           >graf</roleName> Pernharten von Schaunberg, seinem <roleName type="occ"
                           corresp="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270"
                           >landtmarschalich</roleName></rs>, <rs type="person"
                        ref="pe__sigmund_von_ebersdorf_QGW_II_II_3309">Sigmunden von Ebersdorff,
                           <roleName type="occ" corresp="org__oesterreich-herzogtum">obristen
                           kamrer</roleName> und <roleName type="occ"
                           corresp="org__oesterreich-herzogtum">hubmaister</roleName> in
                        Österreich</rs>, und <rs type="person"
                        ref="pe__jakob_sebekch_QGW_II_II_3346">Jacoben Sebekchen, seinem <roleName
                           type="occ" corresp="pe__friedrich_v_herzog_von_oesterreich_QGW_II_I_3270"
                           select="org__wien">anwalt</roleName> in seiner burger rat ze
                     Wienn</rs>,</rs>
                  <rs type="event" ref="ev__QGW_II_II_3360_men_1">unter Berufung auf ein früheres,
                     an den Hubmeister gerichtetes Schreiben</rs>
                  <triggerstring n="disp">den Auftrag</triggerstring>, <triggerstring n="disp">den
                     Beschwerden</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn"><add>den
                        Beschwerden</add></triggerstring><rs type="org"
                        ref="org__wien-zeche_fleischhauer">der Wiener Fleischhauer</rs></rs>
                  <rs type="fn" role="other"><triggerstring n="fn">gegen den</triggerstring>
                     <rs type="person" ref="pe__wolfgang_in_der_scheffstraße_QGW_II_II_3360">Wolffl
                        in der Scheffstrass</rs></rs>, <rs type="event"
                     ref="ev__QGW_II_II_3360_men_2"><rs type="fn" role="issuer"><rs type="person"
                           ref="pe__wolfgang_in_der_scheffstraße_QGW_II_II_3360">der</rs></rs>
                     <rs type="fn" role="other"><triggerstring n="fn">mit Erlaubnis</triggerstring>
                        <rs type="org" ref="org__wien">des Bürgermeisters und Rathes</rs></rs>
                     <triggerstring n="disp"><add>Erlaubnis</add></triggerstring><triggerstring
                        n="impl_rules">all markchteg an dem Graben neben anndern gessten fleisch
                        verkauft und damit trotz eines ergangenen Verbotes nagst vor Vasnacht wieder
                        angefangen habe</triggerstring></rs>, <triggerstring n="disp"
                     >abzuhelfen</triggerstring>.</rs>
            </p>
