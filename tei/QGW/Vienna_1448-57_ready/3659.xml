                  <triggerstring n="disp">theilt</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="org__wien">dem Bürgermeister,
                        Richter, Rathe und den Genannten zu Wien</rs></rs>
                  <triggerstring n="disp">mit</triggerstring>, <triggerstring n="reason">dass er bei gutem
