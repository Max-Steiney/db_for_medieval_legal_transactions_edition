               <rs type="event" ref="ev__QGW_II_II_3298"><rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_eitzinger_QGW_II_II_3270">Ulreich Eiczinger
                        von Eiczing</rs></rs>
                  <triggerstring n="disp">an</triggerstring>
                  <rs type="fn" role="recipient">den <rs type="org" ref="org__wien">Bürgermeister,
                        Richter und Rath der Stadt zu Wien</rs></rs>. Das ihm <rs type="fn" role="other"><triggerstring n="fn">zugesandte Schreiben des</triggerstring>
                     <rs type="person" ref="pe__heinrich_von_bayern_QGW_II_II_3293">Herzogs Heinrich
                        von Baiern</rs></rs> habe er <rs type="fn" role="other">seinem <rs type="person" ref="pe__oswald_eitzinger_QGW_II_II_3293"><roleName type="kin" corresp="pe__ulrich_eitzinger_QGW_II_II_3270">Bruder</roleName></rs>
                     <triggerstring n="fn">übergeben</triggerstring></rs>, die Verzögerung seiner Ankunft
                  in Wien bitte er mit den taidingen zwischen denen von Mähren und hern Tzeniken,
                  sowie zwischen dem Abt und den Bürgern von Znaim, durch die er und sein Bruder in
                  Anspruch genommen wurden, zu entschuldigen.</rs>
