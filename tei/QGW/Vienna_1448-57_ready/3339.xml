               <rs type="event" ref="ev__QGW_II_II_3339"><rs type="fn" role="issuer"><rs type="person" ref="pe__susanne_QGW_II_II_3246"><roleName type="title">Swester</roleName> Susanna Sweinbarterinn, <roleName type="occ" corresp="org__wien-st_klara">abtessin</roleName> des
                        fraunklosters dacz sand Klarn zu Wienn</rs>, und <rs type="org" ref="org__wien-st_klara">der convent gemain daselbs</rs></rs>
                  <triggerstring n="disp">bestätigen, dass</triggerstring> ihnen <rs type="fn" role="recipient">der <rs type="person" ref="pe__simon_poetel_QGW_II_II_2412">Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName>
                        Simon Pötl</rs></rs>
                  <rs type="fn" role="transactiongood_II"><measure>50 lb dn.</measure></rs>
                  <triggerstring n="disp">gegeben habe</triggerstring>, <rs type="event" ref="ev__QGW_II_II_3328">die sie an ainen weingarten, vor Stubentor auf dem
                     Vordern Jeus [312] gelegen, genannt der Judenlus, den sie von Pauln Schonnhauer
                     witiben kauften, gelegt haben,</rs>
                  <triggerstring n="disp">und verpflichten sich</triggerstring> dafür <rs type="fn" role="transactiongood_I"><rs type="org" ref="org__wien-st_klara-messe_poetel_magdalena">des negsten freitags vor
                        sand Sixten tag oder aber inner den nagsten acht tagen vor oder den nagsten
                        acht tagen darnach für sein, <rs type="person" ref="pe__magdalena_QGW_II_II_3339">seiner ersten <roleName type="kin" corresp="pe__simon_poetel_QGW_II_II_2412">Hausfrau</roleName> Magdalen
                              <roleName type="dead"><add>Seelenheil</add></roleName></rs> und <rs type="person" ref="pe__johann_scheibelwiser_QGW_II_II_3339">Hannsen
                           Scheiblwiser, seins <roleName type="kin" corresp="pe__simon_poetel_QGW_II_II_2412">varvadern</roleName>,
                              <roleName type="dead">Seelenheil</roleName></rs>
                        <add>einen Jahrtag zu begehen</add></rs></rs>
                  <triggerstring n="disp">einen Jahrtag zu begehen</triggerstring>.</rs>
