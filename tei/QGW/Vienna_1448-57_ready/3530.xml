               <rs type="event" ref="ev__QGW_II_II_3530"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_kuntstokch_QGW_II_II_3530">Hanns Kuntstokch,
                           <roleName type="occ" corresp="org__wien" cert="unknown">gesworner
                           weger</roleName>, <roleName type="occ" corresp="org__wien">burger</roleName> ze Wienn</rs>,</rs>
                  <triggerstring n="disp">stellt</triggerstring>
                  <rs type="fn" role="recipient">dem <rs type="person" ref="pe__christoph_oeczestorffer_QGW_II_II_3245">Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Kristoffen
                        Öczestorffer</rs></rs>
                  <triggerstring n="disp">einen Schuldbrief</triggerstring>
                  <rs type="fn" role="transactiongood_II">über <measure>28 lb dn.</measure>, die
                     dann diezeit im lannd zu Osterreich gib und ge/ab sein, <triggerstring n="impl_rules">rückzahlbar an dem nächsten sand Merten
                     tag</triggerstring>,</rs>
                  <triggerstring n="disp">aus und versetzt</triggerstring> ihm <triggerstring n="disp">zu
                     phant</triggerstring>
                  <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__st_ulrich-immo_1">drei Achtel Weingarten, <roleName type="topo" corresp="pl__st_ulrich">gelegen in der Kelberspeunt</roleName>
                        <roleName type="topo" corresp="pl__st_ulrich-immo_2">zenagst</roleName>
                        <rs type="place" ref="pl__st_ulrich-immo_2"><roleName type="owner" corresp="pe__johann_kellner_QGW_II_II_3530">Hannsen des
                              Kellner</roleName> weingarten</rs></rs>,</rs> als der sacz umb den
                  vorgenanten weingarten mit nucz mit all <rs type="fn" role="other"><triggerstring n="fn">in</triggerstring>
                     <rs type="org" ref="org__wien-st_stephan-kapelle_tierna">sand Moranden
                        cappellen</rs>
                     <triggerstring n="fn">gruntpuch geschoben stet</triggerstring></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3530"><rs type="fn" role="witness">Siegler: der
                        <rs type="person" ref="pe__johann_kuntstokch_QGW_II_II_3530">Aussteller</rs>
                     und der <rs type="person" ref="pe__niklas_renhart_QGW_II_II_3282">Wiener
                           <roleName type="occ" corresp="org__wien">Bürger</roleName> Niclas
                        Re/anhart</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>