               <rs type="event" ref="ev__QGW_II_II_3495"><rs type="fn" role="issuer"><rs type="person" ref="pe__aeneas_QGW_II_II_3495">Aeneas, <roleName type="occ" corresp="org__siena-dioezese">episcopus</roleName> Senensis ac (
                        apostolice) sedis per Bohemiam, Silesiam, Moraviam necnon per civitates,
                        dioceses, terras et loca Aquilegiensis et Saltzburgensis provinciarum in
                        dominiis illustrissimorum Austrie, Stirie, Karinthie et Carniole ducum
                        consistentes et consistencia cum potestate legati de latere nuncius et
                        orator specialiter deputatus</rs>,</rs>
                  <triggerstring n="disp">verleiht</triggerstring>
                  <rs type="fn" role="recipient">allen Reumüthigen, welche an den angegebenen Tagen
                        <rs type="org" ref="org__wien-st_philipp_und_st_jakob_kapelle">die Kapelle
                        der heil. Philipp und Jakob im Kölnerhofe zu Wien</rs> besuchen und zu ihrer
                     Erhaltung beitragen,</rs>
                  <triggerstring n="disp">einen Ablass von 100 Tagen</triggerstring>.</rs>
            </p></div><div type="nota"><p>Auf dem Buge: H. Steynhoff. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>