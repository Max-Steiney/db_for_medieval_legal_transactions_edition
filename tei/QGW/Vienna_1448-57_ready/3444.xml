               <rs type="event" ref="ev__QGW_II_II_3444"><rs type="fn" role="issuer"><rs type="person" ref="pe__wolfgang_pilsner_QGW_II_II_3444">Wolfgang Pilsner,
                        der <roleName type="prof">keuffl</roleName>, <roleName type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs>, und <rs type="person" ref="pe__margarethe_QGW_II_II_3444">Margreth, sein <roleName type="kin" corresp="pe__wolfgang_pilsner_QGW_II_II_3444">hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">bestätigen, dass</triggerstring> sie <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_neulukchen_3">ein Haus, <roleName type="topo" corresp="pl__wien-neulukchen">vor Widmertor in
                           der Neulukchen</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_neulukchen_5">zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_neulukchen_5"><roleName type="owner" corresp="pe__peter_von_pettau_SB_CD_01261"><rs type="person" ref="pe__peter_von_pettau_SB_CD_01261">Petern, des
                                    <roleName type="prof">pheiffer</roleName></rs></roleName>,
                           haus</rs>, gelegen, <rs type="event" ref="ev__QGW_II_II_3444_men_1"><rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_neulukchen_3">das</rs></rs>
                           <rs type="fn" role="issuer">von <rs type="person" ref="pe__ruprecht_muldorffer_SB_CD_01929">Ruprechten, <roleName type="prof">valkchner</roleName></rs>, und <rs type="person" ref="pe__margarethe_SB_CD_01929">Margreten, <roleName type="dead" cert="high">weilent</roleName> seiner <roleName type="kin" corresp="pe__ruprecht_muldorffer_SB_CD_01929">hausfraun</roleName></rs>,</rs>
                           <triggerstring n="disp">in kaufsweise</triggerstring> an <rs type="fn" role="recipient"><rs type="person" ref="pe__margarethe_QGW_II_II_3444">sie</rs>
                              <rs type="person" ref="pe__wolfgang_pilsner_QGW_II_II_3444"><add>sie</add></rs></rs> komen ist</rs></rs>,</rs>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__martin_von_ofen_QGW_II_II_3444">Merten von Ofen, dem <roleName type="prof">trometter</roleName></rs>, und <rs type="person" ref="pe__anna_QGW_II_II_3444">Annen, seiner <roleName type="kin" corresp="pe__martin_von_ofen_QGW_II_II_3444">hausfraun</roleName></rs>,</rs>
                  <triggerstring n="disp">verkauft haben</triggerstring>, <triggerstring n="disp">und stellen
                     hinsichtlich des alten Kaufbriefes, den sie dem Grundbuche nicht vorlegen
                     konnten, dem Bürgermeister und Rathe einen Revers aus</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3444"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__niklas_renhart_QGW_II_II_3282">Niclasen
                        Rênharts <roleName type="occ" corresp="org__wien"><add>burger</add></roleName></rs> und <rs type="person" ref="pe__johann_puchspaum_QGW_II_II_3038">Hannsen Puchspaum, baid <roleName type="occ" corresp="org__wien">burger</roleName> zu
                     Wienn</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: Wolfgang Pilsner versorgbrief umb ainen verlegten kaufbrief. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>