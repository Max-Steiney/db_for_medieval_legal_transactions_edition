                           abgesprungen.</p></seal></sealDesc></physDesc></msDesc></sourceDesc></fileDesc><encodingDesc><projectDesc default="false"><p><label type="contentual-editing">Dissertation Korbinian Grünwald</label></p></projectDesc></encodingDesc><profileDesc><creation>
            <placeName>Wien</placeName>
            <date when="14551210">1455 XII 10</date>
            <origDate instant="false">zu Wienn, an mittichen vor sand Lucein
            tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03653_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03653_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3653"><rs type="fn" role="issuer"><rs type="person" ref="pe__margarethe_QGW_II_II_3653"><roleName type="title">Swester</roleName> Margret, <rs type="person" ref="pe__konrad_oettinger_QGW_II_II_3653">Conrats Öttinger <roleName type="dead"><add>seligen</add></roleName></rs> und <rs type="person" ref="pe__agnes_QGW_II_II_3653">Agnesen, weilent seiner <roleName type="kin" corresp="pe__konrad_oettinger_QGW_II_II_3653">hausfraun</roleName>
                           <roleName type="dead">seligen</roleName></rs>, <roleName type="kin" corresp="pe__konrad_oettinger_QGW_II_II_3653">tochter</roleName>
                        <roleName type="kin" corresp="pe__agnes_QGW_II_II_3653"><add>tochter</add></roleName>, <roleName type="occ" corresp="org__wien-st_laurenz_am_alten_fleischmarkt">conventswester</roleName> des fraunklosters dacz sand Larenczen hie zu
                        Wienn</rs>,</rs>
                  <triggerstring n="disp">theilt</triggerstring>
                  <rs type="fn" role="recipient">dem <rs type="org" ref="org__wien">Bürgermeister
                        und Rathe der Stadt Wien sowie den Verwesern ihres Grundbuches</rs></rs>
                  <triggerstring n="disp">mit</triggerstring>, dass <rs type="event" ref="ev__QGW_II_II_3653_men_1"><rs type="fn" role="issuer">sie</rs>
                     <rs type="fn" role="other"><triggerstring n="fn">mit Einwilligung</triggerstring>
                        <rs type="person" ref="pe__benigna_QGW_II_II_3653"><roleName type="title">swester</roleName> Benigna der Heuslerin, <roleName type="occ" corresp="org__wien-st_laurenz_am_alten_fleischmarkt">maistrin</roleName></rs>, und <rs type="org" ref="org__wien-st_laurenz_am_alten_fleischmarkt">des convents des
                           egenanten klosters</rs></rs>
                     <rs type="fn" role="recipient">gegen <rs type="person" ref="pe__wolfgang_oettinger_QGW_II_II_3653">ihren <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3653">geswistreidten
                              vaterhalben</roleName>, Wolfgangen dem Öttinger</rs> und <rs type="person" ref="pe__katharina_SB_CD_01938"><roleName type="kin" corresp="pe__margarethe_QGW_II_II_3653"><add>geswistreidten
                                 vaterhalben</add></roleName> Kathrein, seiner <roleName type="kin" corresp="pe__wolfgang_oettinger_QGW_II_II_3653">swester</roleName>,
                              <rs type="person" ref="pe__johann_reuttinger_QGW_II_II_3653">Hannsen
                              Reuttinger</rs>
                           <roleName type="kin" corresp="pe__johann_reuttinger_QGW_II_II_3653">hausfraun</roleName></rs> ,</rs>
                     <triggerstring n="disp">verzichtet habe: Auf alle gerechtikait und
                        erbschafft</triggerstring>, so sie gehabt hat an <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_wiltwerkerstrasse_4">ainem halben haus, ganczes
                              <roleName type="topo" corresp="pl__wien-wiltwerkerstrasse">gelegen in
                              der Wiltwercherstrass</roleName>
                           <roleName type="topo" corresp="pl__wien-st_maria_im_rathaus">zenagst</roleName> herrn Otten und Haymen cappellen <roleName type="topo" corresp="pl__wien-immo_st_maria_im_rathaus_1">und ist der
                              hinder tail desselben hauss gegen <add>über</add></roleName>
                           <rs type="place" ref="pl__wien-immo_st_maria_im_rathaus_1">des Würffls
                              haus</rs> über</rs>, . . . . und an <rs type="place" ref="pl__wien-immo_fischerstiege_5">ainer padstuben, <roleName type="topo" corresp="pl__wien-werdertor_unter_den_fischern">gelegen an
                              der Vischer stiegen</roleName>, genant zu den Scheukchen</rs>, <rs type="event" ref="ev__QGW_II_II_3653_men_2"><rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_wiltwerkerstrasse_4">das</rs>
                              <rs type="place" ref="pl__wien-immo_fischerstiege_5"><add>das</add></rs>
                              <rs type="place" ref="pl__wien-immo_hoher_markt_23"><add>das</add></rs> alles</rs>
                           <rs type="fn" role="recipient"><rs type="person" ref="pe__margarethe_QGW_II_II_3653">ihr</rs> und <rs type="person" ref="pe__johann_oettinger_QGW_II_II_3653">ihrem <roleName type="kin" corresp="pe__margarethe_QGW_II_II_3653">bruder</roleName> Hennslein, der ungevogter gestorben
                              ist</rs>,</rs>
                           <rs type="fn" role="issuer">auf des <rs type="person" ref="pe__konrad_oettinger_QGW_II_II_3653">egenanten ihres vaters,
                                 Conrats des Öttinger seligen</rs>,</rs>
                           <triggerstring n="disp">geschefft</triggerstring>
                           <rs type="fn" role="recipient">gegen den egenanten ihren <rs type="person" ref="pe__katharina_SB_CD_01938">geswistreidten</rs>
                              <rs type="person" ref="pe__wolfgang_oettinger_QGW_II_II_3653"><add>geswistreidten</add></rs></rs>
                           <triggerstring n="disp">an rechter tailung gevallen</triggerstring></rs>
                        <rs type="event" ref="ev__QGW_II_II_3653_men_3">und <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_wiltwerkerstrasse_4">das</rs>
                              <rs type="place" ref="pl__wien-immo_fischerstiege_5"><add>das</add></rs>
                              <rs type="place" ref="pl__wien-immo_hoher_markt_23"><add>das</add></rs></rs> darnach <rs type="fn" role="issuer">von
                              demselben <rs type="person" ref="pe__johann_oettinger_QGW_II_II_3653">Hennslein, ihrem bruder <roleName type="dead"><add>gestorben</add></roleName></rs>,</rs> sein <triggerstring n="disp">tail erblich an</triggerstring>
                           <rs type="fn" role="recipient"><rs type="person" ref="pe__margarethe_QGW_II_II_3653">sie</rs> und ihre <rs type="person" ref="pe__katharina_SB_CD_01938">Geschwister</rs>
                              <rs type="person" ref="pe__wolfgang_oettinger_QGW_II_II_3653"><add>Geschwister</add></rs></rs>
                           <triggerstring n="disp">komen ist</triggerstring>,</rs> ferner auf den
                        Erbanspruch an <rs type="place" ref="pl__wien-immo_hoher_markt_23">das klain
                           heuslein, <roleName type="topo" corresp="pl__wien-kursenhaus">gelegen
                              zenagst</roleName>
                           <rs type="place" ref="pl__wien-kursenhaus">dem Ku/orsenhaus</rs>, <rs type="event" ref="ev__QGW_II_II_3653_men_4"><rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_hoher_markt_23">das <rs type="person" ref="pe__matthias_saffer_QGW_II_II_3581">ihr Vetter <roleName type="title">her</roleName> Matthes Saffer <roleName type="dead"><add>Tod</add></roleName></rs>
                                    <roleName type="owner" corresp="pe__matthias_saffer_QGW_II_II_3581">zu leibgeding
                                       inngehabt hat</roleName></rs></rs> und <rs type="fn" role="recipient">den <rs type="person" ref="pe__margarethe_QGW_II_II_3653">Geschwistern</rs>
                                 <rs type="person" ref="pe__wolfgang_oettinger_QGW_II_II_3653"><add>Geschwistern</add></rs>
                                 <rs type="person" ref="pe__katharina_SB_CD_01938"><add>Geschwistern</add></rs></rs> mit dessen Tod <triggerstring n="disp">ledig geworden ist</triggerstring></rs></rs>.</rs></rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3653"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="pe__benigna_QGW_II_II_3653">der
                        Meisterin</rs> und <rs type="org" ref="org__wien-st_laurenz_am_alten_fleischmarkt">des Conventes von St.
                        Laurenz</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>