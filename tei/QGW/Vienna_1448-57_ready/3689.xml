   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3689"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__wolfgang_holczer_SB_CD_01926">Wolfgang
                     Holczer</rs></rs>
                  <triggerstring n="disp">theilt</triggerstring>
                  <rs type="fn" role="recipient">dem <rs type="org" ref="org__wien">Bürgermeister
                        und Rathe der Stadt zu Wien sowie den Verwesern ihres Grundbuches</rs></rs>
                  <triggerstring n="disp">mit</triggerstring>, dass <rs type="event"
                     ref="ev__QGW_II_II_3689_men_1"><rs type="fn" role="issuer"><rs type="person"
                           ref="pe__wolfgang_holczer_SB_CD_01926">er</rs></rs>
                     <rs type="fn" role="transactiongood_I"><rs type="place"
                           ref="pl__wien-immo_pibersturn_1"><roleName type="owner"
                              corresp="pe__wolfgang_holczer_SB_CD_01926">sein</roleName> Haus,
                              <roleName type="topo" corresp="pl__wien-pibersturn">zu Wienn bei dem
                              Pibersturn <add>gelegen</add></roleName>
                           <roleName type="topo" corresp="pl__wien-immo_pibersturn_2"
                              >zenagst</roleName>
                           <rs type="place" ref="pl__wien-immo_pibersturn_2"><roleName type="owner"
                                 corresp="pe__peter_zechmaister_QGW_II_II_3689"><rs type="person"
                                    ref="pe__peter_zechmaister_QGW_II_II_3689">Petern Zechmaister,
                                    des <roleName type="prof"
                                 >fleischhakcher</roleName></rs></roleName>, haus</rs>
                        gelegen</rs>,</rs>
                     <rs type="fn" role="recipient">dem <rs type="person"
                           ref="pe__georg_esel_QGW_II_II_3689">Jörgen Esel</rs></rs>
                     <triggerstring n="disp"><add>verkauft habe</add></triggerstring></rs>
                  <triggerstring n="disp">verkauft habe, und ersucht sie, den Kaufbrief zu
                     fertigen</triggerstring>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3689"><rs type="fn" role="witness">Siegler: der
                        <rs type="person" ref="pe__wolfgang_holczer_SB_CD_01926">Aussteller</rs> und
                        <rs type="person" ref="pe__stephan_gmaitel_QGW_II_II_3526">Stephan Gmaytl,
                           <roleName type="occ" corresp="org__pressburg">statrichter</roleName> zu
                        Prespurgk</rs>.</rs></rs>
            </p>
