               <rs type="event" ref="ev__QGW_II_II_3581"><rs type="fn" role="issuer"><rs type="person" ref="pe__wolfgang_virling_QGW_II_II_3582">Wolfgang Virling,
                           <roleName type="prof">briester</roleName> Passauer bistumbs <roleName type="occ" corresp="org__wien-st_stephan-altar_st_martin-messe_naezeugerin_lucia"><add>Kaplan</add></roleName></rs>,</rs>
                  <rs type="fn" role="recipient">dem der <rs type="person" ref="pe__oswald_reicholf_QGW_II_II_3314"><roleName type="title">edl</roleName>
                        <roleName type="title">vesst</roleName>
                        <roleName type="title">ritter</roleName>
                        <roleName type="title">her</roleName> Oswalt Reicholf, <roleName type="title">burgermaister</roleName></rs>, und <rs type="org" ref="org__wien">der rat der stat zu Wienn</rs></rs>
                  <rs type="fn" role="transactiongood_II"><rs type="org" ref="org__wien-st_stephan-altar_st_martin-messe_naezeugerin_lucia">die <rs type="event" ref="ev__QGW_II_II_3581_men_1">ewig <triggerstring n="disp">mess</triggerstring>, so
                              <rs type="fn" role="issuer"><rs type="person" ref="pe__lucia_QGW_II_I_1018"><roleName type="dead" cert="high">weilent</roleName>
                                 <roleName type="title">frau</roleName> Lucei die Nêczeugerin, <rs type="person" ref="pe__johann_geschiesser_QGW_II_I_1123">Hannsen
                                    Geschiesser <roleName type="dead">witib</roleName></rs>
                                 <roleName type="kin" corresp="pe__johann_geschiesser_QGW_II_I_1123"><add>witib</add></roleName></rs>,</rs>
                           <rs type="fn" role="recipient">auf <rs type="org" ref="org__wien-st_stephan-altar_st_martin">sand Merten altar dacz
                                 sand Stephan zu Wienn</rs></rs>
                           <triggerstring n="disp">zu stifften geschafft
                     hat</triggerstring></rs></rs>,</rs>
                  <rs type="fn" role="other">nach <rs type="person" ref="pe__matthias_saffer_QGW_II_II_3581"><roleName type="title">hern</roleName> Mathesen Saffer, <roleName type="occ" corresp="org__wien-st_stephan-altar_st_martin-messe_naezeugerin_lucia">weilent caplan</roleName> derselben mess <roleName type="dead"><add>abgang</add></roleName></rs>, <triggerstring n="fn">abgang</triggerstring>
                  </rs>
                  <triggerstring n="disp">verlihen habent, gelobt</triggerstring>, die dazu gehörigen
                  Güter <triggerstring n="disp">in gutem Stande zu erhalten, die Messe</triggerstring>
                  <triggerstring n="impl_rules">virstund in der wochen</triggerstring>
                  <triggerstring n="disp">zu lesen</triggerstring>, <triggerstring n="impl_rules">jerlichen
                     an sand Merten tag oder in derselben wochen ain ambt von sand Merten und an
                     Allerseln tag ain slechts selambt zu lesen und alle Quatemer den armen Leuten
                     in dem Bürgerspitale 1 lb dn. von hand zu handen zu geben</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3581"><rs type="fn" role="witness">Besiegelt mit
