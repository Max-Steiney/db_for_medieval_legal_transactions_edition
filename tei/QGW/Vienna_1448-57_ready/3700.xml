            <placeName>Wien</placeName>
            <date when="14570228">1457 II 28</date>
            <origDate instant="false">zu Wienn, an montag nach sand Mathias tag, des heiligen
               zwelfpoten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03700_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03700_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3700"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_hirss_QGW_II_II_3399">Hanns Hirss, <roleName type="occ" corresp="org__wien">burger</roleName> zu
                     Wienn</rs>,</rs>
                  <triggerstring n="disp">stellt</triggerstring>
                  <rs type="fn" role="recipient">seinen <rs type="person" ref="pe__katharina_QGW_II_II_3711"><roleName type="kin" corresp="pe__johann_hirss_QGW_II_II_3399">Kindern</roleName>
                        <roleName type="kin" corresp="pe__helena_QGW_II_II_3399"><add>Kindern</add></roleName> Kathrein</rs>, <rs type="person" ref="pe__wolfgang_hirss_QGW_II_II_3711">Wolfgangen <roleName type="kin" corresp="pe__johann_hirss_QGW_II_II_3399"><add>Kindern</add></roleName>
                        <roleName type="kin" corresp="pe__helena_QGW_II_II_3399"><add>Kindern</add></roleName></rs>, <rs type="person" ref="pe__johann_hirss_QGW_II_II_3711">Hannsen <roleName type="kin" corresp="pe__johann_hirss_QGW_II_II_3399"><add>Kindern</add></roleName>
                        <roleName type="kin" corresp="pe__helena_QGW_II_II_3399"><add>Kindern</add></roleName></rs>, <rs type="person" ref="pe__laurenz_hirss_QGW_II_II_3711">Larenczen <roleName type="kin" corresp="pe__johann_hirss_QGW_II_II_3399"><add>Kindern</add></roleName>
                        <roleName type="kin" corresp="pe__helena_QGW_II_II_3399"><add>Kindern</add></roleName>
                        <roleName type="kin" corresp="pe__johann_hirss_QGW_II_II_3399"><add>Kindern</add></roleName>
                        <roleName type="kin" corresp="pe__helena_QGW_II_II_3399"><add>Kindern</add></roleName></rs> und <rs type="person" ref="pe__michael_hirss_QGW_II_II_3711">Micheln, so er bei seiner <rs type="person" ref="pe__helena_QGW_II_II_3399"><roleName type="kin" corresp="pe__johann_hirss_QGW_II_II_3399">hausfraun</roleName> Helen,
                           auch ettwenn <rs type="person" ref="pe__niklas_tirman_QGW_II_II_3399">Niclasen des Tirmans <roleName type="dead">seligen</roleName></rs>
                           <roleName type="kin" corresp="pe__niklas_tirman_QGW_II_II_3399">hausfraun</roleName></rs>, gehabt hat</rs>,</rs>
                  <triggerstring n="disp">einen Schuldbrief <add>aus</add></triggerstring>
                  <rs type="fn" role="transactiongood_II">über <measure>246 lb dn. der swarczen
                        münss</measure> aus, <rs type="event" ref="ev__QGW_II_II_3399">die Jörgen,
                        des egenanten Tirmans und er Helen sun, auf seinem nachbenannten Hause
                        verschrieben</rs>
                     <rs type="event" ref="ev__QGW_II_II_3700_men_1">und <rs type="fn" role="transactiongood_I"><measure><add>246 lb dn. der swarczen
                                 münss</add></measure></rs>
                        <rs type="fn" role="issuer">von <rs type="person" ref="pe__georg_tirman_QGW_II_II_3399">diesem, der <roleName type="dead">ungevogter gestorben</roleName> ist</rs>,</rs>
                        <rs type="fn" role="recipient">an seine <rs type="person" ref="pe__laurenz_hirss_QGW_II_II_3711"><roleName type="kin" corresp="pe__georg_tirman_QGW_II_II_3399">Geschwister
                                 muterhalben</roleName></rs>
                           <rs type="person" ref="pe__katharina_QGW_II_II_3711"><roleName type="kin" corresp="pe__georg_tirman_QGW_II_II_3399"><add>Geschwister
                                    muterhalben</add></roleName></rs>
                           <rs type="person" ref="pe__wolfgang_hirss_QGW_II_II_3711"><roleName type="kin" corresp="pe__georg_tirman_QGW_II_II_3399"><add>Geschwister muterhalben</add></roleName></rs>
                           <rs type="person" ref="pe__michael_hirss_QGW_II_II_3711"><roleName type="kin" corresp="pe__georg_tirman_QGW_II_II_3399"><add>Geschwister muterhalben</add></roleName></rs>
                           <rs type="person" ref="pe__johann_hirss_QGW_II_II_3711"><roleName type="kin" corresp="pe__georg_tirman_QGW_II_II_3399"><add>Geschwister muterhalben</add></roleName></rs></rs>
                        <triggerstring n="disp"><add>erblich</add> gekommen
                     waren</triggerstring>,</rs></rs>
                  <triggerstring n="disp">verpflichtet sich zur Rückzahlung nach Eintritt der
                     Mündigkeit und setzt</triggerstring> ihnen <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951"><roleName type="title">hern</roleName> Niclasen Teschler, <roleName type="occ" corresp="org__wien">burgermaister</roleName></rs>, und <rs type="org" ref="org__wien">des Rathes</rs></rs>
                  <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_neuer_markt_3"><roleName type="owner" corresp="pe__johann_hirss_QGW_II_II_3399">sein</roleName> Haus, <roleName type="topo" corresp="pl__wien-neuer_markt">gelegen am
                           Neunmarkt</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_neuer_markt_4">zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_neuer_markt_4">weilent der stat
                           Meczengaden</rs></rs>,</rs>
                  <triggerstring n="disp">zu ainem rechten fürphandt</triggerstring>.</rs>
            </p></div><div type="nota"><p>Indorsat: Nota, die Kathrei, Hannsen Hirssen tochter, ist vogtper und irs tails
               bezalt und Michel, ir pruder, ist ungevogt mit tod abgangen und sein tail gelts auf
               seine geswistreid geerbt . </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>