               <rs type="event" ref="ev__QGW_II_II_3639"><rs type="fn" role="issuer"><rs type="person" ref="pe__barbara_QGW_II_II_3639">Barbara, <roleName type="kin" corresp="pe__wilhelm_eitzinger_QGW_II_II_3419"><add>töchter</add></roleName>
                        <rs type="person" ref="pe__matthias_grasser_QGW_II_II_3578a">Mathesen des
                           Grasser</rs> eliche <roleName type="kin" corresp="pe__matthias_grasser_QGW_II_II_3578a">hausfrau</roleName></rs>,
                        <rs type="person" ref="pe__dorothea_QGW_II_II_3639">Dorothe <roleName type="kin" corresp="pe__barbara_QGW_II_II_3639"><add>swestern</add></roleName>
                        <roleName type="kin" corresp="pe__wilhelm_eitzinger_QGW_II_II_3419"><add>töchter</add></roleName></rs> und <rs type="person" ref="pe__katharina_QGW_II_II_3639">Kathrei, ir <roleName type="kin" corresp="pe__barbara_QGW_II_II_3639">swestern</roleName>, all drei <rs type="person" ref="pe__wilhelm_eitzinger_QGW_II_II_3419">Wilhalm des
                           Eyczinger <roleName type="dead">seligen</roleName></rs>
                        <roleName type="kin" corresp="pe__wilhelm_eitzinger_QGW_II_II_3419">töchter</roleName></rs>,</rs>
                  <triggerstring n="disp">theilen</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="org__wien">dem Bürgermeister
                        und Rathe der Stadt zu Wien</rs></rs>
                  <triggerstring n="disp">mit</triggerstring>, dass <rs type="event" ref="ev__QGW_II_II_3639_men_1"><rs type="fn" role="issuer"><rs type="person" ref="pe__dorothea_QGW_II_II_3639">sie</rs>
                        <rs type="person" ref="pe__katharina_QGW_II_II_3639"><add>sie</add></rs>
                        <rs type="person" ref="pe__barbara_QGW_II_II_3639"><add>sie</add></rs></rs>
                     <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_st_johannsstrasse_7">das Haus und <rs type="place" ref="pl__wien-immo_st_johannsstrasse_8">den Garten</rs>, <roleName type="topo" corresp="pl__wien-immo_st_johannsstrasse_8">daengegen
                              uber</roleName>
                           <roleName type="topo" corresp="pl__wien-st_johannsstrasse">in sand
                              Johanns strass</roleName>
                           <roleName type="topo" corresp="pl__wien-immo_st_johannsstrasse_9">zenagst</roleName>
                           <rs type="place" ref="pl__wien-immo_st_johannsstrasse_9"><roleName type="owner" corresp="pe__sigmund_geumann_QGW_II_II_3639">weilent
                                    <rs type="person" ref="pe__sigmund_geumann_QGW_II_II_3639">Sigmunds des Geuman</rs></roleName> haus und garten</rs>
                        gelegen, <rs type="event" ref="ev__QGW_II_II_3639_men_2"><rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_st_johannsstrasse_7">das</rs></rs>
                              <rs type="fn" role="recipient"><rs type="person" ref="pe__dorothea_QGW_II_II_3639">ihnen</rs>
                                 <rs type="person" ref="pe__katharina_QGW_II_II_3639"><add>ihnen</add></rs>
                                 <rs type="person" ref="pe__barbara_QGW_II_II_3639"><add>ihnen</add></rs></rs>
                              <rs type="fn" role="issuer">von <rs type="person" ref="pe__konrad_eitzinger_QGW_II_II_3310">ihres Vaters <roleName type="kin" corresp="pe__wilhelm_eitzinger_QGW_II_II_3419">Bruder</roleName>
                                    <roleName type="title">hern</roleName> Kunraten dem Eiczinger
                                       <roleName type="dead"><add>anerstorben</add></roleName></rs></rs>
                              <triggerstring n="disp">ist anerstorben und
                           anererbt</triggerstring></rs></rs>,</rs>
                     <rs type="fn" role="recipient"><rs type="person" ref="pe__wilhelm_daechsner_QGW_II_II_3639"><roleName type="title">hern</roleName> Wilhalm Dächsser, <roleName type="occ" corresp="org__mailberg-johanniter">maister</roleName> zu
                        Martperg</rs>, und <rs type="org" ref="org__mailberg-johanniter">seinem
                           convent daselbs</rs></rs>
                     <rs type="fn" role="transactiongood_II">um <measure>300 lb dn.</measure></rs>
                     <triggerstring n="disp">verkauft haben</triggerstring>,</rs>
                  <triggerstring n="disp">und ersuchen</triggerstring> sie, den <triggerstring n="disp">Kaufbrief</triggerstring> mit ihrem gruntinsigl <triggerstring n="disp">zu
                     besiegeln</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3639"><rs type="fn" role="witness">Siegler: <rs type="person" ref="pe__barbara_QGW_II_II_3639">die Grasserin</rs> und die
                        <rs type="person" ref="pe__jost_riedenthaler_QGW_II_II_3578"><roleName type="title">edeln</roleName> Jobst Rietentaler</rs> und <rs type="person" ref="pe__wolfgang_herting_QGW_II_II_3362"><roleName type="title"><add>edeln</add></roleName> Wolfgang
                  Hertting</rs>.</rs></rs>
