            <origDate instant="false">zu Wienn, an mittichen vor sand Maria Magdalen
            tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03723_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03723_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3723"><rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_matzleinsdorfer_QGW_II_II_3362">Ulreich
                        Mêczleinstorffer, des <roleName type="occ" corresp="org__wien">rats</roleName> und <roleName type="occ" corresp="org__wien">kamrer</roleName> der stat zu Wienn</rs>, und <rs type="person" ref="pe__michael_rutenstokch_QGW_II_II_3307">Michel Rutenstokch, <roleName type="occ" corresp="org__wien">burger</roleName> daselbs, <roleName type="occ" corresp="org__wien-st_hieronymus">verweser</roleName> des
                        hauss hincz sand Yeronimus zu Wienn</rs>,</rs>
                  <triggerstring n="disp">beurkunden</triggerstring>, dass <rs type="event" ref="ev__QGW_II_II_3723_men_1"><rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_matzleinsdorfer_QGW_II_II_3362">sie</rs><rs type="person" ref="pe__michael_rutenstokch_QGW_II_II_3307"><add>sie</add></rs></rs>
                     <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__mauer-immo_5">einen Weingarten, <roleName type="topo" corresp="pl__mauer">in der Maur
                              an der Leiten gelegen</roleName>, des fünf rechl ist, <rs type="event" ref="ev__QGW_II_II_3723_men_3"><rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__mauer-immo_5">den</rs></rs>
                              <rs type="fn" role="issuer"><rs type="person" ref="pe__elisabeth_QGW_II_II_3315"><roleName type="title">frau</roleName> Elspeth, <rs type="person" ref="pe__thomas_olm_QGW_II_II_3315">Thomans Olm, des
                                          <roleName type="prof">tuchpraitter</roleName>
                                       <roleName type="dead"><add>wittib</add></roleName></rs>,
                                       <roleName type="kin" corresp="pe__thomas_olm_QGW_II_II_3315">wittib</roleName></rs>,</rs>
                              <triggerstring n="disp">umb ainen ewigen jartag</triggerstring>
                              <rs type="fn" role="recipient">zu <rs type="org" ref="org__wien-st_hieronymus">dem egenanten haus</rs></rs>
                              <triggerstring n="disp">ledigklichen geschafft
                        hat</triggerstring></rs></rs>,</rs>
                     <rs type="fn" role="recipient"><rs type="person" ref="pe__konrad_reiff_SB_CD_00226">Chunczen dem Reiffen</rs></rs>
                     <rs type="fn" role="transactiongood_II">umb <measure>60 lb dn.</measure></rs>
                     <triggerstring n="disp"><add>verkauft haben</add></triggerstring></rs>
                  <rs type="event" ref="ev__QGW_II_II_3723_men_2">und <rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_matzleinsdorfer_QGW_II_II_3362"><add>sie</add></rs><rs type="person" ref="pe__michael_rutenstokch_QGW_II_II_3307"><add>sie</add></rs></rs>
                     <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__poetzleinsdorf-immo_1">einen anderen, <roleName type="topo" corresp="pl__poetzleinsdorf">zu Peczleinstorff in der Pêmwol
                              gelegen</roleName>, <rs type="event" ref="ev__QGW_II_II_3723_men_4"><rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__poetzleinsdorf-immo_1">den</rs></rs>
                              <rs type="fn" role="issuer"><rs type="person" ref="pe__elisabeth_QGW_II_II_3740">Elspeth, <rs type="person" ref="pe__thomas_arbaitter_QGW_II_II_3723">Thomans, des
                                          <roleName type="prof">arbaitter</roleName>
                                       <roleName type="dead"><add>witib</add></roleName></rs>,
                                    witib, weilent <roleName type="occ" corresp="org__wien-st_hieronymus">muter</roleName> zu sand
                                    Yeronimus</rs>,</rs>
                              <rs type="fn" role="recipient"><rs type="org" ref="org__wien-st_hieronymus">ebenfalls</rs></rs>
                              <triggerstring n="disp">zu einem Jahrtage geschafft
                              hatte</triggerstring></rs></rs>,</rs>
                     <rs type="fn" role="recipient"><rs type="person" ref="pe__johann_wunsam_StB_I_5">Hannsen dem Wunnsam daselbs zu
                           Peczleinstorf</rs></rs>
                     <rs type="fn" role="transactiongood_II">umb <measure>40 lb dn.</measure></rs>
                     <triggerstring n="disp">verkauft haben</triggerstring>,</rs>
                  <triggerstring n="disp">und verpflichten sich</triggerstring>
                  <rs type="fn" role="recipient">gegen <rs type="person" ref="pe__paul_von_melk_QGW_II_II_3713"><roleName type="title">maister</roleName> Pauln von Melkch, <roleName type="prof">lerer in der
                           heiligen geschafft</roleName>, <roleName type="occ" corresp="org__wien-st_stephan">korherr</roleName> dacz sand Stephan,
                           <roleName type="occ" corresp="org__wien-st_hieronymus-kapelle_st_hieronymus">obristen
                           caplan</roleName> und <roleName type="occ" corresp="org__wien-st_hieronymus-kapelle_st_hieronymus">verweser</roleName> sand Yeronimus cappellen daselbs</rs>, und <rs type="org" ref="org__wien-st_hieronymus-kapelle_st_hieronymus">seine
                        Nachfolger</rs>
                     <rs type="org" ref="org__wien-st_hieronymus-messe_olmin_elisabeth"><add>für den
                           einen Jahrtag</add></rs>
                     <rs type="org" ref="org__wien-st_hieronymus-messe_arbaitterin_elisabeth"><add>für den andern</add></rs>,</rs>
                  <rs type="fn" role="transactiongood_II">für den einen Jahrtag <triggerstring n="fn">jährlich</triggerstring>
                     <measure>3 sh. dn.</measure>, für den andern <measure>60 dn.</measure>
                     <triggerstring n="fn"><add>zu dienen</add></triggerstring></rs>
                  <triggerstring n="disp">zu dienen</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3723"><rs type="fn" role="witness">Besiegelt mit
                     dem Siegel des <rs type="org" ref="org__wien-st_hieronymus">hauss zu sand
                        Yeronimus</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>