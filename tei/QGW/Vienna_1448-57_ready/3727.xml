    <text>
        <body>
            <div type="abstract" resp="kg">
                <p>
                    <rs type="event" ref="ev__QGW_II_II_3727"><rs type="fn" role="issuer"><rs
                                type="person" ref="pe__johann_hiltprant_QGW_II_II_3727">Hanns
                                Hiltprant, <roleName type="occ" corresp="org__braunau"
                                    >mitburger</roleName> zu Praunau, <roleName type="rep"
                                    corresp="pe__konrad_rugelhofer_QGW_II_II_3727"
                                    ><add>anstat</add></roleName>
                                <roleName type="rep" corresp="pe__konrad_rugelhofer_QGW_II_II_3727"
                                        ><add>zu hannden</add></roleName></rs></rs>
                        <triggerstring n="disp">bestätigt</triggerstring>, anstat und zu hannden <rs
                            type="person" ref="pe__konrad_rugelhofer_QGW_II_II_3727">Conrats
                            Ruglhofer, auch <roleName type="title_ref" corresp="pl__braunau"
                                >zu</roleName> Praunau wonhaft</rs>, <rs type="fn" role="other"
                                ><triggerstring n="fn">auf ein Schreiben</triggerstring> des <rs
                                type="org" ref="org__braunau">Rathes zu Braunau</rs></rs>
                        <rs type="fn" role="recipient">von <rs type="org" ref="org__wien">dem
                                Bürgermeister, Richter und Rathe der Stadt zu Wien</rs></rs>
                        <rs type="fn" role="transactiongood_II">des egenanten Conrats Ruglhofer
                            gewant und klainat, <rs type="event" ref="NULL">so er bei <rs
                                    type="person" ref="pe__georg_gredinger_QGW_II_II_3727">seinem
                                        <roleName type="prof">wirt</roleName>
                                    <unclear instant="false"><roleName type="occ"
                                            corresp="pe__konrad_rugelhofer_QGW_II_II_3727"
                                                ><add>wirt</add></roleName></unclear> Jörgen
                                    Gredinger</rs> daselbs gelassen und dieser ihnen übergeben
                                hatte</rs>,</rs>
                        <triggerstring n="disp">erhalten zu haben</triggerstring>.</rs>
                </p>
            </div>
            <div type="seal">
                <p><rs type="event" ref="ev__QGW_II_II_3727"><rs type="fn" role="witness">Besiegelt
                            mit den Siegeln <rs type="person"
                                ref="pe__thomas_praitenweidacher_QGW_II_II_3462">Thomans
                                Praitenwaidacher <roleName type="occ" corresp="org__wien"
                                        ><add>burger</add></roleName></rs> und <rs type="person"
                                ref="pe__georg_gredinger_QGW_II_II_3727">Jörgen Gredinger, baid
                                    <roleName type="occ" corresp="org__wien">burger</roleName>
                                zu Wienn</rs>.</rs></rs>
                </p>
            </div>
