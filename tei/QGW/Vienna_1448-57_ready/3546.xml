            <placeName>Wien</placeName>
            <date when="14531126">1453 XI 26</date>
            <origDate instant="false">zu Wienn, an montag nach sand Kathrein
            tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03546_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03546_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3546"><rs type="person" ref="pe__johann_schalauczer_QGW_II_II_3414">Hanns Schalaunczer, <roleName type="occ" corresp="org__wien">burger</roleName> zu Wienn,</rs>
                  <triggerstring n="disp">beurkundet</triggerstring>, dass <rs type="event" ref="ev__QGW_II_II_3546_men_1"><rs type="fn" role="recipient"><rs type="person" ref="pe__johann_schalauczer_QGW_II_II_3414">ihm</rs></rs>
                     <rs type="fn" role="issuer"><rs type="person" ref="pe__barbara_QGW_II_II_3414">seine <roleName type="kin" corresp="pe__johann_schalauczer_QGW_II_II_3414">hausfrau</roleName>
                           Barbara, Andres Hiltprants von Meran seligen tochter</rs>,</rs>
                     <rs type="fn" role="transactiongood_I"><measure>400 lb dn.</measure> zu rechter
                           <triggerstring n="fn">haimbsteur</triggerstring></rs>
                     <triggerstring n="disp">zugebracht</triggerstring>, er ihr dagegen <rs type="fn" role="transactiongood_II"><measure>600 lb dn.</measure> zu rechter
                           <triggerstring n="fn">morgengab</triggerstring></rs>
                     <triggerstring n="disp">und Widerlegung versprochen habe</triggerstring>,</rs>
                  <triggerstring n="disp">und setzt</triggerstring>
                  <rs type="fn" role="recipient">ihr</rs>
                  <rs type="fn" role="transactiongood_II">für diese <measure>1000 lb
                     dn.</measure></rs>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951"><roleName type="title">hern</roleName> Niclasen Teschler, <roleName type="occ" corresp="org__wien">burgermaister</roleName></rs>, und <rs type="org" ref="org__wien">des Rathes</rs></rs>
                  <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_peurertor_3"><roleName type="owner" corresp="pe__johann_schalauczer_QGW_II_II_3414">sein</roleName> Haus,
                           <roleName type="owner" corresp="pe__leonhard_suss_QGW_II_II_3546">das
                           Lienharten Süssen gewesen ist</roleName>, <roleName type="topo" corresp="pl__wien-st_peter-freithof">gelegen mit ainem tail an sand
                           Peters freithof</roleName>
                        <roleName type="topo" corresp="pl__wien-graben">und mit dem andern an dem
                           Graben</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_peurertor_2">zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_peurertor_2">Mertten Schrots haus</rs>,
                           <rs type="event" ref="ev__QGW_II_II_3546_men_2"><rs type="fn" role="issuer">von <rs type="place" ref="pl__wien-immo_peurertor_3">dem</rs> man</rs>
                           <rs type="fn" role="recipient"><rs type="org" ref="org__wien-schotten">dem Schottenkloster</rs></rs>
                           <rs type="fn" role="transactiongood_I"><measure>60 dn.</measure>
                              <triggerstring n="impl_rules">zu sand Michels tag</triggerstring>
                              <triggerstring n="fn">zu purkrecht</triggerstring></rs>
                           <triggerstring n="disp"><add>zu purkrecht</add>
                     dient</triggerstring></rs></rs>,</rs>
                  <triggerstring n="disp">zu ainem rechten furphant</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3546">Besiegelt mit dem Siegel des <rs type="person" ref="pe__johann_schalauczer_QGW_II_II_3414">Ausstellers</rs>, <rs type="org" ref="org__wien">dem städtischen Grundsiegel</rs> und dem Siegel des
                     <rs type="person" ref="pe__friedrich_ebmer_QGW_II_II_3350"><roleName type="title">edeln</roleName>
                     <roleName type="title">festen</roleName>
                     <roleName type="title">Ritters</roleName>, <roleName type="title">Herrn</roleName> Fridreich des Ebmer, <roleName type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs>.</rs>
            </p></div><div type="nota"><p>Indorsat: gemächtbrief der Schalauczerin. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>