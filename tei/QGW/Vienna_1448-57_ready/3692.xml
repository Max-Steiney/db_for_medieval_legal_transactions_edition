   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__SB_CD_01467"><rs type="fn" role="issuer"><rs type="person"
                        ref="pe__niklas_planer_QGW_II_II_3692">Niclas Planer, <roleName type="occ" corresp="org__wien">burger</roleName> ze
                     Wienn</rs>,</rs> stellt <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__johann_foechl_QGW_II_II_3692">Hannsen Föchlein <roleName
                           type="title_ref" corresp="pl__memmingen">von</roleName> Mêmingen</rs> und
                     seiner gesellschaft</rs>
                  <rs type="fn" role="transactiongood_II">einen Schuldbrief über <measure>1359 lb 3
                        sh. dn. der swarczen münss</measure></rs> aus, <triggerstring n="impl_rules"
                     >verpflichtet sich zur ratenweisen Rückzahlung an den vereinbarten
                     Terminen</triggerstring> und<triggerstring n="disp"> setzt</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951"><roleName
                           type="title">hern</roleName> Niclasen des Teschler, <roleName type="occ"
                           corresp="org__wien">burgermaister</roleName> und <roleName type="occ"
                           corresp="org__oesterreich-herzogtum" select="pl__wien"
                           >münssmaister</roleName></rs>, <rs type="org" ref="org__wien">und des
                        Rathes</rs></rs>
                  <rs type="fn" role="transactiongood_I"><rs type="place"
                        ref="pl__wien-immo_fischhof_1"><roleName type="owner"
                           corresp="pe__niklas_planer_QGW_II_II_3692">sein</roleName> Haus,
                           <roleName type="topo" corresp="pl__wien-fischhof">gelegen daselbs im
                           Vischhof</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_fischhof_3">zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_fischhof_3"><roleName type="owner"
                              corresp="pe__niklas_knauss_QGW_II_II_3549">Niclasen des
                              Knäussen</roleName> haus</rs></rs>,</rs>
                  <triggerstring n="disp">zu ainem rechten fürphant</triggerstring>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__SB_CD_01467"><rs type="fn" role="witness">Besiegelt mit dem
                        <rs type="org" ref="org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="pe__johann_kuntstokch_QGW_II_II_3530">Wiener
                           <roleName type="occ" corresp="org__wien">Bürgers</roleName> Hanns
                        Kuntstokch, <roleName type="occ" corresp="org__wien">gesworner
                           weger</roleName></rs>.</rs></rs>
            </p>
         </div>
