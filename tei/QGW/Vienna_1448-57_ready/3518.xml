          <rs type="event" ref="ev__QGW_II_II_3518"><rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_hirssauer_QGW_II_II_3518">Ulreich Hirssauer, <roleName type="prof">maister der sieben freien kunst</roleName>, <roleName type="occ" corresp="org__wien-st_hieronymus-kapelle_st_hieronymus-altar_gottesleichnam-messe_abel_margarethe">Kaplan</roleName> der <rs type="event" ref="ev__QGW_II_II_3518_men_1"><rs type="fn" role="issuer">von
                      <rs type="person" ref="pe__margarethe_QGW_II_I_1235"><roleName type="title">frau</roleName> Margret, <rs type="person" ref="pe__simon_abel_QGW_II_I_1235">Simons des Abels von Nösen in Sibenbürgen
                          <roleName type="dead"><add>witib</add></roleName></rs>
                      <roleName type="kin" corresp="pe__simon_abel_QGW_II_I_1235">witib</roleName></rs>,</rs>
                  <rs type="fn" role="recipient">auf <rs type="org" ref="org__wien-st_hieronymus-kapelle_st_hieronymus-altar_gottesleichnam">Goczleichnams altar in sand Yeronimi kappellen hie zu Wienn</rs></rs>
                  <triggerstring n="disp">gestifteten Messe</triggerstring></rs></rs>,</rs>
            <triggerstring n="disp">übergibt</triggerstring>
            <rs type="fn" role="recipient">dem <rs type="person" ref="pe__niklas_teschler_QGW_II_II_2951"><roleName type="occ" corresp="org__wien">Bürgermeister</roleName>
                <roleName type="title">hern</roleName> Niclas Teschler</rs> und <rs type="org" ref="org__wien">dem Rathe</rs></rs>
            <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_neuer_markt_5">das <roleName type="owner" corresp="org__wien-st_hieronymus-kapelle_st_hieronymus-altar_gottesleichnam-messe_abel_margarethe">zu der Messe gehörige</roleName> Haus, <roleName type="topo" corresp="pl__wien-neuer_markt">mit dem vordern tail an dem Neunmarkcht</roleName>
                <roleName type="topo" corresp="pl__wien-immo_neuer_markt_6">zwischen</roleName>
                <rs type="place" ref="pl__wien-immo_neuer_markt_6">der Heiligen Geister
                    <add>heusern</add></rs>
                <roleName type="topo" corresp="pl__wien-immo_neuer_markt_7">und
                  <add>zwischen</add></roleName>
                <rs type="place" ref="pl__wien-immo_neuer_markt_7">des Prantesser heusern</rs>
                <roleName type="topo" corresp="pl__wien-kaerntnerstrasse">und mit dem hindern tail
                  in der Kernerstrass</roleName>
                <roleName type="topo" corresp="pl__wien-immo_kaerntnerstrasse_16">zwischen</roleName>
                <rs type="place" ref="pl__wien-immo_kaerntnerstrasse_16"><roleName type="owner" corresp="pe__niklas_kramhofer_QGW_II_II_3278">Niclasen Kramhofer</roleName>
                  <add>heusern</add></rs>
                <roleName type="topo" corresp="pl__wien-immo_kaerntnerstrasse_9">und
                    <add>zwischen</add></roleName>
                <rs type="place" ref="pl__wien-immo_kaerntnerstrasse_9"><roleName type="owner" corresp="pe__michael_paumgartner_QGW_II_II_2159"><rs type="person" ref="pe__michael_paumgartner_QGW_II_II_2159">Micheln Paumgartner, des
                        <roleName type="prof">flöczer</roleName></rs></roleName>, heusern</rs>
                gelegen, zu ainem melkasten und melgrub und zu andern notdurften</rs>,</rs>
            <triggerstring n="disp">wogegen</triggerstring> diese zur Messe <rs type="fn" role="transactiongood_II"><triggerstring n="fn">jährlich <add>gült</add></triggerstring>
              <measure>32 Ungerisch guldein</measure>, gerecht in gold und wag, oder für jeden
              guldein sovil Wienner phening, als er dieselb zeit gebig ist ,</rs>
            <triggerstring n="disp">reichen sollen</triggerstring>.</rs>
        </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3518"><rs type="fn" role="witness">Siegler: <rs type="person" ref="pe__johann_aichelperger_QGW_II_II_3518"><roleName type="title">her</roleName> Hanns Aichelperger, <roleName type="prof">lerer bäbstlicher
