                        <roleName type="topo" corresp="pl__wien-immo_baeckerstrasse_vordere_5">zenagst <add>an aim tail</add></roleName>
                        <rs type="place" ref="pl__wien-immo_baeckerstrasse_vordere_5"><roleName type="owner" corresp="pe__reinhard_tettlinger_QGW_II_II_3362"><rs type="person" ref="pe__reinhard_tettlinger_QGW_II_II_3362">Reinharts, des <roleName type="occ" corresp="org__oesterreich-herzogtum">hannsgrafen</roleName>,</rs></roleName> haus</rs> an aim
