               <rs type="event" ref="ev__QGW_II_II_3305"><rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_eitzinger_QGW_II_II_3270">Ulreich Eiczinger
                        von Eiczing</rs></rs>
                  <triggerstring n="disp">theilt</triggerstring>
                  <rs type="fn" role="recipient">dem <rs type="org" ref="org__wien">Bürgermeister
                        und Rathe der Stadt zu Wien</rs></rs>
                  <triggerstring n="disp">mit</triggerstring>, dass <rs type="event" ref="ev__QGW_II_II_3304_men_1">die Absage seines Bruders Oswald an den Herzog
                     Heinrich in Baiern</rs>
                  <triggerstring n="disp">ohne sein Wissen und gegen seinen Willen erfolgt
                     sei</triggerstring>, dass <rs type="fn" role="other"><rs type="person" ref="pe__stephan_eitzinger_QGW_II_II_3305">sein <roleName type="kin" corresp="pe__ulrich_eitzinger_QGW_II_II_3270">Bruder</roleName>
                        Stephan</rs>
                     <triggerstring n="fn">sie über die Ursachen und den Verlauf des Streites
                        unterrichtet habe</triggerstring></rs>, <triggerstring n="disp">und dass er
                     geneigt sei, weiterhin in der Sache zu vermitteln</triggerstring> und zu seinem
                  Bruder nach Drosendorf zu reiten.</rs>
            </p></div><div type="nota"><p>Adresse aussen.</p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>