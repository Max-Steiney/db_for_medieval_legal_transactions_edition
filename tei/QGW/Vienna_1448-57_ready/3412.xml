               <rs type="event" ref="ev__QGW_II_II_3412"><rs type="fn" role="issuer"><rs type="person" ref="pe__erasmus_ponhaimer_QGW_II_II_3289">Erasem Ponhaimer,
                           <roleName type="occ" corresp="org__wien">statrichter</roleName> zu
                        Wienn</rs>,</rs>
                  <triggerstring n="disp">beurkundet, dass vor ihm in der Bürgerschranne</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="pe__peter_ebinger_QGW_II_II_3412">Peter Ebinger, der <roleName type="prof">tuchscherer</roleName>, <roleName type="occ" corresp="org__wien">burger</roleName> zu Wienn</rs>, <triggerstring n="fn">mit vorsprechen</triggerstring></rs>
                  <rs type="fn" role="other"><triggerstring n="fn">hincz</triggerstring>
                     <rs type="person" ref="pe__ulrich_plankch_QGW_II_II_3412">Ulreichen dem
                        Plankchen, etwen <unclear instant="false"><roleName type="prof">pedellen</roleName></unclear>, <roleName type="occ" corresp="org__wien">mitburger</roleName> daselbs</rs>,</rs>
                  <rs type="fn" role="transactiongood_III">umb <measure>11 lb dn .</measure>, <rs type="event" ref="ev__QGW_II_II_3412_men_1">die <rs type="fn" role="recipient"><rs type="person" ref="pe__peter_ebinger_QGW_II_II_3412">im</rs></rs> noch unbezalt ausstunden an den <rs type="fn" role="transactiongood_I">20 lb dn.</rs>, so <rs type="fn" role="issuer"><rs type="person" ref="pe__ulrich_plankch_QGW_II_II_3412">er</rs> und
                           auch <rs type="person" ref="pe__kaspar_hesiber_QGW_II_II_3412">Caspar
                                 <roleName type="occ" corresp="org__wien"><add>mitburger</add></roleName></rs> und <rs type="person" ref="pe__michael_hesiber_QGW_II_II_3412">Michel, <roleName type="kin" corresp="pe__kaspar_hesiber_QGW_II_II_3412">gebrüder</roleName>,
                              die hesiber, <roleName type="occ" corresp="org__wien">mitburger</roleName> zu Wienn</rs></rs>, unverschaidenlich im
                           <triggerstring n="disp">nach laut aines geltbriefs schuldig
                           wern</triggerstring></rs>,</rs>
                  <triggerstring n="disp">geklagt habe, und spricht</triggerstring>
                  <rs type="fn" role="recipient">ihm</rs>
                  <triggerstring n="disp">das Pfandrecht auf dem Gute des Schuldners
                  zu</triggerstring>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>