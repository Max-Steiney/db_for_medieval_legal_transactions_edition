               <rs type="event" ref="ev__QGW_II_II_3480"><rs type="fn" role="issuer"><rs type="person" ref="pe__thomas_zimmermann_QGW_II_II_3480">Thoman, <roleName type="prof">zimerman</roleName>, <roleName type="title_ref" corresp="pl__sievering">gesessen zu</roleName> Obernsüfring</rs>,</rs>
                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="pe__johann_hechtl_QGW_II_II_3480"><roleName type="title">hern</roleName> Hannsen Hechtl, <roleName type="occ" corresp="org__klosterneuburg-augustiner_chorherren">korhern</roleName>
