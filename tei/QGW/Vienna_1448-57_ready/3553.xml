   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3553"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__wolfgang_freytag_QGW_II_II_3553">Wolfgang
                        Freytag</rs></rs>
                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> seiner <rs
                        type="person" ref="pe__johann_hechtl_QGW_II_II_3480"><roleName type="title"
                           >Bergherren</roleName>, <roleName type="title">hern</roleName> Hannsen
                        Hechtl, <roleName type="occ"
                           corresp="org__klosterneuburg-augustiner_chorherren">korherr</roleName>
                        und <roleName type="occ" corresp="org__klosterneuburg-augustiner_chorherren"
                           >obristen kellner</roleName> Unser Fraun gotshauss zu
                        Klosterneunburg</rs>, darnach <rs type="person"
                        ref="pe__stephan_QGW_II_II_3553"><roleName type="title"
                              ><add>Bergherren</add></roleName>
                        <roleName type="title">hern</roleName> Stephans, <roleName type="occ"
                           corresp="org__kranichberg-pfarre">pharrer</roleName> zu Kranperg</rs>,
                     und des <rs type="person"
                        ref="pe__hermann_eibensteiner_zu_nussdorf_QGW_II_II_3246"><roleName
                           type="title">edeln</roleName> Hermans Eybenstainer <roleName
                           type="title_ref" corresp="pl__nussdorf">zu</roleName> Nustorff <roleName
                           type="title"><add>Bergherren</add></roleName></rs>,</rs>
                  <rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__grinzing-immo_8"
                           ><roleName type="owner" corresp="pe__wolfgang_freytag_QGW_II_II_3553"
                           >seinen</roleName> weingarten, des emaln drei weingerten gewesen sind,
                           <roleName type="topo" corresp="pl__grinzing">gelegen im Mukkental hinder
                           Grinczing auf dem Nuspach</roleName>, des fünf virtail ist, <roleName
                           type="topo" corresp="pl__grinzing-immo_9">zenagst oberthalb</roleName>
                        <rs type="place" ref="pl__grinzing-immo_9"><roleName type="owner"
                              corresp="pe__georg_nadler_QGW_II_II_3553"><rs type="person"
                                 ref="pe__georg_nadler_QGW_II_II_3553"><roleName type="title"
                                    >hern</roleName> Jörgen des Nadler, eins <roleName type="prof"
                                    >priesters</roleName></rs></roleName>, weingarten</rs>, <rs
                           type="event" ref="ev__QGW_II_II_3553_men_1">da man <triggerstring n="disp"
                              >jerlichen dient</triggerstring>
                           <rs type="fn" role="issuer">von <rs type="place"
                                 ref="pl__grinzing-immo_8">zwei Vierteln</rs></rs>
                           <rs type="fn" role="recipient"><rs type="org" ref="org__klosterneuburg"
                                 >dem genannten Kloster</rs></rs>
                           <rs type="fn" role="transactiongood_I"><measure>einen Eimer
                                 Wein</measure>
                              <triggerstring n="fn">zu Bergrecht</triggerstring></rs> und <rs type="fn"
                              role="transactiongood_I"><measure>1 dn.</measure>
                              <triggerstring n="fn">zu Voitrecht</triggerstring></rs></rs>
                        <rs type="event" ref="ev__QGW_II_II_3553_men_2">und <triggerstring n="disp"
                                 ><add>jerlichen dient</add></triggerstring>
                           <rs type="fn" role="issuer"><add>von</add>
                              <rs type="place" ref="pl__grinzing-immo_8"><add>zwei
                                 Vierteln</add></rs></rs>
                           <rs type="fn" role="recipient"><rs type="person"
                                 ref="pe__hermann_eibensteiner_zu_nussdorf_QGW_II_II_3246">dem
                                 Eibensteiner</rs></rs>
                           <rs type="fn" role="transactiongood_I"><measure>ein Viertel
                                 Wein</measure>
                              <triggerstring n="fn">zu Bergrecht</triggerstring></rs>
                           <rs type="fn" role="transactiongood_I">und <measure>ain ort</measure>
                              <triggerstring n="fn">zu Voitrecht</triggerstring></rs>,</rs>
                        <rs type="event" ref="ev__QGW_II_II_3553_men_3"><triggerstring n="disp"
                                 ><add>jerlichen dient</add></triggerstring>
                           <rs type="fn" role="issuer">von <rs type="place"
                                 ref="pl__grinzing-immo_8">zwei Vierteln</rs></rs>
                           <rs type="fn" role="recipient"><rs type="person"
                                 ref="pe__hermann_eibensteiner_zu_nussdorf_QGW_II_II_3246">dem
                                 Letzteren</rs> allein</rs>
                           <rs type="fn" role="transactiongood_I"><measure>12 dn.</measure>
                              <triggerstring n="fn">zu Bergrecht</triggerstring></rs></rs>
                        <rs type="event" ref="ev__QGW_II_II_3553_men_4">und <triggerstring n="disp"
                                 ><add>jerlichen dient</add></triggerstring>
                           <rs type="fn" role="issuer">von <rs type="place"
                                 ref="pl__grinzing-immo_8">einem Viertel</rs></rs>
                           <rs type="fn" role="recipient"><rs type="org"
                                 ref="org__kranichberg-pfarre">jedem Pfarrer zu Kranperg</rs></rs>
                           <rs type="fn" role="transactiongood_I"><measure>½ Eimer Wein</measure>
                              <triggerstring n="fn">zu Bergrecht</triggerstring></rs>
                           <rs type="fn" role="transactiongood_I">und <measure>einen
                                 Helbling</measure>
                              <triggerstring n="fn">zu Voitrecht</triggerstring></rs></rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_II">um <measure>165 lb dn.</measure></rs>
                  <rs type="fn" role="recipient">dem <rs type="person"
                        ref="pe__castulus_kurcz_QGW_II_II_3286"><roleName type="prof"
                           >Priester</roleName>
                        <roleName type="title">hern</roleName> Kasteln Kurcz von Phaffenhofen,
                           <roleName type="occ"
                           corresp="org__wien-st_stephan-altar_zwoelfapostel-messe_urbetsch"
                           >Kaplan</roleName> der von den Urbetschen auf der Zwelfboten altar dacz
                        sand Stephan zu Wienn gestifteten Messe</rs>.</rs>
                  <rs type="fn" role="transactiongood_II"><triggerstring n="fn">Der Kaufschilling
                        besteht aus</triggerstring>
                     <rs type="event" ref="ev__QGW_II_II_3553_men_5"><rs type="fn"
                           role="transactiongood_I"><measure>64 lb dn.</measure>, die</rs>
                        <rs type="fn" role="issuer">auf <rs type="place"
                              ref="pl__wien-immo_stubentor_13"><roleName type="owner"
                                 corresp="pe__johann_hemerl_QGW_II_II_3494">Hannsen
                                 Hemerlein</roleName> haus <roleName type="topo"
                                 corresp="pl__wien-stubentor">pei Stubentor</roleName></rs></rs>
                        <triggerstring n="disp"><add>gelegen gewesen sind</add></triggerstring>
                        <rs type="fn" role="recipient"><rs type="org"
                              ref="org__wien-st_stephan-altar_zwoelfapostel-messe_urbetsch"
                        /></rs></rs>, <rs type="event" ref="ev__QGW_II_II_3553_men_6"><rs type="fn"
                           role="transactiongood_I"><measure>24 lb dn.</measure>, die</rs>
                        <rs type="fn" role="issuer">auf <rs type="place"
                              ref="pl__wien-immo_mietstat_vor_kaerntnertor_1"><roleName type="owner"
                                 corresp="pe__ulrich_meichsner_QGW_II_II_3553">Ulreichs
                                 Meichsner</roleName> haus <roleName type="topo"
                                 corresp="pl__wien-kaerntnertor">vor Kernertor</roleName></rs></rs>
                        <triggerstring n="disp">gelegen gewesen sind</triggerstring>
                        <rs type="fn" role="recipient"><rs type="org"
                              ref="org__wien-st_stephan-altar_zwoelfapostel-messe_urbetsch"
                        /></rs>,</rs>
                     <rs type="event" ref="ev__QGW_II_II_3553_men_7"><rs type="fn"
                           role="transactiongood_I"><measure>64 lb dn.</measure>, die</rs>
                        <rs type="fn" role="issuer">von <unclear instant="false"><rs type="org"
                                 ref="org__wien-karmeliter"><rs type="person"
                                    ref="pe__sigmund_tumerstorffer_QGW_II_II_2181" cert="medium">der
                                    Tumerstorffer</rs> geschefft, so uber ausrichtigung des glass zu
                                 den Weissenprudern gemacht ist</rs></unclear>
                           <rs type="fn" role="recipient"><rs type="org"
                                 ref="org__wien-st_stephan-altar_zwoelfapostel-messe_urbetsch"
                              /></rs>,</rs>
                        <triggerstring n="disp"><add>geschefft</add> uberbeliben sind</triggerstring>
                        (vgl. Jahrbuch der kais. Kunstsamml. 16b, n° 13981, f. 24),</rs> und <rs
                        type="event" ref="ev__QGW_II_II_3553_men_8"><rs type="fn"
                           role="transactiongood_I"><measure>13 lb dn.</measure>, welche</rs>
                        <rs type="fn" role="issuer"><rs type="person"
                              ref="pe__castulus_kurcz_QGW_II_II_3286">der Kaplan</rs></rs>
                        <triggerstring n="disp">aus Eigenem beigesteuert hatte</triggerstring>
                        <rs type="fn" role="recipient"><rs type="org"
                              ref="org__wien-st_stephan-altar_zwoelfapostel-messe_urbetsch"
                        /></rs>.</rs></rs></rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3553"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="pe__wolfgang_freytag_QGW_II_II_3553"
                     >Aussteller</rs>, den <rs type="person"
                        ref="pe__hermann_eibensteiner_zu_nussdorf_QGW_II_II_3246">Bergherren</rs>
                     <rs type="person" ref="pe__stephan_QGW_II_II_3553"><add>Bergherren</add></rs>
                     <rs type="person" ref="pe__johann_hechtl_QGW_II_II_3480"
                        ><add>Bergherren</add></rs> und dem <rs type="person"
                        ref="pe__niklas_purger_QGW_II_III_3758">Wiener <roleName type="occ"
                           corresp="org__wien">Bürger</roleName> Niclas Purger</rs>.</rs></rs>
            </p>
         </div>
