   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="ev__QGW_II_II_3616"><rs type="fn" role="issuer"><rs
                        type="person" ref="pe__leonhard_von_perching_SB_CD_3616"><roleName
                           type="title">Maister</roleName> Lienhart von Perching, <roleName
                           type="occ"
                           corresp="org__wien-st_agnes_auf_der_himmelpforte-altar_dreikoenige"
                           >kaplan</roleName> der heiligen Dreyr Kunig altar in dem frauncloster
                        dacz der Himelporten zu Wienn</rs>,</rs>
                  <triggerstring n="disp">gibt <add>gelts purkrechts</add></triggerstring>
                  <rs type="fn" role="recipient">dem <rs type="person"
                        ref="pe__michael_haunolt_QGW_II_II_3616">Wiener <roleName type="occ"
                           corresp="org__wien">Bürger</roleName> Micheln Haunolten</rs></rs>
                  <rs type="fn" role="transactiongood_I"><measure>7 lb dn.</measure>
                     <triggerstring n="fn">gelts purkrechts</triggerstring> von <rs type="place"
                        ref="pl__wien-immo_wollzeile_10"><roleName type="owner"
                           corresp="pe__michael_haunolt_QGW_II_II_3616">seinem</roleName> Hause,
                           <roleName type="owner" corresp="pe__johann_hemerl_StB_I_543" cert="high"
                           >das ettwenn <rs type="person" ref="pe__johann_hemerl_StB_I_543"
                              cert="high">Hannsen des Hemerleins</rs> gewesen ist</roleName>,
                           <roleName type="topo" corresp="pl__wien-stubentor">gelegen innerhalb
                           Stubentor</roleName>
                        <roleName type="topo" corresp="pl__wien-wollzeile">in der Wolczeill hie zu
                           Wienn</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_stubentor_16"
                           >zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_stubentor_16"><roleName type="owner"
                              corresp="pe__margarethe_QGW_II_I_1235">weilent der
                              Sibenburgerin</roleName> haus</rs></rs>,</rs>
                  <rs type="fn" role="transactiongood_II">um <measure>56 lb dn.</measure>
                     abzulösen</rs>
                  <rs type="event" ref="ev__SB_CD_00162">und legt diese Summe neuerdings für den
                     Altar auf des Semelroschen haus in der Kernerstrass an.</rs></rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="ev__QGW_II_II_3616"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="pe__simon_von_eslarn_QGW_II_II_3263"
                        >Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Simon von
                        Eslarnn</rs> und <rs type="person"
                        ref="pe__niklas_lainbacher_QGW_II_II_2652">Niclasen Lainbacher, des
                           <roleName type="prof">apotegker</roleName></rs>.</rs></rs>
            </p>
         </div>
