            <placeName>Wien</placeName>
            <date when="14540209">1454 II 09</date>
            <origDate instant="false">zu Wienn, an sambstag vor sand Scolastica tag, der heiligen
               junkchfraun.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03560_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03560_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3560"><rs type="fn" role="issuer"><rs type="person" ref="pe__oswald_reicholf_QGW_II_II_3314">Oswalt Reicholf,
                           <roleName type="occ" corresp="org__wien">burgermaister</roleName></rs>,
                     und <rs type="org" ref="org__wien">der rat gemain der stat zu Wienn</rs></rs>
                  <triggerstring n="disp">stellen</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__wenzel_QGW_II_II_3489"><roleName type="title">hern</roleName> Wenczlaben, der korherren
                           <roleName type="occ" corresp="org__wien-st_stephan" cert="unknown">caplan</roleName>, diezeit <roleName type="occ" corresp="org__wien-st_stephan-messe_meczner_anna">verweser</roleName> der
                        ewigen mess, die frau Anna, weilent Otten des Meczner hausfrau selige, hincz
                        sand Steffan zu Wienn zu stifften geschafft hat, virstund in der wochen ze
                        lesen</rs>, und <rs type="org" ref="org__wien-st_stephan-messe_meczner_anna">seinen Nachfolgern</rs></rs>
                  <triggerstring n="disp">einen Schuldbrief</triggerstring> über <rs type="fn" role="transactiongood_II"><measure>300 lb dn.</measure> guter lanndeswerung in
                     Österreich</rs>
                  <triggerstring n="disp">aus</triggerstring>, <rs type="event" ref="ev__QGW_II_II_3489">welche <rs type="fn" role="recipient"><rs type="org" ref="org__wien">ihnen</rs></rs>
                     <rs type="fn" role="issuer"><rs type="fn" role="transactiongood_I">die
                                 <measure><add>300 lb dn.</add></measure></rs>
                        <rs type="person" ref="pe__ulrich_matzleinsdorfer_QGW_II_II_3362"><roleName type="rep" corresp="pe__otto_meczner_QGW_II_II_2591" cert="medium">Geschäftsherren</roleName> des Meczner</rs>
                        <rs type="person" ref="pe__philipp_kraukcher_QGW_II_II_3353"><roleName type="rep" corresp="pe__otto_meczner_QGW_II_II_2591" cert="medium"><add>Geschäftsherren</add></roleName></rs></rs>
                     <rs type="fn" role="transactiongood_II"><rs type="org" ref="org__wien-st_stephan-messe_meczner_anna">zur Stiftung dieser
                           Messe</rs></rs>
                     <triggerstring n="disp">übergeben hatten</triggerstring>,</rs>
                  <triggerstring n="disp">verpflichten sich</triggerstring>, <rs type="fn" role="transactiongood_I">jedem Kaplan davon <triggerstring n="fn">jährlich</triggerstring>
                     <measure>15 lb dn.</measure>
                     <triggerstring n="fn">zu dienen</triggerstring>,</rs> sowie das Capital im Falle der
                  Forderung zurückzuzahlen.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3560"><rs type="fn" role="witness">Besiegelt mit
                     ihrem <rs type="org" ref="org__wien">klainem anhangundem
                  statinsigl</rs>.</rs></rs>
