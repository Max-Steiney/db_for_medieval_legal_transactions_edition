          <rs type="event" ref="ev__QGW_II_II_3561"><rs type="fn" role="issuer"><rs type="person" ref="pe__markus_QGW_II_II_3561">Marx, <roleName type="occ" corresp="org__asparn_an_der_donau-pfarre">pfarrer</roleName> zu Asparn pei der
                Tonau, <roleName type="occ" corresp="org__wien-st_michael-altar_heiligenkreuz-messe_tierna" cert="high">capplan</roleName> der ewigen mess, die der Tiem auf des heiligen Kreucz altar zu
                sand Michel zu [ 360] Wienn gestifft hat</rs>,</rs> gibt <triggerstring n="disp"><add xmlns="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03561_r.jpg">empfängt Ablösung des Burgrechtsgeldes</add></triggerstring>
            <rs type="fn" role="recipient">dem <rs type="person" ref="pe__stephan_auer_SB_CD_00229">Steffan Auer, des <roleName type="occ" corresp="org__wien">rats</roleName> der stat
                zu Wienn</rs>,</rs>
            <rs type="fn" role="transactiongood_I"><measure>6 lb 60 dn.</measure>
              <triggerstring n="fn">Burgrechtsgeldes</triggerstring>, welche die Messe auf <rs type="place" ref="pl__wien-immo_st_pankraz_11"><roleName type="owner" corresp="pe__stephan_auer_SB_CD_00229">seinem</roleName> Hause, <roleName type="topo" corresp="pl__wien-st_pankraz">hinder sand Bangrêczen
                    gelegen</roleName>, <rs type="event" ref="ev__QGW_II_II_3561_men_1"><rs type="fn" role="transactiongood_I"><rs type="place" ref="pl__wien-immo_st_pankraz_11">das</rs></rs>
                  <rs type="fn" role="recipient"><rs type="person" ref="pe__stephan_auer_SB_CD_00229">er</rs></rs>
                  <rs type="fn" role="issuer">von <rs type="person" ref="pe__jakob_nadler_QGW_II_II_3511">Jorgen <add xmlns="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03561_r.jpg">Jakob</add>, <roleName type="prof">nadler</roleName></rs>,</rs>
                  <triggerstring n="disp">gekaufft hat</triggerstring>,</rs></rs> laut eines verlorenen
              Burgrechtsbriefes gehabt hat,</rs>
            <rs type="fn" role="transactiongood_II">um <measure>50 lb dn.</measure>
              <triggerstring n="fn"><add xmlns="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03561_r.jpg">empfängt Ablösung des Burgrechtsgeldes</add></triggerstring> abzulösen</rs></rs>
          <rs type="event" ref="ev__SB_CD_00357"><rs type="fn" role="issuer"><rs type="person" ref="pe__markus_QGW_II_II_3561"/></rs><triggerstring n="disp">und legt</triggerstring>
            <rs type="fn" role="transactiongood_II">diese <measure><measure>50 lb
                dn.</measure></measure></rs>
            <rs type="fn" role="transactiongood_I"><measure><add>6 lb 60 dn.</add></measure>
              <triggerstring n="fn"><add>Burgrechtsgeldes</add></triggerstring></rs> neuerdings <rs type="fn" role="recipient">für <rs type="org" ref="org__wien-st_michael-altar_heiligenkreuz-messe_tierna">die Messe</rs></rs>
            <rs type="fn" role="issuer">auf <rs type="place" ref="pl__wien-immo_st_pankraz_12"><roleName type="owner" corresp="pe__engelhart_holczer_QGW_II_II_3561"><rs type="person" ref="pe__engelhart_holczer_QGW_II_II_3561">Engelharts Holczer, des
                      <roleName type="prof">keuffl</roleName></rs></roleName>, haus, <roleName type="topo" corresp="pl__wien-st_pankraz">hinder sant Pangreczen
                  gelegen</roleName></rs>,</rs>
            <triggerstring n="disp">an</triggerstring>.</rs>
        </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3561">Besiegelt mit den Siegeln der <rs type="person" ref="pe__georg_brunntaler_SB_CD_00618">Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Jörgen Prunntaler</rs> und <rs type="person" ref="pe__jakob_kaschauer_QGW_II_II_3048">Jacoben Kasschauer <roleName type="occ" corresp="org__wien"><add>Bürger</add></roleName></rs>.</rs>
