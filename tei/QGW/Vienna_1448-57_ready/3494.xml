                  <triggerstring n="disp">verpflichtet sich</triggerstring>, <rs type="fn" role="other"><triggerstring n="fn">wegen</triggerstring>
                     <rs type="place" ref="pl__wien-immo_wollzeile_10">des Hauses, <roleName type="topo" corresp="pl__wien-wollzeile">in der Wolzeil</roleName>
                        <roleName type="topo" corresp="pl__wien-stubentor">innerhalb
