      <text>
            <body>
                  <div type="abstract" resp="kg">
                        <p>
                              <rs type="event" ref="ev__SB_CD_01462"><rs type="fn" role="issuer"><rs
                                                type="person" ref="pe__niklas_ledrer_QGW_II_II_3650"
                                                >Niclas, <roleName type="prof">ledrer</roleName>,
                                                  <roleName type="occ" corresp="org__wien"
                                                  >mitpurger</roleName> zu Wienn</rs>,</rs>
                                    <triggerstring n="disp">verkauft <add>gelts
                                          purkrechts</add></triggerstring>
                                    <rs type="fn" role="other"><triggerstring n="fn">mit
                                                Handen</triggerstring> des <rs type="person"
                                                ref="pe__konrad_hoelczler_QGW_II_II_3350"><roleName
                                                  type="title">edeln</roleName>
                                                <roleName type="title">hern</roleName> Conrats des
                                                Holczler, <roleName type="occ" corresp="org__wien"
                                                  >burgermaister</roleName></rs>, und <rs type="org"
                                                ref="org__wien">des Rathes</rs></rs>
                                    <rs type="fn" role="transactiongood_I"><measure>7 lb
                                                dn.</measure>
                                          <triggerstring n="fn">gelts purkrechts</triggerstring>
                                          (ablösbar) auf <rs type="place"
                                                ref="pl__wien-immo_baeckerstrasse_vordere_10"
                                                  ><roleName type="owner"
                                                  corresp="pe__niklas_ledrer_QGW_II_II_3650"
                                                  >seinem</roleName> Hause, <roleName type="topo"
                                                  corresp="pl__wien-baeckerstrasse_vordere">gelegen
                                                  in der Vordern Pekchenstrass daselbs</roleName>
                                                zenagst <rs type="place"
                                                  ref="pl__wien-immo_baeckerstrasse_vordere_11"
                                                  ><roleName type="owner"
                                                  corresp="pe__thomas_geweltl_QGW_II_II_3650"><rs
                                                  type="person"
                                                  ref="pe__thomas_geweltl_QGW_II_II_3650">Thomans
                                                  Geweltleins, des <roleName type="prof"
                                                  >fleischhakcher</roleName></rs></roleName>,
                                                  haus</rs>, <roleName type="topo"
                                                  corresp="pl__wien-immo_baeckerstrasse_vordere_11"
                                                  ><add>zenagst</add> an aim
                                          tail</roleName></rs>,</rs>
                                    <rs type="fn" role="transactiongood_II">um <measure>56 lb
                                                dn.</measure>, <rs type="event"
                                                ref="ev__SB_CD_00673_nota">die emaln gelegen gewesen
                                                sind auf weilent Hannsen des Schrots haus innerhalb
                                                Stubentor, die man damit darab geledigt und gelost
                                                hat,</rs></rs>
                                    <rs type="fn" role="recipient"><rs type="person"
                                                ref="pe__andreas_benedicter_QGW_II_II_3650"
                                                  ><roleName type="title">hern</roleName> Andren
                                                Benedicter von [ 380] Waidhofen, <roleName
                                                  type="occ"
                                                  corresp="org__wien-st_stephan-kapelle_st_katharina-altar_st_katharina-messe_kurzmann"
                                                  >capplan</roleName> der messe, die weilent . . .
                                                der Kurczman auf sand Kathrein altar zu sand Steffan
                                                zu Wienn gestifft hat</rs>, und <rs type="org"
                                                ref="org__wien-st_stephan-kapelle_st_katharina-altar_st_katharina-messe_kurzmann"
                                                >seinen Nachfolgern</rs>.</rs></rs>
                        </p>
                  </div>
                  <div type="seal">
                        <p><rs type="event" ref="ev__SB_CD_01462"><rs type="fn" role="witness"
                                          >Besiegelt mit dem <rs type="org" ref="org__wien"
                                                >städtischen Grundsiegel</rs> und dem Siegel des <rs
                                                type="person"
                                                ref="pe__simon_von_eslarn_QGW_II_II_3263">Wiener
                                                  <roleName type="occ" corresp="org__wien"
                                                  >Bürgers</roleName> Simon von
                                    Eslorn</rs>.</rs></rs>
                        </p>
