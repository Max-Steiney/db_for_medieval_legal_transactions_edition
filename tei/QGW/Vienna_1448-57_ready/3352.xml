                  <triggerstring n="disp">Es sei ihm vorgebracht worden, dass</triggerstring>
                  <rs type="fn" role="other"><add>hincz</add> der <rs type="person" ref="pe__georg_schuchler_QGW_II_II_3272">Wiener <roleName type="occ" corresp="org__wien">Bürger</roleName> Jorg Schüchler</rs></rs>
                  <rs type="fn" role="other"><add>mit vorsprechen</add>
                     <rs type="person" ref="pe__margarethe_QGW_II_II_3352">seine <roleName type="kin" corresp="pe__georg_schuchler_QGW_II_II_3272">mumen</roleName>
                        <roleName type="kin" corresp="pe__georg_schuchler_QGW_II_II_3272"><add>Nichte</add></roleName> Margrethen, <rs type="person" ref="pe__haunold_schuchler_QGW_II_II_3411">Haunolten des Schüchler, seins
