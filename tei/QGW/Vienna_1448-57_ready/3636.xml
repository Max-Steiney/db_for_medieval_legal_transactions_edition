      <text>
            <body>
                  <div type="abstract" resp="kg">
                        <p>
                              <rs type="event" ref="ev__QGW_II_II_3636"><rs type="fn" role="issuer"
                                                ><rs type="person"
                                                ref="pe__johann_stoelczl_QGW_II_II_3636">Hanns
                                                Stölczl, der <roleName type="prof"
                                                  >oblatpacher</roleName>, <roleName
                                                  type="title_ref" corresp="pl__wien-widmertor"
                                                  >gesessen vor</roleName> Widmertor zu
                                          Wienn</rs>,</rs>
                                    <triggerstring n="disp">verkauft <add>geltes
                                          purkchrechts</add></triggerstring>
                                    <rs type="fn" role="other"><triggerstring n="fn">mit
                                                Handen</triggerstring>
                                          <rs type="person" ref="pe__christian_prenner_SB_CD_01257"
                                                >Cristans Prenner, <roleName type="occ"
                                                  corresp="org__wien-buergerspital"
                                                  >spitalmaister</roleName> der burger Spital vor
                                                Kernertor zu Wienn</rs>,</rs>
                                    <rs type="fn" role="transactiongood_I"><measure>10 sh. 20
                                                dn.</measure>
                                          <triggerstring n="fn">geltes purkchrechts</triggerstring>
                                          (ablösbar) auf <rs type="place"
                                                ref="pl__wien-immo_weidenstrasse_9"><roleName
                                                  type="owner"
                                                  corresp="pe__johann_stoelczl_QGW_II_II_3636"
                                                  >seinem</roleName> Hause, <roleName type="topo"
                                                  corresp="pl__wien-weidenstrasse">gelegen in der
                                                  Weidenstrass</roleName>
                                                <roleName type="topo" corresp="pl__wien-widmertor"
                                                  >vor Widmertor zu Wienn</roleName> zenagst <rs
                                                  type="place" ref="pl__wien-immo_weidenstrasse_10"
                                                  ><roleName type="owner"
                                                  corresp="pe__christian_ellwein_QGW_II_II_3636"><rs
                                                  type="person"
                                                  ref="pe__christian_ellwein_QGW_II_II_3636"
                                                  >Kristans Ellwein</rs></roleName> haus</rs>
                                                <roleName type="topo"
                                                  corresp="pl__wien-immo_weidenstrasse_10"
                                                  ><add>zenagst</add> an aim tail</roleName>, <rs
                                                  type="event" ref="ev__QGW_II_II_3636_men_1"><rs
                                                  type="fn" role="issuer">von <rs type="place"
                                                  ref="pl__wien-immo_weidenstrasse_9">dem</rs>
                                                  man</rs>
                                                  <rs type="fn" role="recipient">in <rs type="org"
                                                  ref="org__wien-buergerspital">das
                                                  Bürgerspital</rs></rs>
                                                  <rs type="fn" role="transactiongood_I"><measure>15
                                                  dn.</measure> zu <triggerstring n="fn"
                                                  >Grunddienst</triggerstring></rs>
                                                  <triggerstring n="disp"><add>Grunddienst</add>
                                                  <add>dient</add></triggerstring></rs>
                                                <rs type="event" ref="ev__QGW_II_II_3636_men_2">und
                                                  <rs type="fn" role="issuer"><add>von</add>
                                                  <rs type="place"
                                                  ref="pl__wien-immo_weidenstrasse_9"
                                                  ><add>dem</add></rs>
                                                  <add>man</add></rs>
                                                  <rs type="fn" role="recipient"><rs type="person"
                                                  ref="pe__simon_puckwitz_QGW_II_II_3176"><roleName
                                                  type="title">hern</roleName> Simon Bubwitz,
                                                  <roleName type="occ"
                                                  corresp="org__wien-st_michael-altar_st_maria-messe_walichpekch"
                                                  >kaplan</roleName> der ewigen mess, die weilent
                                                  die Walichpekchin selige auf Unser Fraun altar zu
                                                  sand Michel zu Wienn gestifft hat</rs>,</rs>
                                                  <rs type="fn" role="transactiongood_I"><measure>2
                                                  lb dn.</measure> zu ablösbarem <triggerstring n="fn"
                                                  >Burgrecht</triggerstring></rs>
                                                  <triggerstring n="disp"><add>Burgrecht</add>
                                                  dient</triggerstring></rs></rs>,</rs>
                                    <rs type="fn" role="transactiongood_II">um <measure>10 lb 5 sh.
                                                10 dn.</measure>, <rs type="event"
                                                ref="ev__QGW_II_II_3636_men_3"><rs type="fn"
                                                  role="transactiongood_I">die <measure><add>10 lb 5
                                                  sh. 10 dn.</add></measure></rs>
                                                <triggerstring n="disp">emaln gelegen gewesen
                                                  sind</triggerstring>
                                                <rs type="fn" role="issuer">auf <rs type="place"
                                                  ref="pl__wien-immo_schottentor_7"><roleName
                                                  type="owner"
                                                  corresp="pe__katharina_QGW_II_II_3636"><rs
                                                  type="person" ref="pe__katharina_QGW_II_II_3636"
                                                  ><roleName type="kin"
                                                  corresp="pe__philipp_stornschacz_QGW_II_II_3636"
                                                  ><add>witiben</add></roleName> Kathrein, <rs
                                                  type="person"
                                                  ref="pe__philipp_stornschacz_QGW_II_II_3636"
                                                  >Philipps Stornschacz <roleName type="dead"
                                                  >witiben</roleName></rs></rs></roleName> haus
                                                  <roleName type="topo"
                                                  corresp="pl__wien-schottentor">vor Schottentor hie
                                                  zu Wienn</roleName></rs>,</rs>
                                                <rs type="fn" role="recipient"><rs type="org"
                                                  ref="org__wien-st_maria_im_rathaus"/></rs> die man
                                                damit darab geledigt und gelost hat,</rs></rs>
                                    <rs type="fn" role="recipient"><rs type="person"
                                                ref="pe__heinrich_senftleben_QGW_II_II_3263"
                                                  ><roleName type="title">maister</roleName>
                                                Hainreichen Senftleben, <roleName type="occ"
                                                  corresp="org__wien-st_maria_im_rathaus">obristen
                                                  kapplan</roleName> Unser Fraun kappellen, hern
                                                Otten und Haimen stifftung, gelegen in der burger
                                                Rathaus hie zu Wienn</rs>, und <rs type="org"
                                                ref="org__wien-st_maria_im_rathaus">seinen
                                                Nachfolgern</rs>.</rs></rs>
                        </p>
                  </div>
                  <div type="seal">
                        <p><rs type="event" ref="ev__QGW_II_II_3636"><rs type="fn" role="witness"
                                          >Besiegelt mit den Siegeln des <rs type="org"
                                                ref="org__wien-buergerspital">Bürgerspitals</rs> und
                                                <rs type="person"
                                                ref="pe__georg_prunntaler_QGW_II_II_3240">Jörgen des
                                                Prunntaler, des <roleName type="occ"
                                                  corresp="org__wien">rats</roleName> der stat zu
                                                Wienn</rs>.</rs></rs>
                        </p>
                  </div>
                  <div type="nota">
                        <p>Auf dem Buge aufgedrückt das Petschaft des Spitals von grünem Wachse.</p>
                  </div>
