               <rs type="event" ref="ev__QGW_II_II_3319"><rs type="fn" role="issuer"><rs type="person" ref="pe__johann_wuerfel_QGW_II_II_2623">Hanns Würffel zu
                        Radaun</rs></rs>
                  <triggerstring n="disp">verkauft</triggerstring> mit Vorbehalt des Grunddienstes und der
                  Theilnahme beim Wechsel der Hand <rs type="fn" role="transactiongood_II">um eine
                     bestimmte Summe</rs>
                  <rs type="fn" role="recipient">dem <rs type="person" ref="pe__peter_strasser_QGW_II_II_3260">Petern Strasser, des <roleName type="occ" corresp="org__wien">rats</roleName> der stat zu
                     Wienn</rs>,</rs>
                  <rs type="fn" role="transactiongood_I">17 Joch Weingarten, die zu seiner Feste
                     Radaun gehören, und von deren jedem man 10 dn. zu Grunddienst dient, <rs type="place" ref="pl__perchtoldsdorf-immo_1"><roleName type="topo" corresp="pl__perchtoldsdorf-aunpach">gelegen in dem Aunpach bei
                           Perchtolczdorff</roleName>, und zwar <measure>3 Joch</measure>, genannt
                        der Gern <roleName type="topo" corresp="pl__perchtoldsdorf-immo_8">zenagst</roleName> [308] <rs type="place" ref="pl__perchtoldsdorf-immo_8">des pharrer zu Perchtolczdorf
                        akcher</rs></rs>, <rs type="place" ref="pl__perchtoldsdorf-immo_2"><measure>6 Joch</measure>
                        <roleName type="topo" corresp="pl__perchtoldsdorf-aunpach"><add>gelegen in
                              dem Aunpach bei Perchtolczdorff</add> zenagst dem Steig an aim
                           rainn</roleName> und <roleName type="topo" corresp="pl__perchtoldsdorf-immo_7">mit dem andern zenagst</roleName>
                        <rs type="place" ref="pl__perchtoldsdorf-immo_7"><roleName type="owner" corresp="pe__ulrich_schoechtl_QGW_II_II_3319">Ulreichen
                              Schöchtl</roleName> akcher</rs></rs>, <rs type="place" ref="pl__perchtoldsdorf-immo_3"><measure>3 Joch</measure>
                        <roleName type="topo" corresp="pl__perchtoldsdorf-aunpach"><add>gelegen in
                              dem Aunpach bei Perchtolczdorff</add></roleName>
                        <roleName type="topo" corresp="pl__perchtoldsdorf-immo_9">zenagst</roleName>
                        <rs type="place" ref="pl__perchtoldsdorf-immo_9"><roleName type="owner" corresp="pe__wolfgang_hasler_QGW_II_II_3319"><rs type="person" ref="pe__wolfgang_hasler_QGW_II_II_3319">Wolfgangs
                              Hasler</rs></roleName> akcher</rs></rs>, <rs type="place" ref="pl__perchtoldsdorf-immo_4"><measure>2 Joch</measure>, darinn ein
                        stainpruch ist, <roleName type="topo" corresp="pl__perchtoldsdorf-aunpach"><add>gelegen in dem Aunpach bei Perchtolczdorff</add></roleName>
                        <roleName type="topo" corresp="pl__perchtoldsdorf-immo_6">zenagst</roleName>
                        <rs type="place" ref="pl__perchtoldsdorf-immo_6">des Spitals
                        akcher</rs></rs>, <rs type="place" ref="pl__perchtoldsdorf-immo_5"><measure>3 Joch</measure>
                        <roleName type="topo" corresp="pl__perchtoldsdorf-aunpach"><add>gelegen in
                              dem Aunpach bei Perchtolczdorff</add></roleName>
                        <roleName type="topo" corresp="pl__perchtoldsdorf-immo_6">zenagst des
                           Spitals akcher und stossent an den marchstein</roleName></rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3319"><rs type="fn" role="witness">Siegler: der
                        <rs type="person" ref="pe__johann_wuerfel_QGW_II_II_2623">Aussteller</rs>
