            <date when="14530624">1453 VI 24</date>
            <origDate instant="false">an sand Johanns tag zu den Sunibenten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03523_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_03523_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="ev__QGW_II_II_3523"><rs type="fn" role="issuer"><rs type="person" ref="pe__magdalena_QGW_II_II_3523">Magdalena, <roleName type="occ" corresp="org__schlierbach-kloster_st_maria">abbtessin</roleName> zu Unser Fraun Sal, das man nentt Slierbach <roleName type="rep" corresp="pe__barbara_QGW_II_II_3523"><add>für</add></roleName>
                  <roleName type="rep" corresp="pe__anna_QGW_II_II_3523"><add>für</add></roleName></rs>,
                     und <rs type="org" ref="org__schlierbach-kloster_st_maria">der gancz convent
                        daselbs
                     <roleName type="rep" corresp="pe__barbara_QGW_II_II_3523"><add>für</add></roleName>
                     <roleName type="rep" corresp="pe__anna_QGW_II_II_3523"><add>für</add></roleName></rs></rs>
                  <triggerstring n="disp">bestätigen</triggerstring>, dass ihnen <rs type="fn" role="recipient">der <rs type="person" ref="pe__johann_prugkner_QGW_II_II_3523"><roleName type="title">edel</roleName> Hanns der Prukner</rs></rs>
                  <triggerstring n="disp">eine Summe Geldes</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">für</triggerstring> seine <rs type="person" ref="pe__barbara_QGW_II_II_3523"><roleName type="kin" corresp="pe__johann_prugkner_QGW_II_II_3523">Schwestern</roleName>
                        Barbara</rs> und <rs type="person" ref="pe__anna_QGW_II_II_3523"><roleName type="kin" corresp="pe__johann_prugkner_QGW_II_II_3523"><add>Schwestern</add></roleName> Anna</rs></rs>
                  <triggerstring n="disp">übergeben habe</triggerstring>. <triggerstring n="impl_rules">Die
                     Schwestern sollen dafür mit der phrünt und andern notdurfften, als ander
                     mitswestern, die in der profess und gehorsam stendt , versehen werden, Barbara
                     soll innerhalb des Gotteshauses entsprechende Dienste leisten. Nach dem Tode
                     Prukners soll das Kloster jeder der beiden Schwestern ein Pfund Pfennige zur
                     Besserung ihrer Pfründe reichen. Die Ueberwachung des Vertrages wird dem
                     jeweiligen herrn zu Säusenstein übertragen.</triggerstring></rs>
            </p></div><div type="seal"><p><rs type="event" ref="ev__QGW_II_II_3523"><rs type="fn" role="witness">Siegler: <rs type="person" ref="pe__magdalena_QGW_II_II_3523">Aebtissin</rs>, <rs type="org" ref="org__schlierbach-kloster_st_maria">Convent</rs> und <rs type="person" ref="pe__johann_QGW_II_II_3523"><roleName type="title">her</roleName> Hanns, <roleName type="occ" corresp="org__saeusenstein-kloster">abbt</roleName> zu
                     Säusenstein</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>