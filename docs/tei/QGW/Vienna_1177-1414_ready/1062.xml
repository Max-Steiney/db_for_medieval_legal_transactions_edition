               <rs type="event" ref="#ev__QGW_II_I_1062"><rs type="fn" role="issuer"><rs type="person" ref="#pe__peter_velmund_QGW_II_I_1062">Peter der Velmund <roleName type="occ" corresp="#org__wien"><add>Bürger</add></roleName>
                        <roleName type="rep" corresp="#pe__konrad_QGW_II_I_1062"><add>Ausrichter des
                              Geschäfts</add></roleName></rs> und <rs type="person" ref="#pe__niklas_radschmied_QGW_II_I_1062">Niclas, der <roleName type="prof">ratsmid</roleName>
                        <roleName type="rep" corresp="#pe__konrad_QGW_II_I_1062"><add>Ausrichter des
                              Geschäfts</add></roleName>, baid <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienne</rs></rs> , <triggerstring n="disp">verkaufen</triggerstring> als Ausrichter des Geschäftes <rs type="person" ref="#pe__konrad_QGW_II_I_1062">Chu/enrats <roleName type="dead">seligen</roleName>, des <roleName type="prof">bader</roleName></rs>, weilnt
                  gesessen in der padstuben, genannt die Hu/enntinne vor Stubentor ze Wienne , <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__erhard_QGW_II_I_1062"><roleName type="title">Bergherrn</roleName>
                        <roleName type="title">hern</roleName> Erharts, <roleName type="occ" corresp="#org__wien-st_philipp_und_st_jakob_kapelle">kaplan</roleName> der
                        kapellen sand Philipps und sand Jacobs</rs>, gelegen in hern Lienharts
                     seligen des Pollen haus in der Hindern Pekchenstrass ze Wienn</rs> , dreu
                  viertail weingarten, gelegen an dem Rennweg zenechst . . des Scheczleins
                  weingarten, des mentler, von dem man 7 sh. 10 dn. zu Grundrecht dient, um 13 lb
                  dn., <rs type="event" ref="#ev__QGW_II_I_1062_men_1">die an die stat gevallen sind, dahin si der
                     vorgenant Chunrat, der pader, geschafft hat</rs>, <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_heller_QGW_II_I_1062">Jannsen dem Heller
                        ze Wienn</rs> und seiner <rs type="person" ref="#pe__katharina_QGW_II_I_1062"><roleName type="kin" corresp="#pe__johann_heller_QGW_II_I_1062">Hausfrau</roleName>
                        Kathrein</rs></rs> .</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1062"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="#pe__erhard_QGW_II_I_1062">Bergherrn</rs>, 2. <rs type="person" ref="#pe__jakob_echrer_QGW_II_I_1228">Jacobs des
                        Echrer, <roleName type="occ" corresp="#org__oesterreich-herzogtum" select="#pl__wien">anwalt</roleName> in des herzogen münze ze
                     Wienn</rs>.</rs></rs>
            </p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>