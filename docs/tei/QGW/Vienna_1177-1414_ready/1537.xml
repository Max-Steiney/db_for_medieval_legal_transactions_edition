               <rs type="event" ref="#ev__QGW_II_I_1537"><rs type="fn" role="issuer"><rs type="person" ref="#pe__niklas_lebansorg_QGW_II_I_1537">Niclas Lebansorg ze Inzestorf</rs>
                     und <rs type="person" ref="#pe__katharina_QGW_II_I_1537_a">Kathrei, seine
                           <roleName type="kin" corresp="#pe__niklas_lebansorg_QGW_II_I_1537">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__heinrich_ramler_QGW_II_I_1537">Hainreichs des Ramler daselbens ze
