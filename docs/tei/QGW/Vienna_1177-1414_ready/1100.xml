               <rs type="event" ref="#ev__QGW_II_I_1100"><rs type="fn" role="issuer"><rs type="person" ref="#pe__georg_von_liechtenstein_QGW_II_I_1157">Jorg von Liechtenstain von
                        Nicolspurg, Herzog Albrechts <roleName type="occ" corresp="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_1020">Kammermeister</roleName></rs></rs>, <triggerstring n="disp">beurkundet</triggerstring>, dass ihm <rs type="fn" role="recipient"><rs type="person" ref="#pe__lesier_QGW_II_I_1557">Lesier, Patusch <roleName type="kin" corresp="#pe__patusch_QGW_II_I_1557">ôchem</roleName> von
                        Perchtolczdorf</rs></rs>, <triggerstring n="disp">angezeigt habe</triggerstring>,
                  dass <rs type="fn" role="other"><rs type="person" ref="#pe__katharina_chaltengangin_QGW_II_I_1100">Kathrei die Chaltengangin</rs></rs> ihm
                  für 57 lb dn. ihren Hof zu Swechend zenachst des von Tirna hof <triggerstring n="disp">verpfändet habe</triggerstring> und ihm derselbe <triggerstring n="disp">ins
                     dem Judenpuch verschrieben sei</triggerstring>. Nach erfolgter Verständigung sei
                  die Schuldnerin vor dem Aussteller als herzoglichem Kammermeister erschienen und
                  habe den Hof <triggerstring n="disp">freiwillig ihrem Gläubiger
                     aufgegeben</triggerstring>. </rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>