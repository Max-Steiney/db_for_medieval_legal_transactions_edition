            <rs type="fn" role="recipient"><rs type="person" ref="#pe__ulrich_pruschink_QGW_II_I_68"><roleName type="title">hern</roleName> Ulrichen</rs> und <rs type="person" ref="#pe__friedrich_pruschink_QGW_II_I_68"><roleName type="title">hern</roleName>
