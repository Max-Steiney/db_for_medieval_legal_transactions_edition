                        <date when="13460929">1346 IX 29</date>
                        <origDate instant="false">ze Medlikch, an sand Michels
                        tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00304_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00304_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
                              <rs type="event" ref="#ev__QGW_II_I_304"><rs type="fn" role="issuer"><rs type="person" ref="#pe__heinrich_paltram_QGW_II_I_306">Hainreich
                                                der Paltram von Prunne, der Herzogin <roleName type="occ" corresp="#pe__johanna_von_pfirt_QGW_II_I_304">Bergmeister</roleName></rs></rs>, <triggerstring n="disp">beurkundet</triggerstring>, dass vor ihm in der
                                    Schranne ze Medlikch <rs type="fn" role="other"><rs type="person" ref="#pe__ludwig_QGW_II_I_304">Ludweig,
                                                  <roleName type="occ" corresp="#pe__haunold_schuchler_QGW_II_I_170"><add>schreiber</add></roleName><rs type="person" ref="#pe__haunold_schuchler_QGW_II_I_170"><roleName type="title">hern</roleName> Haunolts schreiber
                                                  des Schu/echler, <roleName type="occ" corresp="#org__wien">judenrichter</roleName> ze
                                                  Wienne, </rs><roleName type="rep" corresp="#pe__haunold_schuchler_QGW_II_I_170"><add>an seines Herrn
                                                Statt</add></roleName></rs><triggerstring n="fn">mit
                                                Vorsprechen</triggerstring> an seines Herrn Statt</rs>
                                    <rs type="fn" role="other"><triggerstring n="fn">hinz</triggerstring><rs type="person" ref="#pe__meinhard_wascher_QGW_II_I_304">Meinharts
                                                weingarten des Wascher</rs></rs>, der do leit bei
                                    der chappelln ze Medlich, der weiln Chu/onrats des Nêsleins
                                    gewesen ist , um 2 lb dn. versessenen Burgrechts und die darauf
                                    ertheilte zwispil geklagt habe. Er gibt ihm <rs type="fn" role="other"><rs type="person" ref="#pe__heinrich_werder_QGW_II_I_304">Hainreichen
                                                den Werder</rs> und <rs type="person" ref="#pe__ulrich_schmied_QGW_II_I_304">Ulreichen, den
                                                  <roleName type="prof">smid</roleName> von
                                                Medlikch</rs>, als <triggerstring n="fn">Schätzleute</triggerstring></rs> mit und macht <rs type="fn" role="recipient"><rs type="person" ref="#pe__ludwig_QGW_II_I_304">ihn nach deren Aussage
                                                  <roleName type="rep" corresp="#pe__haunold_schuchler_QGW_II_I_170">an
                                                  Stelle</roleName> seines Herrn</rs></rs> des
                                    Weingartens gewaltig.</rs>
                        </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_304"><rs type="fn" role="witness">Besiegelt von dem <rs type="person" ref="#pe__heinrich_paltram_QGW_II_I_306">Aussteller</rs>.</rs></rs></p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. n. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>