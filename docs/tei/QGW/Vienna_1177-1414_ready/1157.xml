            <origDate instant="false">ze Wienn, des nêgsten sambstags nach sand Margreten tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01157_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01157_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="#ev__QGW_II_I_1157"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_schiermer_QGW_II_I_1157">Hanns der Schiermer,
                           <roleName type="occ" corresp="#pe__georg_von_liechtenstein_QGW_II_I_1157">ambtman</roleName>
                        <rs type="person" ref="#pe__georg_von_liechtenstein_QGW_II_I_1157"><roleName type="title">Hern</roleName> Jörigen von Liechtenstain, <roleName type="occ" corresp="#org__wien-st_stephan">probst</roleName>
                           Allerheiligen tu/emkirichen dacz sand Stephan ze Wienn</rs></rs></rs>,
                     <triggerstring n="disp">beurkundet, dass vor ihm in offenem Gerichte</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="#pe__johann_QGW_II_I_1157"><roleName type="title">her</roleName> Hanns, <roleName type="occ" corresp="#org__wien-st_laurenz_am_alten_fleischmarkt-altar_st_johannes">kaplan</roleName> sand Johanns altar, elegen in sand Larenzen chloster
                        ze Wienn <triggerstring n="fn">mit vorsprechen</triggerstring></rs></rs>, <rs type="fn" role="other"><triggerstring n="fn">auf</triggerstring><rs type="person" ref="#pe__katharina_QGW_II_I_1157"><roleName type="title">frown</roleName>
                        Kathrein, <roleName type="kin" corresp="#pe__stephan_preunreich_QGW_II_I_1157"><add>wittib</add></roleName>
                        <rs type="person" ref="#pe__stephan_preunreich_QGW_II_I_1157">Stephans
                              <roleName type="dead">seligen</roleName> wittib des
                        Pre/aunreichs</rs></rs> haus </rs>, gelegen in der Rasengassen vor Kernertor
                  ze Wienn auf der Wydem zenegst Stephans haus des Pairs, umb 80 dn. versessens
                  purkrechts und um die darauf ertheilten zwischpilt, die von 1/2 lb dn. Burgrecht
                  herrühren, <triggerstring n="disp">geklagt habe</triggerstring>. Da nach erfolgter
                  Verständigung die Besitzerin das Haus nicht aus der Schuld löst, <triggerstring n="disp">gibt</triggerstring> der Amtmann dem Kläger die vier, die auf die Wydem
                  gesaczt wern, <rs type="fn" role="other"><rs type="person" ref="#pe__peter_eberger_QGW_II_I_1157">Petrein den Eberger</rs>, <rs type="person" ref="#pe__christian_schoerndl_QGW_II_I_1157">Christann den
                        Schörndlein</rs>, <rs type="person" ref="#pe__michael_herwart_QGW_II_I_1157">Micheln den Herwort</rs> und <rs type="person" ref="#pe__kolomann_rebstock_QGW_II_I_1157">Cholmann den Rebstokch</rs>,
                        <triggerstring n="fn">als Beschauleute mit</triggerstring></rs> und <triggerstring n="disp">macht <add>gewaltig</add></triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_QGW_II_I_1157">ihn</rs></rs> nach deren Aussage des Hauses gewaltig.</rs></p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1157"><rs type="fn" role="witness">Besiegelt mit
                     dem Siegel des <rs type="person" ref="#pe__georg_von_liechtenstein_QGW_II_I_1157"><roleName type="occ" corresp="#org__wien-st_stephan">Propstes</roleName></rs></rs>.</rs></p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>