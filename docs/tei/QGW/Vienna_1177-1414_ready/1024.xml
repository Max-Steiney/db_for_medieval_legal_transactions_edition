                  ihr <rs type="fn" role="recipient"><rs type="person" ref="#pe__ruediger_von_lanzendorf_QGW_II_I_1024"><roleName type="kin" corresp="#pe__johann_weidner_QGW_II_I_1024">Schwager</roleName>
