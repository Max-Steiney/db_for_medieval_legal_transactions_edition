               <rs type="event" ref="#ev__QGW_II_I_1024"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_weidner_QGW_II_I_1024">Hanns</rs> und <rs type="person" ref="#pe__hartneid_weidner_QGW_II_I_1024">Hertneid, <roleName type="kin" corresp="#pe__johann_weidner_QGW_II_I_1024">gebrüder</roleName>
