            <origDate instant="false">ze Wienne, des nagsten eritags vor Unser Vrowen tag der
               Lihtmesse.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00069_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00069_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p><rs type="event" ref="#ev__QGW_II_I_69">
                  <rs type="fn" role="issuer"><rs type="person" ref="#pe__hermann_von_st_poelten_QGW_II_I_61">Herman von Sand Polten,
                           <roleName type="occ" corresp="#org__wien">Bürgermeister</roleName></rs>,
                     und <rs type="org" ref="#org__wien">der Rath von der Stadt zu Wien</rs></rs>
                  <triggerstring n="disp">beurkunden</triggerstring>, dass vor ihnen <rs type="fn" role="other"><rs type="person" ref="#pe__engel_QGW_II_I_69"><roleName type="title">Frau</roleName> Engel <roleName type="kin" corresp="#pe__otto_piterl_QGW_II_I_69"><add>witibe</add></roleName>
                        <roleName type="kin" corresp="#pe__heinrich_chra_QGW_II_I_69"><add>tochter</add></roleName>, <rs type="person" ref="#pe__otto_piterl_QGW_II_I_69">Otten witibe des Piterlein</rs> und <rs type="person" ref="#pe__heinrich_chra_QGW_II_I_69">Heinriches tohter des
                           Chra</rs></rs>,<triggerstring n="fn"> aus
                        ehafter<add>Noth</add></triggerstring></rs>,<rs type="fn" role="other"> mit <rs type="person" ref="#pe__ulrich_von_wien_QGW_II_I_69"><roleName type="title">h.</roleName> Ulrich van Wienne</rs> und <rs type="person" ref="#pe__heinrich_straubing_QGW_II_I_69">Heinrich dem Stroubinger</rs>
                     <triggerstring n="fn">bewiesener Noth</triggerstring></rs> 2 lb dn. von ihrem Vater
                  ererbten Burgrechts, gelegen an dem Alten Fleischmarcht ze Wienne auf des
                  Chundigen hous gegen sand Laurenzen über, um 10 lb dn. und einen vierdung löthigen
                  Silbers <rs type="fn" role="recipient"><rs type="person" ref="#pe__georg_an_dem_kienmarkt_QGW_II_I_124"><roleName type="title">hern</roleName> Georien <roleName type="kin" corresp="#pe__andreas_an_dem_kienmarkt_QGW_II_I_107"><add>sun</add></roleName>,<rs type="person" ref="#pe__andreas_an_dem_kienmarkt_QGW_II_I_107">
                           <roleName type="title">hern</roleName> Andres sun an dem
                        Chienmarcht</rs></rs>, und <rs type="person" ref="#pe__jutta_QGW_II_I_69">seiner <roleName type="kin" corresp="#pe__georg_an_dem_kienmarkt_QGW_II_I_124">Hausfrau</roleName>
                        Jeuten</rs></rs>
                  <triggerstring n="disp">verkauft habe</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_69"><rs type="fn" role="witness"><rs type="org" ref="#org__wien">Besiegelt mit der stat insigel</rs></rs>.</rs>
