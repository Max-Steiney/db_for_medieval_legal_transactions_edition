            <origDate instant="false">an sant Michels abent.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00416_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00416_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p><rs type="event" ref="#ev__QGW_II_I_416">
                  <rs type="fn" role="issuer"><rs type="person" ref="#pe__heinrich_wuerfel_QGW_II_I_459">Hainreich der
                     Würffel</rs></rs><triggerstring n="disp"> gibt</triggerstring> 12 sh. dn. gelts
                  purchrechts, <rs type="event" ref="#ev__QGW_II_I_416_men_1">die er auf dem Weingarten, gelegen ze
                     Engelschalchstorf, gehabt hat, der weiln gewesen ist Dietreichs, des
                     pergmaister, der Schafferin sun, der von dem herzogen perchrecht ist, und den
                     man verdient auf das haus ze Medlich, und auf dem hof daselbs ze
                     Engelschalchstorf, der auch des vorgenanten Dietreichs, des pergmaister,
                     gewesen ist , von dem man dem Oheime des Ausstellers Haunolden dem Schüchler 80
                     dn. an S. Michaelstag, drei Hühner zu Weihnachten, 30 Eier und drei Käse zu
                     Ostern dient, welches Burgrecht Würfel von Herman dem Chrannest laut zweier
                     jetzt verlorenen Urkunden gekauft hatte, um 16 lb dn</rs>. <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_paechl_QGW_II_I_416">Jansen
                        dem Paechlein</rs> und <rs type="person" ref="#pe__engel_QGW_II_I_416">seiner
                           <roleName type="kin" corresp="#pe__johann_paechl_QGW_II_I_416">Hausfrau</roleName> Engeln </rs></rs><triggerstring n="disp">abzulösen</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_416"><rs type="fn" role="witness">Besiegelt mit
               den Siegeln: 1. <rs type="person" ref="#pe__heinrich_wuerfel_QGW_II_I_459">des
                        Ausstellers</rs>, 2. <rs type="person" ref="#pe__haunold_schuchler_QGW_II_I_170">seines <roleName type="kin" corresp="#pe__heinrich_wuerfel_QGW_II_I_459">Oheims</roleName> Haunolts des
                        Schüchler</rs>, 3. <rs type="person" ref="#pe__niklas_wuerfel_QGW_II_I_1001">seines <roleName type="kin" corresp="#pe__heinrich_wuerfel_QGW_II_I_459">Sohnes
                        </roleName>Nichlas des Würfels</rs>, 4. <rs type="person" ref="#pe__hermann_chrannest_QGW_II_I_416">Hermans des
                  Chrannests</rs></rs>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>