                  <triggerstring n="disp">bestätigt</triggerstring>, <rs type="fn" role="other">dass der
                        <rs type="person" ref="#pe__johann_von_ybbs_QGW_II_I_1033"><roleName type="title">Ritter</roleName>
                        <roleName type="title">her</roleName> Jans von Ibs, <roleName type="dead">seliger gedechtnusse</roleName></rs>, zu ainem selgerêt für sein, seiner
                        <rs type="person" ref="#pe__margarethe_QGW_II_I_417_a"><roleName type="dead">verstorbenen</roleName>
                        <roleName type="kin" corresp="#pe__johann_von_ybbs_QGW_II_I_1033">Hausfrau</roleName> Margreten</rs>, seiner Vorfahren und Nachkommen
