   <text>
      <body>
         <div type="abstract" resp="lp">
            <p>
               <rs type="event" ref="#ev__QGW_II_I_733"><rs type="fn" role="issuer"><rs type="person"
                        ref="#pe__michael_vierdung_QGW_II_I_804">Michel der Vierdung, <roleName
                           type="occ" corresp="#org__wien">purger</roleName> ze Wienn</rs>, und <rs
                        type="person" ref="#pe__margarethe_QGW_II_I_733">Margret, seine <roleName
                           type="kin" corresp="#pe__michael_vierdung_QGW_II_I_804"
                           >Hausfrau</roleName></rs></rs>, <triggerstring n="disp"
                     >verkaufen</triggerstring><rs type="fn" role="other">
                     <triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__ulrich_spaet_QGW_II_I_733">ihres <roleName
                           type="occ" corresp="#org__heiligenkreuz-zisterzienser"
                           >Bergmeisters</roleName> Ulreichs des Späten von Praitense, <roleName
                           type="occ" corresp="#org__heiligenkreuz-zisterzienser"
                           >pergmaister</roleName> der erbern geistlichen herren dacz dem
                        Heiligenchräutz</rs></rs>, 7 sh. dn. geltes purchrechts (ablösbar) auf ihrem
                  Weingarten, gelegen ze Praitense, des fumf ochtail sind, zenast des Jendleins
                  weingarten auf der Widem ze Wienn , von dem man 75 dn. für Bergrecht und Zehent, 3
                  dn. zu Voitrecht dient,<rs type="fn" role="recipient">
                     <rs type="person" ref="#pe__heinrich_silberbrenner_QGW_II_I_733">Hainreichen
                           <roleName type="kin" corresp="#pe__klara_QGW_II_I_733"
                           ><add>sun</add></roleName>,<rs type="person" ref="#pe__klara_QGW_II_I_733"
                           > Chlarn sun der Silberprennerin</rs></rs></rs>, um 7 lb dn., <rs
                     type="event" ref="#ev__QGW_II_I_733_men_1">die diesem angefallen waren von dem
                     Hause, gelegen var Chernertor ze Wienn, das sein steufvater Ulreich, der
                     maurer, und die egenant sein mueter, baide mit ainander hinder in lassen
                     habent, und das Niclas, der pader auf dem Mist var Schottentar ze Wienn , dem
                     Ulreich der Maurer 7 lb dn. schuldete, für 14 lb dn. Ulreichen dem Rasenlacher,
                     dem schuster, und seiner Hausfrau Kathrein verkauft hatte.</rs></rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_733"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1.<rs type="person" ref="#pe__michael_vierdung_QGW_II_I_804"> des
                        Ausstellers</rs>, 2. <rs type="person" ref="#pe__kolomann_QGW_II_I_1111">des
                           <roleName type="title">obersten Bergherrn</roleName>
                        <roleName type="occ" corresp="#org__heiligenkreuz-zisterzienser"
                           >Abt</roleName> Cholman dacz dem Heiligenchräutz</rs>.</rs>
               </rs></p>
         </div>
