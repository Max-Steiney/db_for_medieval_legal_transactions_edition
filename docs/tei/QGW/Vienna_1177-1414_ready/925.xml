            <origDate instant="false">ze Wienne, des nasten freitags vor Unser Vrowen tag zu der
               Liechtmesse.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00925_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00925_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_925"><rs type="fn" role="issuer"><rs type="person" ref="#pe__wolfhard_von_amstetten_QGW_II_I_925">Wolfhard von Amsteten, <roleName type="occ" corresp="#org__wien">urtailschreiber</roleName> ze Wienn</rs> , und <rs type="person" ref="#pe__gertrud_QGW_II_I_732">Gedraud, seine <roleName type="kin" corresp="#pe__wolfhard_von_amstetten_QGW_II_I_925">Hausfrau</roleName></rs></rs> , <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__paul_holzkaeufel_QGW_II_I_1010"><roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Paulus des Holzchauffels</rs> und des
                        <rs type="org" ref="#org__wien">rates gemain der stat ze Wienne</rs></rs> ein
                  lb dn. gelts purchrechts (ablösbar) auf ihrem Hause, genant der Tu/ern und auf den
                  vier chrêmen, die darzu/e geho/erent, gelegen an dem Hahenmarkcht ze Wienne an
                  ainem tail und mit dem andern tail in dem Huenrgêsslein, und leit zenast dem haus,
                  das weilnt Jannsens des Raten gewesen ist , von welchem Hause und den Krämen man
                  den geistlichen Frauen dacz der Himelparden ½ lb dn., in den dritten Orden ze Wien
                  ½ lb dn. und hern Jannsen, pharrer ze Vesnicz, 7 lb dn. gelts, alles ze
                  purchrecht, dient, um 8 lb dn. <rs type="fn" role="recipient">dem <rs type="person" ref="#pe__otto_QGW_II_I_925"><roleName type="prof">Priester</roleName>
                        <roleName type="title">hern</roleName> Otten , <roleName type="occ" corresp="#org__wien-st_stephan-altar_st_margarethe-messe_urbetsch">Kaplan</roleName></rs> der ewigen Messe</rs>, die di Urbêtzschen sêlig
                  auf sand Margreten alter auf der parchirchen dacz sand Stephan ze Wienne gewidempt
                  und gestifft habent , <rs type="event" ref="#ev__QGW_II_I_925_men_1">der zum Ankaufe 8 lb dn.
                     verwendete, mit denen <rs type="person" ref="#pe__niklas_QGW_II_I_925">Niclas,
                        der <roleName type="prof">hantschuster</roleName></rs>, 1 lb dn. gelts von
                     seinem Hause, gelegen auf dem Anger, abgelöst hatte</rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_925"><rs type="fn" role="witness">Besiegelt mit
                     dem städtischen <rs type="org" ref="#org__wien">Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="#pe__konrad_slecht_QGW_II_I_773">Wiener <roleName type="occ" corresp="#org__wien">Bürgers</roleName>
                        <roleName type="title">hern</roleName> Chunrads des Slechten</rs>.</rs></rs>
            </p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>