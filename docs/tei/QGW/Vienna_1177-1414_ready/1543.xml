            <date when="14030618">1403 VI 18</date>
            <origDate instant="false">ze Wienn, des nagsten eritags nach sand Veits tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01543_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01543_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="#ev__QGW_II_I_1543"><rs type="fn" role="issuer"><rs type="person" ref="#pe__peter_angerfelder_QGW_II_I_1373">Peter der Angervelder,
                        statrichter ze Wienn</rs>,</rs>
                  <triggerstring n="disp">beurkundet, dass vor ihm in der Bürgerschranne</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="#pe__otto_murbecz_QGW_II_I_1543">Ott Murbeczel <triggerstring n="fn">mit Vorsprechen</triggerstring></rs></rs>
                  <triggerstring n="disp">geklagt habe</triggerstring>, dass im Jacob Hunthoch invell und
                  irrung tet an seinem und seins enikchel Wilhalms des Hannsgrafen haus und
                  wachsglet, gelegen in der Hindern Pekchenstrass ze Wienn zenagst Niclas Oswalts
                  haus. Darauf habe ihn Herzog Albrecht beauftragt, <rs type="fn" role="other"><triggerstring n="fn"><add>hincz</add></triggerstring>
                     <rs type="person" ref="#pe__jakob_hunthoch_QGW_II_I_1543">Jacoben Hunthoch</rs>
                     vorzuladen</rs> da nun dieser an dem festgesetzten Tage nicht vor Gericht
                  erscheint, so weist er jeden Anspruch gegen <rs type="fn" role="recipient">den
                     Kläger</rs> ab.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1543"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="#pe__peter_angerfelder_QGW_II_I_1373">Aussteller</rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>