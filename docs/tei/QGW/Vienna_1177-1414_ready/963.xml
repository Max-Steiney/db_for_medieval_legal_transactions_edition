            <origDate instant="false">des nechsten mantags vor Gotesleichnam tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00963_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00963_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_963"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_von_wildeck_QGW_II_I_963">Hanns von Wildekk</rs> und <rs type="person" ref="#pe__ursula_QGW_II_I_963">Ursula, seine <roleName type="kin" corresp="#pe__johann_von_wildeck_QGW_II_I_963">Hausfrau</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen</triggerstring> eine Brandstatt, die weilnt <rs type="person" ref="#pe__leopold_von_sierndorf_QGW_II_I_1230"><roleName type="title">hern</roleName> Leupolts von Sierndorf gewesen ist, dem <roleName type="dead">got genad</roleName></rs>, gelegen ze Wienn oberhalb des hauses
                  in der Ratstrass, das auch desselben hern Leupolts gewesen ist, und stosst dieselb
                  prantstat an herrn Hannsen haus des Losperger und an Ernreichs haus, des pekchen,
                  und ist ledig und frei, also dass sie nichts dient weder gruntrecht noch
                  purchrecht , um 6 lb dn. dem <rs type="fn" role="recipient"><rs type="person" ref="#pe__thomas_von_st_georgen_QGW_II_I_1230"><roleName type="title">Grafen</roleName> Thomann von Sant Jörgen</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_963"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="#pe__johann_von_wildeck_QGW_II_I_963">Ausstellers</rs>, 2. der <rs type="person" ref="#pe__agnes_reichenstainerin_QGW_II_I_963"><roleName type="title">Frau</roleName> Angnesen der Raichenstainerinn, des vorgenannten hern
                        Leupolts <roleName type="kin" corresp="#pe__leopold_von_sierndorf_QGW_II_I_1230">Schwester</roleName></rs>, 3. des <rs type="person" ref="#pe__rudolf_scheurbekch_QGW_II_I_963">
                        <roleName type="kin" corresp="#pe__johann_von_wildeck_QGW_II_I_963">Eidams</roleName> des
                        Ausstellers Rudolfs des Sche/aurbekchen</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>