            <date when="13570427">1357 IV 27</date>
            <origDate instant="false">ze Wienne, des naechsten phincztags nach sant Jörigen
               tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00497_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00497_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_497"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_poll_QGW_II_I_850">Jans der Poll, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienne</rs>, und <rs type="person" ref="#pe__katharina_QGW_II_I_497">Katrei, seine <roleName type="kin" corresp="#pe__johann_poll_QGW_II_I_850">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  5 lb dn. geltes ewiges purchrechts (<rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__johann_greiffe_QGW_II_I_792">des <roleName type="title">Grundherrn</roleName> des <roleName type="title">Ritters</roleName>
                        <roleName type="title">hern</roleName> Jansen des Greifen</rs></rs> 2 lb dn.
                  auf Esrams haus, des Juden, das weiln Joesleins, des Juden, gewesen ist, das da
                  leit in der Judengassen ze Wienn zenaechst dem Turn , und <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__peter_QGW_II_I_497">des <roleName type="title">Grundherrn</roleName>
                        <roleName type="title">hern</roleName> Petreins, <roleName type="occ" corresp="#org__wien-st_niklas_dacz_den_roeren">chaplan</roleName> der
                        chapellen sant Nichlas dacz den Rören ze Wienne</rs></rs>, 3 lb dn. auf dem
                  Hause in der Messrerstrasse ze Wienne gegen Paeurertor über und haisset in dem
                  Eisnein gattern) um 70 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__heinrich_QGW_II_I_497"><roleName type="title">hern</roleName>
                        Hainreichen, <roleName type="occ" corresp="#org__wien-st_anton_auf_der_wieden">chaplan und
                           verweser</roleName> des alter sant Thomans, der da stet in der chirichen
                        sant Antonii auf der Widem vor Chaernertor ze Wienne</rs> .</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_497"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1.<rs type="person" ref="#pe__johann_poll_QGW_II_I_850"> des
                        Ausstellers</rs>, 2., 3. <rs type="person" ref="#pe__johann_greiffe_QGW_II_I_792">der Grundherren</rs>
                     <rs type="person" ref="#pe__peter_QGW_II_I_497"><add>der Grundherrn</add></rs>,
                     4. <rs type="person" ref="#pe__konrad_herrscheftel_QGW_II_I_447"><roleName type="title">hern</roleName> Chunrats des Herschaeftleins</rs>, 5. <rs type="person" ref="#pe__herbert_deckenschaden_QGW_II_I_390"><roleName type="title">hern</roleName> Herborts des Tekchenschaden</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>