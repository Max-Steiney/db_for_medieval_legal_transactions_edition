            <date when="13820121">1382 I 21</date>
            <origDate instant="false">Das ist geschehen nach Christ gepurt 1300 iar und darnach in dem 82. iar, an
               dem tag der heiligen iunchfraun sand Agnes. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01023_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01023_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1023"><rs type="fn" role="issuer"><rs type="person" ref="#pe__heinrich_QGW_II_I_1023">Heinrich, <roleName type="title">paternostrer</roleName></rs></rs>, <triggerstring n="disp">zeigt <add>an</add></triggerstring> dem <rs type="fn" role="recipient"><rs type="person" ref="#pe__leopold_prunner_QGW_II_I_896">Leubel,
                        pru/enner</rs></rs>, an, dass er das Haus hinder sand Pangracen <rs type="fn" role="other"><triggerstring n="fn">vor</triggerstring> dem <rs type="org" ref="#org__wien">purgermaister</rs></rs> und <rs type="fn" role="other"><triggerstring n="fn">vor</triggerstring> dem <rs type="person" ref="#pe__pilgrim_QGW_II_I_1023">Pilgrein</rs></rs>
                  <triggerstring n="disp"><add>das Haus</add> aufgegeben</triggerstring> und auf das Geld
                     <rs type="fn" role="other"><triggerstring n="fn">gegen</triggerstring> seines Bruders
                     Weib</rs>
                  <triggerstring n="disp">verzichtet habe</triggerstring>, sowie dass er <rs type="fn" role="other"><triggerstring n="fn">vor</triggerstring> dem <rs type="person" ref="#pe__jakob_QGW_II_I_1023"><roleName type="occ" corresp="#org__ofen">gesworn man</roleName> der stat zu Oven Jacob, <roleName type="prof">chürsner</roleName></rs></rs>, <triggerstring n="disp">erklärt
                     habe</triggerstring>, dass Leubel, wenn er das Geld, dessen er sich vervangen
                  habe, den Juden ausrichte, <triggerstring n="disp">über das Haus volle Gewalt haben
                     solle</triggerstring>. <rs type="fn" role="witness">Zur Beglaubigung habe <rs type="person" ref="#pe__jakob_QGW_II_I_1023">Jacob, <roleName type="prof">chürsner</roleName></rs>, diesem Schreiben sein Siegel
                  aufgedrückt</rs>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>