                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen </triggerstring><rs type="person" ref="#pe__laurenz_scharrer_QGW_II_I_769">Larenzs des Scharrer, <roleName type="occ" corresp="#org__perchtoldsdorf">richter</roleName> ze
