            <date when="13460803">1346 VIII 03</date>
            <origDate instant="false">ze Wienne, an sand Stephans tage in dem
            snit.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00301_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00301_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_301"><rs type="fn" role="issuer"><rs type="person" ref="#pe__andreas_von_hacking_QGW_II_I_301">Andre, der <roleName type="occ" corresp="#org__wien-st_klara" select="#pl__hacking">pergmaister</roleName>
                        von Haekkingen</rs></rs>, <triggerstring n="disp">verpfändet</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> seiner <rs type="person" ref="#pe__mathilde_QGW_II_I_301"><roleName type="title">Grundfrau</roleName>
                        <roleName type="title">vrowen</roleName>
                        <roleName type="title">swester</roleName> Mechtilten, <roleName type="occ" corresp="#org__wien-st_klara">aptessinne</roleName> dacz sand Chlarn ze
                        Wienne</rs></rs>, die Uebertheuerung seiner Mühle ze Haekkinge, von der man
                  jährlich 3 lb dn. zu Grund und Burgrecht dient, über die 12 lb dn., um welche er
                  die Mühle hinz <rs type="person" ref="#pe__haetschel_jude_QGW_II_I_301">Haetschlein, dem Juden,<roleName type="kin" corresp="#pe__plum_QGW_II_I_85"><add>sun</add></roleName>
                     <rs type="person" ref="#pe__plum_QGW_II_I_85">Plumen sun von
                  Neunburch</rs></rs>, versetzt hatte, <rs type="fn" role="recipient"><rs type="person" ref="#pe__berthold_poll_QGW_II_I_121"><roleName type="title">hern</roleName> Perichtolden dem Pollen</rs></rs> zesampt der müle, die
                  er von diesem gekauft hatte, die da leit ze Hietzinge an dem Gern, an ein halb
                  phunt umb zwainzich lb dn. geltes purchrechtes . <rs type="fn" role="other">Als
                        <triggerstring n="fn">Bürgen</triggerstring> werden neben dem Aussteller genannt
                     seine <rs type="person" ref="#pe__ulrich_haiden_QGW_II_I_301"><roleName type="kin" corresp="#pe__andreas_von_hacking_QGW_II_I_301">Brüder</roleName> Ulreich der Haiden </rs>und <rs type="person" ref="#pe__stephan_schricker_QGW_II_I_301"><roleName type="kin" corresp="#pe__andreas_von_hacking_QGW_II_I_301"><add>Brüder</add></roleName>Stephan der Schricker</rs> mit ihren <rs type="person" ref="#pe__anna_QGW_II_I_301"><roleName type="kin" corresp="#pe__ulrich_QGW_II_I_301">Hausfrauen</roleName> Anna</rs> und <rs type="person" ref="#pe__elisabeth_QGW_II_I_301_a"><roleName type="kin" corresp="#pe__stephan_schricker_QGW_II_I_301"><add>Hausfrauen</add></roleName>Elsbet</rs>, <rs type="person" ref="#pe__bernhard_QGW_II_I_301">Wernhart, der <roleName type="occ" corresp="#org__oesterreich-herzogtum" select="#pl__lainz">amman</roleName>
                        von Lu/entz</rs>, und <rs type="person" ref="#pe__jutta_QGW_II_I_301">dessen
                           <roleName type="kin" corresp="#pe__bernhard_QGW_II_I_301">Hausfrau</roleName> Jeut</rs>, sowie dessen. <rs type="person" ref="#pe__peter_QGW_II_I_301"><roleName type="kin" corresp="#pe__bernhard_QGW_II_I_301">Söhne</roleName> Peter</rs>, <rs type="person" ref="#pe__konrad_mestenbach_QGW_II_I_301"><roleName type="kin" corresp="#pe__bernhard_QGW_II_I_301"><add>Söhne</add></roleName>Chunrat
                        der Mestenbach</rs>, <rs type="person" ref="#pe__ulrich_QGW_II_I_301"><roleName type="kin" corresp="#pe__bernhard_QGW_II_I_301"><add>Söhne</add></roleName>Ulreich</rs> mit ihren <rs type="person" ref="#pe__petra_QGW_II_I_301"><roleName type="kin" corresp="#pe__peter_QGW_II_I_301">Hausfrauen</roleName> Peters</rs>, <rs type="person" ref="#pe__elisabeth_QGW_II_I_301_b"><roleName type="kin" corresp="#pe__konrad_mestenbach_QGW_II_I_301"><add>Hausfrauen</add></roleName>Elsbet</rs> und <rs type="person" ref="#pe__margarethe_QGW_II_I_301"><roleName type="kin" corresp="#pe__ulrich_QGW_II_I_301"><add>Hausfrauen</add></roleName>Margret</rs>.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_301"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="#pe__ulrich_haiden_QGW_II_I_301">Ulreichs
                        des Heiden</rs>, 2.<rs type="person" ref="#pe__mathilde_QGW_II_I_301"> der
                        Grundfrau,</rs> 3. <rs type="person" ref="#pe__friedrich_von_topel_QGW_II_I_301">hern Fridreichs von
                     Toppel</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. L. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>