               <rs type="event" ref="#ev__QGW_II_I_153"><rs type="fn" role="issuer"><rs type="person" ref="#pe__jakob_feldsberger_QGW_II_I_153">Jacob der Velsperger von Lô</rs>
                     und <rs type="person" ref="#pe__margarethe_QGW_II_I_153">Margret, seine
                           <roleName type="kin" corresp="#pe__jakob_feldsberger_QGW_II_I_153">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="#pe__siegfried_von_obern_suefring_QGW_II_I_153">
                        <roleName type="occ" corresp="#pe__herr_von_wolkersdorf_QGW_II_I_153">Bergmeisters</roleName> Seifrides von Obern Su/ofringe, <roleName type="occ" corresp="#pe__herr_von_wolkersdorf_QGW_II_I_153">amptman</roleName> des <rs type="person" ref="#pe__herr_von_wolkersdorf_QGW_II_I_153">erbern herren von
                           Wolfkersdorf</rs></rs></rs>, ein halbes Joch und ein Achtel Weingarten ze
                  Chlaitzingen zenachst der Teutschen Herren weingarten, von dem man jährlich 18 ½
                  dn. zu Bergrecht und zu Voitrecht dient, um 15 Mark Silber, ie zwen und sibenzich
                  grosser pehemischer phenninge fu/er ein iegleich march, <rs type="fn" role="recipient">dem <rs type="person" ref="#pe__pilgrim_rot_QGW_II_I_408_a">
                        <roleName type="title">ehrbaren</roleName> Manne <roleName type="title">hern</roleName> Pilgreim <roleName type="kin" corresp="#pe__markhard_rot_QGW_II_I_777"><add>sun</add></roleName>, des<rs type="person" ref="#pe__markhard_rot_QGW_II_I_777"> Roten hern Marichartes
                           sun, <roleName type="dead">dem got genade</roleName></rs></rs>, und <rs type="person" ref="#pe__agnes_QGW_II_I_279">seiner <roleName type="kin" corresp="#pe__pilgrim_rot_QGW_II_I_408_a">Hausfrau</roleName>
                     Agnes</rs></rs></rs>. </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_153"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="#pe__jakob_feldsberger_QGW_II_I_153">des
                        Ausstellers</rs>, 2. <rs type="person" ref="#pe__heinrich_auf_der_saeule_QGW_II_I_199"><roleName type="title">hern</roleName> Hainreichs auf der Seul</rs>, 3. <rs type="person" ref="#pe__berthold_schuetzenmeister_QGW_II_I_153"><roleName type="title">hern</roleName> Perichtolds des Schützenmaister</rs>.</rs></rs>
