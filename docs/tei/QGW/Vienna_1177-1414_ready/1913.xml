         <div type="abstract">
            <p>
               <rs type="event" ref="#ev__QGW_II_II_1913"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_eitzinger_QGW_II_II_1913">Hanns der
                        Eiczinger</rs></rs>
                  <triggerstring n="disp">bestätigt</triggerstring>, von dem <rs type="fn" role="recipient">Wiener <roleName type="occ" corresp="#org__wien">Bürger</roleName> Hanns Mosprunner</rs> 28 lb dn. <triggerstring n="disp">erhalten zu haben</triggerstring>, <rs type="event" ref="NULL">welche <rs type="person" ref="#pe__johann_arnstorfer_QGW_II_I_1249">Hanns
                        Arnstarffer</rs>
                     <rs type="person" ref="#pe__elisabeth_QGW_II_II_1913">junchfraun Elspeten</rs>,
                     die der Eitzinger einem <rs type="person" ref="#pe__albrecht_jedel_QGW_II_II_1913"><roleName type="title">erbern
                           chnecht</roleName>, genannt Albrecht Jedel</rs>, versprochen hat, zu
                     einem man geschafft hatte</rs>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_II_1913"><rs type="fn" role="witness">Besiegelt mit den petschaden des <rs type="person" ref="#pe__johann_eitzinger_QGW_II_II_1913">Ausstellers</rs> und <rs type="person" ref="#pe__johann_fritzelsdorfer_StB_I_532">Hannsen des
                     Friczestärffer</rs></rs>.</rs>
            </p>
