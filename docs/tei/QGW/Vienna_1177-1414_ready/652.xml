                              <rs type="event" ref="#ev__QGW_II_I_652"><rs type="fn" role="issuer"><rs type="person" ref="#pe__agnes_QGW_II_I_652">Angnes, <roleName type="kin" corresp="#pe__leopold_velmund_QGW_II_I_758"><add>witib</add></roleName>
                                                <rs type="person" ref="#pe__leopold_velmund_QGW_II_I_758">Leupolts
                                                  <roleName type="dead">witib</roleName> des
                                                  Valmunds</rs></rs></rs>, <triggerstring n="disp">verkauft</triggerstring>
                                    <rs type="fn" role="other"><triggerstring n="fn">mit
                                                Handen</triggerstring> des <rs type="person" ref="#pe__thomas_von_moellersdorf_QGW_II_I_652"><roleName type="occ" corresp="#org__gumpoldskirchen-pfarre">Bergmeisters</roleName> Thomans von Molesdorf,
