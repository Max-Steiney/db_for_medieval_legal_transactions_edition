            <date when="13841230">1384 XII 30</date>
            <origDate instant="false">Der geben ist ze Wienn, nach Kristes gepurd 1300 jar darnach in dem 85. jar,
               des nächsten freitags nach dem heiligen Weichnachttag. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01080_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01080_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1080"><rs type="fn" role="issuer"><rs type="person" ref="#pe__heczschl_jude_von_herzogenburg">Hetschel, der Jud
                        von Herzogenburkch ze Wienn, Izrahels <roleName type="kin" corresp="#pe__israel_jude_von_krems_QGW_II_I_1080">sun</roleName> von
                        Chrems</rs></rs>, <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__paul_holzkaeufel_QGW_II_I_1010"><roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Pauln des Holzkäuffels</rs> und des
                        <rs type="org" ref="#org__wien">rates gemain der stat ze Wienn</rs></rs> ein
                  Haus, <rs type="event" ref="#ev__QGW_II_I_1080_men_1">das ihm für haubtgut und gesuch verstanden war
                     von <rs type="person" ref="#pe__brigitta_QGW_II_I_1080"><roleName type="title">fraun</roleName> Preiden <roleName type="kin" corresp="#pe__erhard_geswenter_QGW_II_I_1080"><add>witib</add></roleName></rs>, <rs type="person" ref="#pe__erhard_geswenter_QGW_II_I_1080">Erharts <roleName type="dead">seligen</roleName> wittib des Geswentter</rs>, wegen des Geldes, welches
                     sie und <rs type="person" ref="#pe__peter_pehem_QGW_II_I_1080">Peter der Pehem</rs> ihm
                     schuldig waren</rs>, gelegen under den Satlern ze Wienn zenechst Chunrats haus
                  des Ympnauer, von dem man in der purger Spital vor Kernertor ze Wienn 3 lb dn. zu
                  Burgrecht dient, um 100 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_don_QGW_II_I_1080">Jannsen dem Don, dem <roleName type="prof">gürtler</roleName> ze Wienn</rs>, und seiner <rs type="person" ref="#pe__katharina_QGW_II_I_1080"><roleName type="kin" corresp="#pe__johann_don_QGW_II_I_1080">Hausfrau</roleName>
                     Kathrein</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1080"><rs type="fn" role="witness">Besiegelt : 1.
                     mit dem <rs type="org" ref="#org__wien">städtischen Grundsiegel</rs> und mit den
                     Siegeln: 2. <rs type="person" ref="#pe__johann_puettreich_QGW_II_I_1079"><roleName type="title">hern</roleName> Hannsen des Pu/etreichs, <roleName type="occ" corresp="#org__wien">judenrichter</roleName> ze Wienn</rs>, 3.
                        <rs type="person" ref="#pe__ulrich_roessl_QGW_II_I_1025"><roleName type="title">hern</roleName> Ulreichs des Rössleins, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienn</rs>. </rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>