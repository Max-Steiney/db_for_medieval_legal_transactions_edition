            <origDate instant="false">ze Wienn, des nachsten phinztags vor sand Lucein tag, der heiligen
               junkchfraun.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01606_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01606_v.jpg"/></surface></facsimile><!-- weitere recipienten? roles? --><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="#ev__QGW_II_I_1606"><rs type="fn" role="issuer"><rs type="person" ref="#pe__salomon_QGW_II_I_1606">Salman, der Jud,
                           <roleName type="kin" corresp="#pe__mair_jude_QGW_II_I_1535"><add>sun</add></roleName>
                        <rs type="person" ref="#pe__mair_jude_QGW_II_I_1535"><roleName type="title">maister</roleName> Mairs sun, des Juden ze
                        Wienn</rs></rs>,</rs>
                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__paul_wuerfel_QGW_II_I_1200"><roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Pauln des Würffels</rs> und des <rs type="org" ref="#org__wien">rats gemain der stat ze Wienn</rs></rs> ein
                  Haus, <rs type="event" ref="#ev__QGW_II_I_1606_men_1">das er Hannsen dem Siedendorfer anstat der
                     zwair Ju/edinn Hannsuez/zz/zen, Steussen tochter des Juden, Riffca, Abrahams
                     hausfrau des Juden, für ir geltschuld mit rechten nottêdingen in der
                     Purgerschrann ze Wienn anerlangt und anbehabt hat,</rs> gelegen in der
                  Su/enigerstrass ze Wienn zenechst der padstuben, von dem man zu der ewigen Messe,
                  die der Urbetsch auf der heiligen Zwelfboten altar, gelegen in sand Stephans
                  tumkirchen ze Wienn gewidemt und gestifft hat, 5 lb dn. zu Burgrecht dient, <rs type="fn" role="recipient">dem <rs type="person" ref="#pe__niklas_hauser_QGW_II_I_1606">Wiener <roleName type="occ" corresp="#org__wien">Bürger</roleName> Niklasen dem
                        Hauser, dem <roleName type="prof">ku/ersner</roleName></rs>,</rs> um 117 lb
                  7 sh. 3 dn., wovon 71 lb 43 dn. den beiden Jüdinnen, 17 lb 6 sh. 20 dn. Ulreichen
                  dem Werder, 5 lb dn. Wernharten, dem tuchbraitter, und 23 lb 7 sh. dn. Hannsen dem
                  Perman zufallen.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1606"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="#org__wien">städtischen Grundsiegel</rs> und dem Siegel
                        <rs type="person" ref="#pe__georg_von_nikolsburg_QGW_II_I_1010"><roleName type="title">hern</roleName> Jörgen von Nicolspurgkch, des <roleName type="occ" corresp="#org__wien">aussern rats der stat</roleName> zu
                  Wienn</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>