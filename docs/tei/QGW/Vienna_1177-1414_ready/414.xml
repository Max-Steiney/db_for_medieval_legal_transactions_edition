               <rs type="event" ref="#ev__QGW_II_I_414"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_QGW_II_I_414">Johans, <roleName type="kin" corresp="#pe__wolfgang_QGW_II_I_414">su/on</roleName>
                        <rs type="person" ref="#pe__wolfgang_QGW_II_I_414"><roleName type="title">hern </roleName>Wolfgers su/on, <roleName type="occ" corresp="#org__oedenburg">riehter</roleName> in Oedenburch</rs></rs>,
                     und die <rs type="org" ref="#org__oedenburg">gesworn purger mitsompt der gemain
                        auch daselbs</rs></rs> , <triggerstring n="disp">beurkunden</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="#org__wien">den flaischkern von
                        der stat ze Wienn</rs> und allen den laeuten, di da arbaitend di strass aus
                     den landen des hochgeporn fürsten hern Albrecht . . . unz gen Oedenburch</rs>,
                  dass die maut an dem Crauczhof ze Oedenburch von alter her also chomen ist : Es
                  sind zu entrichten von einem schweren Tuch von Dorn 6 dn., von einem geringen von
                  Dorn 4 dn., von einem langen von Koln 6 dn., von einem Eiperschen Tuch 9 dn., von
                  einem langen von Leven 9 dn., von einem kurzen von Leven 6 dn., von einem von Auch
                  4 dn., von einem langen von Mentz 4 dn., von einem Polanischen 2 dn., von einem
                  loden oder von einem grauen tu/och 3 helbling. </rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>