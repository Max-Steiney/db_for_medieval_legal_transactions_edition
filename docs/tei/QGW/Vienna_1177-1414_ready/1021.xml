            <date when="13811213">1381 XII 13</date>
            <origDate instant="false">ze Wienn, des nasten freitags nach sand Niclas tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01021_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01021_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1021"><rs type="fn" role="issuer"><rs type="person" ref="#pe__wolfhard_pob_QGW_II_I_1011">Wolfhard der Pob, <roleName type="occ" corresp="#org__wien">statrichter</roleName> ze Wienn</rs></rs>,
                     <triggerstring n="disp">beurkundet, dass vor ihm in der
                     Bürgerschranne</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="#pe__friedrich_naezeuger_QGW_II_I_1018">Fridreich der Nezeuger <roleName type="rep" corresp="#pe__lucia_QGW_II_I_1018"><add>anstatt</add></roleName></rs>
                     <triggerstring n="fn">mit Vorsprechen</triggerstring> anstatt</rs>
                  <rs type="person" ref="#pe__lucia_QGW_II_I_1018"><roleName type="title">frown</roleName> Lucein <roleName type="kin" corresp="#pe__stephan_naezeuger_QGW_II_I_1011"><add>witib</add></roleName></rs>, <rs type="person" ref="#pe__stephan_naezeuger_QGW_II_I_1011"><roleName type="title">hern</roleName> Stephans <roleName type="dead">selig</roleName> witib des
                     Nezeuger</rs>, <triggerstring n="disp">bewiesen habe</triggerstring>, dass diese nach
                  der Stadt Recht <triggerstring n="disp">ein Verbot</triggerstring> auf 9 Fuder und 3
                  Dreiling Wein <triggerstring n="disp">genommen habe</triggerstring> wegen der 200 lb
                  dn., die Merten dem Stainer gebührten an den 800 lb dn., <rs type="event" ref="#ev__QGW_II_I_1021_men_1">darumb sich derselb <rs type="person" ref="#pe__martin_stainer_QGW_II_I_1011">Mert
                        der Stainer</rs>, <rs type="person" ref="#pe__johann_an_dem_kienmarkt_QGW_II_I_1009"><roleName type="title">her</roleName> Jans an dem Chienmarcht</rs>, <rs type="person" ref="#pe__stephan_naezeuger_QGW_II_I_1011">Stephan der Nezeuger</rs> und <rs type="person" ref="#pe__ulrich_muenzer_QGW_II_I_1547">Ulreich, der
                           <roleName type="prof">münsser</roleName></rs>, unverschaidenlichen hinz
                     dem <rs type="person" ref="#pe__georg_pollnheimer_QGW_II_I_1011">Pollenhaimer</rs> umb
                        <triggerstring n="disp">verschriben hieten</triggerstring></rs> . Da nun <rs type="person" ref="#pe__martin_stainer_QGW_II_I_1011">Mert der Stainer</rs> und seine <rs type="person" ref="#pe__anna_QGW_II_I_1021"><roleName type="kin" corresp="#pe__martin_stainer_QGW_II_I_1011">Hausfrau</roleName> Anne</rs> gestorben waren,
                  ohne ihren Antheil an dieser Schuld gezahlt zu haben, <triggerstring n="disp">spricht
                        <add>zu</add></triggerstring> der Richter der genannten <rs type="fn" role="recipient"><rs type="person" ref="#pe__lucia_QGW_II_I_1018">Lucein</rs></rs>
                  den Wein zu, den das Ehepaar in seinem Hause am Chienmarkt zurückgelassen
                  hatte.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1021"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="#pe__wolfhard_pob_QGW_II_I_1011">Aussteller</rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>