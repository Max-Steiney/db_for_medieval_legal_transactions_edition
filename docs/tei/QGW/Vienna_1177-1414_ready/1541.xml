            <origDate instant="false">ze Wienn, an Unsers Herren Aufvart abend.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01541_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01541_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="#ev__QGW_II_I_1541"><rs type="fn" role="issuer"><rs type="person" ref="#pe__jakob_suzz_QGW_II_I_1541">Jacob der Suez/zz/z,
                           <roleName type="occ" corresp="#org__wien">purger ze
                           Wienn</roleName></rs>,</rs>
                  <triggerstring n="disp">beurkundet die</triggerstring>
                  <rs type="fn" role="recipient">mit seinem <rs type="person" ref="#pe__urban_holzkaeufel_QGW_II_I_1508"><roleName type="kin" corresp="#pe__jakob_suzz_QGW_II_I_1541">Bruder</roleName> Urbann dem
                        Holzke/auffel, auch <roleName type="occ" corresp="#org__wien">purger
                           ze Wienn</roleName></rs>,</rs>
                  <triggerstring n="disp">vorgenommene Theilung</triggerstring> der ihnen von ihrer <rs type="person" ref="#pe__christine_QGW_II_I_1541"><roleName type="kin" corresp="#pe__jakob_suzz_QGW_II_I_1541">Mutter</roleName>
                     <roleName type="kin" corresp="#pe__urban_holzkaeufel_QGW_II_I_1508"><add>Mutter</add></roleName>
                     <roleName type="title">fraun</roleName> Christein <roleName type="dead">anerstorbenen</roleName></rs> Güter, der zufolge Urban ein Haus, gelegen an
                  dem Liechtensteg ze Wienn zenagst Hannsen haus des Zebinger gegen der von Tierna
                  haus über, Jakob ein Haus, gelegen an. dem Liechtensteg zenagst Dietreichs haus
                  des Prenner, und ½ Joch Weingarten, gelegen zu Sand Veit in der Obern Hagenau
                  zenagst der geistleichen herren weingarten von Perichtelsgadem, erhält.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1541"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="#pe__jakob_suzz_QGW_II_I_1541">Ausstellers</rs>, 2. seines <rs type="person" ref="#pe__konrad_vorlauf_QGW_II_I_1320"><roleName type="kin" corresp="#pe__jakob_suzz_QGW_II_I_1541">Eidams</roleName>
                        <roleName type="title">hern</roleName> Chunrats des Vorlaufs, des <roleName type="occ" corresp="#org__wien">rates der stat</roleName> ze Wienn</rs>,
                     3. <rs type="person" ref="#pe__niklas_karner_QGW_II_I_1541">Niclas des Charner,
                           <roleName type="occ" corresp="#org__wien">purger</roleName>
                        daselbens</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>