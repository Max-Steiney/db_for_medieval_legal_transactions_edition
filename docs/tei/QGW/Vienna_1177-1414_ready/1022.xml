            <placeName>Wien</placeName>
            <date when="13811220">1381 XII 20</date>
            <origDate instant="false">ze Wienn, des nasten freitags vor sand Thomans tag, des heiligen
               zwelifpoten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01022_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01022_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="#ev__QGW_II_I_1022">
                  <rs type="fn" role="issuer"><rs type="person" ref="#pe__wolfhard_pob_QGW_II_I_1011">Wolfhard der
                        Pob, <roleName type="occ" corresp="#org__wien">statrichter</roleName> ze
                        Wienn</rs></rs>, <triggerstring n="disp">beurkundet, dass vor ihm in der
                     Bürgerschranne</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="#pe__friedrich_naezeuger_QGW_II_I_1018">Fridreich der Nezeuger
                           <triggerstring n="fn">mit Vorsprechen</triggerstring>
                        <roleName type="rep" corresp="#pe__lucia_QGW_II_I_1018">anstatt</roleName></rs></rs>
                  <rs type="person" ref="#pe__lucia_QGW_II_I_1018"><roleName type="title">frawen</roleName> Lucein <roleName type="kin" corresp="#pe__stephan_naezeuger_QGW_II_I_1011"><add>witib</add></roleName></rs>,<rs type="person" ref="#pe__stephan_naezeuger_QGW_II_I_1011">
                     <roleName type="title">hern</roleName> Stephans <roleName type="dead">witib</roleName> des Nezeuger</rs>, um 12 sh. dn. gelts purchrechts
                     <triggerstring n="disp">geklagt habe</triggerstring>, <rs type="event" ref="#ev__QGW_II_I_1022_men_1">die
                        <rs type="person" ref="#pe__johann_an_dem_kienmarkt_QGW_II_I_1009"><roleName type="title">her</roleName> Jans an dem Chienmarkt</rs> auf Dietreichs haus des
                     Reusen, gelegen linder den Spenglern ze Wienne, zenast dem haus genant dacz dem
                     Eisnein gatern , gehabt hatte</rs> wegen der 800 lb dn., <rs type="event" ref="#ev__QGW_II_I_1022_men_2">für die sich <rs type="person" ref="#pe__stephan_naezeuger_QGW_II_I_1011">Stephan
                        der Nezeuger</rs>, <rs type="person" ref="#pe__martin_stainer_QGW_II_I_1011">Mert der
                        Stainer</rs>, <rs type="person" ref="#pe__ulrich_muenzer_QGW_II_I_1547">Ulreich, der <roleName type="prof">munsser</roleName></rs>, und <rs type="person" ref="#pe__johann_an_dem_kienmarkt_QGW_II_I_1009">Jans an dem Chienmarkt</rs>
                     hinz <rs type="person" ref="#pe__georg_pollnheimer_QGW_II_I_1011"><roleName type="title">hern</roleName> Jorgen von Pollenhaim</rs>
                     <triggerstring n="disp">verschrieben hatten</triggerstring></rs>. Da Frau Lucein auf
                  dieser Gült ein <triggerstring n="disp">Verbot genommen hatte</triggerstring>, und da
                  auch <rs type="fn" role="other"><rs type="person" ref="#pe__johann_an_dem_kienmarkt_QGW_II_I_1009">Jans</rs>
                     <triggerstring n="fn">seinen Schuldantheil nicht zurückgezahlt
                     hatte</triggerstring></rs>, <triggerstring n="disp">spricht
                     <add>zu</add></triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="#pe__lucia_QGW_II_I_1018">ihr</rs></rs> der Richter die 12 sh. dn. gelts purkrechts zu.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1022"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="#pe__wolfhard_pob_QGW_II_I_1011">Aussteller</rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>