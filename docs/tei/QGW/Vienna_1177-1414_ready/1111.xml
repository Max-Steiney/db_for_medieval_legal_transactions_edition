                           <roleName type="title">obersten Bergherrn</roleName>
                        <roleName type="title">pru/eder</roleName> Cholmans, <roleName type="occ" corresp="#org__heiligenkreuz-zisterzienser">abt</roleName> des klosters ze
                        dem Heiligenchreucz</rs>, 2. des <rs type="person" ref="#pe__stephan_leitner_QGW_II_I_1012"><roleName type="occ" corresp="#org__wien">Wiener Bürgers</roleName>
                        <roleName type="title">hern</roleName> Stephan des Leitner</rs>.</rs></rs>
