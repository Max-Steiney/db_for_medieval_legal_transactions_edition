               <rs type="event" ref="#ev__QGW_II_I_1622"><rs type="fn" role="issuer"><rs type="person" ref="#pe__jakob_am_ort_StB_I_372">Jacob, <roleName type="kin" corresp="#pe__johann_am_ort_facs_32_TextRegion_1644494407145_115"><add>sun</add></roleName></rs>
                     <rs type="person" ref="#pe__johann_am_ort_facs_32_TextRegion_1644494407145_115">Hannsen sun am Ort, <roleName type="dead">dem got gnad</roleName></rs>, und
                        <rs type="person" ref="#pe__katharina_QGW_II_I_1622">Kathrei, sein <roleName type="kin" corresp="#pe__jakob_am_ort_StB_I_372">hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <triggerstring n="fn">mit Handen</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="#pe__katharina_die_oederin_QGW_II_I_1477">ihrer <roleName type="title">Grundfrau</roleName>
                        <roleName type="title">swester</roleName> Kathrein der Öderin, <roleName type="occ" corresp="#org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">abptessin</roleName> dacz sand Niclas vor Stubentor ze Wienn</rs></rs>,
                  ihres rechten Kaufgutes ein halbes Joch Weingarten auf dem Jeus vor Stubentor
                  zenegst dem weingarten, der weilnt Fridreichs, des zimermans, ist gewesen , von
                  dem man 1/2 lb dn. zu Grundrecht dient, um 26 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__paul_pretschelich_StB_I_295">dem
                        Wiener <roleName type="occ" corresp="#org__wien">Bürger</roleName>
                        Pauln dem Pretschelich</rs> zu <rs type="org" ref="#org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen-messe_haimlin_katharina_QGW_II_I_1622">der Messe,</rs>
                     <rs type="event" ref="NULL">die <rs type="person" ref="#pe__katharina_haimlin_QGW_II_I_1622"><roleName type="title">frau</roleName> Kathrei die Haimlin <roleName type="dead">selig</roleName></rs> geschaft hat in sand Niclas kapelln, gelegen in
                        der Lantstrass vor Stubentor</rs>
                  </rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1622"><rs type="fn" role="witness">Besiegelt mit
