               <rs type="event" ref="#ev__QGW_II_I_510"><rs type="fn" role="issuer"><rs type="person" ref="#pe__ulrich_poelzl_QGW_II_I_510">Ulreich der Pöltzel</rs>, <rs type="person" ref="#pe__hildegard_QGW_II_I_510">Hilt, seine <roleName type="kin" corresp="#pe__ulrich_poelzl_QGW_II_I_510">Hausfrau</roleName></rs>, und <rs type="person" ref="#pe__bertha_QGW_II_I_510">Percht, seine <roleName type="kin" corresp="#pe__ulrich_poelzl_QGW_II_I_510">swiger</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="#pe__thomas_swaeml_QGW_II_I_1012"><roleName type="title">Grundherrn</roleName>
                        <roleName type="title">hern</roleName> Thomans des Swemleins, <roleName type="occ" corresp="#org__wien-buergerspital">spitalmaister</roleName> der
                        purger Spital ze Wienne</rs></rs>, 1 lb dn. geltes auf ihrem Hause und auf
                  der Hofstatt Weingarten hinden daran, gelegen in der Chumphluchen ze Wienne
                  zenaest Hainreichs haus des Minner, von dem man jährlich dem Bürgerspital 15 dn.
                  zu Grundrecht und hern Jacoben von Eslarn, purger ze Wienne, 1 lb dn. ewigs
                  purchrechts dient, um 8 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__jakob_von_eslarn_QGW_II_I_601"><roleName type="title">hern</roleName> Jacoben von Eslarn</rs> und seiner <rs type="person" ref="#pe__kunigunde_QGW_II_I_510"><roleName type="kin" corresp="#pe__jakob_von_eslarn_QGW_II_I_601">Hausfrau</roleName>
                        Chunigunden</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_510"><rs type="fn" role="witness">Besiegelt mit
