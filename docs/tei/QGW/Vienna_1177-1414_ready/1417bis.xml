                  <triggerstring n="disp">theilt <add>mit</add></triggerstring> dem <rs type="fn" role="recipient"><rs type="org" ref="#org__wien">Bürgermeister, Richter und
                        Rathe der Stadt zu Wien</rs></rs> mit, dass seine <rs type="fn" role="other"><rs type="person" ref="#pe__thomas_haiden_QGW_II_I_1417bis"><roleName type="occ" corresp="#org__wiener_neustadt">Mitbürger</roleName> Thoman der
                        Haiden</rs>, <rs type="person" ref="#pe__konrad_rueber_QGW_II_I_1417bis"><roleName type="occ" corresp="#org__wiener_neustadt"><add>Mitbürger</add></roleName>
                        <roleName type="kin" corresp="#pe__lya_QGW_II_I_1417bis"><add>Ehemann</add></roleName> Chunrat der Rueber, der nimbt sich an
                           <roleName type="rep" corresp="#pe__peter_QGW_II_I_1417bis"><add>für</add></roleName>
                        <roleName type="rep" corresp="#pe__lya_QGW_II_I_1417bis">für</roleName> sein
                           <rs type="person" ref="#pe__lya_QGW_II_I_1417bis"><roleName type="kin" corresp="#pe__konrad_rueber_QGW_II_I_1417bis">hausfraun</roleName>, <roleName type="title">fraun</roleName> Lya</rs></rs>, und <rs type="person" ref="#pe__jakob_haiden_QGW_II_I_1417bis">
                        <roleName type="occ" corresp="#org__wiener_neustadt"><add>Mitbürger</add></roleName> Jacob der Haiden , der Letzteren
                           <roleName type="kin" corresp="#pe__lya_QGW_II_I_1417bis">Bruder</roleName>
                        <roleName type="kin" corresp="#pe__esther_QGW_II_I_1417bis"><add>Bruder</add></roleName><roleName type="rep" corresp="#pe__lya_QGW_II_I_1417bis">für</roleName></rs>, und derselb
                     Chunrat und Jacob, die habent sich auch angenomen für <rs type="person" ref="#pe__peter_QGW_II_I_1417bis">Peterlein, fraun Hester selig <roleName type="kin" corresp="#pe__esther_QGW_II_I_1417bis">sun</roleName></rs>, <rs type="person" ref="#pe__esther_QGW_II_I_1417bis">
                        <roleName type="title"><add>frau</add></roleName>
                        <add>Hester</add>
                        <roleName type="dead"><add>selig</add></roleName> des egenanten Jacobs
                           <roleName type="kin" corresp="#pe__jakob_haiden_QGW_II_I_1417bis">swester</roleName></rs>,
                        <triggerstring n="fn"><add>Anspruch an ein Leibgeding</add></triggerstring></rs>
                  <triggerstring n="disp">ihren Anspruch an ein Leibgeding</triggerstring>, <rs type="fn" role="other"><triggerstring n="fn">welches <add>innhat</add></triggerstring> der <rs type="person" ref="#pe__pilgrim_snaeczl_QGW_II_I_1015">Wiener <roleName type="occ" corresp="#org__wien">Bürger</roleName> Piligreim der Sneczel</rs></rs>
                  innhat und daz <rs type="fn" role="other"><triggerstring n="fn">herchomen ist
                        von</triggerstring>
                     <rs type="person" ref="#pe__anna_QGW_II_I_1418"><roleName type="title">fraun</roleName> Annen, seiner <roleName type="kin" corresp="#pe__pilgrim_snaeczl_QGW_II_I_1015">hausfraun</roleName></rs></rs>, <rs type="fn" role="recipient">ihren lieben freunden und miterben, <rs type="person" ref="#pe__leonhard_haiden_QGW_II_I_1308"><roleName type="occ" corresp="#org__wiener_neustadt"><add>Mitbürger</add></roleName>
                        <roleName type="friend" corresp="#pe__thomas_haiden_QGW_II_I_1417bis"><add>Freund</add></roleName>
                        <roleName type="friend" corresp="#pe__konrad_rueber_QGW_II_I_1417bis"><add>Freund</add></roleName>
                        <roleName type="friend" corresp="#pe__jakob_haiden_QGW_II_I_1417bis"><add>Freund</add></roleName>
                        <add>miterben</add> Linharten dem Haiden</rs> und <rs type="person" ref="#pe__erhard_haiden_QGW_II_I_1417bis"><roleName type="occ" corresp="#org__wiener_neustadt"><add>Mitbürger</add></roleName> Erharten
                        dem Haiden <roleName type="friend" corresp="#pe__thomas_haiden_QGW_II_I_1417bis"><add>Freund</add></roleName>
                        <roleName type="friend" corresp="#pe__konrad_rueber_QGW_II_I_1417bis"><add>Freund</add></roleName>
                        <roleName type="friend" corresp="#pe__jakob_haiden_QGW_II_I_1417bis"><add>Freund</add></roleName>
                        <add>miterben</add>
                     </rs> , auch seinen mitpurgern</rs>, <triggerstring n="disp">übergeben
                     haben</triggerstring>.</rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>