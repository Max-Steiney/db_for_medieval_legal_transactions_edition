            tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00599_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00599_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_599"><rs type="fn" role="issuer"><rs type="person" ref="#pe__kunigunde_QGW_II_I_599"><roleName type="title">Swester</roleName>
                        Chunigund die Vivianzin, <roleName type="occ" corresp="#org__wien-st_laurenz_am_alten_fleischmarkt">priorinn</roleName>
                        in sand Larenzen chloster an dem Altenfleischmarcht ze Wienne</rs>, und <rs type="org" ref="#org__wien-st_laurenz_am_alten_fleischmarkt">der convent
                        gemain daselbs</rs></rs>
                  <triggerstring n="disp">stellen <add>ein Revers aus</add></triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="#pe__albrecht_schenk_QGW_II_I_599"><roleName type="title">hern</roleName> Albrechten dem Schenchen, <roleName type="occ" corresp="#pe__rudolf_iv_herzog_von_oesterreich_QGW_II_I_769">obrister
                           chelrmaister</roleName>
                        <rs type="person" ref="#pe__rudolf_iv_herzog_von_oesterreich_QGW_II_I_769"><roleName type="title">Herzog</roleName> Rudolfs IV.</rs></rs></rs>,
                     <rs type="event" ref="#ev__QGW_II_I_599_men_1">einen Revers aus über 7 Mut waitzs gelt und 1 lb
                     dn. gelts auf behaustem Gut zu Herzogenpierbaum, die er von <rs type="person" ref="#pe__berthold_poll_QGW_II_I_395"><roleName type="title">hern</roleName>
                        Perichtolten dem Pollen, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienne</rs>, gekauft und von <rs type="person" ref="#pe__markhard_von_mistelbach_QGW_II_I_141"><roleName type="title">hern</roleName> Marcharten <add>den Mistelbechen</add></rs> und <rs type="person" ref="#pe__erchenbrecht_von_mistelbach_QGW_II_I_599"><roleName type="title">hern</roleName> Erchenprechten den Mistelbechen</rs> zu
                     Lehen gehabt, dann aber dem Kloster verkauft hatte, und über 13 sh. 9 dn., die
                     ebenda auf gestiftem gut behauster holden liegen und die er von <rs type="person" ref="#pe__heinrich_von_rauhenstein_QGW_II_I_853"><roleName type="title">hern</roleName> Hainreichen von Rauchenstain</rs> zu Lehen
                     hat.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_599"><rs type="fn" role="witness">Besiegelt von
                        <rs type="person" ref="#pe__kunigunde_QGW_II_I_599">Priorin</rs> und <rs type="org" ref="#org__wien-st_laurenz_am_alten_fleischmarkt">Convent</rs></rs>.</rs></p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. L. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>