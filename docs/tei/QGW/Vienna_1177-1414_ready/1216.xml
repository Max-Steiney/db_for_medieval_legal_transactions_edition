            <origDate instant="false">ze Wienn, des negsten eritags nach sand Gilgen tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01216_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01216_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="#ev__QGW_II_I_1216"><rs type="fn" role="issuer"><rs type="person" ref="#pe__lucia_QGW_II_I_1018">Lucei, Stephans <roleName type="kin" corresp="#pe__stephan_naezeuger_QGW_II_I_1011">Witwe</roleName>
                        <rs type="person" ref="#pe__stephan_naezeuger_QGW_II_I_1011"><add>Stephan</add> des
                           Nezeuger <roleName type="dead"><add>witwe</add></roleName></rs>,
                           <roleName type="rep" corresp="#pe__johann_naezeuger_ii_QGW_II_I_1018">für</roleName></rs> sich und <rs type="person" ref="#pe__johann_naezeuger_ii_QGW_II_I_1018">ihren unmündigen <roleName type="kin" corresp="#pe__lucia_QGW_II_I_1018">Sohn</roleName> Hansen</rs>, und <rs type="person" ref="#pe__margarethe_QGW_II_I_1172">Margret, ihre <roleName type="kin" corresp="#pe__lucia_QGW_II_I_1018">Tochter</roleName>, Hainreichs
                           <roleName type="kin" corresp="#pe__heinrich_von_jamnitz_QGW_II_I_1778">hausfrau</roleName>
                        <rs type="person" ref="#pe__heinrich_von_jamnitz_QGW_II_I_1778"><add>Hainreich</add> von
                           Jempnitz</rs></rs></rs>, <triggerstring n="disp">theilen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit</triggerstring>
                     <rs type="person" ref="#pe__johann_naezeuger_QGW_II_I_1123">Hannsen dem Nezeuger, dem eltern,
                        dem <roleName type="kin" corresp="#pe__margarethe_QGW_II_I_1172">Bruder</roleName> der Margret</rs></rs>, <triggerstring n="disp">die Güter
                        <add>die ihnen erblich zugefallen waren</add></triggerstring>, <rs type="event" ref="#ev__QGW_II_I_1216_men_1">welche <rs type="person" ref="#pe__stephan_naezeuger_QGW_II_I_1011">Stephan der
                        Nezeuger</rs> seiner <rs type="person" ref="#pe__anna_QGW_II_I_1216"><roleName type="kin" corresp="#pe__stephan_naezeuger_QGW_II_I_1011">Tochter</roleName>
                        Annen zu irem <rs type="person" ref="#pe__friedrich_wassermauter_QGW_II_I_1216"><roleName type="kin" corresp="#pe__anna_QGW_II_I_1216">wirt</roleName>
                           Fridreichen, dem Wassermauter</rs></rs>, gegeben hatte</rs>, und <rs type="event" ref="#ev__QGW_II_I_1216_men_2">die ihnen nach dem Ableben des Ehepaares erblich
                     zugefallen waren</rs>. An <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_naezeuger_QGW_II_I_1123">Hans, den elteren</rs></rs>, fällt ein
                  Weingarten, geleich halber gelegen ze Perchtoltstorf in dem Nidern Haspan, der
                  ober gegen dem holz , mit 5 lb dn., <rs type="event" ref="#ev__QGW_II_I_1216_men_3">welche ihm Margret
                     ze aufschatz gegeben hatte</rs> diese <rs type="fn" role="recipient"><rs type="person" ref="#pe__margarethe_QGW_II_I_1172"><add>Margarethe</add></rs></rs> erhält zwei rehel weingarten, gelegen ze
                  Perichtoltstorf in dem Hochrain zenechst dem weingarten, der weilnt hern Niclas
                  des Stainer gewesen ist  an <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_naezeuger_ii_QGW_II_I_1018"><roleName type="kin" corresp="#pe__lucia_QGW_II_I_1018"><add>Sohn</add></roleName> Hanns den
                        Jüngern</rs></rs> fällt die andere Hälfte des Weingartens in dem Niedern
                  Haspan, der nieder rain gegen dem margt ze Perichtoltstorf.</rs></p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1216"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="person" ref="#pe__kolomann_nussdorfer_QGW_II_I_1216">Wiener
                           <roleName type="occ" corresp="#org__wien">Bürger</roleName> Cholmans
                        des Nusdorffer, des <roleName type="kin" corresp="#pe__margarethe_QGW_II_I_1172">Vetters</roleName> der
                        Margret</rs>, und<rs type="person" ref="#pe__heinrich_von_emmersdorf_QGW_II_I_1081"><roleName type="occ" corresp="#org__wien"><add>Bürger</add></roleName> Hainreichs von
               Emmerstorf</rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>