            <origDate instant="false">ze Wienne, an dem heiligen abend ze
            Weihennachten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00297_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00297_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="#ev__QGW_II_I_297"><rs type="fn" role="issuer"><rs type="person" ref="#pe__walter_doener_QGW_II_I_297">Walther der Do/ener</rs></rs>
                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> seines <rs type="person" ref="#pe__heinrich_lang_QGW_II_I_193"><roleName type="title">Grundherrn</roleName>
                        <roleName type="title">hern</roleName> Hainreichs des Langen</rs></rs> sein
                  Haus, das da leit in dem Geraeut zenaehst Gilgen, des ledrer, haus, von dem man 14
                  dn. zu Grundrecht und ½ lb dn. zu Burgrecht dient, vor rechter ehafter not wegen
                  der Schulden, die ihm seine <rs type="person" ref="#pe__gertrud_QGW_II_I_297"><roleName type="dead">verstorbene</roleName>
                     <roleName type="kin" corresp="#pe__walter_doener_QGW_II_I_297">Frau</roleName>
                     Gedraut</rs> hinterlassen hat und für die es <rs type="person" ref="#pe__trautmann_lederer_QGW_II_I_384">Trautmanne, dem ledrer</rs>, und
                  seiner <rs type="person" ref="#pe__margarethe_QGW_II_I_297"><roleName type="kin" corresp="#pe__trautmann_lederer_QGW_II_I_384">Hausfrau</roleName>
                     Margreten</rs> versetzt war, um 12 lb dn. <rs type="fn" role="recipient">dem
                     genannten <rs type="person" ref="#pe__trautmann_lederer_QGW_II_I_384">Gläubiger</rs>
                     <rs type="person" ref="#pe__margarethe_QGW_II_I_297"><add>Gläubiger</add></rs>.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_297"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="#pe__heinrich_lang_QGW_II_I_193">Grundherrn</rs>, 2. des <rs type="person" ref="#pe__reinhard_zaunruede_QGW_II_I_297"><roleName type="title">Ritters</roleName>
                        <roleName type="title">hern</roleName> Reinprechts des Zaunru/eden,
                           <roleName type="occ" corresp="#org__wien">purgermaister</roleName> ze
                        Wienne</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>