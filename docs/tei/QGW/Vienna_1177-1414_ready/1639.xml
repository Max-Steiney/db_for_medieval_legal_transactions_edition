            <date when="14060105">1406 I 05</date>
            <origDate instant="false">Der geben ist ze Wienn an der heiligen Dreir Künig abend, nach Kristi geburde
               1400 jar darnach in dem 6. jar. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01639_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01639_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1639"><rs type="fn" role="issuer"><rs type="person" ref="#pe__niklas_korner_QGW_II_I_1639">Niklas der Korner,
                           <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                        Wienn</rs></rs>, <triggerstring n="disp">stiftet</triggerstring> eine <rs type="fn" role="recipient">
                     <rs type="org" ref="#org__wien-st_stephan-altar_st_jakob-messe_korner_niklas">Messe auf sand Jacobs altar, gelegen in der Zwelfboten abseiten dacz sand
                        Stephan ze Wienn</rs></rs>, <triggerstring n="disp">verleiht</triggerstring> sie
                  dem <rs type="fn" role="recipient"><rs type="person" ref="#pe__konrad_von_retz_QGW_II_I_1639"><roleName type="prof">Priester</roleName>
                        <roleName type="title">hern</roleName> Chunraten von Retz</rs></rs> und
                     <triggerstring n="disp">widmet</triggerstring> zu derselben 24. lb dn. auf Jacobs des
                  Suessen haus, gelegen an dem Graben ze Wienn zenechst des von Pettau haus .</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1639"><rs type="fn" role="witness">Besiegelt mit
                     dem Siegel des <rs type="person" ref="#pe__niklas_korner_QGW_II_I_1639">Ausstellers</rs> und mit der <rs type="org" ref="#org__wien">stat
                        gruntinsigel</rs> ze Wienn, das weilent der durleuchtig hochgeborn fürst
                     herzog Rudolf ze Osterreich, seliger gedechtnuss, ze einer bestettung des
                     grundes in der stat und in den vorsteten ze Wienn durch sunder würdichait der
                     stat darüber gegeben hat .</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>