                        <rs type="person" ref="#pe__bernhard_schenk_QGW_II_I_372"><roleName type="title">hern</roleName> Wernhers, des <roleName type="occ" corresp="#org__oesterreich-herzogtum">forstmaister</roleName></rs></rs>.</rs>
