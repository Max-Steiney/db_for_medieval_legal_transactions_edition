               <rs type="event" ref="#ev__QGW_II_I_404"><rs type="fn" role="issuer"><rs type="person" ref="#pe__niklas_QGW_II_I_404">Nichlas, <roleName type="occ" corresp="#pe__bernhard_schenk_QGW_II_I_372">choch</roleName>
                        <rs type="person" ref="#pe__bernhard_schenk_QGW_II_I_372"><roleName type="title">hern</roleName> Wernhers des Schenchen, <roleName type="occ" corresp="#org__oesterreich-herzogtum">forstmaister</roleName> in Österreich</rs></rs>, <rs type="person" ref="#pe__margarethe_QGW_II_I_404">Margret, seine <roleName type="kin" corresp="#pe__niklas_QGW_II_I_404">Hausfrau</roleName>
                        <roleName type="kin" corresp="#pe__ruediger_scheuchroesslein_QGW_II_I_404"><add>chinder</add></roleName></rs>, und <rs type="person" ref="#pe__jakob_scheuchroesslein_QGW_II_I_404">Jacob, ir <roleName type="kin" corresp="#pe__margarethe_QGW_II_I_404">pruder</roleName>
                        <roleName type="kin" corresp="#pe__ruediger_scheuchroesslein_QGW_II_I_404"><add>chinder</add></roleName></rs>, <rs type="person" ref="#pe__ruediger_scheuchroesslein_QGW_II_I_404">Ru/egers chinder des
                        Scheuchrössleins, <roleName type="dead">dem got genade</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen mit gesammter Hand</triggerstring> und <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihrer <rs type="person" ref="#pe__katharina_QGW_II_I_404"><roleName type="title">Grundfrau</roleName>
                        <roleName type="title">swester</roleName> Katrein, <roleName type="occ" corresp="#org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">aptessinne</roleName> datz sant Nichlas ze Wienne</rs></rs>, eine
                  Brandstatt, gelegen an dem Cholmarchte ze Wienne zenaehst Seifrits haus, weiln der
                  hochgeborn fürstinne herzoginne Johanna saelig wagenchnecht , von der man jährlich
                  30 dn. nach S. Niklas zu Grundrecht und 2 lb dn. Burgrecht auf den neuen Chorner
                  datz sand Stephan ze Wienne dient, um 31 ½ lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__peter_weniger_QGW_II_I_404">Petrein dem Weniger,
                        weiln der egenanten hochgeborn fürstinne <roleName type="occ" corresp="#pe__johanna_von_pfirt_QGW_II_I_304">chamrer</roleName></rs>, und
                     seiner <rs type="person" ref="#pe__elisabeth_QGW_II_I_404"><roleName type="kin" corresp="#pe__peter_weniger_QGW_II_I_404">Hausfrau</roleName>
                        Elsbeten</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_404"><rs type="fn" role="witness">Besiegelt mit
