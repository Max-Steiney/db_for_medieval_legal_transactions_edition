        <placeName>Brünn</placeName>
        <date when="13640212">1364 II 12</date>
        <origDate instant="false">Der gegeben ist zu Brunne, noch Cristus geburte 1300 jar darnoch
          in dem 64. jare, an dem nehsten mantage vor sant Valentins tag, unser keiser Karls reiche
          in dem 18. und des keisertums in dem nunden jare. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00623_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00623_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p><rs type="event" ref="#ev__QGW_II_I_623"><rs type="fn" role="issuer"><rs type="person" ref="#pe__karl_iv_QGW_II_I_725"><roleName type="title">Kaiser</roleName> Karl
                IV.</rs>, <rs type="person" ref="#pe__wenzel_koenig_von_boehmen_QGW_II_I_974">sein
                  <roleName type="kin" corresp="#pe__karl_iv_QGW_II_I_725">Sohn</roleName> Wenzela,
                  <roleName type="occ" corresp="#org__boehmen-koenigreich">König</roleName> von
                Böhmen,</rs> und sein <rs type="person" ref="#pe__johann_von_maehren_QGW_II_I_623"><roleName type="kin" corresp="#pe__karl_iv_QGW_II_I_725">Bruder</roleName> Johans,
                  <roleName type="title">Markgraf</roleName> zu Mähren</rs></rs>, <triggerstring n="disp">beurkunden <add>Erbvertrag</add></triggerstring>, dass sie mit den Habsburgern
              <rs type="fn" role="recipient"><rs type="person" ref="#pe__rudolf_iv_herzog_von_oesterreich_QGW_II_I_769"><roleName type="title">Herzog</roleName> Rudolf</rs>, <rs type="person" ref="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_1020">Albrecht</rs> und <rs type="person" ref="#pe__leopold_iii_herzog_von_oesterreich_QGW_II_I_780">Lupolt</rs>,
              sowie <rs type="person" ref="#pe__margarethe_QGW_II_I_623">deren <roleName type="kin" corresp="#pe__rudolf_iv_herzog_von_oesterreich_QGW_II_I_769">Schwester</roleName>
                <roleName type="kin" corresp="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_1020"><add>Schwester</add></roleName>
                <roleName type="kin" corresp="#pe__leopold_iii_herzog_von_oesterreich_QGW_II_I_780"><add>Schwester</add></roleName>Margarehte, <roleName type="title">Markgräfin</roleName> zu Brandenburg</rs></rs>, einen Erbvertrag geschlossen
            haben, und verpflichten sich, falls in Folge davon die habsburgischen Lande an sie oder
            ihre Erben fallen sollten, alle Städte, Märkte und Landleute bei ihren Rechten, Gütern
            und Freiheiten zu belassen.</rs>
        </p></div><div type="nota"><p>Indorsat: R. Petrus, scolasticus Lubicensis. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>