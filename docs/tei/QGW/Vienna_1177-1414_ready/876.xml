               <rs type="event" ref="#ev__QGW_II_I_876"><rs type="fn" role="issuer"><rs type="person" ref="#pe__peter_weischoph_QGW_II_I_1097">Peter der Weischoph, <roleName type="occ" corresp="#org__wien">purger ze Wienne</roleName></rs>, und <rs type="person" ref="#pe__katharina_QGW_II_I_876">Kathrei, seine <roleName type="kin" corresp="#pe__peter_weischoph_QGW_II_I_1097">Hausfrau</roleName></rs></rs>,
