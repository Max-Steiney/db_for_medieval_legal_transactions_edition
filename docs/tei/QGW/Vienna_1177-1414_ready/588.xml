            <date when="13610609">1361 VI 09</date>
            <origDate instant="false">ze Wienn, des naesten mittichens vor sand Veits
               tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00588_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00588_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="#ev__QGW_II_I_588"><rs type="fn" role="issuer"><rs type="person" ref="#pe__friedrich_rueschel_QGW_II_I_317">Fridreich der Ruschel, <roleName type="occ" corresp="#org__wien">statrichter</roleName> ze
                  Wienne</rs></rs>, <triggerstring n="disp">beurkundet</triggerstring>, dass vor ihm in
                  der Bürgerschranne <rs type="fn" role="other"><rs type="person" ref="#pe__konrad_wolgemut_QGW_II_I_587">Chunrat der Wolgmut</rs>
                     <triggerstring n="fn">mit Vorsprechen geklagt habe</triggerstring></rs>, seine
                  verstorbene Frau habe ihm eine halbe Fleischbank, gelegen an dem Ekke under den
                  Fleischpenkchen ze Wienne zenast hern Jansens fleischpanch von Tyrna, ze rechter
                  morgengab auszaigt und er habe sie Chunraten, des Schencenmarchts aidem, gegen
                  einen Hofzins von 13 sh. dn. auf ein Jahr vermiethet, die dieser ihm auch bis auf
                  4 sh. dn. entrichtet habe. <rs type="fn" role="other"><triggerstring n="fn">Dagegen
                        behauptet</triggerstring>
                     <rs type="person" ref="#pe__margarethe_QGW_II_I_638">Margret, <roleName type="kin" corresp="#pe__konrad_QGW_II_I_638"><add>hausvrowe</add></roleName>
                        <rs type="person" ref="#pe__konrad_QGW_II_I_638">Chunrats hausvrowe, <rs type="person" ref="#pe__schencenmarcht_QGW_II_I_638">des
                              Schencenmarchts</rs>
                           <roleName type="kin" corresp="#pe__schencenmarcht_QGW_II_I_638">aidem</roleName></rs></rs>, <triggerstring n="fn">mit
                        Vorsprechen</triggerstring></rs>, dass die halbe Fleischbank ihr von ihrer
                  verstorbenen Schwester, der Frau des Klägers, anerstorben sei. Die Sache war vor
                  den Rath gebracht und von diesem <rs type="fn" role="recipient"><rs type="person" ref="#pe__margarethe_QGW_II_I_638">zu Gunsten Margretens</rs></rs>
                  entschieden worden, welche Entscheidung nunmehr auch der Stadtrichter
                  verbrieft.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_588"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="#pe__friedrich_rueschel_QGW_II_I_317">Aussteller</rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>