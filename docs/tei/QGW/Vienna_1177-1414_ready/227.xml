            <origDate instant="false">ze Wienne, an sant Nichlas tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00227_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00227_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_227"><rs type="fn" role="issuer"><rs type="person" ref="#pe__leopold_langenstainer_QGW_II_I_227">Leutolt der
                     Langenstainer</rs></rs>
                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> seines <rs type="person" ref="#pe__gerung_chol_QGW_II_I_185"><roleName type="occ" corresp="#org__klosterneuburg-augustinerchorfrauen" select="#pl__klosterneuburg">Bergmeisters</roleName>
                        <roleName type="title">hern</roleName> Gerunges des Choln, <roleName type="occ" corresp="#org__klosterneuburg-augustinerchorfrauen">amptman</roleName> des gotshaus Unser Vrowen ze Neuenburch
                        chlosterhalben</rs></rs>, seines rechten Kaufgutes ein Achtel Joch
                  Weingarten, der da leit ze Grinzingen in der Sumeraue und haisset deu Wiegen, da
                  man alle iar von dient siben viertail und zwo staeuff weins ze perchrecht und
                  drithalben pheninge ze voitrecht . . . und leit zenaehst Hirz/zz/zen chinder
                  weingart von Nuz/zdorf, um 48 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__niklas_hirnprech_QGW_II_I_227">Nichlasen dem
                        Hirnpreche</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_227"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="fn" ref="#pe__gerung_chol_QGW_II_I_185">des
                        Bergmeisters</rs>, 2. <rs type="person" ref="#pe__hagen_von_spielberg_QGW_II_I_118"><roleName type="title">hern</roleName> Hagens von Spilberch</rs></rs>.</rs>
