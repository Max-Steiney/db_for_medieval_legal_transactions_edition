               <rs type="event" ref="#ev__QGW_II_I_483"><rs type="fn" role="issuer"><rs type="person" ref="#pe__heinrich_von_traunstein_QGW_II_I_483">Hainreich <roleName type="kin" corresp="#pe__kastner_von_traunstein_QGW_II_I_483"><add>sun</add></roleName>, des <rs type="person" ref="#pe__kastner_von_traunstein_QGW_II_I_483">chastner sun von
                           Traunstein</rs></rs>, und <rs type="person" ref="#pe__elisabeth_QGW_II_I_483">Elsbet, seine <roleName type="kin" corresp="#pe__heinrich_von_traunstein_QGW_II_I_483">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verpfänden</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="#pe__gilg_QGW_II_I_483"><roleName type="title">Bergherrn</roleName>
                        <roleName type="title">pruder</roleName> Gilgen, <roleName type="occ" corresp="#org__wien-deutsche_herren">comiteur</roleName> datz dem
                        Taeutschen haus ze Wienne</rs></rs>, ein halbes Joch Weingarten, gelegen in
                  der Herren Alsse in den Langen halben jeuchen, zenaechst Perichtolts weingarten
                  des Slaetner , von dem man 60 dn. zu Bergrecht und 3 dn. zu Voitrecht dient,<rs type="event" ref="#ev__QGW_II_I_483_men_1"> und den sie von dem Gelde gekauft
                     haben, für das sie den unmündigen Kindern der Elsbeth <rs type="person" ref="#pe__jakob_QGW_II_I_483">Jacoben <roleName type="kin" corresp="#pe__elisabeth_QGW_II_I_483"><add>kindern</add></roleName></rs>und <rs type="person" ref="#pe__dorothea_QGW_II_I_483">Torothen <roleName type="kin" corresp="#pe__elisabeth_QGW_II_I_483"><add>kindern</add></roleName></rs>
                     einen Hof zu Eistorf verkauft hatten</rs>, <rs type="fn" role="recipient">für
                        <rs type="person" ref="#pe__jakob_QGW_II_I_483">die genannten Kinder</rs>
                     <rs type="person" ref="#pe__dorothea_QGW_II_I_483"><add>für die genannten
                           Kinder</add></rs>
                     <rs type="person" ref="#pe__friedrich_piber_QGW_II_I_483"><roleName type="title">hern</roleName> Fridreichen dem Piber</rs> und dessen Brüdern</rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_483"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1.<rs type="person" ref="#pe__gilg_QGW_II_I_483"> des
                        Bergherrn</rs>, 2. <rs type="person" ref="#pe__hartneid_von_lichtenstein_QGW_II_I_483">Haertneits von
                        Liechtenstain, <roleName type="prof">schaffer</roleName> der erbern herrn
                        von Walsse ab der Steirmarich</rs>.</rs></rs>
