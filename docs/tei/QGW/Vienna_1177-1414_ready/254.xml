   <text>
      <body>
         <div type="abstract" resp="ks">
            <p>
               <rs type="event" ref="#ev__QGW_II_I_254"><rs type="fn" role="issuer"><rs type="person"
                        ref="#pe__friedrich_von_topel_QGW_II_I_301">Fridreich von Toppel von Sand
                        Veit</rs> und <rs type="person" ref="#pe__katharina_QGW_II_I_254">Kathrei,
                        seine <roleName type="kin" corresp="#pe__friedrich_von_topel_QGW_II_I_301"
                           >Hausfrau</roleName></rs></rs>, <triggerstring n="disp"
                     >verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Einwilligung</triggerstring> der
                        <rs type="person" ref="#pe__ortolf_von_topel_QGW_II_I_254"><roleName
                           type="kin" corresp="#pe__friedrich_von_topel_QGW_II_I_301"
                           >Brüder</roleName> des Ausstellers <roleName type="title">hern</roleName>
                        Ortolfes von Toppel, <roleName type="occ" corresp="#org__retz-pfarre"
                           >pharrer</roleName> ze Ratze</rs>, <rs type="person"
                        ref="#pe__ulrich_von_topel_FRA_II_1308_II_25"><roleName type="kin"
                           corresp="#pe__friedrich_von_topel_QGW_II_I_301"
                           ><add>Brüder</add></roleName>
                        <roleName type="title">hern</roleName> Ulreiches von Toppel</rs>, <rs
                        type="person" ref="#pe__weichart_von_topel_FRA_II_1308_II_25"><roleName
                           type="kin" corresp="#pe__friedrich_von_topel_QGW_II_I_301"
                              ><add>Brüder</add></roleName><roleName type="title">hern</roleName>
                        Weicharts von Toppel, <roleName type="occ"
                           corresp="#org__oesterreich-herzogtum">hoferichter</roleName> ze
                        Oesterreich</rs> , und seines <rs type="person"
                        ref="#pe__stephan_von_topel_QGW_II_I_661"><roleName type="kin"
                           corresp="#pe__friedrich_von_topel_QGW_II_I_301">vettern</roleName>
                        Stephans des Jungen von Toppel, <roleName type="kin"
                           corresp="#pe__stephan_von_topel_QGW_II_I_254"><add>sun</add></roleName>
                        <rs type="person" ref="#pe__stephan_von_topel_QGW_II_I_254"><roleName
                              type="title">hern</roleName> Stephans sun, seines <roleName type="kin"
                              corresp="#pe__friedrich_von_topel_QGW_II_I_301">Bruders</roleName>,
                              <roleName type="dead">dem got gnade</roleName></rs></rs></rs>, 12 lb
                  dn. gelts, die dem Aussteller von seinem Vater hern Weicharten dem Alten von
                  Toppel anerstorben sind, die da ligent in dem Altenperge und in der Smeltz in
                  Preitensewer aigen auf 24 jeuchen weingarten , um 144 lb dn. <rs type="fn"
                     role="recipient"><rs type="person" ref="#pe__dietrich_urbetsch_QGW_II_I_950"
                           ><roleName type="title">hern</roleName> Dietreichen dem Urbetschen,
                           <roleName type="occ" corresp="#org__wien">munzmaister</roleName> ze
                        Wienne</rs>, und seiner <rs type="person" ref="#pe__elisabeth_QGW_II_I_386"
                           ><roleName type="kin" corresp="#pe__dietrich_urbetsch_QGW_II_I_950"
                           >Hausfrau</roleName> Elspethen</rs></rs>. <rs type="fn" role="other">Die
                        <rs type="person" ref="#pe__friedrich_von_topel_QGW_II_I_301">Aussteller</rs>
                     <rs type="person" ref="#pe__katharina_QGW_II_I_254"><add>Aussteller</add></rs>
                     und <rs type="person" ref="#pe__ortolf_von_topel_QGW_II_I_254">Ortolf von
                        Toppel</rs> stellen sich zu <triggerstring n="fn">rechtem Schirm, gegen alle
                        Ansprache</triggerstring></rs>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_254"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="person" ref="#pe__friedrich_von_topel_QGW_II_I_301">1.
                        des Ausstellers</rs>, <rs type="person"
                        ref="#pe__ortolf_von_topel_QGW_II_I_254">2. seines Bruders Ortolf</rs>, <rs
                        type="person" ref="#pe__ulrich_von_pergau_QGW_II_I_206">3. hern Ulreichs von
                        Pergawe, <rs type="person"
                           ref="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_596">herzog
                           Albrechts</rs>
                        <roleName type="occ"
                           corresp="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_596"
                           >hofmaister</roleName> in Österreich</rs>, <rs type="person"
                        ref="#pe__ulrich_von_topel_FRA_II_1308_II_25">4. hern Ulreichs</rs> und <rs
                        type="person" ref="#pe__weichart_von_topel_FRA_II_1308_II_25">5. hern
                        Weicharts von Toppel</rs>.</rs></rs>
            </p>
         </div>
