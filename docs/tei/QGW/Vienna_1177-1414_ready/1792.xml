            <date when="14100222">1410 II 22</date>
            <origDate instant="false">Der brief ist geben an sambstag vor dem sunntag, so man singet Oculi in der
               Vasten, nach Christs gepurd 1400 jar darnach in dem 10. jare. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01792_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01792_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1792"><rs type="fn" role="issuer"><rs type="person" ref="#pe__wolfhard_inprucker_QGW_II_I_1725">Wolfhart der
                        Inprucker, der herzogen ze Österreich <roleName type="occ" corresp="#org__oesterreich-herzogtum" select="#pl__wien">anwalt</roleName>
                        in dem rat der stat ze Wienn</rs>, <rs type="person" ref="#pe__andreas_an_dem_st_petersfreithof_QGW_II_I_1398">Andre an sand
                        Peters freithof, <roleName type="occ" corresp="#org__oesterreich-herzogtum">kellermaister</roleName> in Osterreich,</rs>
                     <rs type="person" ref="#pe__johann_fuechsel_QGW_II_I_1562">Hans der Fuchsel,
                           <roleName type="occ" corresp="#org__wien">judenrichter</roleName> und des
                           <roleName type="occ" corresp="#org__wien">rats</roleName> ze Wienn</rs>,
                     und <rs type="person" ref="#pe__friedrich_von_dorfen_QGW_II_II_2815">Fridreich
                        der Dorfner, auch des <roleName type="occ" corresp="#org__wien">rats</roleName> daselbs</rs></rs> , <triggerstring n="disp">beurkunden die
                     von ihnen in dem Streite</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">zwischen</triggerstring>
                     <rs type="person" ref="#pe__klara_QGW_II_I_1792"><roleName type="title">fraun</roleName> Klaren, Hainreichs
                        <roleName type="kin" corresp="#pe__heinrich_druchkel_QGW_II_I_1792">hausfrau</roleName> des Druchkleins von Krems</rs> an ainem tail und <rs type="person" ref="#pe__konrad_kunigswiser_StB_I_34">Chunraten dem Kunigswiser</rs> an dem
                     andern tail</rs>
                  <triggerstring n="disp">gefällte Entscheidung</triggerstring>, die dahin geht, dass
                  Clara ihrem Gegner 10 lb dn. entrichten, dieser aber die Güter, die er ihr
                  verhefft oder in verbot genomen hat, freigeben soll. Wer den Spruch nicht hält,
                  soll sein Recht verlieren und zu dem Bau hinz sand Stephan und hinz Unser Fraun
                  Brüdern an dem Hof je 50 lb dn. geben.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1792"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der drei ersten Aussteller<rs type="person" ref="#pe__wolfhard_inprucker_QGW_II_I_1725"><add>Wolfhart der
                        Inprucker</add></rs>, <rs type="person" ref="#pe__andreas_an_dem_st_petersfreithof_QGW_II_I_1398"><add>Andre an sand
                           Peters freithof, kellermaister in Osterreich,</add></rs>
                     <rs type="person" ref="#pe__johann_fuechsel_QGW_II_I_1562"><add>Hans der
                           Fuchsel, judenrichter und des rats ze Wienn</add></rs></rs>. </rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>