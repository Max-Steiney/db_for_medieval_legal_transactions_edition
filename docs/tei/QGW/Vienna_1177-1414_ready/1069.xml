            <origDate instant="false">ze Wienn, des nechsten phinztags nach sant Margreten tag, der heiligen
               junchfrown.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01069_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01069_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1069"><rs type="fn" role="issuer"><rs type="person" ref="#pe__stephan_QGW_II_I_1069">Stephan, Seidleins sun am
                        Hof</rs>, und <rs type="person" ref="#pe__katharina_QGW_II_I_1069">Kathrei,
                        Go/eschleins hausfrow, desselben Stephans <roleName type="kin" corresp="#pe__stephan_QGW_II_I_1069">swester</roleName></rs></rs> ,
                     <triggerstring n="disp">bestätigen</triggerstring>, von dem Erlöse für das Haus,
                  gelegen bei Stubentor ze Wienn in der Wollzeil, genant in der Gugel, gegen dem
                  haus über, das weilnt <rs type="person" ref="#pe__johann_phuntimaschen_QGW_II_I_1069">Jansen
                        <roleName type="dead">seligen</roleName> des Phuntimaschen</rs> gewesen ist
                  , <rs type="event" ref="#ev__QGW_II_I_1069_men_1">das ihr <rs type="person" ref="#pe__niklas_pokchl_QGW_II_I_1069"><roleName type="kin" corresp="#pe__stephan_QGW_II_I_1069">Geschwisterkind</roleName> Niclas der Pökchel</rs> mit seiner <rs type="person" ref="#pe__kunigunde_QGW_II_I_1069"><roleName type="dead">früheren</roleName>
                        <roleName type="kin" corresp="#pe__niklas_pokchl_QGW_II_I_1069">Hausfrau</roleName>
                        Chunigunden</rs> gekauft hatte</rs>, <rs type="event" ref="#ev__QGW_II_I_1069_men_2">und das
                     nach Beider Ableben her <rs type="person" ref="#pe__paul_holzkaeufel_QGW_II_I_1010">Paul der
                        Holzchäuffel, <roleName type="occ" corresp="#org__wien">purgermaister</roleName></rs>, und der <rs type="org" ref="#org__wien">rat der stat ze Wienne</rs> um 60 lb dn. verkauft hatten</rs>, den ihnen
                  gebührenden Antheil von 30 lb dn. <triggerstring n="disp"><add>den ihnen gebührenden
                        Antheil</add> erhalten zu haben</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1069"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="#pe__thomas_swaeml_QGW_II_I_1012"><roleName type="title">hern</roleName> Thomans des Swembels <roleName type="occ" corresp="#org__wien"><add>Wiener
                        Bürger</add></roleName></rs>, 2. <rs type="person" ref="#pe__bernhard_sleiher_von_wiener_neustadt_QGW_II_I_1017">Wernharts des Sleiher, baid
                           <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                        Wienn</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>