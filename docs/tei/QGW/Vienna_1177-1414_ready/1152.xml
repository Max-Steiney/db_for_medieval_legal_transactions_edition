            <origDate instant="false">ze Wienn, des nechsten freitags vor sant Veits tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01152_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01152_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="#ev__QGW_II_I_1152"><rs type="fn" role="issuer"><rs type="person" ref="#pe__ulrich_stuchs_ii_QGW_II_I_1152">Ulreich der Stuchs</rs> und <rs type="person" ref="#pe__katharina_QGW_II_I_1152">Kathrei, seine <roleName type="kin" corresp="#pe__ulrich_stuchs_ii_QGW_II_I_1152">Hausfrau</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__niklas_schoen_QGW_II_I_1037">Schönen Niclas ze Su/efring,
                           <roleName type="occ" corresp="#org__mauerbach-kartaeuser">pergmaister</roleName> der erbern geistleichen herren ze
                        Allerheiligental ze Maurbach, des Ordens von Karthus</rs></rs>, ihres
                  Kaufgutes ½ Joch Weingarten, gelegen ze Süfring in dem Veld zenechst des Pilleichs
                  weingarten, des vischer, von dem man 6 dn. für Berg- und Voitrecht dient, <rs type="fn" role="recipient"><rs type="person" ref="#pe__paul_holzkaeufel_QGW_II_I_1010"><roleName type="rep" corresp="#pe__leonhard_poll_QGW_II_I_1152"><add>Ausrichter</add></roleName>
                        <roleName type="title">hern</roleName> Pauln dem Holzchäuffel, des <roleName type="occ" corresp="#org__wien">rates</roleName> der stat ze Wienn</rs>
                     und <rs type="person" ref="#pe__niklas_von_der_schemnitz_iii_QGW_II_I_1371"><roleName type="rep" corresp="#pe__leonhard_poll_QGW_II_I_1152"><add>Ausrichter</add></roleName>
                        Niclasen dem Schebnitzer, <roleName type="occ" corresp="#org__wien">purger</roleName> daselbens</rs> , als Ausrichtern des Geschäftes nach
                     Lienhart dem Pollen</rs>, um 45 lb dn., <rs type="event" ref="#ev__QGW_II_I_1152_men_1">welche von
                     100 lb dn. herrühren, die <rs type="fn" role="issuer"><rs type="person" ref="#pe__leonhard_poll_QGW_II_I_1152">Lienhart der Poll</rs></rs> der S. Philipps- und
                     S. Jakobs-Kapelle zur Besserung der von <rs type="person" ref="#pe__siegfried_poll_QGW_II_I_1152"><roleName type="title">hern</roleName> Seifrid dem
                        Pollen, auch <roleName type="dead">seliger gedechtnuss</roleName></rs>,
                     gemachten <rs type="fn" role="recipient"><rs type="org" ref="#org__wien-st_philipp_und_st_jakob_kapelle-altar_st_maria-messe_siegfried_poll">Stiftung</rs></rs> geschafft hatte</rs>.</rs></p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1152"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="#pe__heinrich_QGW_II_I_1152"><roleName type="title">obersten Bergherrn</roleName>
                        <roleName type="title">pruder</roleName> Hainreichs, <roleName type="occ" corresp="#org__mauerbach-kartaeuser">prior</roleName> des gotshauses ze
                        Maurbach</rs>, 2. <rs type="person" ref="#pe__michael_vinkch_QGW_II_I_1082"><roleName type="title">hern</roleName> Michels des Vinkchen, des <roleName type="occ" corresp="#org__wien">rates</roleName> der stat ze
                     Wienn</rs></rs>.</rs>
