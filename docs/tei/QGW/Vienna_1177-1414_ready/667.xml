                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__konrad_QGW_II_I_667">ihres <roleName type="title">Bergherrn</roleName>
                        <roleName type="title">hern</roleName> Chunrats, <roleName type="occ" corresp="#org__hernals-pfarre">pharrer</roleName> dacz sant Pêrtelme ze
                        Alsse</rs></rs>, einen Weingarten, <rs type="event" ref="#ev__QGW_II_I_667_men_1">welcher der Kathrei für den Anspruch, den sie an
