      <body>
         <div type="abstract" resp="lp">
            <p><rs type="event" ref="#ev__QGW_II_I_259"><rs type="fn" role="issuer"><rs type="person"
                        ref="#pe__johanna_von_pfirt_QGW_II_I_304"><roleName type="title"
                           >Herzogin</roleName> Johanna, <roleName type="title">Gräfin</roleName> zu
                        Pfirt</rs></rs>, <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__gerung_chol_QGW_II_I_185">des <roleName type="occ"
                           corresp="#org__klosterneuburg" select="#pl__klosterneuburg"
                           >Bergmeisters</roleName> Gerungs des Choln, <roleName type="occ"
                           corresp="#org__klosterneuburg">amptman</roleName> des chlosters ze
                        Neunburch</rs></rs>, <rs type="fn" role="recipient"><rs type="person"
                        ref="#pe__konrad_wiltwercher_QGW_II_I_204">ihrem getreuen <roleName
                           type="occ" corresp="#org_wien" cert="high">Bürger</roleName> Chunrat dem
                        Wiltwercher, <roleName type="occ" corresp="#org__wien"
                           >purgermaister</roleName> ze Wienn</rs>, und <rs type="person"
                        ref="#pe__margarethe_QGW_II_I_204">seiner <roleName type="kin"
                           corresp="#pe__konrad_wiltwercher_QGW_II_I_204">Hausfrau</roleName>
                        Mergarten</rs></rs> ein halbes Joch Weingarten, der da leit an dem
                  Purchstal, davon man alle iare dienet dem chloster Unserr Vraun ze Neunburch fumf
                  viertail weins ze perchrecht und drei helbling ze voitrecht , um 70 Mark Silber,
                  immer an zehen fumfzehen Schilling Wienner phenng fu/er ein iegleich march.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_259"><rs type="fn" role="witness">Besiegelt von
                        <rs type="person" ref="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_596"
                           ><roleName type="title">Herzog</roleName> Albrecht</rs> und <rs
                        type="person" ref="#pe__johanna_von_pfirt_QGW_II_I_304">der
                     Herzogin</rs>.</rs></rs></p>
         </div>
