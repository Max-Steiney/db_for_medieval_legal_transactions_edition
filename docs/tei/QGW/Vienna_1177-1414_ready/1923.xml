      <body>
         <div type="abstract">
            <p>
               <rs type="event" ref="#ev__QGW_II_II_1923"><rs type="fn" role="issuer"><rs type="person" ref="#pe__hartneid_von_pottendorf_QGW_II_I_1766">Hortneid von
                        Potendorff, <roleName type="occ" corresp="#org__oesterreich-herzogtum">landmarschalich</roleName> in Osterreich</rs>,</rs>
                  <triggerstring n="disp">weist</triggerstring> den <rs type="fn" role="recipient"><rs type="org" ref="#org__wien">Bürgermeister, Richter und Rath der Stadt zu
                        Wien</rs></rs>
                  <triggerstring n="disp">an</triggerstring>, die Juden <rs type="person" ref="#pe__smerl_QGW_II_II_1923">Smerl, Scheftleins sun</rs>, <rs type="person" ref="#pe__jekel_welichlein_QGW_II_II_1923">Jecl Welichl</rs>, <rs type="person" ref="#pe__flemel_QGW_II_II_1923">Flemel, sein <roleName type="kin" corresp="#pe__jekel_welichlein_QGW_II_II_1923">sun</roleName></rs>, <rs type="person" ref="#pe__muschel_QGW_II_II_1923">Muschel, Tenichleins aidem</rs>, in der freien
                  Verfügung über die Güter und Pfänder, die sie von dem Wiener Bürger Chunrade
                  Ernsten vor dem Geleite, das er und die Stadt diesem gegeben hatten, erhalten
                  haben, <triggerstring n="disp">nicht zu hindern</triggerstring>.</rs>
            </p>
         </div>
