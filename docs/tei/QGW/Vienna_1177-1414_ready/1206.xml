                           <add>von Weitra</add></rs>
                        <roleName type="kin" corresp="#pe__stephan_von_weitra_QGW_II_I_1206">sun</roleName> von
                        Weitra <roleName type="rep" corresp="#pe__ulrich_QGW_II_I_1206"><add>für</add></roleName><roleName type="rep" corresp="#pe__kunigunde_QGW_II_I_1206"><add>für</add></roleName></rs></rs>, <triggerstring n="disp">verkauft</triggerstring>
