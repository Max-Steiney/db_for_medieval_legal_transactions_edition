            <origDate instant="false">an sand Marie Magdalen abent.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01070_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01070_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1070"><rs type="fn" role="issuer"><rs type="person" ref="#pe__dietrich_schmied_QGW_II_I_1070">Dietreich, der
                           <roleName type="prof">smied</roleName> von Engschalichsveld</rs></rs>,
                     <triggerstring n="disp">stellt <add>einen Urfehdebrief aus</add></triggerstring>
                  wegen der vankchnuss, die <rs type="fn" role="recipient"><rs type="person" ref="#pe__niklas_wuerfel_QGW_II_I_1001">sein <roleName type="occ" corresp="#pe__dietrich_schmied_QGW_II_I_1070">Herr</roleName>, der
                           <roleName type="title">Ritter</roleName>
                        <roleName type="title">her</roleName> Niclas der Würffel</rs></rs>, an ihm
                  gethan hatte, da er sein behauster holde und ihm enpharn was, einen Urfehdebrief
                  aus und <triggerstring n="disp">stellt <add>zu Bürgen</add></triggerstring>
                  <rs type="fn" role="other">seine <rs type="person" ref="#pe__bartholomaeus_QGW_II_I_1070"><roleName type="kin" corresp="#pe__dietrich_schmied_QGW_II_I_1070">Brüder</roleName>
                        Pertelme</rs> und <rs type="person" ref="#pe__meinhard_QGW_II_I_1070">Meinharten <roleName type="kin" corresp="#pe__dietrich_schmied_QGW_II_I_1070"><add>Bruder</add></roleName></rs>, sowie seine guten <rs type="person" ref="#pe__niklas_von_enzersdorf_QGW_II_I_1070"><roleName type="friend" corresp="#pe__dietrich_schmied_QGW_II_I_1070">Freunde</roleName>
                        Niclasen von Enzestorf</rs>, <rs type="person" ref="#pe__ulrich_chnappenfeint_QGW_II_I_1070"><roleName type="friend" corresp="#pe__dietrich_schmied_QGW_II_I_1070"><add>Freund</add></roleName> Ulreichen den Chnappenfeint</rs> und <rs type="person" ref="#pe__johann_steirer_QGW_II_I_1070"><roleName type="friend" corresp="#pe__dietrich_schmied_QGW_II_I_1070"><add>Freund</add></roleName> Jannsen den Steirer</rs>
                     <triggerstring n="fn">zu Bürgen</triggerstring></rs>. Sollte Dietreich das Gelöbnis
                  nicht halten, so sollen er und die Bürgen dem Herzoge und Niklas dem Würfel je 10
                  lb dn. zahlen.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1070"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="#pe__johann_auf_der_saeule_QGW_II_I_1070">Hannsen auf
                        der Seul</rs>, 2. <rs type="person" ref="#pe__johann_ratgeb_QGW_II_I_1040">Jannsen des
                        Ratkebn, <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                        Wienn</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: Nota der brief sagt uber Dietlein, smid von Enzesfelt. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>