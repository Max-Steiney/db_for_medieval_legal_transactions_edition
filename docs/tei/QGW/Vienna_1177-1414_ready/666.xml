               <rs type="event" ref="#ev__QGW_II_I_666"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_von_ybbs_QGW_II_I_1033">Jans von Ibs</rs> und <rs type="person" ref="#pe__elisabeth_QGW_II_I_748">Elspet, seine <roleName type="kin" corresp="#pe__johann_von_ybbs_QGW_II_I_1033">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="#pe__niklas_von_wildungsmauer_QGW_II_I_807"><roleName type="title">Bergherrn</roleName>
                        <roleName type="title">pruder</roleName> Niclas von Wildungsmauer, <roleName type="occ" corresp="#org__mauerbach-kartaeuser">maister</roleName> des
                        hauses ze Maeurperg und <roleName type="occ" corresp="#org__wien-st_johann_in_der_kaerntnerstrasse">comiteur</roleName>
                        des hauses dacz sand Johanns in der Chernerstrasse ze Wienn</rs></rs> ,
                  einen Weingarten, den Elsbet von ihren Eltern ererbt hatte, ze Grinzingen in der
                  Arnoltzawe zena/est hern Ulreichs weingarten von Chranichperch, von dem man 72 dn.
                  und ain halbeu gans in dem lesen ze rechtem perchrecht dient, um 60 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__ulrich_zerrenchitel_QGW_II_I_1046">Ulreichen dem Zerrenchitel</rs>
                     und seiner <rs type="person" ref="#pe__katharina_QGW_II_I_1046"><roleName type="kin" corresp="#pe__ulrich_zerrenchitel_QGW_II_I_1046">Hausfrau</roleName> Kathrein</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_666"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="person" ref="#pe__johann_von_ybbs_QGW_II_I_1033">1. des
                        Ausstellers</rs>, <rs type="person" ref="#pe__niklas_von_wildungsmauer_QGW_II_I_807">2. des Bergherrn</rs>, <rs type="person" ref="#pe__konrad_urbetsch_QGW_II_I_950">3. des <roleName type="kin" corresp="#pe__elisabeth_QGW_II_I_748">Bruders</roleName> der
                        Elsbet Chunrats des Urwechschen, des <roleName type="occ" corresp="#org__wien">rats</roleName> der stat ze Wienn</rs>, <rs type="person" ref="#pe__lukas_popphinger_QGW_II_I_776">4. <roleName type="title">hern</roleName> Lucas des Pophinger, <roleName type="occ" corresp="#org__wien">purgermaister</roleName> ze Wienn</rs>.</rs></rs>
