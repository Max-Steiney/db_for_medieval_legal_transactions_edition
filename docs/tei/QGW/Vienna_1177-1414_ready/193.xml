            <origDate instant="false">ze Wienne, an sand Pangraetzen tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00193_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00193_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_193"><rs type="fn" role="issuer"><rs type="person" ref="#pe__anna_QGW_II_I_193">Anne, <rs type="person" ref="#pe__markhard_jan_QGW_II_I_856"><roleName type="title">hern</roleName> Marcharts</rs>
                        <roleName type="kin" corresp="#pe__markhard_jan_QGW_II_I_856">witibe</roleName> des Janes</rs></rs>, <triggerstring n="disp">bestätigt</triggerstring>,<triggerstring n="disp">dass sie und ihr Kind von ihrem
                     Manne ein paumgaertel geerbt haben</triggerstring>, das da leit zenaehste des
                  erbern herren paumgarten hern Hermannes, canceler und obrister schreiber des
                  hochgeporn fürsten herzog Otten in Osterreich, und das rechtes purchrecht ist von
                  dem erwirdigen herren dem apte von den Schotten zu Wienne, dem man dient alle iar
                  ze gruntrecht auf sand Michahels tage 6 dn . Sie <triggerstring n="disp">verkauft</triggerstring> das Baumgärtchen <rs type="fn" role="other"><triggerstring n="fn">nach dem Rathe</triggerstring> ihres <rs type="person" ref="#pe__heinrich_lang_QGW_II_I_193"><roleName type="kin" corresp="#pe__anna_QGW_II_I_193">Vaters</roleName>, <roleName type="title">hern</roleName> Hainrichs des Langen</rs></rs>, <rs type="fn" role="other">
                     <triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__benedikt_QGW_II_I_191"><roleName type="title">hern</roleName> Benedicten, der Schotten<roleName type="occ" corresp="#org__wien-schotten"> amman</roleName> ze Wienne</rs></rs>, um 20
                  lb dn. <rs type="fn" role="recipient">dem <rs type="person" ref="#pe__hermann_kanzler_QGW_II_I_193"><roleName type="occ" corresp="#pe__otto_herzog_von_oesterreich_QGW_II_I_837">Kanzler</roleName>
                        Hermann</rs></rs> und <triggerstring n="disp">kauft</triggerstring> für den Erlös
                  einen anderen Baumgarten, der weiln und e der Engelprechtinne gewesen ist,
                  zenaehest dem paumgarten, den sie von ihrem Wirthe hern Marcharten dem Jane geerbt
                  und den sie hiemit ihrem Kinde <triggerstring n="disp">widerlegt</triggerstring>
                  hat.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_193">Besiegelt mit den Siegeln: <rs type="fn" role="witness"><rs type="person" ref="#pe__anna_QGW_II_I_193">1. der
                        Ausstellerin,</rs>
                     <rs type="person" ref="#pe__benedikt_QGW_II_I_191">2. Benedicts, des
                        Schottenamtmannes,</rs>
                     <rs type="person" ref="#pe__heinrich_lang_QGW_II_I_193">3. des <roleName type="kin" corresp="#pe__anna_QGW_II_I_193">Vaters</roleName> der
                           Ausstellerin
                        <roleName type="title">hern</roleName> Hainrichs des Langen,</rs>
                     <rs type="person" ref="#pe__heinrich_schuchler_QGW_II_I_193">4. <roleName type="title">hern</roleName> Hainrichs des Schuheler, <roleName type="occ" corresp="#org__wien">munzmaister</roleName> ze
                     Wienne.</rs></rs>
               </rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>