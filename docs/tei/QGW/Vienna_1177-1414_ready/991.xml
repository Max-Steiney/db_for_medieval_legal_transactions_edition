            <date when="13800809">1380 VIII 09</date>
            <origDate instant="false">ze Wienn, an sant Larenzen abent.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00991_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00991_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_991"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_sirfeier_QGW_II_I_1082bis">Hanns der Syrfeier, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienn</rs></rs>, <triggerstring n="disp">bestätigt</triggerstring> für sich und <rs type="fn" role="other"><triggerstring n="fn"><add>für</add></triggerstring> seinen <rs type="person" ref="#pe__paul_sirfeier_QGW_II_I_991"><roleName type="kin" corresp="#pe__johann_sirfeier_QGW_II_I_1082bis">unmündigen Bruder</roleName> Pauln</rs></rs>, dass <rs type="fn" role="recipient">ihr <rs type="person" ref="#pe__hermann_sirfeier_QGW_II_I_991"><roleName type="kin" corresp="#pe__johann_sirfeier_QGW_II_I_1082bis">uren</roleName>
                        <roleName type="title">her</roleName> Herman der Syrfeier</rs></rs> eine <rs type="org" ref="#org__wien-st_stephan-altar_zwoelfapostel-messe_sirfeier">Messe
                     auf der Zwelifpoten altar dacz sand Stephan</rs>
                  <triggerstring n="disp">gestiftet</triggerstring> und mit gulten <triggerstring n="disp">dotiert habe</triggerstring>, die auf Häusern zu Wien gelegen waren, aber nach
                  dem Gebote Herzog Rudolfs IV. abgelöst worden sind, wofür ihr <rs type="fn" role="recipient"><rs type="person" ref="#pe__christoph_sirfeier_QGW_II_I_991"><roleName type="kin" corresp="#pe__johann_sirfeier_QGW_II_I_1082bis">Vater</roleName>
                        <roleName type="kin" corresp="#pe__paul_sirfeier_QGW_II_I_991"><add>Vater</add></roleName>
                        Christoff der Syrfeier <roleName type="dead"><add>Testamente</add></roleName></rs></rs>88 lb dn. eingenommen habe. In
                  seinem Testamente habe dieser für diesen Betrag und zu besserer Ausstattung der
                  Messe 200 lb dn. oder den Weingarten, gelegen an dem Nusperg, der da haisst der
                  Chruter, des ein halbes jeuch und ein achttail ist, zenêchst Hansen weingarten des
                  Pusenchofer, und dient dem chloster ze Neunburch alle iar anderthalben emmer und
                  ein halbes achttail weins ze perchrecht und achthalb ort ze voitrecht , zu der
                  Messe <triggerstring n="disp">gewidmet</triggerstring>. <rs type="fn" role="other"><triggerstring n="fn">Nach dem Rathe</triggerstring> der<rs type="person" ref="#pe__johann_von_tierna_QGW_II_I_1018"><roleName type="rep" corresp="#pe__christoph_sirfeier_QGW_II_I_991">Geschäftsvollstrecker</roleName> des
                        Vaters, <roleName type="title">hern</roleName> Jannsen von Tierna, <roleName type="occ" corresp="#org__oesterreich-herzogtum">huebmaister</roleName> in
                        O/esterreich</rs>, und <rs type="person" ref="#pe__eberhard_von_znaim_QGW_II_I_839">
                        <roleName type="rep" corresp="#pe__christoph_sirfeier_QGW_II_I_991"><add>Geschäftsvollstrecker</add></roleName> Eberharts von
                     Znaim</rs></rs>, <triggerstring n="disp">gibt</triggerstring> Hanns für sich und
                  seinen Bruder <rs type="fn" role="other"><triggerstring n="fn">mit
                        Handen</triggerstring> des<rs type="person" ref="#pe__peter_mannseber_QGW_II_I_1037">
                        <roleName type="title">Bergmeisters</roleName> Petreins des Mannseber,
                           <roleName type="occ" corresp="#org__klosterneuburg-augustiner_chorherren">amptman</roleName> des chlosters ze Neunburch</rs></rs>, den
                  vorgenannten Weingarten zu der <rs type="fn" role="recipient"><rs type="org" ref="#org__wien-st_stephan-altar_zwoelfapostel-messe_sirfeier">Messe</rs></rs>, mit der Bestimmung, dass der <rs type="fn" role="recipient"><rs type="person" ref="#pe__reicher_QGW_II_I_1066a"><roleName type="occ" corresp="#org__wien-st_stephan-altar_zwoelfapostel-messe_sirfeier">Kaplan</roleName> der Messe <roleName type="title">her</roleName>
                        Reicher</rs> und seine Nachfolger</rs> ihn <triggerstring n="disp">stets
                     innehaben und bauen sollen</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_991"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="#pe__johann_von_tierna_QGW_II_I_1018"><roleName type="title">hern</roleName> Jansen von Tierna</rs>, 2. <rs type="person" ref="#pe__eberhard_von_znaim_QGW_II_I_839">Eberharts von Znaim</rs>, 3. des <rs type="person" ref="#pe__peter_mannseber_QGW_II_I_1037">Bergmeisters</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>