            <date when="13650819">1365 VIII 19</date>
            <origDate instant="false">des nachsten eritags vor sant Bartholomes tage, des
               zwelifpoten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00654_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00654_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="#ev__QGW_II_I_654"><rs type="fn" role="issuer"><rs type="person" ref="#pe__niklas_poelzl_QGW_II_I_654">Niclas der Pölczel von
                        Perichtoltzdorf</rs> und <rs type="person" ref="#pe__katharina_QGW_II_I_654_b">Kathrei, seine <roleName type="kin" corresp="#pe__niklas_poelzl_QGW_II_I_654">Hausfrau</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="#pe__ruediger_waldner_QGW_II_I_787"><roleName type="occ" corresp="#org__gaming-kartaeuser">Bergmeisters</roleName> Rugers des
                        Waldner von Perichtoltzdorf, <roleName type="occ" corresp="#org__gaming-kartaeuser">amptman</roleName> und <roleName type="occ" corresp="#org__gaming-kartaeuser">perchmaister</roleName> der
                        geistleichen herren von Gaemnikch ze sant Marien thron, des ordens von
                        Cartus</rs></rs> , einen Weingarten, des ain setz ist, gelegen ze
                  Perichtoltzdorf in der Wispeunt zenechst Ulreichs weingarten des Hierz/zz/zen ,
                  von dem man 13 dn. zu Bergrecht dient, um 31 lb dn. dem vorgenannten <rs type="fn" role="recipient">
                     <rs type="person" ref="#pe__ruediger_waldner_QGW_II_I_787">Rugern dem
                        Waldner</rs>, seiner <rs type="person" ref="#pe__anna_QGW_II_I_654"><roleName type="kin" corresp="#pe__ruediger_waldner_QGW_II_I_787">Hausfrau</roleName> Annen</rs>, ihrem <rs type="person" ref="#pe__jakob_paumgartner_QGW_II_I_1182"><roleName type="kin" corresp="#pe__anna_QGW_II_I_654">Schwager</roleName> Jacoben dem
                        Paumgartner</rs>, dessen <rs type="person" ref="#pe__katharina_QGW_II_I_654_a"><roleName type="kin" corresp="#pe__jakob_paumgartner_QGW_II_I_1182">Hausfrau</roleName>
                        Katrein</rs>, <rs type="person" ref="#pe__niklas_QGW_II_I_654">Niclasen
                           <roleName type="kin" corresp="#pe__konrad_lang_QGW_II_I_654_b">Kindern</roleName></rs> und <rs type="person" ref="#pe__johann_QGW_II_I_654_a">Jansen, den <roleName type="kin" corresp="#pe__konrad_lang_QGW_II_I_654_b">Kindern</roleName> des <rs type="person" ref="#pe__konrad_lang_QGW_II_I_654_b"><roleName type="dead">verstorbenen</roleName>
                           <roleName type="kin" corresp="#pe__anna_QGW_II_I_654">Bruders</roleName>
                           <roleName type="kin" corresp="#pe__katharina_QGW_II_I_654_a"><add>Bruders</add></roleName> beider Frauen Chunrats des Langen
                           von Probstorf</rs></rs></rs>. Diese haben den Weingarten ihrem <rs type="person" ref="#pe__johann_QGW_II_I_654_b"><roleName type="kin" corresp="#pe__anna_QGW_II_I_654">Oheim</roleName>
                     <roleName type="kin" corresp="#pe__katharina_QGW_II_I_654_a"><add>Oheim</add></roleName> Jansen, <roleName type="kin" corresp="#pe__konrad_lang_QGW_II_I_654_a"><add>eninchel</add></roleName>
                     <roleName type="kin" corresp="#pe__elisabeth_QGW_II_I_654"><add>sun</add></roleName>
                     <rs type="person" ref="#pe__konrad_lang_QGW_II_I_654_a">Chunrats eninchel des
                        Langen</rs>, <rs type="person" ref="#pe__elisabeth_QGW_II_I_654"><roleName type="title">vrown</roleName> Elsbeten sun, der vorgenanten vier
                        geswistreid <roleName type="kin" corresp="#pe__katharina_QGW_II_I_654_a">swester</roleName>
                        <roleName type="kin" corresp="#pe__anna_QGW_II_I_654"><add>swester</add></roleName>
                        <roleName type="kin" corresp="#pe__konrad_lang_QGW_II_I_654_b"><add>swester</add></roleName>, der auch <roleName type="dead">got
                           genade</roleName></rs></rs> , für das Geld, mit dem sie ihm sein Erbtheil
                  abgelöst hatten, gekauft.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_654"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="person" ref="#pe__gottfried_QGW_II_I_654">1. des
                           <roleName type="title">obersten Bergherrn</roleName>
                        <roleName type="title">pruder</roleName> Go/etfrits, <roleName type="occ" corresp="#org__gaming-kartaeuser">prior</roleName> des chlosters ze
                        Gaemnikch</rs>, <rs type="person" ref="#pe__johann_stainpeckh_QGW_II_I_698">2. <roleName type="title">hern</roleName> Jansen des
                     Stainpekchen</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: uber die nider secz. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>