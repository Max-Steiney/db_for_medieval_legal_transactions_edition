            <origDate instant="false">ze Wienn, des mitichens vor dem Palmtag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01618_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01618_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1618"><rs type="fn" role="issuer"><rs type="person" ref="#pe__albrecht_zetter_QGW_II_I_1577">Albrecht der Zetter,
                           <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                        Wienn</rs>,</rs>
                  <triggerstring n="disp">verkauft</triggerstring> seines ledigen Erbgutes ein halbes Joch
                  Weingarten, gelegen ze Nusdorf in den Honern ob des dorfs zenechst Wolfharts
                  weingarten von Regenspurch, gesessen daselbs ze Nusdorf , von dem man nur den
                  Zehent dient, <rs type="person" ref="#pe__leopold_QGW_II_I_1567"><roleName type="title">hern</roleName> Leupolten von Wienn, <roleName type="occ" corresp="#org__wien-st_stephan">kaplan</roleName> dacz sand Stephan der
                     caplanei,</rs> die <rs type="person" ref="#pe__georg_nussdorfer_QGW_II_I_1228">Jorg der Nusdorfer, <roleName type="dead">dem got genad</roleName></rs>, dahin
                  geschafft hat , <triggerstring n="fn">mit Einwilligung</triggerstring> der <rs type="fn" role="other"><rs type="person" ref="#pe__georg_von_nikolsburg_QGW_II_I_1010">Wiener <roleName type="occ" corresp="#org__wien">Bürger</roleName>
                        Jörgen von Nicolspurg <roleName type="rep" corresp="#pe__georg_nussdorfer_QGW_II_I_1228"><add>Ausrichter</add></roleName></rs> und <rs type="person" ref="#pe__georg_neuer_QGW_II_I_1195">Jörgen des Neuer, als <roleName type="rep" corresp="#pe__georg_nussdorfer_QGW_II_I_1228">Ausrichter</roleName> dieses Geschäftes</rs></rs>, um 81 lb dn., die von
                  den 106 lb dn. herrühren, <rs type="event" ref="NULL">welche Jörg der Nussdorfer
                     zu dieser Kaplanei geschafft hatte</rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1618"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="#pe__albrecht_zetter_QGW_II_I_1577">Ausstellers</rs> und der <rs type="person" ref="#pe__haunold_schuchler_QGW_II_I_1557">Wiener <roleName type="occ" corresp="#org__wien">Bürger</roleName> Haunolcz des Schuechler</rs> und
                        <rs type="person" ref="#pe__niklas_flusthart_QGW_II_I_1200">Niclas des
                        Flustharts <roleName type="occ" corresp="#org__wien"><add>Bürger</add></roleName></rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>