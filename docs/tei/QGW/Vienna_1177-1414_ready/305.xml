               <rs type="event" ref="#ev__QGW_II_I_305"><rs type="fn" role="issuer"><rs type="person" ref="#pe__rudolf_QGW_II_I_305">Rudolf,<roleName type="kin" corresp="#pe__albrecht_von_st_poelten_QGW_II_I_305"><add>sun</add></roleName>
                        <rs type="person" ref="#pe__albrecht_von_st_poelten_QGW_II_I_305">Albrechts
                           sun von Sant Pölten</rs></rs>, und <rs type="person" ref="#pe__brunhilde_QGW_II_I_305">Praeunhilt, seine<roleName type="kin" corresp="#pe__rudolf_QGW_II_I_305"> Hausfrau</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="#pe__stephan_QGW_II_I_305"><roleName type="title">
                           Bergherrn </roleName><roleName type="title">hern</roleName> Stephans,
                           <roleName type="occ" corresp="#org__hernals-pfarre">pharrer</roleName>
                        dacz sant Paertelme zu der Herren Alsse</rs></rs>, 1 lb dn. geltes
                  purchrechts auf ihrem halben Joch Weingarten, der da leit zu der Herren Alsse
                  hinder dem dorfe in den langen halben Jeuchen zenaehst Nichlas weingarten des
                  Cholben, da man auch alle iar von dient 2 dn. für perchrecht und für voitrecht ,
                  um 8 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__jakob_poll_QGW_II_I_770"><roleName type="title">hern</roleName>
                        Jacoben dem Pollen, <roleName type="occ" corresp="#org__wien-st_maria_im_rathaus">chaplan</roleName> der chappellen
                        Unser Vrowen, hern Otten Haime stiftunge, in dem Rathaus ze Wienne</rs>, und
                        <rs type="org" ref="#org__wien-st_maria_im_rathaus">derselben seiner
                        chappellen</rs> .</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_305"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1.<rs type="person" ref="#pe__rudolf_QGW_II_I_305"> des
                        Ausstellers</rs>, 2. <rs type="person" ref="#pe__stephan_QGW_II_I_305">des
                        Bergherrn</rs>, 3. <rs type="person" ref="#pe__reimprecht_zaunrüde_QGW_II_I_305"><roleName type="title">hern</roleName> Reinprechts des Zaunru/eden, <roleName type="occ" corresp="#org__wien">purgermaister</roleName> ze Wienne</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. M. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>