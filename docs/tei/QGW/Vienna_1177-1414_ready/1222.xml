                  <triggerstring n="disp">verkauft habe</triggerstring>, <triggerstring n="disp">und
                     beglaubigt <add>als Volmachtträger</add></triggerstring> ihren <rs type="fn" role="recipient"><rs type="person" ref="#pe__engelhart_gruber_QGW_II_I_1222"><roleName type="kin" corresp="#pe__agnes_QGW_II_I_1222">Mann</roleName>
