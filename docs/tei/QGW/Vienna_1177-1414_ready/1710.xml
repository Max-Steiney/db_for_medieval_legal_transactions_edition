            <placeName>Wien</placeName>
            <date when="14070714">1407 VII 14</date>
            <origDate instant="false">ze Wienn, am phinztag nach sand Margreten tag, der heiligen
               junkchfraun.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01710_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01710_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="#ev__QGW_II_I_1710">
                  <rs type="fn" role="issuer"><rs type="person" ref="#pe__konrad_vorlauf_QGW_II_I_1320">Chunrat der Vorlauf, <roleName type="occ" corresp="#org__wien">purgermaister</roleName></rs>, und <rs type="org" ref="#org__wien">der rat gemain der stat ze Wienn</rs></rs>
                  <triggerstring n="disp">beurkunden</triggerstring>, dass <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_chottaner_QGW_II_I_1710">Hanns der
                        Chotanner</rs></rs> ihnen vorgebracht habe, <rs type="event" ref="NULL">wie
                     er ein Haus, gelegen am Alten Fleischmarkcht ze Wienne zunechst Pauln haus von
                     Eger an ainem tail und zenechst des Schonn Jacoben haus an dem andern tail von
                     seinem <rs type="person" ref="#pe__michael_chotanner_QGW_II_I_1309"><roleName type="title">pruder</roleName> Micheln <roleName type="dead">seligen</roleName> dem Chottaner</rs> gekauft habe, die Besiegelung des
                     darüber ausgestellten Kaufbriefes mit dem Grundsiegel der Stadt aber in Folge
                     des Todes Michels unterblieben sei,</rs> weshalb er sie um nachträgliche
                  Besiegelung bitte. Dem entgegen habe <rs type="person" ref="#pe__peter_menschein_QGW_II_I_1684">Peter der Mênschein an seiner hausfraun
                        <roleName type="rep" corresp="#pe__anna_QGW_II_I_1684">stat</roleName></rs>
                  <rs type="person" ref="#pe__anna_QGW_II_I_1684">Annen, des egenanten Michels des
                     Kottaner <roleName type="kin" corresp="#pe__michael_chotanner_QGW_II_I_1309">tochter</roleName>
                     <roleName type="kin" corresp="#pe__peter_menschein_QGW_II_I_1684"><add>hausfrau</add></roleName></rs> bei seiner <rs type="person" ref="#pe__katharina_QGW_II_I_1684"><roleName type="dead">erern</roleName>
                     <roleName type="kin" corresp="#pe__michael_chotanner_QGW_II_I_1309">hausfraun</roleName> Kathrein,<roleName type="dead"> der auch got genad
                     </roleName>,</rs> nachgewiesen, dass der alt chaufbrif, damit der egenant
                  Michel das vorgenant haus gechauft hiet, im und seiner erern hausfraun Kathrein
                  lautet und sagt , das Haus also seiner Frau von Vater und Mutter anerstorben sei.
                  Der Rath <triggerstring n="disp">entscheidet</triggerstring> in diesem Sinne und
                     <triggerstring n="disp">erklärt</triggerstring> den von Hanns vorgebrachten Kaufbrief
                     <triggerstring n="disp">für null und nichtig</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1710"><rs type="fn" role="witness">Besiegelt mit
                     der <rs type="org" ref="#org__wien">Stadt</rs> klainem anhangundem insigil.</rs>
               </rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>