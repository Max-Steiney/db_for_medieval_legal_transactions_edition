               <rs type="event" ref="#ev__QGW_II_I_482"><rs type="fn" role="issuer"><rs type="person" ref="#pe__eberhard_von_osterhofen_QGW_II_I_481">Eberhart von Osterhofen</rs>
                     und <rs type="person" ref="#pe__wendelmut_QGW_II_I_481">Wendelmu/ot, seine
                           <roleName type="kin" corresp="#pe__eberhard_von_osterhofen_QGW_II_I_481">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="#pe__heinrich_straiher_QGW_II_I_331"><roleName type="title">Bergherrn</roleName>
                        <roleName type="title">hern</roleName> Hainreichs des Straiher, <roleName type="occ" corresp="#org__wien">purgermaister</roleName> ze Wienne und
                           <roleName type="occ" corresp="#org__dornbach-pfarre">hofmaister</roleName>
                        ze Dornpach</rs></rs>, 12 sh. dn. gelts purchrechts auf ihrem Weingarten,
                  gelegen an dem Alssekk in der Waligris, des fumf viertail sint, der weilnt
                  Pilgreims seligen des Cho/echleins gewesen ist, zenachst Chunrats weingarten des
                  Helt , von dem man jährlich 62 ½ dn. zu Bergrecht in den Hof zu Dornbach dient, um
                  14 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__jakob_poll_QGW_II_I_770">hern Jacoben dem Pollen, <roleName type="occ" corresp="#org__wien-st_maria_im_rathaus">chaplan</roleName>
                        Unser Vrowen chappellen, hern Otten Haimen seligen Stiftung, gelegen in der
                        purger Rathaus ze Wienn</rs></rs> .</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_482"><rs type="fn" role="witness">Besiegelt mit
