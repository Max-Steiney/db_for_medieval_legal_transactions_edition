      <body>
         <div type="abstract">
            <p>
               <rs type="event" ref="#ev__QGW_II_II_1960"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_auf_der_saeule_QGW_II_II_1960">Hans auf der
                        Seul, <roleName type="occ" corresp="#org__wien">burger</roleName> ze Wienn,</rs></rs>
                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__rudolf_angerfelder_QGW_II_I_1335"><roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName>
                        Rudolfs des Angervelder</rs> und des <rs type="org" ref="#org__wien">Rathes</rs></rs> einen Gewandkeller, gelegen under den langen Tuchlauben ze
                  Wienn zenechst Hermans von Eslarn gewantkeller, von dem man auf sand Jörgen altar
                  in sand Michels pfarrkirchen 5 lb dn. ze purkrecht dient, um 80 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_pob_QGW_II_II_1958">dem Wiener <roleName type="occ" corresp="#org__wien">Bürger</roleName> Hannsen dem Poben</rs>
                     und seiner <rs type="person" ref="#pe__dorothea_QGW_II_II_1960"><roleName type="kin" corresp="#pe__johann_pob_QGW_II_II_1958">Gemahlin</roleName>
                        Dorothen</rs></rs>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_II_1960"><rs type="fn" role="witness">Besiegelt mit
                     dem Siegel des <rs type="person" ref="#pe__johann_auf_der_saeule_QGW_II_II_1960">Ausstellers</rs> und dem <rs type="org" ref="#org__wien">städtischen Grundsiegel</rs>.</rs></rs>
            </p>
