                     <rs type="fn" role="recipient"><rs type="person" ref="#pe__ulrich_von_enzersdorf_QGW_II_I_729">ihm</rs></rs> und <rs type="fn" role="recipient"><rs type="person" ref="#pe__walter_binder_QGW_II_I_729">seinem <roleName type="kin" corresp="#pe__ulrich_von_enzersdorf_QGW_II_I_729">geswein</roleName>
