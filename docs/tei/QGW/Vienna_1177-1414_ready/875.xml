                        <rs type="person" ref="#pe__haunold_schuchler_QGW_II_I_170"><roleName type="title">hern</roleName> Haunolts <roleName type="dead">seligen</roleName> eninkchel des Schu/echler</rs><roleName type="kin" corresp="#pe__haunold_schuchler_QGW_II_I_170"><add>eninkchel</add></roleName>
                     </rs>, und <rs type="person" ref="#pe__margarethe_QGW_II_I_827">Margret,
                           <roleName type="kin" corresp="#pe__johann_poltz_QGW_II_I_827"><add>hausvrowe</add></roleName>
                        <rs type="person" ref="#pe__johann_poltz_QGW_II_I_827">Jannsen hausvrowe des
