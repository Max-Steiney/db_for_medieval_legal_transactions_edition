               <rs type="event" ref="#ev__QGW_II_I_307"><rs type="fn" role="issuer"><rs type="person" ref="#pe__niklas_von_ruppersdorf_QGW_II_I_307">Nicla von Ruepprechtzdorf</rs>
                     und seine <rs type="person" ref="#pe__kunigunde_QGW_II_I_307"><roleName type="kin" corresp="#pe__niklas_von_ruppersdorf_QGW_II_I_307">Hausfrau</roleName> Chunigunt</rs></rs>
                  <triggerstring n="disp">nehmen den Schiedspruch an</triggerstring>,<rs type="event" ref="#ev__QGW_II_I_307_men_1"> den <rs type="fn" role="other"><rs type="person" ref="#pe__reimprecht_zaunrüde_QGW_II_I_305"><roleName type="title">her</roleName> Reinprecht der Zaunru/ede,<roleName type="occ" corresp="#org__wien"> purgermaister </roleName>ze Wienne</rs>, und <rs type="person" ref="#pe__dietrich_urbetsch_QGW_II_I_950"><roleName type="title">her</roleName> Dietreich der Urbaetsch</rs>
                        <triggerstring n="fn">in. dem Streite</triggerstring></rs> mit des Niklas <rs type="person" ref="#pe__ulrich_QGW_II_I_307"><roleName type="kin" corresp="#pe__niklas_von_ruppersdorf_QGW_II_I_307">Schwager</roleName>
                        Ulreichen, <rs type="person" ref="#pe__oswald_QGW_II_I_307"> Oswalten</rs>
                        <roleName type="kin" corresp="#pe__oswald_QGW_II_I_307">Sohn</roleName></rs>,
                     und dessen<rs type="person" ref="#pe__niklas_QGW_II_I_307">
                        <roleName type="kin" corresp="#pe__ulrich_QGW_II_I_307">Geschwistern</roleName> Niclasen</rs>,<rs type="person" ref="#pe__agnes_QGW_II_I_307">
                        <roleName type="kin" corresp="#pe__ulrich_QGW_II_I_307"><add>Geschwister</add></roleName>Agnesen</rs> und <rs type="person" ref="#pe__konrad_QGW_II_I_307"><roleName type="kin" corresp="#pe__ulrich_QGW_II_I_307"><add>Geschwister</add></roleName>Chunraten</rs> gefällt haben.</rs> Sie
                     <triggerstring n="disp">entsagen allen Forderungen </triggerstring>an das Haus,
                  gelegen an dem Liechtensteg zunaest Dietreiches haus von Eger, wogegen ihnen die
                  genannten Geschwister bis zum nächsten Michaelistage 14 lb dn. bezahlen
                  sollen.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_307"><rs type="fn" role="witness">Besiegelt mit
