        <origDate instant="false">ze Wienne, des naehsten vreitages vor sant Marein Magdalenen
          tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00406_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00406_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
          <rs type="event" ref="#ev__QGW_II_I_406"><rs type="fn" role="issuer"><rs type="person" ref="#pe__eberger_praunstorfer_QGW_II_I_406">Eberger der Praunstorfer</rs> und <rs type="person" ref="#pe__anna_QGW_II_I_406">Anna, seine <roleName type="kin" corresp="#pe__eberger_praunstorfer_QGW_II_I_406">Hausfrau</roleName></rs></rs>,
              <triggerstring n="disp">geben <add>ze einem widerwechsel</add></triggerstring>
            <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="#pe__gerung_chol_QGW_II_I_417"><roleName type="occ" corresp="#org__klosterneuburg-augustiner_chorherren">Bergmeisters</roleName>
                Gerungs des Choln, <roleName type="occ" corresp="#org__klosterneuburg-augustiner_chorherren">amptman</roleName> des
                chlosters ze Neuenburch</rs></rs>, ze einem widerwechsel dem <rs type="fn" role="recipient"><rs type="person" ref="#pe__peter_des_goleins_aidem_QGW_II_I_406">Wiener <roleName type="occ" corresp="#org__wien">Bürger</roleName> Petrein,
                des <rs type="person" ref="#pe__golein_QGW_II_I_406">Goleins</rs>
                <roleName type="kin" corresp="#pe__golein_QGW_II_I_406">aidem</roleName></rs></rs>,
            ihr Joch Weingarten, gelegen zu Grinczingen in dem Mukkental, und haisset der Ledrer,
            zenaehst Nichlas weingarten des Eisenreichs , (belastet mit 3 Eimern Wein Bergrecht und
            3 dn. Voitrecht), wogegen sie von Peter erhalten 3 Viertel Weingarten ze Purpach,
            zenaehst Weicharts weingarten von Prukke.</rs>
        </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_406"><rs type="fn" role="witness">Besiegelt mit den
              Siegeln: 1. des <rs type="person" ref="#pe__eberger_praunstorfer_QGW_II_I_406">Ausstellers</rs>, 2. des <rs type="person" ref="#pe__gerung_chol_QGW_II_I_417"><roleName type="occ" corresp="#org__klosterneuburg-augustiner_chorherren">Bergmeisters</roleName></rs>, 3. <rs type="person" ref="#pe__heinrich_von_wulzendorf_QGW_II_I_406">Hainreichs von Wultzendorf, Annas
                  <roleName type="kin" corresp="#pe__anna_QGW_II_I_406">Bruder</roleName></rs>.</rs></rs>
        </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. M. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>