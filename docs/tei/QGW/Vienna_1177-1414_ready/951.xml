                        <rs type="person" ref="#pe__leonhard_poll_QGW_II_I_1152"><roleName type="dead"><add>dead</add></roleName> Wiener <roleName type="occ" corresp="#org__wien">Bürger</roleName> Leonhardus Poll</rs> seinen
