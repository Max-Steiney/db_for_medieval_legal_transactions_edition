                        Chunradus, <roleName type="prof">pistor</roleName></rs> , und seine <rs type="person" ref="#pe__margarethe_QGW_II_I_951">
                        <roleName type="kin" corresp="#pe__konrad_pistor_QGW_II_I_951">Gemahlin</roleName>
