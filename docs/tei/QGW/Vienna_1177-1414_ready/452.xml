            <date when="13540324">1354 III 24</date>
            <origDate instant="false">ze Wienne, an Unser Vrowen abent ze der chündung.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00452_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00452_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_452"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_hesner_QGW_II_I_452">Jans der Hesner</rs>
                  </rs><triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> seines <rs type="person" ref="#pe__leopold_von_sachsengang_QGW_II_I_452">
                        <roleName type="title">Grund und Bergherrn</roleName>
                        <roleName type="title">hern</roleName> Leupolts von Sachsengang, <roleName type="occ" corresp="#org__wien-st_stephan">pharrer</roleName> dacz sant
                        Stephan ze Wienne</rs>,</rs> 3 lb dn. <triggerstring n="disp">geltes
                     purchrechts</triggerstring> auf seiner Hofstatt weingarten, gelegen bei der Wienn
                  zwischen baiden müln und haisset der V/eginge, von dem man dem Pfarrer bei S.
                  Stephan jährlich 12 Hühner, je vier zu Ostern, Pfingsten und Weihnachten, dient
                  und auf 18 sh. 8 dn. geltes, die er auf Aeckern hat, gelegen oberhalben Gumpendorf
                  bei des hof von Mu/eling, von dem man 60 dn. Grundrecht an sand Merteins tag
                  dient, um 24 lb dn. mit dem Vorbehalte der Ablösung um den gleichen Betrag <rs type="fn" role="recipient"><rs type="person" ref="#pe__andreas_QGW_II_I_452"><roleName type="title">hern</roleName> Andren, <roleName type="occ" corresp="#org__wien-st_stephan-altar_st_martin">chapplan</roleName> der
                        chappellen sant Merteins vor Widmertor</rs></rs>, der diese Gült von den
                  phenningen kauft, <rs type="event" ref="#ev__QGW_II_I_452_men_1">da <rs type="person" ref="#pe__konrad_loeffler_QGW_II_I_452"><roleName type="title">her</roleName>
                        Chunrat der Löffler</rs> ander purchrecht mit abgelöst hat</rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_452"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="#pe__johann_hesner_QGW_II_I_452">des
                        Ausstellers</rs>, 2. <rs type="person" ref="#pe__leopold_von_sachsengang_QGW_II_I_452">des Pfarrers</rs>, 3. <rs type="person" ref="#pe__lukas_popphinger_QGW_II_I_776"><roleName type="title">hern</roleName> Lucas des Popphinger,<roleName type="occ" corresp="#org__wien"> hansgraf</roleName> ze Wienne</rs>, 4. <rs type="person" ref="#pe__konrad_loeffler_QGW_II_I_452">hern Chunrats des
                        Löffler</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>