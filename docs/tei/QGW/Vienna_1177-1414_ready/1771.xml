            <date when="14090905">1409 IX 05</date>
            <origDate instant="false">ze Wienn, des nachsten phinztags nach sand Gilgen tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01771_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01771_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1771"><rs type="fn" role="issuer"><rs type="person" ref="#pe__paul_geir_QGW_II_I_1406">Paul der Geyr, des <roleName type="occ" corresp="#org__wien">rats</roleName> der stat ze Wienn und
                           <roleName type="rep" corresp="#pe__lucia_QGW_II_I_1018">ausrichter und
                           volfürer</roleName></rs></rs> des geschefts, <rs type="person" ref="#pe__lucia_QGW_II_I_1018">so <roleName type="title">frau</roleName> Lucei,
                     Hansen des Geschiesser <roleName type="dead">witiben</roleName>, den baiden
                        <roleName type="dead">got gnad</roleName>,</rs> getan hat , <triggerstring n="disp">stiftet nach ihrer letztwilligen Anordnung</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="#org__wien-st_stephan-altar_st_martin-messe_naezeugerin_lucia">eine
                        Messe</rs></rs>, <rs type="event" ref="NULL">welche schon bei Lebzeiten
                     Luzei's dem <rs type="person" ref="#pe__simon_von_rukersburg_QGW_II_I_1771"><roleName type="prof">Priester</roleName>
                        <roleName type="title">hern</roleName> Simonen von Rukerspurk</rs> verliehen
                     worden war</rs>, auf sand Mertein altar dacz sand Stephan ze Wienn und
                     <triggerstring n="disp">widmet</triggerstring> zu derselben der vorgenanten Lucein
                  hof, gelegen ze Prunn bei Perchtolstorf zenechst dem Keunspies, mit allem Zubehör,
                  von dem man dem herzogen gen Lachsendorf zehen meezen habern vogtfüueters oder 80
                  dn. dient, und ihr Haus, gelegen in der Offenlucken, von dem man den Schotten 24
                  dn. zu Grundrecht dient, ferner einen Kelch, ein Messbuch und zwei Messgewänder,
                  mit der Bestimmung, dass der Kaplan die Stiftung ordentlich ausführen und jährlich
                  zu den Quatembern je 1 lb dn. den <rs type="fn" role="recipient">Dürftigen in der
                        <rs type="org" ref="#org__wien-buergerspital">burger Spital vor Kernertor ze
                        Wienn</rs></rs> reichen solle. </rs></p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1771"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="#pe__paul_geir_QGW_II_I_1406">Ausstellers</rs>, 2. <rs type="person" ref="#pe__johann_veltsperger_QGW_II_I_1560">des <roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName> hern Hansen des
                        Veltsperger</rs>, 3. <rs type="person" ref="#pe__johann_kaufmann_QGW_II_I_1760">Hansen des Kaufmans, <roleName type="occ" corresp="#org__wien-st_stephan">kirichmaister</roleName> dacz
                        sand Stephan ze Wienn,</rs> 4. <rs type="person" ref="#pe__johann_naezeuger_QGW_II_I_1123">Hansen des Nezeuger, des eltern,
                        der egenanten Lucein <roleName type="kin" corresp="#pe__lucia_QGW_II_I_1018">steufsun</roleName></rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>