        <origDate instant="false">ze Wienne, an sant Michels tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00443_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00443_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
          <rs type="event" ref="#ev__QGW_II_I_443"><rs type="fn" role="issuer"><rs type="person" ref="#pe__agnes_QGW_II_I_443"><roleName type="title">Swester</roleName> Agnes die
                Snaeczlinne, <roleName type="occ" corresp="#org__wien-st_agnes_auf_der_himmelpforte">maisterinne</roleName></rs>, <rs type="person" ref="#pe__margarethe_QGW_II_I_443_a"><roleName type="title">swester</roleName>
                Margret, <roleName type="occ" corresp="#org__wien-st_agnes_auf_der_himmelpforte">priorinne</roleName></rs>, und der <rs type="org" ref="#org__wien-st_agnes_auf_der_himmelpforte">convent gemain der geistlichen vrowen
                chloster datz der Himelporten ze Wienne</rs></rs>
            <triggerstring n="disp">verkaufen</triggerstring>
            <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="#pe__johann_von_rappach_QGW_II_I_392"><roleName type="title">Grundherrn</roleName>
                <roleName type="title">hern</roleName> Jansen von Rappach</rs></rs> ein Haus,
            gelegen innerhalben Werdertor ze Wienne auf der Goldsmit zenaechst Rudleins haus des
            Singer, das weilent Hainreichs des Goy gewesen ist , und das ihnen um 5 sh. 10 dn.
            versessenes Burgrecht und die darauf ertheilten zwispilde in der Bürgerschranne
            zugesprochen worden war, <rs type="fn" role="recipient"><rs type="person" ref="#pe__heinrich_golthann_QGW_II_I_443">Hainrichen dem Golthanne, dem <roleName type="prof">chürsner</roleName></rs>, und seiner <rs type="person" ref="#pe__margarethe_QGW_II_I_443_b"><roleName type="kin" corresp="#pe__heinrich_golthann_QGW_II_I_443">Hausfrau</roleName>
              Margreten</rs></rs>.</rs>
        </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_443"><rs type="fn" role="witness">Besiegelt mit den
              Siegeln: 1. der <rs type="person" ref="#pe__agnes_QGW_II_I_443">Meisterin</rs>, 2. des
                <rs type="org" ref="#org__wien-st_agnes_auf_der_himmelpforte">Conventes</rs>, 3. des
                <rs type="person" ref="#pe__johann_von_rappach_QGW_II_I_392">Grundherrn</rs>, 4. <rs type="person" ref="#pe__jakob_maeserl_QGW_II_I_121"><roleName type="title">hern</roleName> Jacobs des Maeserlein, von des herzogen wegen des chlosters
                  <roleName type="occ" corresp="#org__wien-st_agnes_auf_der_himmelpforte">phleger</roleName> und <roleName type="occ" corresp="#org__wien-st_agnes_auf_der_himmelpforte">verweser</roleName></rs>.</rs></rs>
        </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>