                        Albrecht IV.</rs></rs>
                  <triggerstring n="disp">verleiht zur Belohnung lange und treu geleisteter
                     Dienste</triggerstring> seinem <rs type="fn" role="recipient"><rs type="person" ref="#pe__bernhard_gravenwerder_QGW_II_I_1327"><roleName type="occ" corresp="#pe__albrecht_iv_herzog_von_oesterreich_QGW_II_I_1332">kamrer</roleName>
