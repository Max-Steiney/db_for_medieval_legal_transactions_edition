            <origDate instant="false">Der geben ist ze Wienn an montag nach sand Anthonien tag, nach Christs gepurd
               1400 jar darnach in dem 10. jare. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01788_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01788_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1788"><rs type="fn" role="issuer"><rs type="person" ref="#pe__heinrich_schmied_QGW_II_I_1788"><roleName type="title">Maister</roleName> Hainreich, der <roleName type="prof">smid</roleName>,</rs> und <rs type="person" ref="#pe__friedrich_raissmid_QGW_II_I_1788">Fridreich, der <roleName type="prof">raissmid</roleName>, sein <roleName type="kin" corresp="#pe__heinrich_schmied_QGW_II_I_1788">aidem</roleName></rs>, und
                        <rs type="person" ref="#pe__anna_QGW_II_I_1788">Ann, sein <roleName type="kin" corresp="#pe__friedrich_raissmid_QGW_II_I_1788">hausfrau</roleName>, maister Hainreichs <roleName type="kin" corresp="#pe__heinrich_schmied_QGW_II_I_1788">tochter</roleName></rs>,</rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other">mit Handen des <rs type="person" ref="#pe__paul_geir_QGW_II_I_1406"><roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Pauln des Geyr</rs> und des <rs type="org" ref="#org__wien">rats gemain der stat ze Wienn</rs></rs> 1 lb dn.
                  gelts purkchrechts auf ihrem Hause, gelegen bei den Predigern ze Wienn zenechst
                  Pauln haus des Wagendrussel, von dem man den geistlichen Frauen hinz sand Nicla
                  vor Stubentor 1 lb dn. und hinz sand Jeronimus 2 lb dn. zu Burgrecht dient, um 8
                  lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__thomas_zeidler_QGW_II_I_1788">hern
                     Thomann dem Zeidler, <roleName type="occ" corresp="#org__wien-st_stephan-altar_allerheiligen-messe_sindram">Kaplan</roleName></rs></rs> der von <rs type="person" ref="#pe__anna_sindramin_QGW_II_I_1788"><roleName type="title">frau</roleName>
                     Anna der Syndramin, der <roleName type="dead">got gnad</roleName>,</rs> hinz
                     <rs type="fn" role="recipient"><rs type="org" ref="#org__wien-st_stephan-altar_allerheiligen-messe_sindram">sand Stepfan ze
                        Wienn auf Allerheiligen altar gestifteten Messe, zu dieser
                  Messe</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1788"><rs type="fn" role="witness">Besiegelt mit
                     dem städtischen <rs type="org" ref="#org__wien">Grundsiegel</rs> und mit dem
                     Siegel <rs type="person" ref="#pe__konrad_innauer_QGW_II_I_1521">Chunrats des
                        Innawer</rs></rs>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>