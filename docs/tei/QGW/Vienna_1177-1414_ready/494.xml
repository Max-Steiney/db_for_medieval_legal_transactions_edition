                Bergherrn</rs>, 2.<rs type="person" ref="#pe__haunold_schuchler_QGW_II_I_170">
                <roleName type="title">hern</roleName> Haunolts des Schu/echler, <roleName type="occ" corresp="#org__wien">purgermaister</roleName> ze Wienne</rs>.</rs></rs>
