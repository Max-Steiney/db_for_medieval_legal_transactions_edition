          <rs type="event" ref="#ev__QGW_II_I_494"><rs type="fn" role="issuer"><rs type="person" ref="#pe__bertha_QGW_II_I_494">Pericht deu Röslinne</rs>, <rs type="person" ref="#pe__ulrich_smaekkel_QGW_II_I_494">Ulreich der Smaekkel</rs>,<rs type="person" ref="#pe__elisabeth_QGW_II_I_494"> Elsbet, seine <roleName type="kin" corresp="#pe__ulrich_smaekkel_QGW_II_I_494">Hausfrau</roleName></rs>, <rs type="person" ref="#pe__friedrich_allerlaier_QGW_II_I_494">Fridreich der
                Allerlaier</rs> und <rs type="person" ref="#pe__brigitta_QGW_II_I_494">Preide, seine
                  <roleName type="kin" corresp="#pe__friedrich_allerlaier_QGW_II_I_494">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen mit gesammter
              Hand</triggerstring> und <rs type="fn" role="other"><triggerstring n="fn">mit
                Handen</triggerstring>
              <rs type="person" ref="#pe__heinrich_straiher_QGW_II_I_331">ihres <roleName type="title">Bergherrn</roleName>
                <roleName type="title">hern</roleName> Hainreichs des Straiher, <roleName type="occ" corresp="#org__dornbach-pfarre">hofmaister</roleName> ze Dornpach</rs></rs>, ihre
            wartunge und alle ihre Rechte, <rs type="event" ref="NULL">die sie von <rs type="person" ref="#pe__margarethe_QGW_II_I_494">der <roleName type="kin" corresp="#pe__bertha_QGW_II_I_494">Schwester</roleName> der Pericht, Margreten, der
                  <roleName type="kin" corresp="#pe__konrad_haelenrede_QGW_II_I_494">Hausfrau</roleName>
                <rs type="person" ref="#pe__konrad_haelenrede_QGW_II_I_494">Chunrats des
                  Haelenrede</rs></rs> ererbt hatten</rs>, an dem Viertel Weingarten ze Dornpach in
            den Schaeukchen zenaehst Wisenten dem Amman, von dem man jährlich 12 ½ dn. Bergrecht und
            3 Ort Voitrecht dient, um 8 lb dn. dem genannten <rs type="fn" role="recipient"><rs type="person" ref="#pe__konrad_haelenrede_QGW_II_I_494">Chunraden dem
              Haelenrede</rs></rs>.</rs>
        </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_494"><rs type="fn" role="witness">Besiegelt mit den
