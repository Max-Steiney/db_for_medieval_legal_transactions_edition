            <date from="99999999" to="99999999"/>
            <origDate instant="false">ze Wienn, des nechsten freitags nach sant Gregorien tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01084_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01084_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="#ev__QGW_II_I_1084">
                  <rs type="fn" role="issuer"><rs type="person" ref="#pe__andreas_watman_QGW_II_I_1084">Andre der
                        Watman, <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                        Wienn</rs> , und <rs type="person" ref="#pe__kunigunde_QGW_II_I_1084">Chu/enigund, seine <roleName type="kin" corresp="#pe__andreas_watman_QGW_II_I_1084">Hausfrau</roleName></rs></rs> , <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__paul_holzkaeufel_QGW_II_I_1010"><roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Pauln des Holzcha/euffels</rs> und
                     des <rs type="org" ref="#org__wien">rates gemain der stat ze Wienn</rs></rs> 5
                  lb dn. geltes purchrechts (ablösbar) auf ihrem Hause, gelegen in der Weichenpurch
                  an dem ekk ze Wienn und stosset hinden an die padstuben, um 40 lb dn. <rs type="person" ref="#pe__andreas_leisser_QGW_II_I_1084"><roleName type="title">hern</roleName>
                     Andren dem Leiter, <roleName type="occ" corresp="#org__schwadorf-pfarre">pharrer</roleName> ze Swobdorf , <roleName type="occ" corresp="#org__wien-gottesleichnam_kapelle_vor_dem_werdertor-messe_stettner">Kaplan</roleName></rs> der von <rs type="person" ref="#pe__ulrich_stettner_QGW_II_I_1084">
                     Ulreich dem Stettner, <roleName type="dead">dem got gnad</roleName></rs>, auf
                  Unser Vrown altar, gelegen in Gotesleichnam chapellen vor Werdertor ze Wienn ,
                  gestifteten <rs type="fn" role="recipient"><rs type="org" ref="#org__wien-gottesleichnam_kapelle_vor_dem_werdertor-messe_stettner">Messe</rs></rs> . Derselbe <triggerstring n="disp">hat zum Ankaufe
                     verwendet</triggerstring> 32 lb dn., für welche 4 lb dn. von dem Hause rown
                  Margreten, Niclasen witiben des Hinlaufs, abgelöst worden waren, während 8 lb dn.
                  von dem Pfunde herrührten, das auf Andre's Haus gelegen war.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1084"><rs type="fn" role="witness">Besiegelt : 1.
                     mit dem <rs type="org" ref="#org__wien">städtischen Grundsiegel</rs>, 2. dem
                     Siegel des <rs type="person" ref="#pe__leopold_metsakch_QGW_II_I_1084">Wiener <roleName type="occ" corresp="#org__wien">Bürgers</roleName> Leupolts des
                        Metsakchs</rs>.</rs></rs>
            </p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>