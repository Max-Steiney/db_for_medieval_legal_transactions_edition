               <rs type="event" ref="#ev__QGW_II_I_1124"><rs type="fn" role="issuer"><rs type="person" ref="#pe__albrecht_stuchs_QGW_II_I_1124">Alber der Stuchs ze
                        Trautmanstorf</rs></rs>
                  <triggerstring n="disp">bestätigt</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">für</triggerstring> sich und seinen <rs type="person" ref="#pe__georg_stuchs_QGW_II_I_1124"><roleName type="kin" corresp="#pe__albrecht_stuchs_QGW_II_I_1124">Vetter</roleName> Jorigen den
                     Stuchsen</rs></rs>, dass <rs type="fn" role="other"><triggerstring n="fn">vor
                        ihm</triggerstring>
                     <rs type="person" ref="#pe__agnes_QGW_II_I_1124">Agnes, <roleName type="kin" corresp="#pe__gundolt_QGW_II_I_1125"><add>witib</add></roleName>
                        <rs type="person" ref="#pe__gundolt_QGW_II_I_1125">Gundolts <roleName type="dead">witib</roleName> von Trautmansdorf</rs></rs></rs>, <rs type="fn" role="recipient"><rs type="person" ref="#pe__wulfing_QGW_II_I_1124">ihrem <roleName type="kin" corresp="#pe__agnes_QGW_II_I_1124">Sohne</roleName> Wulfingen</rs></rs>
                  <triggerstring n="disp">alle Lehen <add>aufgegeben habe</add></triggerstring>, die sie
                  von ihren Eltern ererbt hatte, aufgegeben habe, und zwar einen Hof, gelegen ze
                  Trautmanstorf zenachst dem pharrhof, und alles das zu demselbigen hof gehoret, . .
                  . wa das gelegen ist auf dem Deuschen oder auf dem Ungerischen.</rs>
