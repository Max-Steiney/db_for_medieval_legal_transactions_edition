   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="#ev__QGW_II_II_1993">
               <rs type="fn" role="issuer"><rs type="person" ref="#pe__rudolf_angerfelder_QGW_II_I_1335">Rudolf der Angerfelder, <roleName type="occ" corresp="#org__wien">burgermaister</roleName> und <roleName type="occ" corresp="#org__wien">münssmaister</roleName>,</rs> und <rs type="org" ref="#org__wien">der rat gemain der stat ze Wienn</rs></rs>
               bestätigen, von <rs type="fn" role="recipient"><rs type="person" ref="#pe__erhard_schierl_QGW_II_I_1845">Erhart dem Schierl, <roleName type="occ" corresp="#org__freising-dioezese">tumbherrn</roleName> ze Freising und
                        <roleName type="occ" corresp="#org__wien-st_stephan"><add>tumbherrn</add></roleName> dacz sand Stepfan ze Wienn und <roleName type="occ" corresp="#org__nappersdorf-pfarre">pfarrer</roleName> ze
                        Napperstorf<roleName type="rep" corresp="#pe__leonhard_schaur_QGW_II_I_1242"><add>Geschäftsherrn</add></roleName></rs>, <rs type="person" ref="#pe__wolfgang_purkchartsperger_QGW_II_I_1560">Wolfgang Purckartsperger,
                        <roleName type="occ" corresp="#org__wien">statrichter</roleName><roleName type="rep" corresp="#pe__leonhard_schaur_QGW_II_I_1242"><add>Geschäftsherrn</add></roleName>,</rs>
                  <rs type="person" ref="#pe__heinrich_starkch_StB_I_62">Hainreich dem Starck von
                     Sparbach<roleName type="rep" corresp="#pe__leonhard_schaur_QGW_II_I_1242"><add>Geschäftsherrn</add></roleName></rs>, und <rs type="person" ref="#pe__michael_purkchartsperger_QGW_II_I_1560">Michel Purckartsperger, des
                     statrichter <roleName type="kin" corresp="#pe__wolfgang_purkchartsperger_QGW_II_I_1560">bruder</roleName> ,
                     als <roleName type="rep" corresp="#pe__leonhard_schaur_QGW_II_I_1242">Geschäftsherrn</roleName></rs></rs> nach Lienhart dem Schaur 300 lb dn.,
               die dieser hinz <rs type="org" ref="#org__wien-st_maria_am_gestade-altar_st_leonhard-messe_schauer_leonhard">Unser
                  Fraun auf der Stetten in die neu kapelln zenest dem turn zu ainer ewigen mess</rs>
               ze stiften geschafft hat , erhalten und für diese Messe auf Andres haus des Rysen,
               das weilent Pauln seligen des Ernsts gewesen ist, angelegt zu haben. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_II_1993"><rs type="fn" role="witness">Besiegelt mit <rs type="org" ref="#org__wien">der stat
                     klainem insigel</rs>.</rs>
            </rs></p>
