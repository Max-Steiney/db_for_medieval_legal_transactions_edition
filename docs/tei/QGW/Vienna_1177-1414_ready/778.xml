               <rs type="event" ref="#ev__QGW_II_I_778"><rs type="fn" role="issuer"><rs type="person" ref="#pe__konrad_urbetsch_QGW_II_I_950">Chu/onrad der Urbêtzsch, <roleName type="occ" corresp="#org__wien">statrichter ze Wienn</roleName></rs></rs>,
