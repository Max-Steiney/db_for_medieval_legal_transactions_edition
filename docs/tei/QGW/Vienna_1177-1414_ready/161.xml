            <origDate instant="false">ze Medlich, an sand Jacobes tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00161_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00161_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_161"><rs type="fn" role="issuer"><rs type="person" ref="#pe__wolfger_choeberl_QGW_II_I_161">Wolfger der Chöberl von
                     Prunn,</rs></rs>
                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Willen</triggerstring> seiner <rs type="person" ref="#pe__katharina_QGW_II_I_161">
                        <roleName type="kin" corresp="#pe__wolfger_choeberl_QGW_II_I_161">Schwester</roleName> Katrein</rs></rs>
                  <triggerstring n="disp">die wartung</triggerstring>, die er nach dem <rs type="person" ref="#pe__hildegard_QGW_II_I_161"><roleName type="dead">Ableben</roleName>
                     seiner <roleName type="kin" corresp="#pe__wolfger_choeberl_QGW_II_I_161">Mutter</roleName> Hiltgund</rs> nach <rs type="person" ref="#pe__friedrich_choeberl_QGW_II_I_161">seinem <roleName type="dead">verstorbenen</roleName>
                     <roleName type="kin" corresp="#pe__wolfger_choeberl_QGW_II_I_161">Vater</roleName> Fridreich dem Chöberl</rs> hat, seinen halben Hof, der do
                  leit ze Prunn zeno/est Wolfgers hof des Reichen, von dem man 3 ½ sh. dn. an S.
                  Michaels Tag Chunraden dem Sch^ ytzen ze Prunn zu Burgrecht und 5 Metzen
                  voithabern ze Wienne in die Purch dient, um 8 lb dn.<rs type="fn" role="recipient">dem<rs type="person" ref="#pe__niklas_QGW_II_I_161">
                        <roleName type="kin" corresp="#pe__hildegard_QGW_II_I_161">Bruder</roleName>
                        seiner Mutter Niclosen</rs> und dessen <rs type="person" ref="#pe__gertrud_QGW_II_I_161"><roleName type="kin" corresp="#pe__niklas_QGW_II_I_161">Hausfrau</roleName>
                  Gedrauten</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_161"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="#pe__konrad_lonholz_QGW_II_I_161"><roleName type="title">hern</roleName> Chunrates des Lonholtz ze Medlich, der des
                        vorgenanten gu/etes zu/e den zeiten stifter und sto/erer</rs> gewesen , und
                        <rs type="person" ref="#pe__heinrich_von_eisenburg_QGW_II_I_161">
                        <roleName type="title">hern</roleName> Hainreiches von Eisenburch, <roleName type="occ" corresp="#pe__elisabeth_herzogin_von_oesterreich_QGW_II_I_789">
                           Hofmeisters</roleName>
                        <rs type="person" ref="#pe__elisabeth_herzogin_von_oesterreich_QGW_II_I_789">der <roleName type="kin" corresp="#pe__heinrich_herzog_von_oesterreich_QGW_II_I_90">Witwe</roleName> des <rs type="person" ref="#pe__heinrich_herzog_von_oesterreich_QGW_II_I_90"><roleName type="occ" corresp="#org__oesterreich-herzogtum">Herzogs</roleName> Heinrich
                                 <roleName type="dead"><add>Witwe</add></roleName></rs></rs></rs>.</rs></rs>
            </p><p><rs type="event" ref="#ev__QGW_II_I_161"><rs type="fn" role="witness">Zeugen: dacz
                     Prunn: <rs type="person" ref="#pe__konrad_QGW_II_I_161">Chu/enrat</rs>, <rs type="person" ref="#pe__urban_QGW_II_I_161">Urban</rs>, <rs type="person" ref="#pe__engelbrecht_QGW_II_I_161">Engelprecht</rs>, <rs type="person" ref="#pe__hebrant_QGW_II_I_161">Hebrant</rs>, <rs type="person" ref="#pe__peter_QGW_II_I_161">Peter, sein <roleName type="kin" corresp="#pe__hebrant_QGW_II_I_161">pru/eder</roleName></rs>, <rs type="person" ref="#pe__gileis_QGW_II_I_161">Gileis</rs> datz
                     Engelschalichstorf: <rs type="person" ref="#pe__ulrich_QGW_II_I_161">Ulreich,
                        der Herzogin <roleName type="occ" corresp="#pe__elisabeth_herzogin_von_oesterreich_QGW_II_I_789">Bergmeister</roleName></rs>, <rs type="person" ref="#pe__eberhard_choelbl_QGW_II_I_447">Ewerhar Cholbel</rs>, <rs type="person" ref="#pe__niklas_chreuss_QGW_II_I_161">Niclas der Chreuss</rs>,
                        <rs type="person" ref="#pe__walter_payr_QGW_II_I_161">Walther der Payr</rs>
                     datz Medlich: <rs type="person" ref="#pe__dietrich_vaelschel_QGW_II_I_161">Dietreich Vaelschel</rs>, <rs type="person" ref="#pe__siegfried_vaelschel_QGW_II_I_161">Seifrid, sein <roleName type="kin" corresp="#pe__dietrich_vaelschel_QGW_II_I_161">pru/eder</roleName></rs>, <rs type="person" ref="#pe__ulrich_schmied_QGW_II_I_304">Ulreich, der <roleName type="prof">smit</roleName></rs>, <rs type="person" ref="#pe__ruediger_paumgartner_QGW_II_I_161">Ru/edger der
                     Paungartner</rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>