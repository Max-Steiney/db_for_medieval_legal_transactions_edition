               <rs type="event" ref="#ev__QGW_II_I_1612"><rs type="fn" role="issuer"><rs type="person" ref="#pe__niklas_wuerfel_QGW_II_I_1001">Niclas der Würffel</rs>
                     und <rs type="person" ref="#pe__sigmund_wuerfel_QGW_II_I_1404">Sigmund der
                        Würffel, sein <roleName type="kin" corresp="#pe__niklas_wuerfel_QGW_II_I_1001">prüder</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen</triggerstring> ihren Antheil an dem Weingarten,
                  gelegen ze Grinzing, des anderthalb jeuch ist, genant das Sumerekk, zenechst des
                  Spitals weingarten ze Wienn , dessen <rs type="person" ref="#pe__niklas_wuerfel_QGW_II_I_1001"><roleName type="title">Bergherr</roleName> Niclas der Würffel </rs>von des chlosters wegen ze
                  Neunburg ist, und von dem man 15 Viertel Wein zu Bergrecht und 4 1/2 dn. zu
                  Voitrecht dient, um 300 lb dn. <rs type="fn" role="recipient">ihren <rs type="person" ref="#pe__johann_wuerfel_QGW_II_I_1404"><roleName type="kin" corresp="#pe__niklas_wuerfel_QGW_II_I_1001">Brüdern</roleName>
                        <roleName type="title">hern</roleName> Hannsen dem Würffel</rs> und <rs type="person" ref="#pe__ulrich_wuerfel_QGW_II_I_1404">Ulreichen dem
                           Würffel<roleName type="kin" corresp="#pe__niklas_wuerfel_QGW_II_I_1001"><add>Brüdern</add></roleName></rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1612"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1., 2. der <rs type="person" ref="#pe__niklas_wuerfel_QGW_II_I_1001">Aussteller</rs>
                     <rs type="person" ref="#pe__sigmund_wuerfel_QGW_II_I_1404"><add>Aussteller</add></rs>, 3. <rs type="person" ref="#pe__paul_wuerfel_QGW_II_I_1200">ihres <roleName type="kin" corresp="#pe__niklas_wuerfel_QGW_II_I_1001">Vetters</roleName> Pauln des
                        Würffels, <roleName type="occ" corresp="#org__wien">purgermaister</roleName>
                        ze Wienn</rs>, 4. <rs type="person" ref="#pe__albrecht_zetter_QGW_II_I_1577">Albrechts des Zetter, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienn</rs>.</rs></rs>
