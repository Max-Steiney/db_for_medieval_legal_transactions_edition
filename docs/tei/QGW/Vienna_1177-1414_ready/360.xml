            <origDate instant="false">ze Wienne, an sant Jacobs abent.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00360_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00360_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="#ev__QGW_II_I_360"><rs type="fn" role="issuer"><rs type="person" ref="#pe__peter_golnhofer_QGW_II_I_309">Peter der Golnhover</rs></rs>
                  <triggerstring n="disp">verkauft</triggerstring> vor rechter êhafter not wegen der
                  Schulden, die ihm <rs type="person" ref="#pe__margarethe_QGW_II_I_309">seine Frau
                     Margret <roleName type="dead">hinterlassen hatte</roleName></rs>, zwei
                  Weingärten, a) <rs type="fn" role="other"><triggerstring n="fn">mit
                        Handen</triggerstring> seines <rs type="person" ref="#pe__johann_von_hausbach_QGW_II_I_360"><roleName type="title">Bergherrn</roleName>
                        <roleName type="title">pruder</roleName> Chunrats von Hauspach, <roleName type="occ" corresp="#org__wien-johanniter">comiteur</roleName> des hauses
                        sand Johans in der Chaernerstrasse ze Wienne</rs></rs> , seinen Weingarten,
                  der da leit ze Engelschalichstorf an Prunnerperg und haisst der Ölachter, zenaehst
                  und der weingarten, gehaissen der Marschalich, der da leit niderthalb des wegs ,
                  von dem man jährlich 4 dn. zu Bergrecht dient, b) <rs type="fn" role="other"><triggerstring n="fn">mit seines Bergherrn Handen</triggerstring>
                     <rs type="person" ref="#pe__andreas_von_mannswoerth_QGW_II_I_360"><roleName type="title"><add>Bergherrn</add></roleName>
                        <roleName type="title">hern</roleName> Andres von Manswerde</rs></rs> seinen
                  Weingarten, gelegen daselbens ze Engelschalichstorf an Prunnerperg und haisst der
                  Marschalich, zenaehst dem weingarten, der da haisset der Hesner , von dem man
                  jährlich 8 Eimer Wein zu Bergrecht dient, um 150 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__konrad_herrscheftel_QGW_II_I_447"><roleName type="title">hern</roleName> Chunraden dem Herschaeftlein,
                           <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                        Wienne</rs></rs>, <rs type="event" ref="#ev__QGW_II_I_360a"><rs type="fn" role="issuer"><rs type="person" ref="#pe__konrad_herrscheftel_QGW_II_I_447"><add><roleName type="title">hern</roleName> Chunraden dem
                              Herschaeftlein, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienne</add></rs></rs> der sie seiner <rs type="fn" role="recipient"><rs type="person" ref="#pe__katharina_QGW_II_I_360"><roleName type="kin" corresp="#pe__konrad_herrscheftel_QGW_II_I_447">Frau</roleName>
                           Katrein</rs></rs> zu rechter Morgengabe gibt</rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_360"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="person" ref="#pe__peter_golnhofer_QGW_II_I_309">1. des
                        Ausstellers</rs>, <rs type="person" ref="#pe__johann_von_hausbach_QGW_II_I_360">2. <add>der
                     Bergherren</add></rs>, <rs type="person" ref="#pe__andreas_von_mannswoerth_QGW_II_I_360">3. der Bergherren</rs>,
                     ferner seiner <rs type="person" ref="#pe__leopold_poltz_QGW_II_I_776"><roleName type="kin" corresp="#pe__peter_golnhofer_QGW_II_I_309">Schwäger</roleName>, 4. <roleName type="title">hern</roleName> Leupolts des
                        Poltzs</rs>, <rs type="person" ref="#pe__heinrich_poltz_QGW_II_I_186">5.
                        Hainreichs des Poltzs <roleName type="kin" corresp="#pe__peter_golnhofer_QGW_II_I_309"><add>Schwäger</add></roleName></rs>, <rs type="person" ref="#pe__heinrich_von_der_neisse_QGW_II_I_459">6. Hainreichs von der
                        Neiz/zz/ze <roleName type="kin" corresp="#pe__peter_golnhofer_QGW_II_I_309"><add>Schwäger</add></roleName></rs>, endlich <rs type="person" ref="#pe__haunold_schuchler_QGW_II_I_170">7. <roleName type="title">hern</roleName> Haunolts des Schu/echler</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>