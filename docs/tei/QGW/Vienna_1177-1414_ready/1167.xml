            <origDate instant="false">ze Wienn, an Allerheiligen abende.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01167_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01167_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="#ev__QGW_II_I_1167"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_von_schiltern_QGW_II_I_1167">Hanns <roleName type="kin" corresp="#pe__georg_von_schiltern_QGW_II_I_1167"><add>gebrüder</add></roleName>
                        <add>von Schiltarn</add></rs> und <rs type="person" ref="#pe__georg_von_schiltern_QGW_II_I_1167">Jörg, <roleName type="kin" corresp="#pe__johann_von_schiltern_QGW_II_I_1167">gebrüder</roleName> von
                     Schiltarn</rs></rs>, <triggerstring n="disp">Urkunden wegen des
                     Hauses</triggerstring>, das weiln des Herrscheftleins gewesen ist, gelegen mit dem
                  Vordern tail in der Kernerstrasse ze Wienn und mit dem hindern tail an dem
                  Neunmarkt, an ainem tail zenechst der geistleichen herren haus von dem
                  Heiligengeist und an dem andern tail zenechst dem haus, das weilnt Philipps
                  seligen des Chaltenweins gewesen ist, von dem man in das Bürgerspital 5 sh. dn. zu
                  Burgrecht dient, und auf welchem hern Ulreichs des Pollen erben 100 lb dn. gehabt
                  habent. Auf demselben Hause hatte ihres <rs type="person" ref="#pe__anna_QGW_II_I_1167_i"><rs type="person" ref="#pe__ruediger_von_schiltern_QGW_II_I_1167"><roleName type="kin" corresp="#pe__johann_von_schiltern_QGW_II_I_1167">Bruders</roleName>
                        <roleName type="kin" corresp="#pe__georg_von_schiltern_QGW_II_I_1167"><add>Bruders</add></roleName> Rugers von Schiltarn <roleName type="dead"><add>Witwe</add></roleName></rs>
                     <roleName type="dead">frühere</roleName>
                     <roleName type="kin" corresp="#pe__ruediger_von_schiltern_QGW_II_I_1167">frühere
                        Hausfrau</roleName> Anna, <rs type="person" ref="#pe__ulrich_poll_QGW_II_I_1167"><roleName type="title">hern</roleName> Ulreichs des Pollen</rs>
                     <roleName type="kin" corresp="#pe__ulrich_poll_QGW_II_I_1167">tochter</roleName></rs>, 200
                  lb dn., welche die <rs type="fn" role="recipient"><rs type="person" ref="#pe__anna_QGW_II_I_1167_ii">zweite Frau Rugers, <roleName type="kin" corresp="#pe__ruediger_von_schiltern_QGW_II_I_1167"><add>Witwe</add></roleName> Anna,
                           <rs type="person" ref="#pe__siegfried_verber_QGW_II_I_1167">Seifrids des <roleName type="prof" cert="unknown">Verber</roleName>
                           <add>von Neunburch</add></rs>
                        <roleName type="kin" corresp="#pe__siegfried_verber_QGW_II_I_1167">tochter</roleName> von
                        Neunburch <roleName type="kin" corresp="#pe__peter_pehem_QGW_II_I_1080"><add>eleichen</add></roleName></rs></rs>, zurückgezahlt hatte. Nach
                  ihres Bruders Tode <triggerstring n="disp">verkaufen</triggerstring> sie nunmehr <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__michael_geukramer_QGW_II_I_1137"><roleName type="title">hern</roleName> Michels des Geuchramer, <roleName type="occ" corresp="#org__wien">purgermaister</roleName> und <roleName type="occ" corresp="#org__oesterreich-herzogtum" select="#pl__wien">münzmaister</roleName></rs>, und des <rs type="org" ref="#org__wien">rates gemain der stat ze Wienn</rs></rs>
                  <triggerstring n="disp">ihren Erbanspruch</triggerstring> um 70 lb dn. der Witwe, die nu
                     <rs type="person" ref="#pe__peter_pehem_QGW_II_I_1080">Petrein den Pehem</rs> eleichen genomen
                  hat.</rs></p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1167"><rs type="fn" role="witness">Besiegelt : 1.,
                     2. mit den Siegeln der <rs type="person" ref="#pe__johann_von_schiltern_QGW_II_I_1167"><add>Aussteller</add></rs>
                     <rs type="person" ref="#pe__georg_von_schiltern_QGW_II_I_1167">Aussteller</rs>, 3. mit dem <rs type="org" ref="#org__wien">städtischen Grundsiegel</rs>, 4. dem Siegel des
                        <rs type="person" ref="#pe__heinrich_wuerfel_QGW_II_I_1049">Wiener <roleName type="occ" corresp="#org__wien">Bürgers</roleName> Hainreichs des
                        Würfels</rs></rs>.</rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>