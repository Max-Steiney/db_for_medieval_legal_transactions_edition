               <rs type="event" ref="#ev__QGW_II_I_794"><rs type="fn" role="issuer"><rs type="person" ref="#pe__thomas_deckenschaden_QGW_II_I_794">Thoman der Dechenschaden, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienn</rs></rs>
