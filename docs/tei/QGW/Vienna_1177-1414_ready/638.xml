               <rs type="event" ref="#ev__QGW_II_I_638"><rs type="fn" role="issuer"><rs type="person" ref="#pe__anna_QGW_II_I_638"><roleName type="title">Swester</roleName> Ann
                        die U/erfarrin, <roleName type="occ" corresp="#org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">aptessin</roleName> in sand Niclas chloster var Stubentar ze Wienn</rs>,
                     und <rs type="org" ref="#org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">der convent
                        gemain daselbs</rs></rs>
                  <triggerstring n="disp">geben nach dem Gebote Herzog Rudolfs IV.</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="#pe__konrad_QGW_II_I_638">Chunraden, <rs type="person" ref="#pe__schencenmarcht_QGW_II_I_638">des
