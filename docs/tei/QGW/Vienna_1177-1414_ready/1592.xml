                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__konrad_vorlauf_QGW_II_I_1320"><roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName>
