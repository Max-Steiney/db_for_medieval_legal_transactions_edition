                           ><add>Aussteller</add></rs><rs type="person"
                        ref="#pe__johann_ziernast_QGW_II_I_1371"><add>Aussteller</add></rs><rs
                        type="person" ref="#pe__michael_menschein_QGW_II_I_1218"
                           ><add>Aussteller</add></rs><rs type="person"
                        ref="#pe__martin_hausleitter_QGW_II_I_1234"><add>Aussteller</add></rs><rs
                        type="person" ref="#pe__bernhard_hauenstainer_QGW_II_I_1404"
                           ><add>Aussteller</add></rs><rs type="person"
                        ref="#pe__ulrich_herwart_QGW_II_I_1098">Ausstellern</rs>.</rs></rs>
            </p>
