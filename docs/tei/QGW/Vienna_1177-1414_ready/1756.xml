         <div type="abstract" resp="cs">
            <p>
               <rs type="event" ref="#ev__QGW_II_I_1756"><rs type="fn" role="issuer"><rs
                        type="person" ref="#pe__leb_nussdorfer_QGW_II_I_1752">Leb der
                           Nusdorfer<roleName type="occ" corresp="#org__perchtoldsdorf"
                              ><add>rat</add></roleName><roleName type="occ" corresp="#org__perchtoldsdorf"><add>purger</add></roleName></rs>, <rs
                        type="person" ref="#pe__johann_poelzl_QGW_II_I_1646">Hanns der
                           Pollczl<roleName type="occ" corresp="#org__perchtoldsdorf"
                           ><add>rat</add></roleName><roleName type="occ" corresp="#org__perchtoldsdorf"><add>purger</add></roleName></rs>,<rs
                        type="person" ref="#pe__bernhard_haug_QGW_II_I_1749"> Wernhart der
                           Haug<roleName type="occ" corresp="#org__perchtoldsdorf"
                           ><add>rat</add></roleName>,</rs>
                     <rs type="person" ref="#pe__niklas_desendel_QGW_II_I_1756">Niclas der alt
                        Desendel </rs>und <rs type="person"
                        ref="#pe__niklas_sauberhart_QGW_II_I_1756">Niclas der Sauberhart, all
                           <roleName type="occ" corresp="#org__perchtoldsdorf"
                           >purger</roleName> und des <roleName type="occ"
                           corresp="#org__perchtoldsdorf">rates</roleName> ze
                     Perichtoltczdorf</rs></rs> , <triggerstring n="disp">beurkunden</triggerstring> die
                  von ihnen in dem Streite zwischen <rs type="fn" role="recipient"><rs type="person"
                        ref="#pe__agnes_QGW_II_I_1756"><roleName type="title">fraun</roleName>
                        Angnesen der Gabliczerin</rs> und <rs type="person"
                        ref="#pe__barbara_QGW_II_I_1756">ihrer <roleName type="kin"
                           corresp="#pe__agnes_QGW_II_I_1756">Tochter</roleName> Barbare, Ruegern des
                        Rarvogel <roleName type="kin" corresp="#pe__ruediger_rarvogel_QGW_II_I_1756"
                           >hausfrau</roleName>,</rs>
                  </rs>über das von Hanns dem Gabliczer zurückgelassene fahrende Gut <triggerstring
                     n="disp">gefällte Entscheidung</triggerstring>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_1756"><rs type="fn" role="witness">Besiegelt von
                     den drei erstgenannten <rs type="person" ref="#pe__leb_nussdorfer_QGW_II_I_1752"
                        >Ausstellern</rs>
                     <rs type="person" ref="#pe__johann_poelzl_QGW_II_I_1646"
                        ><add>Aussteller</add></rs><rs type="person"
                        ref="#pe__bernhard_haug_QGW_II_I_1749"><add>Aussteller</add></rs>.</rs></rs>
            </p>
