    <text>
        <body>
            <div type="abstract" resp="ks">
                <p>
                    <rs type="event" ref="#ev__QGW_II_I_216"><rs type="fn" role="issuer"><rs
                                type="person" ref="#pe__elisabeth_QGW_II_I_216">Elspet, <roleName
                                    type="kin" corresp="#pe__konrad_methsieder_QGW_II_I_216"
                                    >wittibe</roleName>
                                <rs type="person" ref="#pe__konrad_methsieder_QGW_II_I_216">Chunrates
                                        <roleName type="dead">wittibe</roleName> des
                                metsieder</rs></rs>,</rs>
                        <triggerstring n="disp">verkauft</triggerstring>
                        <rs type="fn" role="other"><triggerstring n="fn">nach Rath</triggerstring> des <rs
                                type="person" ref="#pe__heinrich_QGW_II_I_216"><roleName type="occ"
                                    corresp="#org__wien-schotten">Schottenabtes</roleName>
                                Hainreich</rs></rs> und <rs type="fn" role="other"><triggerstring
                                n="fn">mit Handen</triggerstring> ihrer <rs type="person"
                                ref="#pe__albrecht_von_hohenberg_II_QGW_II_I_216"><roleName
                                    type="title">Grundherren</roleName> ( <roleName type="title"
                                    >graf</roleName> Albrechts von Hohenwerch, <roleName type="occ"
                                    corresp="#org__wien-st_stephan">pharrer</roleName> datz sand
                                Stephan zu Wienne</rs>, <rs type="person"
                                ref="#pe__jakob_maeserl_QGW_II_I_121"><roleName type="title"
                                        ><add>Grundherren</add></roleName>
                                <roleName type="title">hern</roleName> Jacobes des Maeserlein,
                                    <roleName type="occ" corresp="#org__wien-buergerspital">obrister
                                    spitalmaister</roleName> der purger Spital ze Wienne</rs> und
                                <rs type="person" ref="#pe__herbert_auf_der_saeule_QGW_II_I_184"
                                    ><roleName type="title"><add>Grundherren</add></roleName>
                                <roleName type="title">hern</roleName> Herworts auf der Seule
                            )</rs></rs> ihres rechten ledigen Burgrechts 11 lb dn., die sie
                        wittibenweise gekauft hatte, wovon 5 lb dn. geltes ligent auf Leutoldes
                        haus, des Wolfes sun von Radaun, pei Werdertor, das sie früher besessen
                        hatte, und 6 lb dn. gelts purchrechts auf Stephans hause des Pophinger in
                        der Wollzeil, das weiln und e Dietmares des Rauber gewesen ist , um 99 lb
                        dn. <rs type="fn" role="recipient"><rs type="person"
                                ref="#pe__dietrich_urbetsch_QGW_II_I_950"><roleName type="title"
                                    >hern</roleName> Dietreichen dem Urbetschen, <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                                Wienne</rs>, und seiner <rs type="person"
                                ref="#pe__elisabeth_QGW_II_I_386"><roleName type="kin"
                                    corresp="#pe__dietrich_urbetsch_QGW_II_I_950">Hausfrau</roleName>
                                Elspet</rs></rs>.</rs>
                </p>
            </div>
            <div type="seal">
                <p><rs type="event" ref="#ev__QGW_II_I_216"><rs type="fn" role="witness">Besiegelt
                            mit den Siegeln des <rs type="person" ref="#pe__heinrich_QGW_II_I_216"
                                >Schottenabtes</rs> und der <rs type="person"
                                ref="#pe__albrecht_von_hohenberg_II_QGW_II_I_216">Grundherren</rs>
                            <rs type="person" ref="#pe__jakob_maeserl_QGW_II_I_121"
                                    ><add>Grundherren</add></rs>
                            <rs type="person" ref="#pe__herbert_auf_der_saeule_QGW_II_I_184"
                                    ><add>Grundherren</add></rs>.</rs></rs>
                </p>
            </div>
