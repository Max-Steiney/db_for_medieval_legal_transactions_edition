                  <triggerstring n="disp">entscheiden einen vor sie gebrachten Streit</triggerstring>
                     zwischen<rs type="fn" role="other">
                     <rs type="person" ref="#pe__jedung_sluerf_QGW_II_I_61">Jedung dem Sluerfe</rs>
