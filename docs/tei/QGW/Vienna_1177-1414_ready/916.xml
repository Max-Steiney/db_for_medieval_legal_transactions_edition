            <origDate instant="false">ze Wienn, an sant Cholmans tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00916_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00916_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_916"><rs type="fn" role="issuer"><rs type="person" ref="#pe__jakob_poll_QGW_II_I_770">Jacob der Poll, <roleName type="occ" corresp="#org__wien-st_maria_im_rathaus">caplan</roleName>
                        <roleName type="rep" corresp="#pe__leonhard_poll_QGW_II_I_1152">
                           <add>ausrichter des geschefts</add></roleName></rs> Unser Vrown chapelln,
                     gelegen in der purger Rathaus ze Wienn, hern Ottenhaimen seligen Stiftung , <rs type="person" ref="#pe__paul_holzkaeufel_QGW_II_I_1010">Paul der Holzchäuffel, <roleName type="occ" corresp="#org__wien">purgermaister</roleName> ze Wienn
                           <roleName type="rep" corresp="#pe__leonhard_poll_QGW_II_I_1152">
                           <add>ausrichter des geschefts</add></roleName></rs> , und <rs type="person" ref="#pe__niklas_von_der_schemnitz_iii_QGW_II_I_1371">Niclas der Schebnitzer,
                           <roleName type="occ" corresp="#org__wien">purger ze Wienn</roleName>
                        <roleName type="rep" corresp="#pe__leonhard_poll_QGW_II_I_1152">
                           <add>ausrichter des geschefts</add></roleName></rs></rs> , <triggerstring n="disp">beurkunden</triggerstring>, dass sie als ausrichter des geschefts, das
                  Lienhart der Polle geschafft hat, <rs type="fn" role="other"><triggerstring n="disp">mit Handen</triggerstring> des <rs type="person" ref="#pe__peter_lenhofer_QGW_II_I_1001"><roleName type="title">Bergherrn</roleName>
                        <roleName type="title">hern</roleName> Petreins des Leenhofer, <roleName type="occ" corresp="#org__klosterneuburg-augustiner_chorherren">chorherr
                           und obrister chelner</roleName> des chlosters ze Neunburch</rs></rs> ,
                     <rs type="fn" role="recipient">dem <rs type="person" ref="#pe__weichart_von_zistersdorf_QGW_II_I_798"><roleName type="prof">Priester</roleName>
                        <roleName type="title">hern</roleName> Weikcharten von Zistesdorf ,
                           <roleName type="occ" corresp="#org__wien-st_philipp_und_st_jakob_kapelle-altar_st_maria-messe_leonhard_poll_QGW_II_I_889_a">Kaplan</roleName></rs> der von Lienhart dem Poll auf Unser Vrown altar
                     in der abseiten in sant Philipps und sant Jacobs chapelln</rs>, gelegen in
                  weilnt seinem haus in der Hindern Pekchenstrass ze Wienn , gestifteten Messe, ein
                  halbes Joch Weingarten, haisset der Ger, gelegen ze Challnperg an dem Purchstal,
                     <triggerstring n="disp">eingeantwortet haben</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_916"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="person" ref="#pe__jakob_poll_QGW_II_I_770">1. <add>Aussteller</add></rs>
                     <rs type="person" ref="#pe__paul_holzkaeufel_QGW_II_I_1010">2.</rs> - <rs type="person" ref="#pe__niklas_von_der_schemnitz_iii_QGW_II_I_1371">3. der Aussteller</rs>, 4. des <rs type="person" ref="#pe__peter_lenhofer_QGW_II_I_1001">Bergherrn</rs>.</rs></rs>
            </p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>