   <text>
      <body>
         <div type="abstract" resp="ks">
            <p>
               <rs type="event" ref="#ev__QGW_II_I_384"><rs type="fn" role="issuer"><rs type="person"
                        ref="#pe__thomas_swaeml_QGW_II_I_1012">Toman der Swemmel, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienne</rs>,
                     und <rs type="person" ref="#pe__christine_QGW_II_I_384">Christein, seine
                           <roleName type="kin" corresp="#pe__thomas_swaeml_QGW_II_I_1012"
                           >Hausfrau</roleName></rs></rs>, <triggerstring n="disp">setzen <add>ze
                        rechter ebenteuer</add></triggerstring> über das Haus, das sie Trautmanne, dem
                  ledrer, und seiner Hausfrau Annen verkauft haben, <rs type="fn" role="other"
                        ><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__heinrich_meter_QGW_II_I_384"><roleName type="occ"
                           corresp="#org__tulln-dominikanerinnen">maister</roleName> Hainreiches des
                        Meter, des <roleName type="prof">pogner</roleName> ze Wienne, der vrowen
                           <roleName type="occ" corresp="#org__tulln-dominikanerinnen"
                           >amptman</roleName> von Tuln</rs></rs>, ze rechter ebenteuer <rs
                     type="fn" role="recipient"><rs type="person"
                        ref="#pe__trautmann_lederer_QGW_II_I_384"><add>Trautmanne, dem</add>
                        <roleName type="prof"><add>ledrer</add></roleName></rs><add>, und
                        seiner</add>
                     <rs type="person" ref="#pe__anna_QGW_II_I_384"><roleName type="kin"
                           corresp="#pe__trautmann_lederer_QGW_II_I_384"
                           ><add>Hausfrau</add></roleName>
                        <add>Annen</add></rs></rs> ein Joch Weingarten, gelegen ze To/eblich in den
                  Setzen zenaehst Tomans weingarten von Medlich, dovon man alle iar dient den vrowen
                  von Tulln drei emmer weins ze perchrecht und drei phening ze voitrecht .</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_384"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="#pe__thomas_swaeml_QGW_II_I_1012"
                        >Ausstellers</rs>, 2. <rs type="person"
                        ref="#pe__heinrich_meter_QGW_II_I_384">maister Hainreichs des Meter, des
                        pogner</rs>, 3. <rs type="person"
                        ref="#pe__niklas_in_der_scheffstraße_QGW_II_I_450"><roleName type="title"
                           >hern</roleName> Niclas in der Schefstrasse, <roleName type="occ"
                           corresp="#pe__johanna_von_pfirt_QGW_II_I_304">amptman</roleName> der
                        Herzogin Johanna.</rs></rs></rs>
            </p>
         </div>
