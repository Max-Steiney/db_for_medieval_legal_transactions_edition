            <date when="13520928">1352 IX 28</date>
            <origDate instant="false">ze Wienne, an sant Michels abent.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00415_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00415_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p><rs type="event" ref="#ev__QGW_II_I_415">
                  <rs type="fn" role="issuer"><rs type="person" ref="#pe__stephan_neuburg_QGW_II_I_415">Stephan der Neunburger</rs> und <rs type="person" ref="#pe__kunigunde_QGW_II_I_415">Chunigunt, seine <roleName type="kin" corresp="#pe__stephan_neuburg_QGW_II_I_415">
                           Hausfrau</roleName></rs></rs>, <triggerstring n="disp">geben 3 ½ lb dn.
                     gelts purchrechts</triggerstring>, <rs type="event" ref="#ev__QGW_II_I_415_men_1">welche <rs type="person" ref="#pe__kunigunde_QGW_II_I_415">Kunigunde</rs> und
                     ihr unmündiger<rs type="person" ref="#pe__hermann_QGW_II_I_895">
                        <roleName type="kin" corresp="#pe__kunigunde_QGW_II_I_415">Sohn</roleName>
                        Hermann</rs> aus <rs type="person" ref="#pe__heinrich_stadtschreiber_QGW_II_I_415">ihrer ersten <roleName type="kin" corresp="#pe__kunigunde_QGW_II_I_415">Ehe</roleName> mit
                        Hainreichen, dem statschreiber</rs>, auf Michels haus des Pollen, das da
                     leit in der Wiltwu/ercherstrasse ze Wienne an dem ekk gegen der widerm dacz
                     hern Otten Haim über an ainem tail und an dem andern tail zenaechst hern
                     Ulreichs haus des Pollen , haben</rs>, um 35 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__michael_poll_QGW_II_I_440">Micheln
                        dem Pollen</rs> und <rs type="person" ref="#pe__elisabeth_QGW_II_I_415">seiner<roleName type="kin" corresp="#pe__michael_poll_QGW_II_I_440">
                           Hausfrau</roleName> Elsbeten</rs></rs> abzulösen und <triggerstring n="disp">legen</triggerstring> dafür 3 ½ lb dn. Geldes Burgrechts<rs type="fn" role="other">
                     <triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__leopold_von_sachsengang_QGW_II_I_452">ihres
                           <roleName type="title">Grundherrn</roleName>
                        <roleName type="title">hern</roleName> Leupolts von Sachssenkange, <roleName type="occ" corresp="#org__wien-st_stephan">pharrer</roleName> dacz sand
                        Stephan ze Wienne</rs></rs>, <triggerstring n="disp">als
                     Leibgedinge</triggerstring>
                  <rs type="event" ref="#ev__QGW_II_I_415_men_2">für Frau Kunigund und nach ihrem
                     Ableben als Erbe für Hermann auf ihrem Hause an, das da leit in der
                     Su/onhingerstrasse ze Wienne gegen den Taeutschen Herren über zenaechst der
                     Löfflerin haus , das sie um 97 lb dn. von Jansen dem Illsunch gekauft haben,
                     und von dem man jährlich dem Pfarrer von S. Stephan 3 1/2 sh. dn. Grundrecht
                     und den Deutschen Herren in der Neustadt 10 lb dn. Burgrecht</rs> dient.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_415"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="#pe__leopold_von_sachsengang_QGW_II_I_452">des Grundherrn</rs>, 2. <rs type="person" ref="#pe__friedrich_von_tierna_QGW_II_I_1106"><roleName type="title">hern</roleName> Fridreichs von Tierna, <roleName type="occ" corresp="#org__wien">purgermaister</roleName> ze
                        Wienne</rs>, 3.<rs type="person" ref="#pe__heinrich_wuerfel_QGW_II_I_459"><roleName type="title"> hern </roleName>Hainreichs des
                     Würffels</rs>.</rs>
               </rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>