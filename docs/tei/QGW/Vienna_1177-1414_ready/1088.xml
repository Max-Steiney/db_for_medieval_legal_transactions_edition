            <origDate instant="false">ze Wienn, des nächsten montags vor Gotzleichnams tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01088_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01088_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1088"><rs type="fn" role="issuer"><rs type="person" ref="#pe__stephan_leitner_QGW_II_I_1012">Stephan der Leitner <roleName type="occ" corresp="#org__wien"><add>Ratsherr</add></roleName></rs> und
                        <rs type="person" ref="#pe__konrad_rokk_QGW_II_I_1031">Chunrat der Rokk, baid des <roleName type="occ" corresp="#org__wien">rates der stat ze
                     Wienn</roleName></rs></rs>, <triggerstring n="disp">beurkunden <add>,
                     dass</add></triggerstring>, dass <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_goll_QGW_II_I_1088">Janns Go/ell</rs>, <rs type="person" ref="#pe__ludwig_QGW_II_I_1088">Ludweig <roleName type="prof" cert="unknown">Rostauscher</roleName></rs>, <rs type="person" ref="#pe__ulrich_angelpekch_QGW_II_I_1088">Ulreich Angelpekch</rs>,.. der <rs type="person" ref="#pe__litschauer_QGW_II_I_1088">Litschauer</rs> und <rs type="person" ref="#pe__johann_pruemaister_QGW_II_I_1088">Jans der <roleName type="prof" cert="unknown">Pruemaister</roleName></rs></rs> vor dem Rathe <triggerstring n="disp">darüber Klage geführt haben</triggerstring>, <rs type="person" ref="#pe__paul_wagendruessel_QGW_II_I_1064">Paul der Wogendrüz/zz/zel</rs> ein rinnen aus
                  seiner padstuben, gelegen an dem Alten Fleischmarcht ze Wienn hiet, darinne das
                  wasser von derselben padstuben und ander unflat, der nicht ziemleich ze nennen
                  wer, für ireu häuser flu/ess . <triggerstring n="disp">Als vom Rathe bestellte
                     Beschauer entscheiden sie</triggerstring> dahin, dass Paul der Wogendrüz/zz/zel
                  das wasser von seiner padstuben under der erden verdakchtes furn sol unz für
                  Chunrats haus des Payrs und denn fürbass in einem offenn graben für den
                  Piberstu/orn durich die Parkanmaur ous unz in die Tuenau , und dass diesen Graben
                  nicht verunreinigen, noch den Ablauf des Wassers irgendwie hindern dürfe.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1088"><rs type="fn" role="witness">Besiegelt von
                     den <rs type="person" ref="#pe__stephan_leitner_QGW_II_I_1012">Ausstellern</rs>
                     <rs type="person" ref="#pe__konrad_rokk_QGW_II_I_1031"><add>Aussteller</add></rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>