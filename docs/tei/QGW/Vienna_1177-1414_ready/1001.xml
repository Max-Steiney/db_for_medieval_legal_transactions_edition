            <date from="99999999" to="99999999"/>
            <origDate instant="false">des nechsten montags vor sant Philipps und sant Jacobs tag, der
               zwelifpoten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01001_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01001_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1001"><rs type="fn" role="issuer"><rs type="person" ref="#pe__peter_lenhofer_QGW_II_I_1001">Peter der Lenhofer,
                           <roleName type="occ" corresp="#org__klosterneuburg-augustiner_chorherren">chorherr</roleName>
                        und <roleName type="occ" corresp="#org__klosterneuburg-augustiner_chorherren">obrister
                           cheller</roleName> des chlosters ze Neunburch</rs></rs> , <triggerstring n="disp">beurkundet, dass vor ihm in offenem Gerichte</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="#pe__johann_QGW_II_I_1001">Janns,
                        des <rs type="person" ref="#pe__niklas_wuerfel_QGW_II_I_1001"><roleName type="title">erbern</roleName>
                           <roleName type="title">vesten</roleName>
                           <roleName type="title">ritter</roleName>
                           <roleName type="title">hern</roleName> Niclas des Würffels</rs>
                        <roleName type="occ" corresp="#pe__niklas_wuerfel_QGW_II_I_1001">schaffer</roleName>, <triggerstring n="fn">mit Vorsprechen</triggerstring>
                        <roleName type="rep" corresp="#pe__niklas_wuerfel_QGW_II_I_1001">an seines
                           Herrn Statt</roleName></rs></rs> auf Petreins hof des Popphinger, gelegen
                  ze Otakchrinn, der weilnt des Starichants gewesen war, um 60 lb dn. <triggerstring n="disp">versessens diensts und die darauf ertheilten zwispild geklagt
                     habe</triggerstring>. Er <triggerstring n="disp">gibt</triggerstring> dem Kläger anstatt
                  seines Herrn die vier, <rs type="fn" role="other"><rs type="person" ref="#pe__otto_hoerner_QGW_II_I_1001">Otten den Ho/erner
                     </rs>, <rs type="person" ref="#pe__konrad_oedler_QGW_II_I_1001">Chu/enraten den
                        O/edler </rs>, <rs type="person" ref="#pe__ulrich_schuler_QGW_II_I_1001">Ulreichen den Schu/eler </rs> und <rs type="person" ref="#pe__konrad_schoenprot_QGW_II_I_1001">Chu/enraten den Scho/enprot </rs>,
                     all gesessen ze Otakchrinn , <triggerstring n="fn">als Beschauleute
                        mit</triggerstring></rs> und <triggerstring n="disp">macht ihn <add>des Hofes
                        gewaltig</add></triggerstring> nach deren Aussage anstatt seines Herrn des
                  Hofes gewaltig. </rs></p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1001"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="#pe__peter_lenhofer_QGW_II_I_1001">Aussteller</rs>.</rs></rs></p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>