          <rs type="event" ref="#ev__QGW_II_I_367"><rs type="fn" role="issuer"><rs type="person" ref="#pe__ulrich_von_enzersdorf_QGW_II_I_367"><roleName type="title">Pruder</roleName> Ulreich von Enzeinstorf, <roleName type="occ" corresp="#org__wien-dominikaner">prior</roleName> in der Prediger chloster ze
                Wienne</rs>, und <rs type="org" ref="#org__wien-dominikaner">der convent gemain in
                demselben chloster</rs> und <rs type="person" ref="#pe__adelheit_QGW_II_I_367"><roleName type="title">swester</roleName> Alhait die Lengpekchinne, <roleName type="occ" corresp="#org__wien-st_laurenz_am_alten_fleischmarkt">priorinne</roleName> in sande Larenzen chloster ze Wienne</rs>, und <rs type="org" ref="#org__wien-st_laurenz_am_alten_fleischmarkt">der convent gemain in
                demselben chloster</rs> und <rs type="person" ref="#pe__ruediger_wenig_QGW_II_I_367">Rueger, des <rs type="person" ref="#pe__leopold_wenig_QGW_II_I_320">Wenigen hern
                  Leupolts</rs>
                <roleName type="kin" corresp="#pe__leopold_wenig_QGW_II_I_320">sun</roleName>,
                  <roleName type="occ" corresp="#org__wien">purger</roleName> ze
              Wienne</rs></rs> , <triggerstring n="disp">bestätigen</triggerstring>, dass <rs type="fn" role="recipient"><rs type="person" ref="#pe__niklas_von_ragelsdorf_QGW_II_I_1107">Niclas von Raechleinstorf <roleName type="rep" corresp="#pe__elisabeth_QGW_II_I_367"><add>in Ausführung</add></roleName></rs></rs>
            <rs type="event" ref="#ev__QGW_II_I_367_men_1">in Ausführung des in Gegenwart des <rs type="person" ref="#pe__albrecht_QGW_II_I_367">Dominikaners <roleName type="title">pruder</roleName> Albrechts</rs> und <rs type="person" ref="#pe__ruediger_wenig_QGW_II_I_367"><roleName type="title">hern</roleName>
                Ruegers</rs> vorgenommenen Geschäftes der <rs type="person" ref="#pe__elisabeth_QGW_II_I_367"><roleName type="title">Frau</roleName> Elspet,
                weilnt <roleName type="occ" corresp="#pe__christine_QGW_II_I_327"><add>schafferinne</add></roleName><rs type="person" ref="#pe__christine_QGW_II_I_327"><roleName type="title">vrown</roleName> Christein
                  schafferinne der Puchserinne</rs></rs>, dem Predigerkloster 19 lb dn. zur
              Abhaltung eines Jahrtages und zum Lesen von 30 Messen, dem Kloster S. Laurenz 5 lb dn.
              zu einer Romfart und ihrem <rs type="person" ref="#pe__heinrich_QGW_II_I_367"><roleName type="occ" corresp="#pe__elisabeth_QGW_II_I_367" cert="medium">Knechte</roleName>
                Hainreichen</rs> ½ lb dn. ausbezahlt habe</rs>.</rs>
