            <origDate instant="false">ze Wienne, an sant Philips und sant Jacobs tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00192_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00192_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="#ev__QGW_II_I_192"><rs type="fn" role="issuer"><rs type="person" ref="#pe__niklas_wittige_QGW_II_I_192">Nichlas der Wittige, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienne</rs>, und <rs type="person" ref="#pe__elisabeth_QGW_II_I_192">Elsbet, seine <roleName type="kin" corresp="#pe__niklas_wittige_QGW_II_I_192">Hausfrau</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="#pe__konrad_von_michaelbeuern_QGW_II_I_192"><roleName type="title">Bergherrn</roleName>, <roleName type="occ" corresp="#org__michaelbeuern-benediktiner">apt</roleName> Chunrades von
                        Peuern</rs></rs>, drei Viertel Weingarten, der da leit ze Waerich in dem
                  Gotshausperige zenaehst vron Chu/enigunden Weingarten von Hof (belastet mit 7 ½
                  Viertel Wein Bergrecht und zwen phenningen und ein ort ze voitrecht), um 80 lb dn.
                     <rs type="fn" role="recipient"><rs type="person" ref="#pe__siegfried_minnganch_QGW_II_I_192"><roleName type="title">hern</roleName> Seifriten dem Minnganch,
                           <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                        Wienne</rs>, und <rs type="person" ref="#pe__lucia_QGW_II_I_192">seiner<roleName type="kin" corresp="#pe__siegfried_minnganch_QGW_II_I_192">
                           Hausfrau</roleName> Lucei</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_192">Besiegelt von dem <rs type="fn" role="witness"><rs type="person" ref="#pe__niklas_wittige_QGW_II_I_192">Aussteller</rs>, <rs type="person" ref="#pe__konrad_von_michaelbeuern_QGW_II_I_192">dem Bergherrn</rs> und dem
                        <rs type="person" ref="#pe__niklas_jan_QGW_II_I_192"><roleName type="kin" corresp="#pe__niklas_wittige_QGW_II_I_192">Eidam</roleName> des Ausstellers Nichlas dem
                        Jann</rs></rs>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>