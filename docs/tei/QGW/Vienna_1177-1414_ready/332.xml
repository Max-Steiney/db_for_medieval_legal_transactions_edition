   <text>
      <body>
         <div type="abstract" resp="ks">
            <p>
               <rs type="event" ref="#ev__QGW_II_I_332"><rs type="fn" role="issuer"><rs type="person"
                        ref="#pe__stephan_schaerdinger_QGW_II_I_332">Stephan der Scherdinger von
                        Grinzing</rs> und <rs type="person" ref="#pe__katharina_QGW_II_I_332"
                        >Kathrei, seine <roleName type="kin"
                           corresp="#pe__stephan_schaerdinger_QGW_II_I_332"
                     >Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs
                        type="person" ref="#pe__heinrich_straiher_QGW_II_I_331"><roleName
                           type="title">Bergherrn</roleName><roleName type="title">hern</roleName>
                        Hainreichs des Straicher, <roleName type="occ"
                           corresp="#org__oesterreich-herzogtum" select="#pl__dornbach"
                           >hofmaister</roleName> ze Dornpach</rs></rs>, ein Joch Weingarten, der do
                  leit ze Dornpach in der Aue und haisst der Chelbel und leit zenest dem weingarten,
                  der weilnt maister Liepharts, des arczt, gewesen ist, dem got genade, <rs
                     type="event" ref="#ev__QGW_II_I_332_men_1">dovon man alle iar dient in den hof
                     ze Dornpach 60 dn. ze perchrecht und 3 dn. ze voitrecht</rs> , um 40 lb dn. <rs
                     type="fn" role="recipient"><rs type="person"
                        ref="#pe__haunold_schuchler_QGW_II_I_170"><roleName type="title"
                           >hern</roleName> Haunolten dem Schuchler, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienne</rs></rs>. [Die Kaufsumme
                  ist gleicher Herkunft wie in no 331.]</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_332"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="#pe__heinrich_straiher_QGW_II_I_331"
                        >Bergherrn</rs>, 2. <rs type="person"
                        ref="#pe__leopold_schuchler_QGW_II_I_332"><roleName type="title"
                           >hern</roleName> Leupolts des Schüchler, <roleName type="occ"
                           corresp="#org__wien">richter</roleName> ze Wienne</rs></rs>.</rs>
            </p>
         </div>
         <div type="nota">
            <p>Indorsat: Aufschrift des Magister Theodericus. K. </p>
         </div>
