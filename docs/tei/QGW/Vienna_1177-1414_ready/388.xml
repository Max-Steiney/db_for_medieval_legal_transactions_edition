               <rs type="event" ref="#ev__QGW_II_I_388"><rs type="fn" role="issuer"><rs type="person" ref="#pe__niklas_wuerfel_QGW_II_I_1001">Niclas der Würffel, <roleName type="occ" corresp="#org__wien">richter</roleName> ze Wienne</rs></rs>,
                     <triggerstring n="fn">spricht <add>frei</add></triggerstring> im Gerichte auf der
