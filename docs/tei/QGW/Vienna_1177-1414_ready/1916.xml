         <div type="abstract">
            <p>
               <rs type="event" ref="#ev__QGW_II_II_1916"><rs type="fn" role="issuer"><rs type="person" ref="#pe__wolfgang_purkchartsperger_QGW_II_I_1560">Wolfgang der
                        Purkcharczperger, <roleName type="occ" corresp="#org__wien">statrichter</roleName> ze Wienn</rs></rs>, <triggerstring n="disp">beurkundet, dass vor ihm in der Bürgerschranne</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="#pe__stephan_swebel_QGW_II_II_1916">Stephan Swebel</rs>
                     <triggerstring n="fn">mit Vorsprechen</triggerstring></rs>
                  <rs type="fn" role="other"><triggerstring n="fn">auf</triggerstring>
                     <rs type="person" ref="#pe__anna_QGW_II_II_1916"><roleName type="title">fraun</roleName> Annen, Hannsen des Chremser von Neundorf <roleName type="kin" corresp="#pe__johann_kremser_QGW_II_II_1916">hausfraun</roleName></rs>, und irer miterben haus, gelegen innerhalb
                     Stubentor ze Wienn, das weilnt Fridreichs des Reschen ist gewesen, zenechst
                     Hannsen haus des Makauer</rs> , um 60 lb dn., für die ihm nach Aussage des
                  Grundbuchs das Haus verpfändet war, <triggerstring n="disp">geklagt
                  habe</triggerstring>, und spricht dem <rs type="fn" role="recipient"><rs type="person" ref="#pe__wolfgang_purkchartsperger_QGW_II_I_1560">Kläger</rs></rs> das Haus zu.</rs>
            </p>
