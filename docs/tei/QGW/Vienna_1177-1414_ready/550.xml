               <rs type="event" ref="#ev__QGW_II_I_550"><rs type="fn" role="issuer"><rs type="person" ref="#pe__margarethe_QGW_II_I_278_b"><roleName type="title">Swester</roleName> Margret von Poungarten, <roleName type="occ" corresp="#org__tulln-dominikanerinnen">priorin</roleName> ze Tuln in dem
