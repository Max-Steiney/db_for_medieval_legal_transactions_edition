               <rs type="event" ref="#ev__QGW_II_I_417"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_von_ybbs_QGW_II_I_1033">Jans, <roleName type="occ" corresp="#org__ybbs">richter</roleName> ze Ibs</rs>, und <rs type="person" ref="#pe__margarethe_QGW_II_I_417_a">Margret, seine <roleName type="kin" corresp="#pe__johann_von_ybbs_QGW_II_I_1033">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__gerung_chol_QGW_II_I_417">ihres <roleName type="occ" corresp="#org__klosterneuburg-augustinerchorfrauen">Bergmeisters</roleName>
                        <roleName type="title">hern</roleName> Gerungs des Choln, <roleName type="occ" corresp="#org__klosterneuburg-augustinerchorfrauen">amptman</roleName> des gotshauses Unser Vrowen ze Neunburch
                        chlosterhalben</rs></rs>, <rs type="event" ref="#ev__QGW_II_I_417_men_1">ein
                     Viertel Weingarten an dem Nuz/zperch und haisset das Neue viertail, zenaechst
                     der gaestleichen herren weingarten von Zedlitz, der da haisset der
                     Chaufweingart , von dem man jährlich 2 ½ Viertel Wein zu Bergrecht und 3 Ort zu
                     Voitrecht dient, <rs type="event" ref="#ev__QGW_II_I_417_men_1">den <rs type="person" ref="#pe__margarethe_QGW_II_I_417_a">Margret von irem enen
                              <rs type="person" ref="#pe__hermann_von_st_poelten_QGW_II_I_118"><roleName type="kin" corresp="#pe__margarethe_QGW_II_I_417_a">hern</roleName>
                              <roleName type="dead"><add>enen</add></roleName> Hermann, <roleName type="kin" corresp="#pe__rudolfine_QGW_II_I_417"><add>enenchel</add></roleName><rs type="person" ref="#pe__rudolfine_QGW_II_I_417">der Rudolfinne enenchel von Sant
                                 Pölten</rs></rs></rs>, geerbt hatte, und der ihr gegen <rs type="person" ref="#pe__johann_von_st_poelten_QGW_II_I_417">seinem
                              <roleName type="kin" corresp="#pe__hermann_von_st_poelten_QGW_II_I_118">sun</roleName>
                           Jansen </rs>und gegen <rs type="person" ref="#pe__kunigunde_QGW_II_I_417">seiner <roleName type="kin" corresp="#pe__hermann_von_st_poelten_QGW_II_I_118">tochter</roleName>
                           <roleName type="title">vrowen</roleName> Chunigunden der Padnerin</rs>
                        und gegen seinem <rs type="person" ref="#pe__matthias_ploder_QGW_II_I_417"><roleName type="kin" corresp="#pe__hermann_von_st_poelten_QGW_II_I_118">eninchlein</roleName> Mathesen dem Ploder</rs> zugefallen war</rs>,
                     um 10 lb dn.</rs>
                  <rs type="fn" role="recipient"><rs type="person" ref="#pe__siegfried_reicholf_QGW_II_I_1242"><roleName type="title">hern</roleName> Seifriden, gesessen an des herzogen stat in der
                        Slagstuben ze Wienne</rs>, und <rs type="person" ref="#pe__margarethe_QGW_II_I_417_b">seiner<roleName type="kin" corresp="#pe__siegfried_reicholf_QGW_II_I_1242">Hausfrau</roleName>
                        Margreten</rs>.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_417"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="#pe__johann_von_ybbs_QGW_II_I_1033">des
                        Ausstellers</rs>, 2. <rs type="person" ref="#pe__gerung_chol_QGW_II_I_417">des Bergmeisters</rs> der Oheime der Margarethe, 3. <rs type="person" ref="#pe__johann_von_st_poelten_QGW_II_I_417">Jansen, <roleName type="kin" corresp="#pe__margarethe_QGW_II_I_417_a"><add>Oheime</add></roleName><roleName type="kin" corresp="#pe__hermann_von_st_poelten_QGW_II_I_118"><add>sun</add></roleName>
                        <rs type="person" ref="#pe__hermann_von_st_poelten_QGW_II_I_118"><roleName type="title">hern</roleName> Hermans sun</rs>,</rs> 4. <rs type="person" ref="#pe__matthias_ploder_QGW_II_I_417">Mathes des Ploder, <roleName type="kin" corresp="#pe__margarethe_QGW_II_I_417_a"><add>Oheime</add></roleName><roleName type="kin" corresp="#pe__hermann_von_st_poelten_QGW_II_I_118"><add>enenchel</add></roleName>
                        <rs type="person" ref="#pe__hermann_von_st_poelten_QGW_II_I_118"><roleName type="title">hern</roleName> Hermans enenchel</rs></rs>, und 5. <rs type="person" ref="#pe__lukas_popphinger_QGW_II_I_776"><roleName type="title">hern</roleName> Lucas des Popphinger, <roleName type="occ" corresp="#org__wien">hansgraf</roleName> ze Wienn</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>