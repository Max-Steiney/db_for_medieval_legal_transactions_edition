            <origDate instant="false">Gegeben nach Christes geburt 1300 jar darnach in dem 55. jar, an dem
               Ostertag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00462_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00462_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="#ev__QGW_II_I_462"><rs type="fn" role="issuer"><rs type="person" ref="#pe__gerlach_QGW_II_I_462"><roleName type="occ" corresp="#org__lilienfeld-zisterzienser">Apt</roleName> Gerlach</rs> und
                     der <rs type="org" ref="#org__lilienfeld-zisterzienser">convent gemain des
                        chlosters ze Liligenveld</rs></rs>
                  <triggerstring n="disp">bestätigen</triggerstring>, dass ihnen <rs type="event" ref="#ev__QGW_II_I_462_men_1"><rs type="person" ref="#pe__hugo_kaemmerer_QGW_II_I_340">
                        <roleName type="dead"><add>verstorben</add></roleName><roleName type="title">her</roleName> Haug, weilnt <roleName type="occ" corresp="#pe__friedrich_QGW_II_I_462">chamerer</roleName>
                        <rs type="person" ref="#pe__friedrich_QGW_II_I_462"><roleName type="occ" corresp="#org__heiliges_roemisches_reich">chunich</roleName> Fridreiches von Ram <roleName type="dead">saeligen</roleName></rs></rs>, und <rs type="person" ref="#pe__jutta_QGW_II_I_462">seine <roleName type="kin" corresp="#pe__hugo_kaemmerer_QGW_II_I_340">Hausfrau</roleName> Jeut
                           <roleName type="dead"><add>verstorben</add></roleName></rs> 3 lb dn.
                     gelts ewiges purchrechtes 12 sh. dn. geltes mit 4 dn. gruntrechts auf hern
                     Jansen haus von Prunn, gelegen ze Wienn in der Rotstrasse, das weiln hern
                     Pilgreim des Hesmer was, zenaechst Dietreichs haus des Neuenmaisters an zehen
                     zehen sh. dn. geltes gelegen in Chülber pharr auf Niclas hof des
                     Maetzenpekchen, und haisset der hof in der Grueb 60 dn. gelts, gelegen ze
                     Chrispental auf Heinreichs hof auf dem pach zur Abhaltung eines Jahrtages vier
                     tag vor Unserr Vrowen tag, als si geborn ist, oder vier tag hinnach verschafft
                     haben.</rs> Sie verpflichten sich zur Ausführung dieser Stiftung und verzichten
                  gegenüber <rs type="fn" role="recipient"><rs type="person" ref="#pe__lukas_popphinger_QGW_II_I_776"><roleName type="title">hern</roleName> Lucasen dem Popphinger</rs> und <rs type="person" ref="#pe__stephan_popphinger_QGW_II_I_776"><roleName type="title">hern</roleName> Stephan dem Popphinger, seinem <roleName type="kin" corresp="#pe__lukas_popphinger_QGW_II_I_776">bruder</roleName>, weilnt
                           <roleName type="occ" corresp="#org__wien">hansgrafen</roleName> und
                           <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                        Wienn</rs> , und den anderen Erben</rs> des verstorbenen Ehepaares auf alle
                  Ansprüche an den früher zu demselben selgeraete bestimmt gewesenen Weingarten ze
                  Su/efring.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>