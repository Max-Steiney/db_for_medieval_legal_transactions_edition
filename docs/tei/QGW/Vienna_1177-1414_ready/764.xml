               <rs type="event" ref="#ev__QGW_II_I_764"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_von_tierna_QGW_II_I_1018">Jans von Tirna, <roleName type="occ" corresp="#org__oesterreich-herzogtum">hubmaister</roleName> in
                        Österreich und <roleName type="occ" corresp="#org__wien">münsmaister</roleName> ze Wienn</rs></rs>, <triggerstring n="disp">entscheidet über die Klage</triggerstring>, welche <rs type="fn" role="other"><rs type="person" ref="#pe__kunigunde_QGW_II_I_764">Chunigund, <roleName type="kin" corresp="#pe__ortolf_vierdung_QGW_II_I_1025"><add>hausvrowe</add></roleName>
