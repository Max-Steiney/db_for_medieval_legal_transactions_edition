            <origDate instant="false">ze Wienn, des nagsten freitags nach sand Margreten tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01549_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01549_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="#ev__QGW_II_I_1549"><rs type="fn" role="issuer"><rs type="person" ref="#pe__rudolf_von_tierna_QGW_II_I_1351">Rudolf</rs> und <rs type="person" ref="#pe__ludwig_von_tierna_QGW_II_I_1351">Ludweig, <roleName type="kin" corresp="#pe__rudolf_von_tierna_QGW_II_I_1351">geprüder</roleName> von Tyrna</rs>,</rs>
                  <triggerstring n="disp">bestätigen, dass</triggerstring>
                  <rs type="event" ref="#ev__QGW_II_I_1549_men_1">her Niclas der Würffel selig und seine Erben, welche
                     für sie hern Ulreichen von Wolffurt Bürgschaft geleistet hatten, das ihnen
                     dafür verpfändete Haus an dem Liechtensteg under den Fleischpenkchen zenegst
                     Rudolfs des Angervelder haus verkauft und von dem Erlöse die Gläubiger
                     befriedigt haben,</rs>
                  <triggerstring n="disp">und sagen</triggerstring>
                  <rs type="fn" role="recipient">den <rs type="person" ref="#pe__johann_wuerfel_QGW_II_I_1404">Ritter hern Hannsen den Wurffel</rs> und seine <rs type="person" ref="#pe__niklas_wuerfel_von_nussdorf_QGW_II_I_1107"><roleName type="kin" corresp="#pe__johann_wuerfel_QGW_II_I_1404">Brüder</roleName> Niclasen</rs>, <rs type="person" ref="#pe__ulrich_wuerfel_QGW_II_I_1404"><roleName type="kin" corresp="#pe__johann_wuerfel_QGW_II_I_1404"><add>Brüder</add></roleName> Ulreichen</rs>
                     und <rs type="person" ref="#pe__sigmund_wuerfel_QGW_II_I_1404"><roleName type="kin" corresp="#pe__johann_wuerfel_QGW_II_I_1404"><add>Brüder</add></roleName> Sigmund die
                        Würffeln</rs></rs> der betreffenden Summe <triggerstring n="disp">quitt und
                     ledig</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1549"><rs type="fn" role="witness">Besiegelt von
                     den <rs type="person" ref="#pe__rudolf_von_tierna_QGW_II_I_1351">Ausstellern</rs>
                     <rs type="person" ref="#pe__ludwig_von_tierna_QGW_II_I_1351"><add>Ausstellern</add></rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>