            <origDate instant="false">zu Wienn, an sand Jorgen abend.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01759_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01759_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1759"><rs type="fn" role="issuer"><rs type="person" ref="#pe__paul_geir_QGW_II_I_1406">Paul der Geyr,<roleName type="occ" corresp="#org__wien"><add>rats</add></roleName></rs>
                     <rs type="person" ref="#pe__leopold_weiler_QGW_II_I_1677">Leupolt der
                           Weiler<roleName type="occ" corresp="#org__wien"><add>rats</add></roleName></rs> und <rs type="person" ref="#pe__paul_wagendruessel_QGW_II_I_1064">Paul der Wagendrussel, all drei
                        des <roleName type="occ" corresp="#org__wien">rats</roleName> der stat zu
                        Wienn ,</rs></rs>
                  <triggerstring n="disp">beurkunden</triggerstring>, dass <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_QGW_II_I_1759"><roleName type="title">her</roleName> Hanns, <roleName type="occ" corresp="#org__wien-st_stephan-messe_stichel">capplan</roleName> der
                        ewigen mess,</rs></rs>
                  <rs type="event" ref="NULL">die <rs type="person" ref="#pe__anna_QGW_II_I_1619">di
                        alt Stichlin, <roleName type="dead">der got gnad</roleName></rs>, ze Widem und ze stiften geschah : hat, an
                     aim tail von des hauses wegen, das halbs Hannsen des Makkauer ist, gelegen bei
                     Stubentor zu Wienn zenechst Hannsen haus des Reicher, des münzer , und der
                     Letztere ihren Streit über ain gruben ains privets, darauf derselb Hanns einen
                     stu/el hiet und die vorgenanten her Hanns und Hans Makkauer den andern stul
                     darauf hieten , vor den Rath gebracht haben.</rs>
                  <rs type="fn" role="other"><triggerstring n="fn">Im Auftrage</triggerstring> des
                     Rathes</rs>
                  <triggerstring n="disp">entscheiden</triggerstring> die Aussteller nach vorgenommener
                  Beschau, dass jede der beiden streitenden Parteien das Recht habe, auf der Grube
                  einen Stuhl zu haben, und jede die Hälfte der etwa sich ergebenden Auslagen zu
                  tragen habe, dass aber, wann man die grueb räumet oder furbet, das haerb allzeit
                  ausgefürt werden soll durch hern Hannsen und Hannsen des Makkauer zwaier tail
                  heuser </rs>. </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1759"><rs type="fn" role="witness">Besiegelt von
                     den Ausstellern<rs type="person" ref="#pe__paul_geir_QGW_II_I_1406"><add>Paul
                           der Geyr</add>,</rs>
                     <rs type="person" ref="#pe__leopold_weiler_QGW_II_I_1677"><add>Leupolt der
                           Weiler</add></rs> und <rs type="person" ref="#pe__paul_wagendruessel_QGW_II_I_1064"><add>Paul der
                        Wagendrussel</add></rs>.</rs>
               </rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>