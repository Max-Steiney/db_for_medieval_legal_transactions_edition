      <text>
            <body>
                  <div type="abstract" resp="lp">
                        <p><rs type="event" ref="#ev__QGW_II_I_113"><rs type="fn" role="issuer"><rs
                                                type="person"
                                                ref="#pe__friedrich_iii_herzog_von_oesterreich_QGW_II_I_853"
                                                  ><roleName type="occ" corresp="#org__heiliges_roemisches_reich"
                                                  >König</roleName> Friedrich,<roleName type="occ" corresp="#org__oesterreich-herzogtum"><add>Herzog
                                                  </add>
                                                </roleName>
                                                <roleName type="occ" corresp="#org__steiermark-herzogtum"><add>Herzog
                                                  </add></roleName></rs>, <rs type="person"
                                                ref="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_596"
                                                  >Albrecht<roleName type="occ" corresp="#org__oesterreich-herzogtum"
                                                  ><add>Herzog</add>
                                                </roleName>
                                                <roleName type="occ" corresp="#org__steiermark-herzogtum"><add>Herzog
                                                  </add></roleName></rs> und <rs type="person"
                                                ref="#pe__otto_herzog_von_oesterreich_QGW_II_I_837"
                                                >Otto, <roleName type="occ" corresp="#org__oesterreich-herzogtum">Herzöge zu
                                                  Oesterreich und Steyr</roleName>
                                                <roleName type="occ" corresp="#org__steiermark-herzogtum"
                                                  ><add>Herzog</add></roleName></rs>,</rs>
                                    <triggerstring n="disp">beurkunden</triggerstring>, dass sie der <rs
                                          type="fn" role="recipient"><rs type="org"
                                                ref="#org__neuberg-zisterzienser">neustift des
                                                chlosters ze sand Marien in dem Neunperg grabs
                                                ordens</rs></rs>, <triggerstring n="disp">ze selgeret
                                          alljährlich ein phunt fu/eder salzes an den sieden ze
                                          Halstat geschenkt haben</triggerstring> und dem Kloster
                                    erlauben, ebenda noch ein halbes phunt fu/eder salzs zu kaufen,
                                    das sich baidenthalben zeucht u/of zwelf phunt chueffel des
                                    chlainen pandes. Für die Zufuhr des Salzes von Hallstadt nach
                                    Wien <triggerstring n="disp">verleihen</triggerstring> sie dem Kloster
                                    Mauthfreiheit.</rs>
                        </p>
                  </div>
                  <div type="seal">
                        <p><rs type="event" ref="#ev__QGW_II_I_113"><rs type="fn" role="witness"
                                          >Besiegelt mit <rs type="person"
                                                ref="#pe__otto_herzog_von_oesterreich_QGW_II_I_837"
                                                >unsern insigeln.</rs><rs type="person"
                                                ref="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_596"
                                                  ><add>unsern insigeln</add></rs>
                                          <rs type="person"
                                                ref="#pe__friedrich_iii_herzog_von_oesterreich_QGW_II_I_853"
                                                  ><add>unsern ingigeln</add></rs></rs></rs>
                        </p>
