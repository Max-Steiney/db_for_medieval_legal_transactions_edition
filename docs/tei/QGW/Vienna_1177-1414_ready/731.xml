        <origDate instant="false">ze Wienn, an dem Sunibent abent.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00731_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00731_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
          <rs type="event" ref="#ev__QGW_II_I_731"><rs type="fn" role="issuer"><rs type="person" ref="#pe__niklas_wuerfel_QGW_II_I_1001">Nichlas der Würfel, <roleName type="occ" corresp="#org__wien">purgermaister</roleName></rs>, und <rs type="org" ref="#org__wien">der rat gemain der stat ze Wienn</rs></rs>, <triggerstring n="disp">beurkunden <add>Klage</add></triggerstring>, dass vor ihnen <rs type="fn" role="other"><rs type="person" ref="#pe__wendelmut_QGW_II_I_731"><roleName type="title">junchvrowe</roleName> Wendelmut,<roleName type="kin" corresp="#pe__heinrich_pluem_QGW_II_I_731"><add>tochter</add></roleName>
                <rs type="person" ref="#pe__heinrich_pluem_QGW_II_I_731">Hainreichs tochter des
                  Pluemen, des <roleName type="prof">sneider</roleName></rs>, aus <roleName type="kin" corresp="#pe__katharina_QGW_II_I_731"><add>tochter</add></roleName><rs type="person" ref="#pe__katharina_QGW_II_I_731">seiner <roleName type="dead">ersten</roleName>
                  <roleName type="kin" corresp="#pe__heinrich_pluem_QGW_II_I_731">Ehe</roleName> mit
                  Frau Katrein</rs></rs>, <triggerstring n="fn">geklagt habe</triggerstring></rs> wegen
            zweier Weingärten, des jegleichs ein halbs jeuch ist, die gelegen sind, ainer in dem
            Mittern Hard bei Sant Ulreich zenast Chunrats weingarten von Radaun und der ander ze
            Süffring zenast Wisents weingarten, des ammans daselbs , <rs type="event" ref="#ev__QGW_II_I_731_men_1">welche <rs type="person" ref="#pe__christine_QGW_II_I_731">ihre rechte <roleName type="kin" corresp="#pe__wendelmut_QGW_II_I_731">Muhme</roleName> Christein,<roleName type="dead"><add>den allen got
                  genad</add></roleName>ihrer <roleName type="kin" corresp="#pe__katharina_QGW_II_I_731">Mutter Schwester</roleName>
              </rs>, <rs type="person" ref="#pe__konrad_paternostrer_QGW_II_I_731">mit ihrem
                  <roleName type="kin" corresp="#pe__christine_QGW_II_I_731">Manne</roleName>
                Chunraten, dem <roleName type="prof">paternustrer</roleName>, <roleName type="dead">den allen got genad</roleName></rs>, zu gesammter Hand gekauft hatte</rs>. <rs type="fn" role="other"><triggerstring n="fn">Dem entgegen</triggerstring> erheben auch die
              unmündigen Kinder Konrads aus seiner andern Ehe mit Elsbeten, junchvrowe <rs type="person" ref="#pe__anna_QGW_II_I_731">
                <roleName type="kin" corresp="#pe__konrad_paternostrer_QGW_II_I_731"><add>Kinder</add></roleName>
                <roleName type="kin" corresp="#pe__elisabeth_QGW_II_I_731"><add>Kinder</add></roleName>Ann</rs>, <rs type="person" ref="#pe__laurenz_QGW_II_I_731">
                <roleName type="kin" corresp="#pe__konrad_paternostrer_QGW_II_I_731"><add>Kinder</add></roleName><roleName type="kin" corresp="#pe__elisabeth_QGW_II_I_731"><add>Kinder</add></roleName>Larenz</rs> und
                <rs type="person" ref="#pe__jakob_QGW_II_I_731"><roleName type="kin" corresp="#pe__elisabeth_QGW_II_I_731"><add>Kinder</add></roleName>
                <roleName type="kin" corresp="#pe__konrad_paternostrer_QGW_II_I_731"><add>Kinder</add></roleName> Jacob</rs>, Anspruch auf beide Weingärten</rs>.
              <triggerstring n="disp">Bürgermeister und Rath entscheiden dahin</triggerstring>, <rs type="fn" role="recipient">dass <rs type="person" ref="#pe__wendelmut_QGW_II_I_731">beide Theile</rs>
              <rs type="person" ref="#pe__anna_QGW_II_I_731"><add>beide Theile</add></rs>
              <rs type="person" ref="#pe__laurenz_QGW_II_I_731">
                <add>beide Theile</add></rs>
              <rs type="person" ref="#pe__jakob_QGW_II_I_731"><add>beide Theile</add></rs> gleich
              erbberechtigt sind</rs>, da die Weingärten von dem Ehepaare mit gesammter Hand gekauft
            worden waren.</rs>
        </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_731"><rs type="fn" role="witness"><rs type="org" ref="#org__wien">Besiegelt mit der stat chlainem anhangundem insigel</rs></rs>.</rs>
