               <rs type="event" ref="#ev__QGW_II_I_920"><rs type="fn" role="issuer"><rs type="person" ref="#pe__heimo_von_gerersdorf_QGW_II_I_920">Haiman von Gerolczdorf <roleName type="rep" corresp="#pe__katharina_QGW_II_I_920"><add>Gerhab</add></roleName>
                        <roleName type="rep" corresp="#pe__ursula_QGW_II_I_920"><add>Gerhab</add></roleName>
                        <roleName type="rep" corresp="#pe__anna_QGW_II_I_920"><add>Gerhab</add></roleName></rs></rs>
                  <triggerstring n="disp">verkauft</triggerstring> als Gerhab der unmündigen Töchter
                  seines <rs type="person" ref="#pe__johann_von_haslau_QGW_II_I_920"><roleName type="kin" corresp="#pe__heimo_von_gerersdorf_QGW_II_I_920">Oheims</roleName> Hanns von Haselau</rs>,
                     <rs type="person" ref="#pe__katharina_QGW_II_I_920"><roleName type="kin" corresp="#pe__johann_von_haslau_QGW_II_I_920"><add>Tochter</add></roleName> Katrei</rs>,
                     <rs type="person" ref="#pe__ursula_QGW_II_I_920"><roleName type="kin" corresp="#pe__johann_von_haslau_QGW_II_I_920"><add>Tochter</add></roleName> Urseln</rs>
                  und <rs type="person" ref="#pe__anna_QGW_II_I_920"><roleName type="kin" corresp="#pe__johann_von_haslau_QGW_II_I_920"><add>Tochter</add></roleName> Annen</rs>,
                     <triggerstring n="fn">aus ehafter vor dem Herzoge und dem Rathe der Stadt zu Wien
                     bewiesener Noth</triggerstring> wegen der von seinem Oheime bei Christen und Juden
                  hinterlassenen Geldschuld den Antheil der Kinder an den 200 lb dn., <rs type="event" ref="#ev__QGW_II_I_920_men_1">welche <rs type="person" ref="#pe__johann_von_haslau_QGW_II_I_920">Hanns von Haselau</rs> seiner <rs type="person" ref="#pe__ursula_QGW_II_I_719"><roleName type="kin" corresp="#pe__johann_von_haslau_QGW_II_I_920">Frau</roleName> Urseln</rs> auf der vest
                     ze Froberkch zu rechter Morgengabe verschrieben hatte</rs>, <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_1020"><roleName type="occ" corresp="#pe__heimo_von_gerersdorf_QGW_II_I_920">Lehensherrn</roleName>
                        <roleName type="occ" corresp="#org__oesterreich-herzogtum">Herzog</roleName> Albrechts III.</rs></rs> um 100 lb dn. <rs type="fn" role="recipient">dem <rs type="person" ref="#pe__niklas_wuerfel_QGW_II_I_1001"><roleName type="title">Ritter</roleName>
                        <roleName type="title">hern</roleName> Niclasen dem Würffel</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_920"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="#pe__heimo_von_gerersdorf_QGW_II_I_920">Ausstellers</rs>, 2. des <rs type="person" ref="#pe__jakob_poll_QGW_II_I_770">Kaplans
                        Jakob des Pollen</rs>, 3.<rs type="person" ref="#pe__ulrich_poll_QGW_II_I_1167"> Ulreich
                        des Pollen, <roleName type="occ" corresp="#org__wien">des rates der stat ze
                           Wienn</roleName></rs>, 4.<rs type="person" ref="#pe__stephan_poll_QGW_II_I_1138">
                        Stephans des Pollen, <roleName type="occ" corresp="#org__wien">purger
                           daselbs</roleName>, <roleName type="kin" corresp="#pe__ulrich_poll_QGW_II_I_1167">geprüder</roleName></rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>