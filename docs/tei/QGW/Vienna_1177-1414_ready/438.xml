               <rs type="event" ref="#ev__QGW_II_I_438"><rs type="fn" role="issuer"><rs type="person" ref="#pe__jakob_pfaffstetter_QGW_II_I_438">Jacob der Phafsteter <roleName type="title"><add>Bergherr</add></roleName></rs></rs>
                  <triggerstring n="disp">verbürgt sich</triggerstring> als Bergherr <rs type="fn" role="recipient"><rs type="person" ref="#pe__jakob_zwaiphunt_QGW_II_I_1142">Jacoben dem Zwaiphunt</rs> und seiner <rs type="person" ref="#pe__agnes_QGW_II_I_1142"><roleName type="kin" corresp="#pe__jakob_zwaiphunt_QGW_II_I_1142">Hausfrau</roleName>
