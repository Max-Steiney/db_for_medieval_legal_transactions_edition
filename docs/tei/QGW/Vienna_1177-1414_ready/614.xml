               <rs type="event" ref="#ev__QGW_II_I_614"><rs type="fn" role="issuer"><rs type="person" ref="#pe__klara_QGW_II_I_800">Chlar, <roleName type="kin" corresp="#pe__heinrich_straiher_QGW_II_I_331">witib</roleName>
                        <rs type="person" ref="#pe__heinrich_straiher_QGW_II_I_331"><roleName type="title">hern</roleName> Hainreichs witib des Straicher, <roleName type="dead">dem got genad</roleName></rs>
                        <roleName type="rep" corresp="#pe__klara_QGW_II_I_800"><add>für</add></roleName><roleName type="rep" corresp="#pe__konrad_schenk_QGW_II_I_800"><add>für</add></roleName><roleName type="rep" corresp="#pe__agnes_QGW_II_I_614"><add>für</add></roleName><roleName type="rep" corresp="#pe__elisabeth_QGW_II_I_614"><add>für</add></roleName></rs>, <rs type="person" ref="#pe__konrad_schenk_QGW_II_I_800">Chunrad, <rs type="person" ref="#pe__gerung_chol_QGW_II_I_417"><roleName type="title">maister</roleName> Gerungs</rs>
                        <roleName type="friend" corresp="#pe__gerung_chol_QGW_II_I_417">vreunt</roleName>, ir <roleName type="kin" corresp="#pe__klara_QGW_II_I_800">aidem</roleName></rs>, und <rs type="person" ref="#pe__agnes_QGW_II_I_614">Angnes , seine <roleName type="kin" corresp="#pe__konrad_schenk_QGW_II_I_800">Hausfrau</roleName>,
                        Claras <roleName type="kin" corresp="#pe__klara_QGW_II_I_800">Tochter</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring> für sich und für die <rs type="person" ref="#pe__elisabeth_QGW_II_I_614">unmündige <roleName type="kin" corresp="#pe__klara_QGW_II_I_800">Tochter</roleName> der Clara <roleName type="title">junchfrowe</roleName> Elspet</rs>
                  <triggerstring n="disp">aus ehafter not</triggerstring> wegen der von Heinrich dem
                  Straicher zurückgelassenen Schulden zwei Tagwerke Wiesmahd, die sie gegen hern
                  Ulreichen dem Strobein gehabt haben an der Wiese, di do leit auf der Triesnich,
                  der vier tagwerch sind, halbeu enhalb der Triesnich und halbeu hin derhalb der
                  Triesnich, zenast hern Nichlas wisen, des chamerschreiber , um 11 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__ulrich_strobein_QGW_II_I_898"><roleName type="title">hern</roleName> Ulreichen dem Strobein, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienn</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_614">Besiegelt mit den Siegeln: <rs type="person" ref="#pe__thomas_schuetzenmeister_QGW_II_I_811">1. <roleName type="title">hern</roleName> Thomans des Schützenmaister, des <roleName type="kin" corresp="#pe__klara_QGW_II_I_800">Sohnes</roleName> der Clara</rs>, <rs type="person" ref="#pe__johann_magseit_StB_I_450">2. <roleName type="title">hern</roleName> Jansen des Magseit, des <roleName type="occ" corresp="#org__wien">rates</roleName> der stat ze Wienne</rs>, <rs type="person" ref="#pe__konrad_prenczer_QGW_II_I_489">3. <roleName type="title">hern</roleName> Chunrats des Prenczer, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienne</rs>.</rs>
