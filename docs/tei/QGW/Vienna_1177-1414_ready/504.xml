               <rs type="event" ref="#ev__QGW_II_I_504"><rs type="fn" role="issuer"><rs type="person" ref="#pe__jakob_lang_QGW_II_I_504">Jacob, des <rs type="person" ref="#pe__otto_lang_QGW_II_I_504">Langen Otten</rs>
                        <roleName type="kin" corresp="#pe__otto_lang_QGW_II_I_504">sun</roleName></rs>, und <rs type="person" ref="#pe__margarethe_QGW_II_I_504_a">Margret, seine <roleName type="kin" corresp="#pe__jakob_lang_QGW_II_I_504">Hausfrau</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihrer <rs type="person" ref="#pe__gertrud_QGW_II_I_504"><roleName type="title">Bergfrau</roleName>
                        <roleName type="title">swester</roleName> Gedrauten der Seczerinne,
                           <roleName type="occ" corresp="#org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">aptissin</roleName> in sand Nichlas chloster vor Stubentor ze
                        Wienne</rs></rs> , drei Achtel Weingarten, gelegen an dem Renweg zenest
                  Mayer Otten weingarten, des ledrer, von dem man jährlich dem Kloster 81 dn. an S.
                  Michaels Tage zu Bergrecht dient, um 15 lb dn. an 30 dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__paul_lederer_QGW_II_I_504">Pauln,
                        dem ledrer</rs>, und seiner <rs type="person" ref="#pe__margarethe_QGW_II_I_504_b"><roleName type="kin" corresp="#pe__paul_lederer_QGW_II_I_504">Hausfrau</roleName>
                        Margreten</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_504"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="person" ref="#pe__gertrud_QGW_II_I_504">1. der
                        Bergfrau</rs>, der Bürger <rs type="person" ref="#pe__haunold_schuchler_QGW_II_I_170">2. <roleName type="title">hern</roleName> Haunolts des Schüchler, <roleName type="occ" corresp="#org__wien">purgermaister</roleName> ze Wienne</rs>, und <rs type="person" ref="#pe__friedrich_mergeb_QGW_II_I_504">3. <roleName type="title">hern</roleName> Fridreichs des Mergeben</rs>.</rs></rs>
