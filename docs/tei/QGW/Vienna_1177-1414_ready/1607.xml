            <origDate instant="false">Der geben ist zu Wienn an sand Lucein tag, nach Kristes gepurd 1400 jar und
               darnach in dem 4. jare. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01607_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01607_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="#ev__QGW_II_I_1607_a"><rs type="fn" role="issuer"><rs type="person" ref="#pe__peter_QGW_II_I_1554">Peter der Hofmaister, <roleName type="occ" corresp="#org__wien-st_stephan">cantor</roleName> dacz sand Steffan
                        ze Wienn und <roleName type="occ" corresp="#org__wien-st_stephan">kaplan</roleName> auf <rs type="org" ref="#org__wien-st_stephan">sand
                           Dorethen altar daselbs der ewigen messe, die in der Schu/eler zeche
                           gehöret</rs></rs>,</rs>
                  <triggerstring n="disp">gibt</triggerstring> nach dem Gebote Herzog Rudolfs IV. <rs type="fn" role="recipient"><rs type="person" ref="#pe__jakob_von_tulln_QGW_II_I_1607">Jacoben von Tulln</rs></rs> 3 lb
                  dn. <triggerstring>gelts purkrechts</triggerstring>, <rs type="event" ref="#ev__QGW_II_I_1607_a_men_1">welche
                     die Messe auf Ru/egers des Gu/elhers, des ledrer, purger ze Wienn, und fraun
                     Kathrein, seiner hausfraun, haus, gelegen vor Werdertor in dem Werd zu Wienn
                     zunachst Hannsen haus des Neunburger, gehabt hatte,</rs> um 24 lb dn.
                  abzulösen,</rs>
               <rs type="event" ref="#ev__QGW_II_I_1607_b">die <rs type="fn" role="issuer"><rs type="person" ref="#pe__peter_QGW_II_I_1554">er</rs></rs> an andere 3 lb dn.
                     <triggerstring n="disp">gelts purkrechts anlegt</triggerstring> auf <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_von_graz_QGW_II_I_1607">Hansen von Grecz, des <roleName type="prof">hantschu/echster</roleName></rs>, und <rs type="person" ref="#pe__gertrud_QGW_II_I_1607">Gedrauten, seiner <roleName type="kin" corresp="#pe__johann_von_graz_QGW_II_I_1607">hausfraun</roleName></rs>,</rs> haus, gelegen vor Stubentor zu Wienn zunast
                  dem Steg.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1607_a"><rs type="event" ref="#ev__QGW_II_I_1607_b"><rs type="fn" role="witness">Besiegelt mit den
                        Siegeln <rs type="person" ref="#pe__georg_von_nikolsburg_QGW_II_I_1010"><roleName type="title">hern</roleName> Jörgen von Nicolspurg, des aussern
                              <roleName type="occ" corresp="#org__wien">rats der stat</roleName> zu
                           Wienn</rs>, und <rs type="person" ref="#pe__leopold_sigharczhofer_QGW_II_I_1607">Leutolts des Sigharczhofer, <roleName type="occ" corresp="#org__wien">purger</roleName> daselbs</rs>.</rs></rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>