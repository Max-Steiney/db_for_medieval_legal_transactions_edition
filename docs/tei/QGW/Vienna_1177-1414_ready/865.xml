                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__johann_an_dem_kienmarkt_QGW_II_I_1009"><roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName>
