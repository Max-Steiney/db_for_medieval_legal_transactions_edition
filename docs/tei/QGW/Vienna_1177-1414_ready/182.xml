            tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00182_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00182_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="#ev__QGW_II_I_182"><rs type="fn" role="issuer"><rs type="person" ref="#pe__friedrich_meller_QGW_II_I_182">Fridreich der Meller</rs> und <rs type="person" ref="#pe__katharina_QGW_II_I_182">Katrei, seine <roleName type="kin" corresp="#pe__friedrich_meller_QGW_II_I_182">Hausfrau</roleName>,</rs></rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__otto_von_huetteldorf_QGW_II_I_182"><roleName type="occ" corresp="#org__mauerbach-kartaeuser">Bergmeisters</roleName> Otten von
                        U/eteindorf, der herren <roleName type="occ" corresp="#org__mauerbach-kartaeuser">amptman</roleName> von Allerheiligen
                        tal ze Mauerbach, des ordens von Karthus</rs> ,</rs> ein Pfund dn. Geldes
                  Burgrechts auf ½ Joch Weingarten, leit ze U/eteldorf an dem Spiegel zenest
                  Hainreichs weingarten des Trager, <rs type="event" ref="#ev__QGW_II_I_182_men_1">davon man alle iar
                     dient den herren ze Mauerbach ainen emmer weins ze perchrecht und 3 dn. ze
                     voitrecht ,</rs> um 7 7lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__berthold_poll_QGW_II_I_121"><roleName type="title">hern</roleName>
                        Perichtolten dem Pollen, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienne,</rs> und <rs type="person" ref="#pe__margarethe_QGW_II_I_182"><roleName type="kin" corresp="#pe__berthold_poll_QGW_II_I_121">seiner Hausfrau</roleName>
                     Margreten</rs>.</rs></rs>
            </p></div><div type="seal"><p>
               <rs type="event" ref="#ev__QGW_II_I_182">Besiegelt mit <rs type="fn" role="witness"><rs cert="high" type="person" ref="#pe__thilo_QGW_II_I_201">des <roleName type="occ" corresp="#org__mauerbach-kartaeuser">prior</roleName></rs></rs>
                  und <rs type="org" ref="#org__mauerbach-kartaeuser">des convents chlainem insigel
                     ze Mauerbach</rs> und mit <rs type="person" ref="#pe__niklas_maeserl_QGW_II_I_182"><roleName type="title">hern</roleName> Niclas insigel des Meserleins</rs>.</rs>
            </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. J. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>