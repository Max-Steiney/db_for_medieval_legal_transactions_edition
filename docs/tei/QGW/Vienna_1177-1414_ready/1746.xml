            <origDate instant="false">des nechsten samstags nach sand Andres tag, des heiligen
               zwelifpoten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01746_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01746_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1746"><rs type="fn" role="issuer"><rs type="person" ref="#pe__peter_stainpekch_QGW_II_I_1746">Peter der Stainpekch,
                           <roleName type="occ" corresp="#org__perchtoldsdorf">burger</roleName> ze Perchtoltstorf</rs>, und <rs type="person" ref="#pe__anna_QGW_II_I_1746">Anna, sein <roleName type="kin" corresp="#pe__peter_stainpekch_QGW_II_I_1746">hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__niklas_wuerfel_von_nussdorf_QGW_II_I_1107">Niclass
                        des Würffels, <roleName type="occ" corresp="#org__klosterneuburg">amptman</roleName> des chlosters ze Neunburg</rs>,</rs> aus dem
                  väterlichen Erbgute der Anna ein Vierteljoch Weingarten, gelegen ze Nustorf in dem
                  obern Mitternperg zenechst der geistlichen herren weingarten von Gesten , von dem
                  man dritthalb viertail weins ze perkrecht und dreu ort ze voitrecht dient, um 19
                  lb dn., der 16 lb herchomen sind von den 106 lb dn., <rs type="event" ref="NULL">die <rs type="person" ref="#pe__georg_nussdorfer_QGW_II_I_1228">Jorig der
                        Nustorffer <roleName type="dead">selig</roleName></rs> geschafft hat hinz
                        <rs type="org" ref="#org__wien-st_stephan">sand Stephan ze Wienn</rs> zu der
                     caplanei</rs> . . ., und davon man jerleich 2 lb gelts purkrechts auf dem
                  egenanten unserm weingarten zu der egenanten capplanei gedient hat, und die andern
                  3 lb hat <rs type="event" ref="NULL"><rs type="person" ref="#pe__leopold_QGW_II_I_1567">der <roleName type="title">erber
                           herr</roleName>
                        <roleName type="title">her</roleName> Leupolt, <roleName type="occ" corresp="#org__wien-st_stephan-messe_nussdorfer_georg">capplan und
                           verbeser</roleName> der egenannten capplanei,</rs> durch gots willen von
                     seinem aigenhaften gut zu hilf der egenanten capplanei darzu geben, demselben
                     hern Leupolten und seinen nachkomen, capplan und verbeser derselben
                     capplanei</rs> .</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1746"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="#pe__peter_stainpekch_QGW_II_I_1746">Ausstellers</rs> und des <rs type="person" ref="#pe__niklas_wuerfel_von_nussdorf_QGW_II_I_1107">Amtmannes</rs>.</rs>
               </rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>