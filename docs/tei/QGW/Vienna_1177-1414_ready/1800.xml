            <origDate instant="false">zu Wienn, des nachsten montags vor Goczleichnams tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01800_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01800_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1800"><rs type="fn" role="issuer"><rs type="person" ref="#pe__georg_windjeger_QGW_II_I_1800">Jorg der Windjeger,
                           <roleName type="occ" corresp="#org__wien">purger</roleName> zu
                        Wienn</rs>, und <rs type="person" ref="#pe__elisabeth_QGW_II_I_1800">Elsbet,
                        sein <roleName type="kin" corresp="#pe__georg_windjeger_QGW_II_I_1800">hausfrau</roleName></rs></rs>, <triggerstring n="disp">bestätigen</triggerstring>, dass sie <rs type="fn" role="recipient"><rs type="person" ref="#pe__peter_vend_QGW_II_I_1800">Petrein dem
                     Vennden</rs></rs> 83 lb 80 dn. und<rs type="fn" role="recipient">
                     <rs type="person" ref="#pe__georg_gumpendorfer_StB_I_146">Jorgen dem
                        Gumpendorfer</rs>
                  </rs>33 lb 80 dn. schulden für den Antheil, den Jeder an dem Hause, gelegen an dem
                  Harmarkcht zu Wienn an aim tail zenechst dem haus, das weilent hern Stephans des
                  Leitner gewesen ist, und an dem andern tail zenechst des Haubner kinder haus ,
                  nach Aussage des darüber ergangenen Spruchbriefes gehabt hatte, <triggerstring n="disp">verpflichten sich</triggerstring> zur Abstattung am nächsten S.
                  Michaelstag und setzen den Gläubigern dafür mit gesammter Hand und <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__paul_geir_QGW_II_I_1406">des <roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName> hern Paul des Geyrs</rs>
                     und des <rs type="org" ref="#org__wien">rats gemain der stat zu Wienn</rs>
                  </rs>das angeführte Haus zu Pfand.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1800"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="#org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="#pe__konrad_innauer_QGW_II_I_1521">Wiener <roleName type="occ" corresp="#org__wien">Bürgers</roleName> Chonrats des
                        Innawer</rs>.</rs>
               </rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>