               <rs type="event" ref="#ev__QGW_II_I_197"><rs type="fn" role="issuer"><rs type="person" ref="#pe__niklas_von_moedling_QGW_II_I_197">Niclas von Medlich, <rs type="person" ref="#pe__kalhoch_QGW_II_I_197"><roleName type="title">hern</roleName> Chahochs <roleName type="kin" corresp="#pe__niklas_von_moedling_QGW_II_I_197">aidem</roleName></rs></rs>, und <rs type="person" ref="#pe__adelheid_QGW_II_I_197">Alhait,seine <roleName type="kin" corresp="#pe__niklas_von_moedling_QGW_II_I_197">
