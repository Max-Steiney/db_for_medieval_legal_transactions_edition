                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__agnes_QGW_II_I_197">ihrer <roleName type="title">Grundfrau</roleName>
                        <roleName type="title">vrowen</roleName> Angnesen der
