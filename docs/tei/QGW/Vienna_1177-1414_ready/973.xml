            <origDate instant="false">Geben ze Wienn an mentag vor sand Merten tag, nach Kristes geburdt 1300 jar
               darnach in dem 79. jare. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00973_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00973_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="#ev__QGW_II_I_973"><rs type="fn" role="issuer"><rs type="person" ref="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_1020"><roleName type="occ" corresp="#org__oesterreich-herzogtum">Herzog</roleName> Albrecht
                     III.</rs></rs>
                  <triggerstring n="disp">beurkundet</triggerstring>, dass ihm <rs type="fn" role="recipient"><rs type="person" ref="#pe__heinrich_von_maissau_QGW_II_I_850">Haidenreich
                        von Meissow, <roleName type="occ" corresp="#org__oesterreich-herzogtum">lantmarschalich</roleName> in Österreich</rs></rs>, 1600 lb dn., <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_von_liechtenstein_QGW_II_I_1037">Hanns von Liechtenstain
                        von Nicolspurg, sein <roleName type="occ" corresp="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_1020">Hofmeister</roleName></rs></rs>, 2009 lb dn. und <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_von_tierna_QGW_II_I_1018">Hanns von
                        Tierna, <roleName type="occ" corresp="#org__oesterreich-herzogtum">hubmaister</roleName> in Österreich</rs></rs>, 2000 lb dn. <triggerstring n="disp">geliehen haben</triggerstring>, wofür er ihnen den <rs type="fn" role="other"><rs type="person" ref="#pe__drugsecz_von_reichesdorf_QGW_II_I_973">Druchseczen
                        von Reichestorf</rs>, <rs type="person" ref="#pe__andreas_taetschan_QGW_II_I_973">Andren den Tetschan, seinen
                           <roleName type="occ" corresp="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_1020">Hof Marschall</roleName></rs>,<rs type="person" ref="#pe__niklas_wuerfel_QGW_II_I_1001"> Niclasen den Würfel</rs>, <rs type="person" ref="#pe__johann_an_dem_kienmarkt_QGW_II_I_1009">Hannsen an dem Chienmarkt, <roleName type="occ" corresp="#org__wien">purgermaister</roleName></rs>, <rs type="person" ref="#pe__niklas_stainer_QGW_II_I_1014">Niclasen den Stainer</rs>, <rs type="person" ref="#pe__paul_holzkaeufel_QGW_II_I_1010">Pauln Holzkouffeln</rs> und <rs type="person" ref="#pe__johann_puettreich_QGW_II_I_1079">Henikin den Püttrich, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienn</rs> ,
                        <triggerstring n="fn">zu Bürgen gesetzt habe</triggerstring></rs>, und <triggerstring n="disp">gelobt</triggerstring>, <triggerstring n="disp">diese ohne jeden Schaden von
                     ihrer Bürgschaft zu lösen</triggerstring>.</rs>
            </p></div><div type="nota"><p>Von gleicher Hand: dominus dux per se. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>