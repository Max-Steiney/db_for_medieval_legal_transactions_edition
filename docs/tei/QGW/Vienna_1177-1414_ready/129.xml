        <date when="13301205">1330 XII 05</date>
        <origDate instant="false">ze Wienne, an sand Nichlas abend.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00129_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00129_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
          <rs type="event" ref="#ev__QGW_II_I_129"><rs type="fn" role="issuer"><rs type="person" ref="#pe__volkmar_auf_der_saeule_QGW_II_I_115">Volchmar auf der Seule</rs> und <rs type="person" ref="#pe__katharina_QGW_II_I_115">Kathrei, sein <roleName type="kin" corresp="#pe__volkmar_auf_der_saeule_QGW_II_I_115">hausvrowe</roleName></rs></rs>,
              <triggerstring n="disp">verkaufen</triggerstring>
            <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__herbert_auf_der_saeule_QGW_II_I_912"><roleName type="title">Grundherrn</roleName> Herborts auf der Seule</rs></rs> ihrer rechten gulte 2 lb
            dn. <triggerstring n="disp">Geldes Burgrechts</triggerstring> auf hern Chunrades haus des
            Veltzer von Neunburch, das da leit in der stat ze Wienne pei der patstuben, die da
            haisset datz den Roren, zwischen dem Goez/zlein und maister Gerhartes haus, des brunner
            , um 10 Mark Silber, ie zwen und sibenzich grosser pehemischer phenninge für die march,
            an einen vierdunch <rs type="fn" role="recipient"><rs type="person" ref="#pe__berthold_poll_QGW_II_I_121"><roleName type="title">hern</roleName>
                Perchtolden dem Pollen</rs> und <rs type="person" ref="#pe__margarethe_QGW_II_I_182">seiner <roleName type="kin" corresp="#pe__berthold_poll_QGW_II_I_121">Hausfrau</roleName> Margreten</rs></rs>.</rs>
        </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_129"><rs type="fn" role="witness">Besiegelt vom <rs type="person" ref="#pe__volkmar_auf_der_saeule_QGW_II_I_115">Aussteller</rs> und von
              dem <rs type="person" ref="#pe__herbert_auf_der_saeule_QGW_II_I_912"><roleName type="title">Grundherrn</roleName></rs>.</rs></rs>
        </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. O. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>