            <date when="14020113">1402 I 13</date>
            <origDate instant="false">Der geben ist zu Wienn, an freitag vor sand Antonien tag, nach Krists gepurd
               1400 jar darnach in dem andern jar. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01501_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01501_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="#ev__QGW_II_I_1501"><rs type="fn" role="issuer"><rs type="person" ref="#pe__lucia_QGW_II_I_1018">Lucei, <rs type="person" ref="#pe__stephan_naezeuger_QGW_II_I_1011">Steffans des
                           Ne/azeuger, <roleName type="occ" corresp="#org__wien">burger</roleName> zu Wienn</rs>, <roleName type="kin" corresp="#pe__stephan_naezeuger_QGW_II_I_1011">witib</roleName>,</rs></rs>
                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="#pe__patrick_QGW_II_I_1501"><roleName type="title">Grundherrn</roleName> des <roleName type="occ" corresp="#org__wien-schotten">Schottenabtes</roleName>
                        <roleName type="title">hern</roleName> Patricien</rs></rs> 1 lb dn.
                     <triggerstring n="disp">ablösbaren Burgrechtsgeldes</triggerstring> auf ihrem Hause,
                  gelegen vor Widmertor zu Wien in der Ofenlukchen zunächst Hansen haus des
                  Schoslaitters, <rs type="event" ref="#ev__QGW_II_I_1501_men_1">von dem man den Schotten 24 dn. zu
                     Grundrecht und den geistlichen Frauen ze sand Niclas vor Stubentor ½ lb dn. zu
                     Burgrecht dient</rs>, <rs type="fn" role="recipient">dem <rs type="person" ref="#pe__albrecht_QGW_II_I_1501"><roleName type="prof">Priester</roleName>
                        <roleName type="title">hern</roleName> Albrechten, <roleName type="occ" corresp="#org__wien-st_niklas_vor_stubentor_kapelle">kapellan</roleName>
                        der <rs type="org" ref="#org__wien-st_niklas_vor_stubentor_kapelle">kapellen,
                           gehaissen dacz dem Alten sand Niclas in der Lantstrass zu
                     Wienn</rs></rs>,</rs> um 8 lb dn., <rs type="event" ref="#ev__QGW_II_I_1501_men_2">für welche ein
                     anderes Pfund Burgrechtsgeldes, das weilent frau Elspet, die preuerin, auf der
                     Sleunzerin haus vor Ke/arnertor auf der Widem zu Wienn gehabt und zu eim ewigen
                     liecht in derselben kapelln geschafft hatte, abgelöst worden war.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1501"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="#pe__patrick_QGW_II_I_1501">Grundherrn</rs> und des <rs type="person" ref="#pe__johann_naezeuger_QGW_II_I_1123"><roleName type="occ" corresp="#org__wien">Wiener Bürgers</roleName> Hansen des Ne/azeuger, des
                        eltern, <roleName type="occ" corresp="#org__wien">burger zu
                           Wienn</roleName></rs>.</rs></rs>
            </p></div><div type="nota"><p>Durch Einschnitt cassiert.</p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>