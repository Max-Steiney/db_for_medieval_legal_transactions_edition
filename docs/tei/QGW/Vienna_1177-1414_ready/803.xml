               <rs type="event" ref="#ev__QGW_II_I_803"><rs type="fn" role="issuer"><rs type="person" ref="#pe__konrad_chienaestel_QGW_II_I_802">Chu/onrat der Chienaestel</rs> und <rs type="person" ref="#pe__katharina_QGW_II_I_803">Katrei, seine <roleName type="kin" corresp="#pe__konrad_chienaestel_QGW_II_I_802">Hausfrau</roleName></rs></rs>
