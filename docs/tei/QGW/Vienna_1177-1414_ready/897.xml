            <origDate instant="false">ze Wienne, an sand Antonii abende.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00897_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00897_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_897"><rs type="fn" role="issuer"><rs type="person" ref="#pe__katharina_QGW_II_I_897">Kathrei, <rs type="person" ref="#pe__simon_bei_der_chirchen_QGW_II_I_897">Simons bei der Chirchen <roleName type="dead"><add>witibe</add></roleName></rs>
                        <roleName type="kin" corresp="#pe__simon_bei_der_chirchen_QGW_II_I_897">wittibe</roleName></rs> , und <rs type="person" ref="#pe__jakob_QGW_II_I_897">Jacob, ir <roleName type="kin" corresp="#pe__katharina_QGW_II_I_897">sun</roleName></rs> , <rs type="person" ref="#pe__margarethe_QGW_II_I_897a">Margret, <rs type="person" ref="#pe__wulfing_scharrer_QGW_II_I_897">Wülfings des Scharrer <roleName type="dead"><add>wittibe</add></roleName></rs>
                        <roleName type="kin" corresp="#pe__wulfing_scharrer_QGW_II_I_897">wittibe</roleName></rs>
                     , und <rs type="person" ref="#pe__stephan_QGW_II_I_897">Stephan, ir <roleName type="kin" corresp="#pe__margarethe_QGW_II_I_897a">sun</roleName>
                     </rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="#pe__johann_weczel_QGW_II_I_897"><roleName type="title">Bergmeisters</roleName> Jannsen des Weczels, <roleName type="occ" corresp="#org__mauerbach-kartaeuser">pergmaister</roleName> und <roleName type="occ" corresp="#org__mauerbach-kartaeuser">amtman</roleName> der
                        geistleichen herren ze Maurbach, des Ordens von Karthus</rs></rs> , und zwar
                  die ersteren wegen eines der chirchen sand Kathrein schuldigen Betrages, zwei
                  Viertel Weingarten, baide gelegen nebeinander ze Eczkeinstorf zenachst Jannsen
                  weingarten des Görlicz, von denen man einen Eimer Wein zu Bergrecht und 3 dn. zu
                  Voitrecht dient, <rs type="fn" role="recipient"><rs type="person" ref="#pe__anna_QGW_II_I_897b">Annen <roleName type="kin" corresp="#pe__martin_oeler"><add>Kind</add></roleName><roleName type="kin" corresp="#pe__anna_QGW_II_I_897a"><add>Kind</add></roleName></rs>, <rs type="person" ref="#pe__ulrich_QGW_II_I_897">Ulreichen <roleName type="kin" corresp="#pe__martin_oeler"><add>Kind</add></roleName><roleName type="kin" corresp="#pe__anna_QGW_II_I_897a"><add>Kind</add></roleName></rs> und <rs type="person" ref="#pe__margarethe_QGW_II_I_897b">Margreten, den <roleName type="kin" corresp="#pe__martin_oeler"><add>Kind</add></roleName><roleName type="kin" corresp="#pe__anna_QGW_II_I_897a">unmündigen Kindern</roleName>
                        <rs type="person" ref="#pe__martin_oeler">Merten, des öler <roleName type="dead"><add>got gnade</add></roleName></rs>, bei <rs type="person" ref="#pe__anna_QGW_II_I_897a">Annen, seiner hausfrauen, den
                           baiden <roleName type="dead">got gnade</roleName></rs></rs></rs>, für 13
                  lb dn., den Erlös von dem Verkaufe des Hauses, gelegen vor dem Tumprobsthof ze
                  Wienne zenechst dem haus, das weilnt Wolfgangs seligen des Stainpekchen gewesen
                  ist, an <rs type="fn" role="recipient"><rs type="person" ref="#pe__konrad_QGW_II_I_897"><roleName type="title">hern</roleName>
                        Chunraten, <roleName type="occ" corresp="#org__heidenreichstein-pfarre">pharrer</roleName> ze Haidenreichstain und <roleName type="occ" corresp="#org__wien-st_margarethe_in_der_muenzerstraße">kapellan</roleName> der kapellen sand Margreten in der Münzerstrasse ze
                        Wienne</rs></rs> , dem beide Viertel Weingarten zu Ebenteuer liegen
                  bleiben.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_897"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="#pe__heinrich_QGW_II_I_1152"><roleName type="title">Bergherrn</roleName>
                        <roleName type="title">brueder</roleName> Hainreichs, <roleName type="occ" corresp="#org__mauerbach-kartaeuser">prior</roleName> ze Maurbach</rs>, 2.
                     des <rs type="person" ref="#pe__stephan_naezeuger_QGW_II_I_1011"><roleName type="occ" corresp="#org__wien">Wiener Bürgers</roleName> Stephan des
                     Nêzeuger</rs>.</rs></rs>
            </p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>