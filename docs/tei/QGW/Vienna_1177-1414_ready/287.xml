   <text>
      <body>
         <div type="abstract" resp="lp">
            <p><rs type="event" ref="#ev__QGW_II_I_287"><rs type="fn" role="issuer"><rs type="person"
                        ref="#pe__stephan_chaeufel_QGW_II_I_287">Stephan der Cheuffel von
                        Medlich</rs> und <rs type="person" ref="#pe__gisela_QGW_II_I_287">Geisel,
                        seine <roleName type="kin" corresp="#pe__stephan_chaeufel_QGW_II_I_287"
                           >Hausfrau</roleName></rs></rs>, <triggerstring n="disp"
                     >verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__ulrich_von_lilienfeld_QGW_II_I_287">ihres <roleName
                           type="title">Bergherrn</roleName> und <roleName type="occ"
                           corresp="#org__lilienfeld-zisterzienser" select="#pl__lilienfeld"
                           >Bergmeisters</roleName>, <roleName type="title">bruder</roleName>
                        Ulreichs, <roleName type="occ" corresp="#org__lilienfeld-zisterzienser"
                           >apt</roleName> ze Liligenvelde</rs>, und <rs type="person"
                        ref="#pe__siegfried_felschlein_QGW_II_I_287">Seifrids des Felschleins,
                           <roleName type="occ" corresp="#org__moedling">zechmaister</roleName> ze
                        Medlich</rs></rs>, <triggerstring n="disp">5 lb dn. geltes purchrechtes auf
                     ihren zwei Weingärten</triggerstring>, die da ligent ze Medlich, ainer in den
                  Setzen hinder dem marcht zenest Gotfrids weingarten des Spil, davon man alle iar
                  dient dem apt ze Liligenvelde 20 dn. ze perchrecht und nicht mer, so leit der
                  ander an dem Wartperge zenest des Walseer weingarten, davon man alle iar dient auf
                  den chorner ze Medlich 3 dn. ze perchrecht , mit dem Vorbehalte des
                  Ablösungsrechtes um 35 lb dn. <rs type="fn" role="recipient"><rs type="person"
                        ref="#pe__haunold_schuchler_QGW_II_I_170"><roleName type="title"
                           >hern</roleName> Haunolten dem Schu/echler, <roleName type="occ"
                           corresp="#org_wien">judenrichter</roleName> ze Wienne</rs>, und <rs
                        type="person" ref="#pe__katharina_QGW_II_I_287">seiner <roleName type="kin"
                           corresp="#pe__haunold_schuchler_QGW_II_I_170">Hausfrau</roleName>
                        Katrein</rs></rs>.</rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_287"><rs type="fn" role="witness">Besiegelt 1. mit
                     der <rs type="person" ref="#pe__johanna_von_pfirt_QGW_II_I_304"><roleName
                           type="title">hochgeborn</roleName><roleName type="title"> fürstinne
                           </roleName><roleName type="title">herzoginne</roleName> Johanne in
                        Osterrich, in Steier und in Kernden</rs> perger insigel und 2. mit dem
                     Siegel <rs type="person" ref="#pe__ulrich_von_lilienfeld_QGW_II_I_287">des Abtes
                        Ulrich von Lilienfeld</rs>.</rs></rs></p>
         </div>
