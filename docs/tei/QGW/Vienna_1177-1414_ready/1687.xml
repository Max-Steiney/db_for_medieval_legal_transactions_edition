            <date when="14070511">1407 V 11</date>
            <origDate instant="false">ze Wienn, des negsten mitichens vor dem heiligen
            Phingstag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01687_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01687_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1687"><rs type="fn" role="issuer"><rs type="person" ref="#pe__leopold_prenner_QGW_II_I_1071">Leupolt der Prenner,
                           <roleName type="occ" corresp="#org__wiener_neustadt">purger</roleName> in der Neunstat</rs>,</rs>
                  <triggerstring n="disp">bestätigt</triggerstring>, dass von den 3000 lb dn., welche <rs type="fn" role="recipient"><rs type="person" ref="#pe__leopold_iv_herzog_von_oesterreich_QGW_II_I_1676"><roleName type="occ" corresp="#org__oesterreich-herzogtum">Herzog</roleName>
                        Leupolt</rs>
                  </rs><rs type="event" ref="NULL">ihm und seiner <rs type="person" ref="#pe__margarethe_QGW_II_I_1249"><roleName type="kin" corresp="#pe__leopold_prenner_QGW_II_I_1071">Schwester <roleName type="kin" corresp="#pe__johann_arnstorfer_QGW_II_I_1249"><add>hausfrau</add></roleName></roleName> Margreten <roleName type="dead"><add>got genad</add></roleName>,</rs>
                     <rs type="person" ref="#pe__johann_arnstorfer_QGW_II_I_1249">Hannsen des
                        Arnstorfer hausfrau, den paiden <roleName type="dead">got
                        genad</roleName>,</rs> schuldet,</rs> seiner Schwester 500 lb dn., ihm 100
                  lb dn. <triggerstring n="disp">zurückbezahlt</triggerstring>, 2400 lb dn. noch
                  ausständig seien, <triggerstring n="disp">verpflichtet sich</triggerstring> gegenüber
                  den <rs type="fn" role="recipient">Ausrichtern des von Hanns dem Arnstorfer
                     hinterlassenen Geschäftes, <rs type="person" ref="#pe__johann_ziernast_QGW_II_I_1371">Hannsen dem Ziernast <roleName type="rep" corresp="#pe__johann_arnstorfer_QGW_II_I_1249"><add>ausrichter</add></roleName></rs> und <rs type="person" ref="#pe__johann_mosprunner_QGW_II_I_1096">Hannsen dem Mosprunner<roleName type="rep" corresp="#pe__johann_arnstorfer_QGW_II_I_1249"><add>ausrichter</add></roleName></rs></rs>, von diesen 2400 lb dn.,
                  sobald sie zurückerstattet werden, zu dem Geschäfte seines Schwagers 1000 lb dn.
                  auszurichten, und <triggerstring n="disp">bestätigt</triggerstring>, von den Genannten
                  den brief, der do sagt umb 20 lb dn. geltes, gelegen auf dem gericht ze der
                  Neunstat, <triggerstring n="disp">erhalten zu haben</triggerstring>, wogegen er für sich
                  und seine Erben gelobt, für seine Schwester und seinen Schwager jährlich in den
                  Quatembern vier Jahrtage zu begehen in der <rs type="org" ref="#org__wiener_neustadt-pfarrkirche_st_maria">pharrchirichen dacz Unser Fraun
                     in der Neunstat</rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1687"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="#pe__leopold_prenner_QGW_II_I_1071">Ausstellers</rs>, 2. <rs type="person" ref="#pe__niklas_rorbacher_QGW_II_I_1273">Niclas des Rorbarcher, <roleName type="occ" corresp="#org__oesterreich-herzogtum">richter</roleName> in der
                        Neunstat</rs>, 3. <rs type="person" ref="#pe__peter_guenzburger_QGW_II_I_1235">des <roleName type="kin" corresp="#pe__leopold_prenner_QGW_II_I_1071">swehers</roleName> des
                        Ausstellers Petreins des Gunzpurger, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienn</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>