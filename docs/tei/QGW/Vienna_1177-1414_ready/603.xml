               <rs type="event" ref="#ev__QGW_II_I_603"><rs type="fn" role="issuer"><rs type="person" ref="#pe__paul_von_neuburg_QGW_II_I_603">Paul von Neunburch, <roleName type="occ" corresp="#org__wien-st_johann_in_der_siechenals">maister</roleName> des hauses dacz sand Johans auf der Siechen Alsse ze
                        Wienne</rs>, und <rs type="org" ref="#org__wien-st_johann_in_der_siechenals">die sampnung gemain daselbens</rs>, <rs type="person" ref="#pe__bernhard_neusiedler_QGW_II_I_603">Wernhart der Neusidler, <roleName type="occ" corresp="#org__wien-st_hiob_zum_klagbaum">verbeser</roleName>
                        des hauses dacz dem Chlagpaum</rs>, und <rs type="org" ref="#org__wien-st_hiob_zum_klagbaum">die sampnung gemain daselbens</rs>, <rs type="person" ref="#pe__jakob_auf_dem_stab_QGW_II_I_603">Jacob auf dem Stab,
                           <roleName type="occ" corresp="#org__wien-st_lazarus_siechenhaus">verbeser</roleName> des hauses dacz sand Laz/zers ze Wienne</rs>, und<rs type="org" ref="#org__wien-st_lazarus_siechenhaus"> die sampnung gemain
                        daselbens</rs>
                  </rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="#pe__konrad_QGW_II_I_603"><roleName type="title">Bergherrn</roleName>
                        <roleName type="title">hern</roleName> Chunrats, <roleName type="occ" corresp="#org__hernals-st_bartholomaeus">pharrer</roleName> dacz sand
                        Pertelme ze Alsse</rs></rs>, ein halbes Joch Weingarten hinder dem dorf ze
                  Alsse in den Langen jeuchen, zenast dem weingarten, der weiln Petreins des Cholben
                  gewesen ist, von dem man dem Pfarrer von S. Bartholomäus ze Alsse 2 dn. für
                  Bergrecht und Voitrecht, dem Kaplan der Kapelle im Rathause Jacob dem Pollen 1 lb
                  dn. zu Burgrecht dient, und der ihnen als Vermächtnis Hainreichs des Waller,
                  statschreiber ze Wienn, zugefallen war, um 3 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__konrad_von_gars_QGW_II_I_603"><roleName type="title">hern</roleName> Chunraten von Gars, <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                     Wienne.</rs></rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_603"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. - 3. der drei <rs type="org" ref="#org__wien-st_lazarus_siechenhaus">Siechenhäuser</rs>
                     <rs type="org" ref="#org__wien-st_hiob_zum_klagbaum"><add>Siechenhäuser</add>
                     </rs>
                     <rs type="org" ref="#org__wien-st_johann_in_der_siechenals"><add>Siechenhäuser</add></rs>, 4. <rs type="person" ref="#pe__konrad_QGW_II_I_603">des Bergherrn</rs>, 5. <rs type="person" ref="#pe__herbert_deckenschaden_QGW_II_I_390"><roleName type="title">hern</roleName> Herworts des Deckenschadens, <roleName type="occ" corresp="#org__wien">des rats der stat ze Wienne</roleName>, als <roleName type="rep" corresp="#pe__heinrich_waller_QGW_II_I_429">Geschäftsvollstreckers</roleName> nach <rs type="person" ref="#pe__heinrich_waller_QGW_II_I_429">Heinrich dem
                     Waller</rs></rs>.</rs>
               </rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>