      <text>
            <body>
                  <div type="abstract" resp="cs">
                        <p>* <rs type="event" ref="#ev__QGW_II_I_954"><rs type="fn" role="issuer"><rs
                                                type="person"
                                                ref="#pe__albrecht_bischof_von_passau_QGW_II_I_1007"
                                                  ><roleName type="occ"
                                                  corresp="#org__passau-dioezese">Bischof</roleName>
                                                Albert von Passau</rs></rs>
                                    <triggerstring n="disp">genehmigt</triggerstring> die von der <rs
                                          type="fn" role="recipient"><rs type="person"
                                                ref="#pe__engel_QGW_II_I_954"><roleName type="kin"
                                                  corresp="#pe__stephan_leitner_QGW_II_I_1012"
                                                  >Gemahlin</roleName> des <rs type="person"
                                                  ref="#pe__stephan_leitner_QGW_II_I_1012">Wiener
                                                  <roleName type="occ" corresp="#org__wien"
                                                  >Bürgers</roleName> Stephan des Leitner</rs> ,
                                                Engela</rs> , auf Grund einer letztwilligen
                                          Verfügung ihres <rs type="person"
                                                ref="#pe__ortolf_mit_den_gevattern_QGW_II_I_954"
                                                  ><roleName type="dead">ersten</roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__engel_QGW_II_I_954">Mannes</roleName>
                                                Ortolfi, dicti Mit der Gevattern </rs></rs>, in der
                                    Kapelle beate Marie virginis in Ottenhaim Wienne gestiftete <rs
                                          type="fn" role="recipient"><rs type="org"
                                                ref="#org__wien-st_maria_im_rathaus-messe_gevattern"
                                                >Messe</rs></rs>, deren Präsentation dem genannten
                                          <rs type="fn" role="recipient">Ehepaare <rs type="person"
                                                ref="#pe__engel_QGW_II_I_954"><add>Engela</add></rs>
                                          <add>und</add>
                                          <rs type="person" ref="#pe__stephan_leitner_QGW_II_I_1012"
                                                  ><roleName type="occ" corresp="#org__wien"
                                                  ><add>Wiener Bürger</add></roleName>
                                                <add>Stephan</add></rs></rs> auf Lebenszeit, nach
                                    ihrem Tode dem <rs type="fn" role="recipient"><rs type="org"
                                                ref="#org__wien-st_maria_im_rathaus">Rector der
                                                Kapelle</rs></rs>
                                    <triggerstring n="disp"><add>Präsentation</add> zustehen
                                          soll</triggerstring>, während die Einsetzung dem <rs
                                          type="fn" role="recipient"><rs type="org"
                                                ref="#org__passau-dioezese">Bischof von
                                          Passau</rs></rs>
                                    <triggerstring n="disp"><add>Einsetzung</add> vorbehalten
                                          bleibt</triggerstring>.</rs>
                        </p>
                  </div>
                  <div type="nota">
                        <p>Indorsat: Aufschrift des Magister Theodericus. ff. </p>
