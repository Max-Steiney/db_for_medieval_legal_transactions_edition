            <origDate instant="false">ze Wienne, an sand Georgii tach.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00042_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00042_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_42"><rs type="fn" role="issuer"><rs type="person" ref="#pe__konrad_poll_QGW_II_I_42">Chunrat der Polle, <roleName type="occ" corresp="#org__wien">Bürgermeister</roleName></rs>, und <rs type="org" ref="#org__wien">der Rath von der Stadt zu Wien</rs></rs>
                  <triggerstring n="disp">bezeugen</triggerstring>, dass <rs type="fn" role="other"><rs type="person" ref="#pe__ilian_QGW_II_I_42"><roleName type="title">Frau</roleName> Ilian die Gottesvelderinne</rs>
                     <triggerstring n="fn">aus ehafter <add>Noth</add></triggerstring></rs>, vor dem Rathe
                     <rs type="fn" role="other">mit <rs type="person" ref="#pe__konrad_hubmeister_QGW_II_I_146"><roleName type="title">hern</roleName> Chunraten, dem <roleName type="occ" corresp="#org__oesterreich-herzogtum">hubmaister</roleName></rs>, und<rs type="person" ref="#pe__leopold_auf_der_saeule_QGW_II_I_42">
                        <roleName type="title">hern</roleName> Liupolten auf der Saeul</rs>
                     <triggerstring n="fn">bewiesener Noth</triggerstring></rs> eine Futtergrube an dem
                  Hohen Markt um 11 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__friedrich_minnganch_QGW_II_I_42">Friderichen dem Minnganch, dem
                           <roleName type="prof">sneider</roleName></rs></rs>, mit der Bedingung
                     <triggerstring n="disp">verkauft habe</triggerstring>, dass er ihr davon 10 sh. dn.
                  Burgrecht zu dienen habe.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_42"><rs type="fn" role="witness"><rs type="org" ref="#org__wien">Besiegelt mit der stat insigel</rs></rs></rs>. </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. G. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>