            <origDate instant="false">ze Wienne, an sant Ambrosii tag, des heiligen
               bischofs.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00582_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00582_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="#ev__QGW_II_I_582"><rs type="fn" role="issuer"><rs type="person" ref="#pe__ulrich_poll_QGW_II_I_1167">Ulreich der Poll, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienne</rs>,
                     und <rs type="person" ref="#pe__engel_QGW_II_I_534">Engel, seine <roleName type="kin" corresp="#pe__ulrich_poll_QGW_II_I_1167">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__haunold_schuchler_QGW_II_I_170"><roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Haunolts des Schüchler</rs> und <rs type="org" ref="#org__wien">des Rathes der Stadt zu Wien</rs></rs> von ihrem
                  Hause, gelegen zenast der chapelln Unserr Vrowen in der purger Rathaus ze Wienne,
                  hern Ottenhaim seligen stiftunge, den tail zwischen dem chor an derselben chapelln
                  und der maur des egenanten hauses, die zenast dopei aufget von der stat, do der
                  sagrer der egenanten chapelln weilent gewesen ist, uber sich und under sich
                  durchlangs für sich aus in die Strasse gegen hern Nichlas hous des Würfels uber ,
                  um 50 lb dn. an <rs type="fn" role="recipient"><rs type="person" ref="#pe__jakob_poll_QGW_II_I_770">Ulrichs <roleName type="kin" corresp="#pe__ulrich_poll_QGW_II_I_1167">Bruder</roleName>, den Kaplan
                           <roleName type="title">hern</roleName> Jacob den Pollen</rs></rs> zur
                  Anlage einer Durchfahrt.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_582"><rs type="fn" role="witness">Besiegelt : <rs type="person" ref="#pe__ulrich_poll_QGW_II_I_1167">1. mit dem Siegel des
                        Ausstellers</rs>, <rs type="org" ref="#org__wien">2. mit dem städt.
                        Grundsiegel</rs>, mit den Siegeln <rs type="person" ref="#pe__lukas_popphinger_QGW_II_I_776">3. <roleName type="title">hern</roleName> Lucas des Popphinger</rs>, <rs type="person" ref="#pe__niklas_poll_QGW_II_I_264">4. des <roleName type="kin" corresp="#pe__ulrich_poll_QGW_II_I_1167">Eidams</roleName> des Ausstellers
                           <roleName type="title">hern</roleName> Nichlas des Pollen, <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                     Wienne</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. d. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>