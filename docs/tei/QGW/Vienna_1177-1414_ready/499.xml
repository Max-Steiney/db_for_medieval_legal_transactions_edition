               <rs type="event" ref="#ev__QGW_II_I_499"><rs type="fn" role="issuer"><rs type="person" ref="#pe__heinrich_vinkch_QGW_II_I_499">Hainreich der Vinch, <roleName type="occ" corresp="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_596">chamrer</roleName>
                        <rs type="person" ref="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_596"><roleName type="title">Herzog</roleName> Albrechts</rs></rs>, und <rs type="person" ref="#pe__elisabeth_QGW_II_I_499">seine <roleName type="kin" corresp="#pe__heinrich_vinkch_QGW_II_I_499">Hausfrau</roleName>
                        Elspet</rs></rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__johann_smausser_QGW_II_I_946">ihres <roleName type="title">Grundherrn</roleName>
                        <roleName type="title">hern</roleName> Jansen des Smauz/zz/zer, <roleName type="occ" corresp="#org__wien">statrichter</roleName> ze Wienn</rs></rs>,
                  an sechzig funif lb dn. geltes purchrechts ewiger gült auf Leutolts haus, des
                  choler, hinder dem Neunmarcht zenaechst dem haus, das weiln des Raeschleins
                  gewesen ist , von dem man 15 dn. Grundrecht dient, um 30 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__haunold_schuchler_QGW_II_I_170"><roleName type="title">hern</roleName> Haunolten dem Schuchler,
                           <roleName type="occ" corresp="#org__wien">purgermaister</roleName> ze
                        Wienn</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_499"><rs type="fn" role="witness">Besiegelt mit
