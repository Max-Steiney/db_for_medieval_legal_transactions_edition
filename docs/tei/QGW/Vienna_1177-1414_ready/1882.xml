            <placeName>Eggenburg</placeName>
            <date when="14110602">1411 VI 02</date>
            <origDate instant="false">Datum ze Egenburg an ertag nach dem heiligen Pfingstag zu mittentag, anno
               CCCC//mo undecimo. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01882_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01882_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="#ev__QGW_II_I_1882"><rs type="fn" role="issuer">Die sechs
                     Herren, die zu dem tag gen Egenburg gesandt sind</rs>, <triggerstring n="disp">bringen</triggerstring> dem <rs type="fn" role="recipient"><rs type="org" ref="#org__wien">Bürgermeister, Richter und Rathe der Stadt zu Wien</rs></rs>
                  <triggerstring n="disp">zur Kenntnis,</triggerstring> dass sie an dem heiligen Phingstag
                  (31. Mai) zu vesperzeit, <rs type="fn" role="issuer"><rs type="person" ref="#pe__albrecht_v_herzog_von_oesterreich_QGW_II_I_1730">Herzog
                        Albrecht</rs> und mit ihm <rs type="person" ref="#pe__hartneid_von_pottendorf_QGW_II_I_1766">der von Pottendorf, der
                        marschalich,</rs> <unclear instant="false">der von Meissau</unclear>, <rs type="person" ref="#pe__leopold_von_eckhartsau_QGW_II_II_2841">der von Ekkartsau, der
                     hofmaister,</rs> <rs type="person" ref="#pe__johann_von_neidegg_QGW_II_I_1860">der
                        Neidekker, kamermaister</rs>, <rs type="person" ref="#pe__pilgrim_von_puchheim_QGW_II_I_1882">her Pilgreim von Pucheim, sein
                        <unclear instant="false">rêt</unclear>,</rs>
                     <rs type="person" ref="#pe__burkhard_von_winden_QGW_II_I_1485">her Burchkart von
                        Winden, </rs><rs type="person" ref="#pe__albrecht_von_ottenstein_QGW_II_I_1248">der Ottenstainer,</rs>
                     <rs type="person" ref="#pe__hering_QGW_II_I_1882">der Hering</rs> und ander
                     herrn, ritter und knecht</rs> wol mit 600 pferden am Montage, der von Maidburg
                  und der von Lichtenstain aber erst heute nach Eggenburg gekommen seien, dass sie
                  den von Walssee und andere Prälaten und Herren noch erwarten, und dass sie bisher
                  noch zu keiner Berathung eingeladen worden seien.</rs>
            </p></div><div type="nota"><p>Adresse aussen.</p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>