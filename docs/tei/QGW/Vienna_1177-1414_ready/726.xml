               <rs type="event" ref="#ev__QGW_II_I_726"><rs type="fn" role="issuer"><rs type="person" ref="#pe__gilg_QGW_II_I_622">Brueder Gilig, <roleName type="occ" corresp="#org__wien-deutsche_herren">hauscomiteier</roleName></rs>, und
