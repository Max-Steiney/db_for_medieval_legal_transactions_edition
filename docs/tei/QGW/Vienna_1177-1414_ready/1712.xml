            <origDate instant="false">zu Präge, am nochsten freitag noch Unser lieben Frowen tage, genant
               Nativitatis.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01712_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01712_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1712"><rs type="fn" role="issuer"><rs type="person" ref="#pe__berthold_chramer_QGW_II_I_1712">Pertold Cramer von
                        Eisfeit, <roleName type="occ" corresp="#org__wien">burger</roleName>
                        der grossem stat zu Präge,</rs></rs>
                  <triggerstring n="disp">beurkundet</triggerstring> seinen letzten Willen. Er <triggerstring n="disp">bestellt</triggerstring> zu <rs type="fn" role="recipient">
                     <rs type="person" ref="#pe__heinrich_sachsenfelt_QGW_II_I_1712"><roleName type="rep" corresp="#pe__berthold_chramer_QGW_II_I_1712">Geschäftsverwesern</roleName> die Prager <roleName type="occ" corresp="#org__wien">Bürger</roleName> Heinrich Sachsenfelt</rs> und <rs type="person" ref="#pe__niklas_weisswasser_QGW_II_I_1712">Nicolae Weiswasser
                           <roleName type="rep" corresp="#pe__berthold_chramer_QGW_II_I_1712"><add>Geschäftsverwesern</add></roleName><roleName type="occ" corresp="#org__wien"><add>Bürger</add></roleName></rs>,</rs>
                  <triggerstring n="disp">bestimmt</triggerstring> zur Gesammterbin <rs type="fn" role="recipient">seine <rs type="person" ref="#pe__katharina_QGW_II_I_1712"><roleName type="kin" corresp="#pe__berthold_chramer_QGW_II_I_1712">Frau</roleName> Katherina </rs></rs>und <triggerstring n="disp">schafft</triggerstring> jedem seiner Kinder 40 schok grosser Prager münze, seinem
                  <rs type="fn" role="recipient"><rs type="person" ref="#pe__peter_QGW_II_I_1712"><roleName type="kin" corresp="#pe__berthold_chramer_QGW_II_I_1712">Stiefsohn</roleName> Peter</rs></rs>
                  25 schock grosser Prager munze und <rs type="fn" role="recipient"><rs type="person" ref="#pe__eck_zenkgreff_QGW_II_I_1712">seinem <roleName type="friend" corresp="#pe__berthold_chramer_QGW_II_I_1712">Freunde</roleName> Eckil</rs></rs> 10 schok grosser, bereites geldes
                  .</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1712"><rs type="fn" role="witness">Siegler: <rs type="person" ref="#pe__oswald_roll_QGW_II_I_1712">Oswald Roll, <roleName type="occ" corresp="#org__prag">richter</roleName>,</rs>
                     <rs type="person" ref="#pe__leb_von_prachatitz_QGW_II_I_1712">Leb von Prachaticz
                     </rs>und <rs type="person" ref="#pe__hanuschko_lang_QGW_II_I_1712">Hanuschko,
                        des Langen Procop sun, gesworen <roleName type="occ" corresp="#org__prag">burger</roleName> und <roleName type="occ" corresp="#org__prag">schepfen</roleName> der stat zu Prage</rs></rs>
                  .</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>