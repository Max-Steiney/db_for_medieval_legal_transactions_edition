               <rs type="event" ref="#ev__QGW_II_I_496"><rs type="fn" role="issuer"><rs type="person" ref="#pe__michael_ebner_QGW_II_I_496">Michel der Ebner von Medlich</rs> und
                        <rs type="person" ref="#pe__anna_QGW_II_I_496">Ann, seine <roleName type="kin" corresp="#pe__michael_ebner_QGW_II_I_496">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__heinrich_von_wallsee_QGW_II_I_496">ihrer <roleName type="title">Grundherren</roleName>
                        <roleName type="title">hern</roleName> Hainrichs <roleName type="occ" corresp="#org__oesterreich-herzogtum" select="#pl__drosendorf"><add>hauptleut</add></roleName></rs> und <rs type="person" ref="#pe__friedrich_von_wallsee_QGW_II_I_515_b"><roleName type="title"><add>Grundherren</add></roleName><roleName type="title">hern</roleName> Fridreichs von Waldse, <roleName type="occ" corresp="#org__oesterreich-herzogtum" select="#pl__drosendorf">haupleut</roleName> zu Drosendorf</rs></rs>, ihr Haus zu Medlich, das do
                  leit zenest Neitharts hous, des leinwater, an dem Charnmargcht, und eine Wiese,
                  die do leit zu Laxendorf zenest des vorgenanten Neitharts wis, wovon man 6 dn. zu
                  Grundrecht dient, um 50 ½ lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__meinhard_wascher_QGW_II_I_304">Meinharten dem Wascher von
                        Medlich</rs> und <rs type="person" ref="#pe__margarethe_QGW_II_I_496">seiner
                           <roleName type="kin" corresp="#pe__meinhard_wascher_QGW_II_I_304">Hausfrau</roleName> Margreten</rs>.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_496"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="#pe__heinrich_von_wallsee_QGW_II_I_496">hern Hainreichs</rs>, 2. <rs type="person" ref="#pe__friedrich_von_wallsee_QGW_II_I_515_b">hern Fridreichs von
                        Walse</rs>, 3.<rs type="person" ref="#pe__heinrich_werder_QGW_II_I_304">
                        Hainreichs des Werder, <roleName type="occ" corresp="#org__moedling">purger</roleName> zu Medlich</rs>, 4. <rs type="person" ref="#pe__ulrich_reindl_QGW_II_I_434">Ulreichs des Reindleins, <roleName type="occ" corresp="#org__moedling">purgraf</roleName> zu Medlich
                        und <roleName type="occ" corresp="#org__moedling">richter</roleName>
                        daselbs</rs> .</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>