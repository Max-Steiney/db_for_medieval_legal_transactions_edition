   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="#ev__QGW_II_I_1596"><rs type="fn" role="issuer"><rs
                        type="person" ref="#pe__peter_angerfelder_QGW_II_I_1373">Peter der
                        Angerfelder, <roleName type="occ" corresp="#org__wien"
                        >statrichter</roleName></rs>, und <rs type="org" ref="#org__wien">baid rêt,
                        der inner und der ausser, und die ganz gemain der stat zu Wienn</rs></rs>
                  <triggerstring n="disp">verpflichten sich</triggerstring>, die <rs type="event"
                     ref="#ev__QGW_II_I_1595">in Urk. no 1595</rs>
                  <rs type="fn" role="recipient">Genannten <rs type="person"
                        ref="#pe__johann_von_velden_QGW_II_I_1595"><add>Hanns von Velben,</add>
                        <rs type="person" ref="#pe__wilhelm_herzog_von_oesterreich_QGW_II_I_1313"
                              ><add>herzog Wilhalms</add></rs>
                        <roleName type="occ"
                           corresp="#pe__wilhelm_herzog_von_oesterreich_QGW_II_I_1313"><add>anwalt in
                              dem rat</add></roleName>
                        <add>ze Wienn</add></rs>, <rs type="person"
                        ref="#pe__konrad_vorlauf_QGW_II_I_1320"><add>Chunrat Vorlauf,</add>
                        <roleName type="occ" corresp="#org__wien"><add>purgermaister</add></roleName>
                        <add>daselbs</add></rs>, <rs type="person"
                        ref="#pe__haunold_schuchler_QGW_II_I_1557"><add>Haunolt Schu/echler,
                           des</add>
                        <roleName type="occ" corresp="#org__wien"><add>rats der stat</add></roleName>
                        <add>daselbs</add></rs>, <rs type="person"
                        ref="#pe__andreas_an_dem_st_petersfreithof_QGW_II_I_1398"><add>Andre an sand
                           Peters freithof,</add>
                        <roleName type="occ" corresp="#org__oesterreich-herzogtum"
                              ><add>chelermaister</add></roleName>
                        <add>in Osterreich</add></rs><add>, und</add>
                     <rs type="person" ref="#pe__rudolf_angerfelder_QGW_II_I_1335"><add>Rudolf
                           Angerfelder, des</add>
                        <roleName type="occ" corresp="#org__wien"><add>rats der stat</add></roleName>
                        <add>ze Wienn</add></rs></rs> am nächsten Martinstage <triggerstring n="disp"
                     >von ihrer Bürgschaft zu lösen und sie gegen jeden ihnen etwa aus derselben
                     erwachsenden Schaden und Anspruch zu sichern</triggerstring>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_1596"><rs type="fn" role="witness">Besiegelt mit
                     der <rs type="org" ref="#org__wien">stat ze Wienn</rs> klainem anhangundem
                     insigel.</rs></rs>
            </p>
         </div>
