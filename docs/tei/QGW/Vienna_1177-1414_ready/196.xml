   <text>
      <body>
         <div type="abstract" resp="ks">
            <p>
               <rs type="event" ref="#ev__QGW_II_I_196"><rs type="fn" role="issuer"><rs type="person"
                        ref="#pe__wilhelm_in_dem_strohof_QGW_II_I_197">Wilhalm, <roleName type="kin"
                           corresp="#pe__wilhelm_in_dem_strohof_QGW_II_I_180">sun</roleName><rs
                           type="person" ref="#pe__wilhelm_in_dem_strohof_QGW_II_I_180"><roleName
                              type="title">hern</roleName> Wilhalms sun in dem Strahof, <roleName
                              type="dead">dem got genade</roleName></rs></rs>, und seine
                     Geschwister</rs>
                  <triggerstring n="disp">stellen <add>einen Schuldbrief aus</add></triggerstring>
                  <rs type="fn" role="recipient"><rs type="person"
                        ref="#pe__konrad_wiltwercher_QGW_II_I_204">ihrem <roleName type="kin"
                           corresp="#pe__wilhelm_in_dem_strohof_QGW_II_I_197">geswein</roleName>
                        Chunraten dem Wiltwercher</rs></rs> einen Schuldbrief über 80 lb dn. aus,<rs
                     type="event" ref="#ev__QGW_II_I_196_men_1"> wovon er 44 lb dn. bereits den
                     Eltern geliehen und mit 36 lb dn. ihren Baumgarten sammt dem Hause, der da leit
                     in der Nidern Aue, von Petern Vogelein, purger ze Augspu/erch, gelöst
                     hatte.</rs> Dafür <triggerstring n="disp">verpfänden</triggerstring> sie ihm <rs
                     type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__niklas_QGW_II_I_196">ihres <roleName type="title"
                           >Grundherrn</roleName>
                        <roleName type="title">bruder</roleName> Niclas, <roleName type="occ"
                           corresp="#org__wien-st_johann_in_der_kaerntnerstrasse"
                           >comenteur</roleName> ze sande Johans in der Chernerstrasse ze
                        Wienne</rs></rs>, diesen Baumgarten mit dem Hause, von dem man jährlich 54
                  dn. zu Grundrecht dient.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_196">Besiegelt mit den Siegeln: <rs type="fn"
                     role="witness"><rs type="person" ref="#pe__niklas_QGW_II_I_196">1. des
                        Grundherrn,</rs>
                     <rs type="person" ref="#pe__hermann_snaeczl_QGW_II_I_196">2. <roleName
                           type="title">hern</roleName> Hermans des Snetzleins,</rs>
                     <rs type="person" ref="#pe__herbert_auf_der_saeule_QGW_II_I_184">3. <roleName
                           type="title">hern</roleName> Herborts auf der Seule,</rs>
                     <rs type="person" ref="#pe__hermann_von_st_poelten_QGW_II_I_118">4. <roleName
                           type="title">hern</roleName> Hermans, der <roleName type="kin"
                              corresp="#pe__rudolfine_QGW_II_I_417"
                           ><add>eninchel</add></roleName><rs type="person"
                           ref="#pe__rudolfine_QGW_II_I_417">Rudolfinne eninchel von Sande
                           Polten.</rs></rs></rs></rs>
            </p>
