            <date when="14020427">1402 IV 27</date>
            <origDate instant="false">ze Wienn, das nachsten phinztags nach sand Jorgen tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01510_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01510_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="#ev__QGW_II_I_1510"><rs type="fn" role="issuer"><rs type="person" ref="#pe__elisabeth_QGW_II_I_1498">Elspet, <rs type="person" ref="#pe__ulrich_QGW_II_I_1498">Ulreichs, des <roleName type="prof">cherzenmacher</roleName></rs>, <roleName type="kin" corresp="#pe__ulrich_QGW_II_I_1498">witibe</roleName>, <roleName type="occ" corresp="#org__wien">purgerin ze
                        Wienn</roleName></rs>,</rs>
                  <triggerstring n="disp">stiftet</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="#org__wien-st_stephan">hinz
                        Allerheiligen tumkirchen dacz sand Stephan ze Wienn auf Allerheiligen
                        altar</rs> eine dreimal in der Woche zu lesende ewige Messe,</rs>
                  <triggerstring n="disp">bestimmt nach ihrem Tode</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">zu Lehensherrn</triggerstring> den <rs type="org" ref="#org__wien">Rath der Stadt</rs>,</rs>
                  <triggerstring n="disp">verleiht</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn"><add>verleiht die
                        Messe</add></triggerstring>
                     <rs type="person" ref="#pe__georg_weikersdorfer_QGW_II_I_1510"><roleName type="title">hern</roleName> Jorgen dem Weikerstorfer, <roleName type="occ" corresp="#org__wien-st_stephan">curherr</roleName> bei <rs type="org" ref="#org__wien-st_stephan">S. Stephan</rs></rs>,</rs> und widmet zu derselben
                  ihr Haus, gelegen hinder der Würffel haus, das weilent der Vingerlerin gewesen
                  ist, an ainem tail zenechst Albrechts haus des Zetter und an dem andern tail
                  zenechst dem pachaus.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1510"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="#org__wien">städtischen Grundsiegel</rs> und den
                     Siegeln <rs type="person" ref="#pe__ulrich_herwart_QGW_II_I_1098">Ulreichs des Herwarts,
                           <roleName type="occ" corresp="#org__wien">statschreiber</roleName></rs>, und <rs type="person" ref="#pe__paul_geir_QGW_II_I_1406">Pauln des Geyr, des <roleName type="occ" corresp="#org__wien">aussern
                           rats der stat zu Wienn</roleName></rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>