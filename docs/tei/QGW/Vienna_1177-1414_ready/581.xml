               <rs type="event" ref="#ev__QGW_II_I_581"><rs type="fn" role="issuer"><rs type="person" ref="#pe__haunold_schuchler_QGW_II_I_170">Haunolt der Schüchler, <roleName type="occ" corresp="#org__wien">purgermaister</roleName></rs>, und <rs type="org" ref="#org__wien">der rat gemain der stat ze Wienn</rs></rs>
                  <triggerstring n="disp">bestätigen</triggerstring>, dass <rs type="fn" role="other"><triggerstring n="fn">vor ihnen</triggerstring>
                     <rs type="person" ref="#pe__elisabeth_QGW_II_I_581"><roleName type="title">Frau</roleName> Elspet,<roleName type="kin" corresp="#pe__stephan_neuburger_QGW_II_I_581"><add>witib</add></roleName>
