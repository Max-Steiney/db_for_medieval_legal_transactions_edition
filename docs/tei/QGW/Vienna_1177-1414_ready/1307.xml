                        <rs type="person" ref="#pe__andreas_fasszieher_QGW_II_I_1307"><add>Andres</add> des <roleName type="prof">vasziecher</roleName></rs>, der Kristein <roleName type="kin" corresp="#pe__christine_QGW_II_I_1307">tochter</roleName>
                        <roleName type="kin" corresp="#pe__johann_fasszieher_QGW_II_I_1307"><add>tochter</add></roleName> aus ihrer ersten Ehe</rs></rs>,
