                     seines <rs type="person" ref="#pe__stephan_kraft_QGW_II_I_1299"><roleName type="kin" corresp="#pe__johann_kraft_QGW_II_I_1292">Bruders</roleName> Stephans des
                     Kraften</rs></rs>.</rs>
