            <placeName>Wien</placeName>
            <date when="13380103">1338 I 03</date>
            <origDate instant="false">ze Wienne, des nasten samztags vor dem
            Perichttage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00183_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00183_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_183"><rs type="fn" role="issuer"><rs type="person" ref="#pe__ruediger_deggendorfer_QGW_II_I_183">Ruger der Tekendorfer,
                           <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                        Wienne,</rs> und <rs type="person" ref="#pe__klara_QGW_II_I_183">Chlar, seine
                           <roleName type="kin" corresp="#pe__ruediger_deggendorfer_QGW_II_I_183">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring> einen von Ruger ererbten Zehnten, des funfzehen lehen
                  ist an ain virtail, des zwai lehen ligent ze Vischamunde und aindlef lehen an ain
                  virtail ze Gerestein und ain lehen ze Deubtal und ain lehen ze Haslawe , . . . und
                     <rs type="fn" role="other">der<triggerstring n="fn"> ze lehen</triggerstring> ist von
                        <rs type="person" ref="#pe__hartneid_von_lichtenstein_QGW_II_I_183"><roleName type="title">hern</roleName> Hertneiten von Liechtenstain</rs></rs>, um
                  73 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__berthold_poll_QGW_II_I_121"><roleName type="title">hern</roleName>
                        Perichtolten dem Pollen, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienne,</rs> und <rs type="person" ref="#pe__margarethe_QGW_II_I_182"><roleName type="kin" corresp="#pe__berthold_poll_QGW_II_I_121">seiner Hausfrau</roleName>
                        Margreten.</rs></rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_183">Besiegelt mit den Siegeln: <rs type="fn" role="witness"><rs type="person" ref="#pe__ruediger_deggendorfer_QGW_II_I_183">1. des Ausstellers,</rs>
                     <rs type="person" ref="#pe__johann_deggendorfer_QGW_II_I_183">2. seines
                           <roleName type="kin" corresp="#pe__ruediger_deggendorfer_QGW_II_I_183">Bruders</roleName> Jans des Tekendorfer,</rs>
                     <rs type="person" ref="#pe__heinrich_von_brünn_QGW_II_I_183">3. <roleName type="title">hern</roleName> Hainreichs von Brunne, seines <roleName type="kin" corresp="#pe__ruediger_deggendorfer_QGW_II_I_183">swehers</roleName></rs>, <rs type="person" ref="#pe__berthold_geukramer_QGW_II_I_115">4. <roleName type="title">hern</roleName> Perichtolten des Geuchramer, <roleName type="occ" corresp="#org__wien-st_stephan">chirichmaister</roleName> datz sande
                        Stephan ze Wienne.</rs></rs></rs>
            </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. P. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>