            <date when="13510212">1351 II 12</date>
            <origDate instant="false">ze Wienne, des nasten samz/ztags nach sande Dorothen
               tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00369_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00369_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_369"><rs type="fn" role="issuer"><rs type="person" ref="#pe__margarethe_QGW_II_I_369"><roleName type="title">Swester</roleName>
                        Margret, <roleName type="occ" corresp="#org__wien-st_agnes_auf_der_himmelpforte">priolinne</roleName> in
                        sande Angnesen chloster dacz der Himelporten ze Wienne</rs>, und <rs type="person" ref="#pe__christine_QGW_II_I_369"><roleName type="title">swester</roleName> Christein von Sande Pölten, <roleName type="occ" corresp="#org__wien-st_agnes_auf_der_himmelpforte">subpriolinne</roleName>
                        in dem vorgenannten chloster</rs>, und<rs type="org" ref="#org__wien-st_agnes_auf_der_himmelpforte"> der convent gemain
                        doselbens</rs></rs>
                  <triggerstring n="disp">bestätigen <add>zu einer ewigen Messen angelegt
                     haben</add></triggerstring>, dass <rs type="fn" role="recipient">ihnen <rs type="person" ref="#pe__katharina_QGW_II_I_369"><roleName type="title">Frau</roleName> Katrei die Regenspurgerinne</rs></rs> zu einer ewigen
                  Messe 42 lb dn. mit der Bestimmung vermacht habe, für diesen Betrag 4 lb dn. gelts
                  zu kaufen, und dass sie davon 2 lb dn. gelts purchrechts auf Jorgen haus des
                  Niez/zz/zleins, das do leit in der Vodern Pekchenstrasse ze Wienne an dem ekk ,
                  und 2 lb dn. auf des pharrer haus von dem Gabatsch, das weilnt vrown Engeln
                  gewesen ist und das do leit in der Hindern Pekchenstrasse an dem ekk , angelegt
                  haben.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_369"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="org" ref="#org__wien-st_agnes_auf_der_himmelpforte">1.
                        des Convents</rs>, <rs type="person" ref="#pe__jakob_maeserl_QGW_II_I_121">2.
                           <roleName type="title">hern</roleName> Jacobs des
                  Maeserleins</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. O. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>