            <date when="14030906">1403 IX 06</date>
            <origDate instant="false">Geben ze Wienn nach Kristes geburde 1400 jar darnach in dem 3. jar, des
               nachsten phinztags nach sand Gilgen tag. </origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01554_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01554_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="#ev__QGW_II_I_1554"><rs type="fn" role="issuer"><rs type="person" ref="#pe__niklas_lerrer_QGW_II_I_1554">Niklas der Lerrer, <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                     Wienn</rs></rs>, <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> seines <rs type="person" ref="#pe__thomas_QGW_II_I_1527"><roleName type="title">Grundherrn</roleName> des <roleName type="occ" corresp="#org__wien-schotten">Schottenabtes</roleName>
                        <roleName type="title">hern</roleName> Thomann</rs></rs> 1 lb dn.
                     <triggerstring n="disp">geltes purkrechts</triggerstring> (ablösbar)z auf seinem
                  halben Joch Weingarten, gelegen aufm Jeus vor Stubentor ze Wienn zenechst Jacobs
                  weingarten des Snephfen, von dem man 70 dn. zu Grunddienst dient, um 8 lb dn., <rs type="event" ref="#ev__QGW_II_I_1554_men_1">welche die auf S. Dorotheenaltar bei S. Stephan
                     gestiftete Messe auf Ulreichs haus, des münzer, fraun Kathrein, seiner
                     hausfraun, haus gehabt hatte,</rs>
                  <rs type="fn" role="recipient">dem <rs type="person" ref="#pe__peter_QGW_II_I_1554"><roleName type="occ" corresp="#org__wien-st_stephan">Kaplan</roleName> dieser Messe <roleName type="title">hern</roleName> Petrein, <roleName type="occ" corresp="#org__wien-st_stephan">cantor</roleName> dacz sand Stephan ze
                        Wienn</rs>.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1554"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="#pe__thomas_QGW_II_I_1527">Schottenabtes</rs> und <rs type="person" ref="#pe__herbert_in_der_scheffstrasse_QGW_II_I_1102">Herwarts in der Scheffstrass, der <rs type="person" ref="#pe__beatrix_von_zollern_nuernberg_QGW_II_I_1048"><roleName type="title">hochgeborn</roleName>
                           <roleName type="title">furstin</roleName>
                           <roleName type="title">frau</roleName> Beatricis von Nurnberg, <roleName type="occ" corresp="#org__oesterreich-herzogtum">herzogin ze
                              Osterreich</roleName></rs>, <roleName type="occ" corresp="#pe__beatrix_von_zollern_nuernberg_QGW_II_I_1048">amptman</roleName>
                        daselbs</rs>.</rs></rs>
            </p></div><div type="nota"><p><rs type="event" ref="NULL">Indorsat: Umb 1 lb dn. purkrechtsgelts von Niclasen des
                  Lerrer weingarten auf dem Jeus zu dienen zu der mess, die zu der Cantorei
                  gehört.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>