                  <triggerstring n="disp">beurkunden</triggerstring>, dass sie <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_staindl_QGW_II_I_1532">Hannsen den Staindlein, herzog Leupolts <roleName type="occ" corresp="#pe__leopold_iv_herzog_von_oesterreich_QGW_II_I_1676">klainen
