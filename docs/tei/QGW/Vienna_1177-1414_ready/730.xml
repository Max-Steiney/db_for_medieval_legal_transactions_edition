            <date when="13680623">1368 VI 23</date>
            <origDate instant="false">ze Wienne, an dem Sunnbent abent.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00730_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00730_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="#ev__QGW_II_I_730"><rs type="fn" role="issuer"><rs type="person" ref="#pe__heinrich_wuerfel_QGW_II_I_1049">Hainreich der Würfel</rs></rs>
                  <triggerstring n="disp">beurkundet</triggerstring>, dass er mit <rs type="fn" role="recipient"><rs type="person" ref="#pe__niklas_wuerfel_QGW_II_I_1001">seinem <roleName type="kin" corresp="#pe__heinrich_wuerfel_QGW_II_I_1049">Bruder</roleName>
                        <roleName type="title">hern</roleName> Niclasen dem Würfel, <roleName type="occ" corresp="#org__wien">purgermaister</roleName> ze
                     Wienn</rs></rs>, die ihnen von ihren <rs type="person" ref="#pe__heinrich_wuerfel_QGW_II_I_459"><roleName type="kin" corresp="#pe__heinrich_wuerfel_QGW_II_I_1049">Eltern</roleName>
                     <roleName type="kin" corresp="#pe__niklas_wuerfel_QGW_II_I_1001"><add>Eltern</add></roleName>
                     <roleName type="title">hern</roleName> Hainreichen dem Würfel</rs> und <rs type="person" ref="#pe__katharina_QGW_II_I_128"><roleName type="kin" corresp="#pe__heinrich_wuerfel_QGW_II_I_1049"><add>Eltern</add></roleName>
                     <roleName type="kin" corresp="#pe__niklas_wuerfel_QGW_II_I_1001"><add>Eltern</add></roleName>
                     <roleName type="title">vrowen</roleName> Kathrein</rs> anerstorbenen Kaufgüter
                  getheilt habe. Dem Niklas sind zugefallen: ein weingarten, gelegen an dem
                  Wartperg, haisset der Chranichpeunt ain weingarten, gelegen ze Dornpach, des ein
                  halbs jeuch ist, in den Scheukchen dreu viertail weingarten, gelegen in dem
                  Paczental an dem Wiennerperg ain weingarten, gelegen ze Praitensê, des ein halbs
                  jeuch ist ain weingarten gelegen an dem Erkchenpolczpühel ouf zwain Weingärten,
                  gelegen hinder Alsse haisset in dem Stadel, 3 lb dn. geltes purchrechts 6
                  tagwerich wismads, gelegen ze Lachsendorf . Dem Heinrich sind zugefallen: 1 ½ Joch
                  Weingarten ze Haekking ein haus, gelegen vor Stubentor ze Wienn mit dem garten
                  und mit dem stadel daran 12 tagwerich wismads, gelegen ze Aichawe und haissent
                  die Slüsserinne.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_730"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="person" ref="#pe__heinrich_wuerfel_QGW_II_I_1049">1. des
                        Ausstellers</rs>, <rs type="person" ref="#pe__jakob_poll_QGW_II_I_770">2. des
                        Kaplans Jakob des Pollen</rs>, <rs type="person" ref="#pe__leopold_poltz_QGW_II_I_776">3. <roleName type="title">hern</roleName> Leupolts des Poltzs, <roleName type="occ" corresp="#org__wien">judenrichter</roleName> ze Wienne</rs>, den paiden
                     Heinrich der Würfel sein geschäft enpholhen hat, <rs type="person" ref="#pe__lukas_popphinger_QGW_II_I_776">4. des <roleName type="kin" corresp="#pe__heinrich_wuerfel_QGW_II_I_1049">Oheims</roleName> des
                        Ausstellers <roleName type="title">hern</roleName> Lucas des Popphinger,
                           <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                        Wienne</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>