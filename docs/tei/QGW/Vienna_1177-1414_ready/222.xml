                        <rs type="org" ref="#org__wien-heiligengeistspital">aller convent
                        daselbes</rs></rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__gerung_chol_QGW_II_I_185">ihres <roleName type="title">Bergherrn</roleName> des <roleName type="title">Ritters</roleName>
