               <rs type="event" ref="#ev__QGW_II_I_926"><rs type="fn" role="issuer"><rs type="person" ref="#pe__burkhard_QGW_II_I_918">Pu/erkchart <roleName type="kin" corresp="#pe__konrad_chamrer_QGW_II_I_918">
                           <add>su/en</add></roleName>, <rs type="person" ref="#pe__konrad_chamrer_QGW_II_I_918">Chu/enrats su/en des Kamrer,
                              <roleName type="dead">dem got genad</roleName>
                           <roleName type="rep" corresp="#pe__siegfried_QGW_II_I_918"><add>für</add></roleName></rs>, bei <rs type="person" ref="#pe__elisabeth_QGW_II_I_918"><roleName type="title">vrowen</roleName>
                           Elsbeten, seiner <roleName type="kin" corresp="#pe__konrad_chamrer_QGW_II_I_918"><add>Witwe</add></roleName>
                           <roleName type="kin" corresp="#pe__michael_fuechsel_QGW_II_I_1108">hausvrowen</roleName>, die nu/e Micheln den Fu/echslein êlichen genomen
                           hat</rs></rs></rs> , <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other">
                     <triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__paul_holzkaeufel_QGW_II_I_1010"><roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Paul des Holzkouffels</rs> und des
                        <rs type="org" ref="#org__wien">rates gemain der stat ze Wienne</rs></rs> für
                  sich und seinen <rs type="person" ref="#pe__siegfried_QGW_II_I_918"><roleName type="kin" corresp="#pe__burkhard_QGW_II_I_918">Bruder</roleName>
                     Seifrid</rs>, der nicht inner Landes ist und <rs type="event" ref="#ev__QGW_II_I_926_men_1">ihm
                     laut einer Urkunde der Stadt ze Weiden volle Gewalt übertragen hat</rs>, ihre
                  beiden Antheile an dem Hause, gelegen an dem Alten Kolmarkcht ze Wienne, von dem
                  man der Pfarrkirche zu sand Michel ze Wienne 12 sh. dn. dient, um 142 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__michael_fuechsel_QGW_II_I_1108">Micheln
                        dem Fu/echslein</rs> und seiner <rs type="person" ref="#pe__elisabeth_QGW_II_I_918"><roleName type="kin" corresp="#pe__michael_fuechsel_QGW_II_I_1108">Hausfrau</roleName>
                  Elsbeten</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_926"><rs type="fn" role="witness">Besiegelt mit
