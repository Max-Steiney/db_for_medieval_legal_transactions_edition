            <date when="13480309">1348 III 09</date>
            <origDate instant="false">des sunnetags, wann man singet Invocavit.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00319_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00319_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_319"><rs type="fn" role="issuer"><rs type="person" ref="#pe__konrad_QGW_II_I_410"><roleName type="title">Prueder</roleName>
                        Chu/onrat, <roleName type="occ" corresp="#org__heiligenkreuz-zisterzienser">abt</roleName> dacz dem Heiligen Chreutz</rs>, und der <rs type="org" ref="#org__heiligenkreuz-zisterzienser">convent gemainchlich desselben
                        chlaster</rs></rs>
                  <triggerstring n="disp">bestätigen</triggerstring>, zu Zeiten des Abtes Wulfing dem
                  Pfarrer zu Ruprechtshofen hern Andren dem Chrannest um 100 Mark Silber Wiener
                  Gewichtes 25 lb dn. geltes auf ihrem Hof zu Wien, der da haisset der Ziegelhof,
                     <triggerstring n="disp">verkauft zu haben</triggerstring>, die nach dessen Ableben
                  dem Kloster ledig werden sollten, unter der Bedingung, dass sie das in der ihnen
                  übergebenen Urkunde niedergelegte Geschäft Chrannests ausführen. Nun habe der
                  genannte <rs type="fn" role="recipient"><rs type="person" ref="#pe__andreas_chrannest_QGW_II_I_319">Andre der Chrannest, <roleName type="occ" corresp="#org__ruprechtshofen-pfarre">pharrer</roleName> ze Ruprechshofen
                        und <roleName type="occ" corresp="#org__passau-dioezese">chorherr</roleName> ze Passaue</rs></rs>, ihnen neuerdings 100 lb dn.
                  gegeben, für welche sie 11 lb dn. geltes kaufen sollen, so dass also die ganze
                  Gült 36 lb dn. betrage, die nach Chrannests Tod dem Kloster ledig sein sollen.
                  Dagegen <triggerstring n="disp"> verpflichten sie sich</triggerstring>, dem <rs type="fn" role="recipient"><rs type="person" ref="#pe__dietrich_chrannest_QGW_II_I_319"><roleName type="kin" corresp="#pe__andreas_chrannest_QGW_II_I_319">Bruder</roleName>
                        des <rs type="person" ref="#pe__andreas_chrannest_QGW_II_I_319">Pfarrers</rs>, <roleName type="title">hern</roleName> Dietreichen dem Chrannest</rs></rs>, seinen
                  Brief über 5 lb dn. geltes, das er dem Kloster an S. Maria Magdalena Tag zu dienen
                  hat, <triggerstring n="disp">zurückzustellen</triggerstring> und auch die anderen
                  letztwilligen Verfügungen des <rs type="person" ref="#pe__andreas_chrannest_QGW_II_I_319">Pfarrers</rs>
                  <triggerstring n="disp">auszuführen</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_319"><rs type="fn" role="witness">Besiegelt von
                        <rs type="person" ref="#pe__konrad_QGW_II_I_410">Abt</rs> und <rs type="org" ref="#org__heiligenkreuz-zisterzienser">Convent</rs></rs>.</rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>