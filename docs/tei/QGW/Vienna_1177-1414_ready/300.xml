            <origDate instant="false">zu Altenburch, an sand Jacobs tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00300_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00300_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="#ev__QGW_II_I_300"><rs type="fn" role="issuer"><rs>Mathes, abt
                        zu Altenburch</rs>, und <rs type="org" ref="#org__altenburg-benediktiner">alle di sampnung gemain desselben chlosters</rs></rs>
                  <triggerstring n="disp">bestätigen</triggerstring>, dass ihnen <rs type="fn" role="recipient">die <rs type="person" ref="#pe__leb_nussdorfer_QGW_II_I_401"><roleName type="title">erbern</roleName>
                        <roleName type="occ" corresp="#org__wien">purger</roleName> van Wienn
                        Leb der Nuz/zdorfer</rs>, <rs type="person" ref="#pe__ruediger_chaeser_QGW_II_I_281"><roleName type="title"><add>erbern</add></roleName>
                        <roleName type="occ" corresp="#org__wien"><add>purger</add></roleName>Ruger der Cheser</rs>, <rs type="person" ref="#pe__albrecht_noerdlinger_QGW_II_I_281"><roleName type="title"><add>erbern</add></roleName>
                        <roleName type="occ" corresp="#org__wien"><add>purger</add></roleName>Alber,<roleName type="kin" corresp="#pe__ortolf_noerdlinger_QGW_II_I_219"><add>sun</add></roleName>
                        <rs type="person" ref="#pe__ortolf_noerdlinger_QGW_II_I_219">Ortolfs sun des
                           Nordlinger</rs></rs></rs>, gegeben habent leuterlich durich got
                  ochtzechen schilling dn. gelts rechtes aigens, di do ligent zu Reichpoltsdorf pei
                  Pulka auf drîn westiften lechen, di seu dacz hern Albern von Ottenstain gechauft
                  habent umb 43 lb dn ., welche <rs type="person" ref="#pe__ortolf_noerdlinger_QGW_II_I_219">Ortolf der Nordlinger</rs> und seine
                     <rs type="person" ref="#pe__leukart_QGW_II_I_300"><roleName type="kin" corresp="#pe__ortolf_noerdlinger_QGW_II_I_219">Hausfrau</roleName>
                     Leukart</rs> ihrem <rs type="person" ref="#pe__jakob_QGW_II_I_300"><roleName type="kin" corresp="#pe__ortolf_noerdlinger_QGW_II_I_219">Sohne</roleName>
                     <roleName type="kin" corresp="#pe__leukart_QGW_II_I_300"><add>Sohne</add></roleName>, dem Mönche <roleName type="title">prueder</roleName> Jacoben, und nach dessen <roleName type="dead">Ableben</roleName></rs> dem Convente vermacht hatten, <triggerstring n="disp">und verpflichten sich zur Abhaltung eines Jahrtages</triggerstring> an sand
                  Chrispin und sand Chrispinians tage.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_300"><rs type="fn" role="witness">Besiegelt von
                        <rs>Abt</rs> und <rs type="org" ref="#org__altenburg-benediktiner">Convent</rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>