                     <triggerstring n="disp">beurkundet</triggerstring>, <rs type="event" ref="NULL">dass vor
                     ihm in der Bürgerschranne <rs type="person" ref="#pe__andreas_chrannest_QGW_II_I_319"><roleName type="title">her</roleName> Andre der Chrannest, <roleName type="occ" corresp="#org__ruprechtshofen-pfarre">pharrer</roleName> dacz
