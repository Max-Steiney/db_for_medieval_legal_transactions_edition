               <rs type="event" ref="#ev__QGW_II_I_246"><rs type="fn" role="issuer"><rs type="person" ref="#pe__jakob_von_feldsberg"><roleName type="title">Pruder</roleName> Jacob
                        van Velsperch, <roleName type="occ" corresp="#org__wien-dominikaner">prior</roleName>,</rs> und aller <rs type="org" ref="#org__wien-dominikaner">convent der pruder Prediger ordens ze
                     Wienn</rs></rs>
                  <triggerstring n="disp">verpflichten</triggerstring> sich gegen <rs type="fn" role="recipient"><rs type="person" ref="#pe__elisabeth_QGW_II_I_189_a"><roleName type="title">Frau</roleName> Elspet <roleName type="kin" corresp="#pe__otto_percz"><add>witwe</add></roleName>, weilen <rs type="person" ref="#pe__otto_percz"><roleName type="title">herrn</roleName> Otten Percz witwe ze Neunburch klosteres
