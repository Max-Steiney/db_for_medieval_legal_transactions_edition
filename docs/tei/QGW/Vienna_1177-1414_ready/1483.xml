                  <triggerstring n="disp">beurkundet, dass vor ihm in der Bürgerschranne</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="#pe__margarethe_QGW_II_I_1483"><roleName type="title">frau</roleName> Margret, die paternustrerin</rs>,
