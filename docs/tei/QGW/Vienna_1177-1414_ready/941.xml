            <origDate instant="false">ze Wienn, des nasten phinztags vor sand Urbans tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00941_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00941_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="#ev__QGW_II_I_941"><rs type="fn" role="issuer"><rs type="person" ref="#pe__michael_neuer_QGW_II_I_1298">Michel der Neuer, des <roleName type="occ" corresp="#org__wien">rats der stat ze Wienne</roleName></rs>, <rs type="person" ref="#pe__berthold_schuetzenmeister_QGW_II_I_941">Perichtolt der
                        Schuczenmaister <roleName type="occ" corresp="#org__wien"><add>purger
                              ze Wienne</add></roleName></rs> und <rs type="person" ref="#pe__jakob_graf_QGW_II_I_1122">Jacob der Graf, paid <roleName type="occ" corresp="#org__wien">purger ze Wienne</roleName></rs></rs>, <triggerstring n="disp">fällen in dem Streite</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">zwischen</triggerstring>
                     <rs type="person" ref="#pe__johann_chrannest_QGW_II_I_941">Jannsen dem Chrannest</rs></rs>
                  und <rs type="fn" role="other"><triggerstring n="fn"><add>zwischen</add></triggerstring>
                     <rs type="person" ref="#pe__elisabeth_feldsbergerin_QGW_II_I_912"><roleName type="title">vrowen</roleName> Elsbeten der Velczpergerinne, <rs type="person" ref="#pe__leb_QGW_II_I_941">Leben <roleName type="prof"><add>
                                 goltsmids</add></roleName></rs>
                        <roleName type="kin" corresp="#pe__leb_QGW_II_I_941">hausvrowe</roleName>,
                        des goltsmids</rs></rs>, wegen 8 lb dn.,<rs type="event" ref="#ev__QGW_II_I_941_men_1"> die
                     angeblich Jannsen dem Chrannest auf dem Hause der Elsbeth, gelegen an sand
                     Peters freithof gegen hern Hermanns hous von Eslarn uber ze Wienne zenast
                     Ulreichs hous des Singer , geschafft worden waren, wofür er aber keinen
                     urkundlichen Beweis beibringen konnte</rs>, <triggerstring n="disp">die
                     Entscheidung</triggerstring>, dass <rs type="fn" role="recipient"><rs type="person" ref="#pe__elisabeth_feldsbergerin_QGW_II_I_912">Elsbeth</rs></rs> ihrem
                  Gegner 3 lb dn. zu <triggerstring n="disp">bezahlen habe</triggerstring>, dafür aber
                     <triggerstring n="disp">von jeder weiteren Ansprache frei sein
                  solle</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_941"><rs type="fn" role="witness">Besiegelt von
