               <rs type="event" ref="#ev__QGW_II_I_584"><rs type="fn" role="issuer"><rs type="person" ref="#pe__agnes_QGW_II_I_584">Agnes, <roleName type="kin" corresp="#pe__heinrich_mit_den_vassen_QGW_II_I_584"><add>wittibe</add></roleName>
                        <rs type="person" ref="#pe__heinrich_mit_den_vassen_QGW_II_I_584">Hainreichs
                              <roleName type="dead">wittibe</roleName> mit den Vassen von
                           Grinzing</rs></rs>, <rs type="person" ref="#pe__during_von_fellabrunn_QGW_II_I_584">Durinch von Velabrunne</rs>,
                        <rs type="person" ref="#pe__heimo_von_fellabrunn_QGW_II_I_584">Haim von
                        Velabrunne</rs>, <rs type="person" ref="#pe__gerung_list_QGW_II_I_584">Gerunch der List von Pru/ederndorf <roleName type="kin" corresp="#pe__heinrich_mit_den_vassen_QGW_II_I_584"><add>Vettern</add></roleName></rs>, <rs type="person" ref="#pe__hartmann_gutmann_QGW_II_I_584">Hartman der Gutman daselbens ze
                        Pruderndorf , Heinrichs <roleName type="kin" corresp="#pe__heinrich_mit_den_vassen_QGW_II_I_584">Vettern</roleName></rs>,</rs>
                  <triggerstring n="disp">verkaufen mit gesammter Hand</triggerstring> und <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="#pe__niklas_von_wildungsmauer_QGW_II_I_807"><roleName type="title">Bergherrn</roleName>
                        <roleName type="title">pruder</roleName> Nichlas von Wildungsmaur, <roleName type="occ" corresp="#org__mailberg-johanniter">maister</roleName> des haus
                        ze Maeurperg und <roleName type="occ" corresp="#org__wien-johanniter">comiteur</roleName> des haus dacz sant Johans in der Chaernerstrasse ze
                        Wienne</rs> , und der <rs type="person" ref="#pe__kunigunde_QGW_II_I_363"><roleName type="title">Bergfrau</roleName>
                        <roleName type="title">swester</roleName> Chu/enigunden von Rappach,
                           <roleName type="occ" corresp="#org__wien-st_klara">abtessinne</roleName>
                        dacz sant Chlarn ze Wienne</rs></rs>, anderthalb achttail weingarten ze
                  Grinzing zwischen den Wegen zenächst Petreins weingarten von Velsperch , von denen
                  man den Johannitern 4 dn., dem S. Clarenkloster 6 dn. zu Bergrecht und 3 Ort zu
                  Voitrecht dient, um 9 lb dn. an 30 dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__ulrich_schoenobinall_QGW_II_I_405">Ulreichen dem
                        Scho/enobinallen ze Grinzing</rs> und seiner <rs type="person" ref="#pe__elisabeth_QGW_II_I_405"><roleName type="kin" corresp="#pe__ulrich_schoenobinall_QGW_II_I_405">Hausfrau</roleName>
                        Elsbeten</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_584"><rs type="fn" role="witness">Besiegelt mit
