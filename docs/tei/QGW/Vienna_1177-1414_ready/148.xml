               <rs type="event" ref="#ev__QGW_II_I_148"><rs type="fn" role="issuer"><rs type="person" ref="#pe__hartwig_II_I_148">Haertweich, der <rs type="person" ref="#pe__roettin_QGW_II_I_148">Roettinne</rs>
                        <roleName type="kin" corresp="#pe__roettin_QGW_II_I_148">sun</roleName></rs>,
                     und <rs type="person" ref="#pe__kunigunde_QGW_II_I_148">Chunigunt, seine
                           <roleName type="kin" corresp="#pe__hartwig_II_I_148">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__christine_QGW_II_I_148">ihrer <roleName type="title">Grundfrau</roleName>
                        <roleName type="title">Schwester</roleName> Christein, <roleName type="occ" corresp="#org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">Aebtissin</roleName> bei S. Niklas zu Wien</rs></rs>, einen Baumgarten,
                  den Kunigunde von ihrer <rs type="person" ref="#pe__gertrud_QGW_II_I_163"><roleName type="kin" corresp="#pe__kunigunde_QGW_II_I_148">Mutter</roleName>, der
                     Swaebinne</rs>, geerbt hatte, der da leit in der Nidern Aue zenaechst hern
                  Jacobs paumgarten des Maeserleins, und von dem man jährlich 45 dn. zu Grundrecht
                  dient, um 11 lb dn. an <rs type="fn" role="recipient"><rs type="person" ref="#pe__jakob_maeserl_QGW_II_I_121">Jacob den Maeserlein</rs> und <rs type="person" ref="#pe__katharina_QGW_II_I_148">seine <roleName type="kin" corresp="#pe__jakob_maeserl_QGW_II_I_121">Frau</roleName>
                     Katrein</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_148"><rs type="fn" role="witness">Besiegelt von
