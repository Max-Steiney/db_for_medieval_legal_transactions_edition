            <origDate instant="false">ze Wienn, des nachsten montags nach sand Ambrosien tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01507_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01507_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="#ev__QGW_II_I_1507"><rs type="fn" role="issuer"><rs type="person" ref="#pe__konrad_rampersdorfer_QGW_II_I_1107">Chunrat der Ramperstorfer
                           <roleName type="occ" corresp="#org__wien"><add>rats der
                           stat</add></roleName></rs> und <rs type="person" ref="#pe__johann_ziernast_QGW_II_I_1371">Hanns der Zyrnast, baid des <roleName type="occ" corresp="#org__wien">rats der stat</roleName> ze Wienn</rs>,</rs>
                  <triggerstring n="disp">beurkunden, dass</triggerstring>
                  <rs type="fn" role="other"><rs type="person" ref="#pe__johann_goldschmied_QGW_II_I_1507">Hanns, der <roleName type="prof">goltsmid</roleName>, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienn, <roleName type="rep" corresp="#pe__barbara_QGW_II_I_1507"><add>anstatt</add></roleName></rs>
                     <triggerstring n="fn"><add>an ainem tail</add></triggerstring></rs> anstatt seiner
                     <rs type="person" ref="#pe__barbara_QGW_II_I_1507"><roleName type="kin" corresp="#pe__johann_goldschmied_QGW_II_I_1507">Hausfrau</roleName>
                     Barbaren</rs> an ainem tail, <rs type="fn" role="other"><rs type="person" ref="#pe__johann_zerrer_QGW_II_I_1538">Hanns der Zerrer</rs> an sein selbs
                     stat und <rs type="person" ref="#pe__heinrich_hekchel_QGW_II_I_1538">Hainreich
                        der Hekchel von der Neunstat <roleName type="rep" corresp="#pe__katharina_QGW_II_I_1538">an<add>statt</add></roleName></rs>
                     <triggerstring n="fn"><add>an dem andern tail</add></triggerstring></rs> seiner <rs type="person" ref="#pe__katharina_QGW_II_I_1538"><roleName type="kin" corresp="#pe__heinrich_hekchel_QGW_II_I_1538">hausfraun</roleName> stat
                     Kathrein, desselben Zerrer <roleName type="kin" corresp="#pe__johann_zerrer_QGW_II_I_1538">swester</roleName></rs>, an dem
                  andern tail den Rath <triggerstring n="disp">um die Theilung</triggerstring> des Hauses
                     <triggerstring n="disp">gebeten haben</triggerstring>, <rs type="event" ref="#ev__QGW_II_I_1507_men_1">das sie von irm vater und enen Weicharten seligen, dem pheilsniczer,
                     anerstorben wer,</rs> gelegen oben an dem ekk under den Satlern ze Wienn an
                  ainem tail zenechst der gassen gegen des Ramperstorfer haus uber, das weilent des
                  Prenczer gewesen ist, und an dem andern tail zenechst Meinharts haus, des
                  pheilsniczer. Im Auftrage des Rathes <triggerstring n="disp">nehmen sie</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">nach der zwair werchmann
                        rat</triggerstring>
                     <rs type="person" ref="#pe__ulrich_warnhofer_QGW_II_I_1538"><roleName type="occ" corresp="#org__wien"><add>werchmann</add></roleName> Ulreichs
                        des Warnhofer, des <roleName type="prof">maurer</roleName>,</rs> und <rs type="person" ref="#pe__peter_zimmermann_QGW_II_I_1538"><add>werchmann</add>
                        <roleName type="title">maister</roleName> Petreins, des <roleName type="prof">zimermans</roleName></rs>,</rs>
                  <triggerstring n="disp">die Theilung vor</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1507"><rs type="fn" role="witness">Besiegelt von
                     den <rs type="person" ref="#pe__konrad_rampersdorfer_QGW_II_I_1107">Ausstellern</rs>
                     <rs type="person" ref="#pe__johann_ziernast_QGW_II_I_1371"><add>Ausstellern</add></rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>