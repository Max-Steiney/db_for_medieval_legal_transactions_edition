   <text>
      <body>
         <div type="abstract" resp="cs">
            <p>
               <rs type="event" ref="#ev__QGW_II_I_1668"><rs type="fn" role="issuer"><rs
                        type="person" ref="#pe__elisabeth_QGW_II_I_1668_a">Elspet <roleName type="kin"
                           corresp="#pe__markhard_emmrich_von_enns_QGW_II_I_1668"
                           ><add>tochter</add></roleName></rs>, <rs type="person"
                        ref="#pe__anna_QGW_II_I_1668">Ann<roleName type="kin"
                           corresp="#pe__markhard_emmrich_von_enns_QGW_II_I_1668"
                           ><add>tochter</add></roleName></rs> und <rs type="person"
                        ref="#pe__klara_QGW_II_I_1668">Chlar<roleName type="kin"
                           corresp="#pe__markhard_emmrich_von_enns_QGW_II_I_1668"
                           ><add>tochter</add></roleName></rs>, Maricharts töchter, des iricher von
                     Ens,</rs>
                  <triggerstring n="disp">bestätigen</triggerstring>, dass ihr <rs type="fn"
                     role="recipient"><rs type="person" ref="#pe__ulrich_schabenkes_QGW_II_I_1668"
                           ><roleName type="kin" corresp="#pe__elisabeth_QGW_II_I_1668_a"
                           >Schwager</roleName>
                        <roleName type="kin" corresp="#pe__klara_QGW_II_I_1668"
                           ><add>Schwager</add></roleName><roleName type="kin"
                           corresp="#pe__anna_QGW_II_I_1668"><add>Schwager</add></roleName>Ulreich
                        der Schabenkes, <roleName type="occ" corresp="#org__wien">purger</roleName>
                        ze Wienn</rs></rs>, ihnen 50 lb dn. <triggerstring n="disp">ausbezahlt
                     habe</triggerstring> von seinem Hause, gelegen in der Wildwercherstrass ze Wienn
                  zerlegst dem haus, das weilent Hainreichs, tuechscherer, ist gewesen , <rs
                     type="event" ref="NULL">das er mit <rs type="person"
                        ref="#pe__elisabeth_QGW_II_I_1668_b">seiner <roleName type="dead"
                           >früheren</roleName>
                        <roleName type="kin" corresp="#pe__ulrich_schabenkes_QGW_II_I_1668"
                           >Frau</roleName> Elspet, ihrer <roleName type="kin"
                           corresp="#pe__klara_QGW_II_I_1668">Muhme</roleName><roleName type="kin"
                           corresp="#pe__elisabeth_QGW_II_I_1668_a"
                           ><add>Muhme</add></roleName><roleName type="kin"
                           corresp="#pe__anna_QGW_II_I_1668"><add>Muhme</add></roleName>,</rs> deren
                     nächste Erben sie sind, gekauft hatte</rs>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_1668"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln <rs type="person" ref="#pe__johann_mosprunner_QGW_II_I_1096"
                           ><roleName type="title">hern</roleName> Hannsen des Mosprunner, des
                        innern <roleName type="occ" corresp="#org__wien">rates</roleName> der stat ze
                        Wienn,</rs> und <rs type="person" ref="#pe__konrad_rokk_QGW_II_I_1031"
                        >Chunraten des Rokken, <roleName type="occ" corresp="#org__wien"
                           >purger</roleName> daselbens</rs> .</rs></rs>
            </p>
         </div>
