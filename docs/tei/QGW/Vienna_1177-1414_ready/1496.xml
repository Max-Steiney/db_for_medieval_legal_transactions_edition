            <origDate instant="false">ze Wienn, des nechsten phinztags vor sand Michels tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01496_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01496_v.jpg"/></surface></facsimile><!-- gesworn werichmann evtl rep oder off --><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="#ev__QGW_II_I_1496"><rs type="fn" role="issuer"><rs type="person" ref="#pe__hermann_swarz_QGW_II_I_1496">Herman der Swarz
                           <roleName type="occ" corresp="#org__wien"><add>Stadtrat</add></roleName></rs> und <rs type="person" ref="#pe__jakob_waicz_QGW_II_I_1473">Jacob der Waicz, baid des <roleName type="occ" corresp="#org__wien">rates der stat</roleName> ze Wienn</rs>,</rs>
                  <triggerstring n="disp">beurkunden, dass</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="#pe__ulrich_herwart_QGW_II_I_1098">Ulreich
                        der Herwart, <roleName type="occ" corresp="#org__wien">statschreiber</roleName> ze Wienn, <roleName type="rep" corresp="#pe__ulrich_herwart_QGW_II_I_1496">anstatt</roleName></rs></rs> seines <rs type="person" ref="#pe__ulrich_herwart_QGW_II_I_1496">unmündigen <roleName type="kin" corresp="#pe__ulrich_herwart_QGW_II_I_1098"><add>Sohnes</add></roleName>
                     <roleName type="kin" corresp="#pe__margarethe_QGW_II_I_1494">Sohnes</roleName>
                     Ulreichs aus seiner <rs type="person" ref="#pe__margarethe_QGW_II_I_1494"><roleName type="kin" corresp="#pe__ulrich_herwart_QGW_II_I_1098">Ehe<add>frau</add></roleName> mit <roleName type="title">fraun</roleName> Margreten, <rs type="person" ref="#pe__johann_smerber_QGW_II_I_1496">Hannsen des Smerber <roleName type="dead"><add>got genad</add></roleName></rs>
                        <roleName type="kin" corresp="#pe__johann_smerber_QGW_II_I_1496">tochter</roleName>
                        <roleName type="kin" corresp="#pe__dorothea_QGW_II_I_1496"><add>tochter</add></roleName>
                        <rs type="person" ref="#pe__dorothea_QGW_II_I_1496"> bei <roleName type="title">fraun</roleName> Dorothen, seiner <roleName type="kin" corresp="#pe__johann_smerber_QGW_II_I_1496">hausfraun</roleName>
                           <roleName type="dead"><add>got genad</add></roleName></rs>, den allen
                           <roleName type="dead">got genad</roleName></rs>,</rs> und <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_milt_QGW_II_I_1496">Hanns
                        der Milt, des egenanten Hannsen des Smerber <roleName type="kin" corresp="#pe__johann_smerber_QGW_II_I_1496">sun</roleName>
                        <roleName type="kin" corresp="#pe__dorothea_QGW_II_I_1496"><add>sun</add></roleName> auch bei der egenanten Dorothen</rs>,</rs> vor
                  dem Rathe <triggerstring n="disp">um die Theilung</triggerstring> des Hauses und der
                  dazu gehörigen chre/amen, gelegen doran und darunder und sto/esset mit ainem tail
                  auf die Prantstat gegen sand Stephans freithof über und mit dem andern tail ligt
                  dasselb haus zenechst Philipps haus, des haubner, <rs type="event" ref="#ev__QGW_II_I_1496_men_1">das
                     alles der vorgenant Hanns der Smerber und frau Dorothe, sein hausfrau, mit
                     einander mit gesampter hant gechauft habent,</rs>
                  <triggerstring n="disp">angesucht haben</triggerstring>. Im Auftrage des Rathes
                     <triggerstring n="disp">nehmen</triggerstring> die beiden Aussteller <rs type="fn" role="other"><triggerstring n="fn">nach Rath</triggerstring> der zwair <rs type="person" ref="#pe__ulrich_warnhofer_QGW_II_I_1538"><roleName type="occ" corresp="#org__wien">gesworn werichmann</roleName>
                        <roleName type="title">maister</roleName> Ulreichs des Warnhofer</rs> und
                        <rs type="person" ref="#pe__peter_zimmermann_QGW_II_I_1538"><roleName type="occ" corresp="#org__wien"><add>gesworn werichmann</add></roleName>
                        <roleName type="title">maister</roleName> Petreins, des <roleName type="prof">zimermans</roleName></rs></rs>, <triggerstring n="disp">die
                     Theilung vor</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1496"><rs type="fn" role="witness">Besiegelt von
                     den <rs type="person" ref="#pe__hermann_swarz_QGW_II_I_1496">Ausstellern</rs>
                     <rs type="person" ref="#pe__jakob_waicz_QGW_II_I_1473"><add>Ausstellern</add></rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>