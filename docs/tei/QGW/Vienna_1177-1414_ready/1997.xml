   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="#ev__QGW_II_II_1997">
               <rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_QGW_II_II_1997">Janns,
                     der <roleName type="prof">hengelweiner</roleName> ze Simaning,</rs> und <rs type="person" ref="#pe__dorothea_QGW_II_II_1997">Dorothe, seine <roleName type="kin" corresp="#pe__johann_QGW_II_II_1997">hausfrau</roleName></rs></rs>, verkaufen<rs type="fn" role="other">
                  <triggerstring n="fn">mit Handen</triggerstring> [ 19] des <rs type="person" ref="#pe__johann_spannagel_QGW_II_II_1932"><roleName type="title">Burgherrn</roleName> Hannsen des Spannagels</rs></rs> acht Tagwerke Wiesen,
               gelegen ze Simaning zenechst Eberharts seligen wisen an ainem tail und zenechst der
               Seuringerin wisen an dem andern tail , von denen man 4 dn. an St. Michaelstag zu
               Burgrecht dient, um 26½ lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_strasser_QGW_II_II_2198"><roleName type="title">hern</roleName>
                     Hannsen dem Strasser, des <roleName type="occ" corresp="#org__wien">rats</roleName> der stat ze Wienn,</rs> und <rs type="person" ref="#pe__agnes_QGW_II_II_1997">seiner <roleName type="kin" corresp="#pe__johann_strasser_QGW_II_II_2198">Frau</roleName> Agnesen</rs>.</rs>
            </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_II_1997"><rs type="fn" role="witness">Besiegelt mit den Siegeln des <rs type="person" ref="#pe__johann_spannagel_QGW_II_II_1932">Burgherrn</rs> und <rs type="person" ref="#pe__johann_mosprunner_QGW_II_I_1096"><roleName type="title">hern</roleName> Hannsen des Mosprunner, des
                     <roleName type="occ" corresp="#org__wien">rats</roleName></rs>.</rs>
            </rs></p>
         </div>
