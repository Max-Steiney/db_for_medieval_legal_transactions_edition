            <date when="13601103">1360 XI 03</date>
            <origDate instant="false">ze Wienne, des naechsten eritags vor sand Lienharts
               tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00569_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00569_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_569"><rs type="fn" role="issuer"><rs type="person" ref="#pe__elisabeth_QGW_II_I_569">Elsbet,<roleName type="kin" corresp="#pe__heinrich_schuchler_QGW_II_I_193"><add>wittibe</add></roleName>
                        <rs type="person" ref="#pe__heinrich_schuchler_QGW_II_I_193"><roleName type="title">hern</roleName> Hainreichs <roleName type="dead">wittibe</roleName> des Schüchler</rs></rs></rs>, <triggerstring n="disp">beurkundet ihren letzten Willen</triggerstring>, <rs type="fn" role="other">wobei
                        <rs type="person" ref="#pe__konrad_von_gars_QGW_II_I_603"><roleName type="title">her</roleName> Chunrat von Gors </rs>und <rs type="person" ref="#pe__stephan_raedler_QGW_II_I_571"><roleName type="title">her</roleName>
                        Stephan der Raedler </rs><triggerstring n="fn">anwesend
                     waren</triggerstring></rs>.<triggerstring n="disp"> Sie schafft</triggerstring>: 1. 10
                  lb dn. gelts purchrechts (ablösbar mit 100 lb dn.) auf einem halben Joche
                  Weingarten, der do leit an dem Purchstall, und den sie ihrem Eidam Nichlas von
                  Eslarn verkauft hatte, <rs type="fn" role="recipient"><rs type="org" ref="#org__wien-st_stephan-messe_schuchler">zu der von ihrem Manne bei S.
                        Stephan gestifteten Messe</rs></rs> 2. <rs type="fn" role="recipient"><rs type="person" ref="#pe__elisabeth_QGW_II_I_499">ihrer <roleName type="kin" corresp="#pe__elisabeth_QGW_II_I_569">Tochter</roleName>
                           Elsbeten,<roleName type="kin" corresp="#pe__heinrich_vinkch_QGW_II_I_499"><add>hausvrowe</add></roleName>
                        <rs type="person" ref="#pe__heinrich_vinkch_QGW_II_I_499">Hainreichs
                           hausvrowe des Vinchen</rs></rs></rs>, ½ Joch Weingarten, gelegen in dem
                  Chrotenpach 3. <rs type="fn" role="recipient"><rs type="person" ref="#pe__engel_QGW_II_I_569">ihrer <roleName type="kin" corresp="#pe__elisabeth_QGW_II_I_569">Tochter</roleName> Englein <roleName type="kin" corresp="#pe__johann_von_mannswoerth_QGW_II_I_675"><add>hausvrowe</add></roleName>,<rs type="person" ref="#pe__johann_von_mannswoerth_QGW_II_I_675"> Jansen hausvrowe von
                           Mannswerd</rs></rs></rs>, ½ Joch Weingarten, gelegen in dem Hungerprunne,
                  ½ Joch Weingarten, gelegen an dem Liechtenstain, einen Mantel, einen sloier und
                  ein Bett 4. <rs type="fn" role="recipient"><rs type="person" ref="#pe__heinrich_schuchler_QGW_II_I_499">ihrem <roleName type="kin" corresp="#pe__elisabeth_QGW_II_I_569">Sohne</roleName>
                        <roleName type="title">hern</roleName> Hainreichen</rs></rs> ein Joch
                  Weingarten, gelegen an dem Liechtenstain 5. ihrer Muhme Englein 1 lb gelts,
                  gelegen auf einem weingarten an der Santleiten, und 1 lb dn. Baargeld 6. <rs type="fn" role="recipient"><rs type="org" ref="#org__wien-deutsche_herren">hinz
                        dem Taeutschen haus ze Wienne</rs></rs> 1 lb dn. gelts, gelegen auf einem
                  Judenhaus ze Wienne 7. <rs type="fn" role="recipient"><rs type="person" ref="#pe__anna_QGW_II_I_569">ihrer <roleName type="kin" corresp="#pe__elisabeth_QGW_II_I_569">Tochter</roleName> Annen, der
                           <roleName type="kin" corresp="#pe__niklas_von_eslarn_QGW_II_I_569">Hausfrau</roleName>
                        <rs type="person" ref="#pe__niklas_von_eslarn_QGW_II_I_569">des Nichlas von
                           Eslarn</rs></rs></rs>, einen Weingarten und ein Haus ze
                  Engelschalichstorf, sowie ihren Wein und ihre fahrende Habe.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_569"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="#pe__elisabeth_QGW_II_I_569">der
                        Ausstellerin</rs>, 2. <rs type="person" ref="#pe__johann_schuchler_QGW_II_I_460">ihres <roleName type="kin" corresp="#pe__elisabeth_QGW_II_I_569">Sohnes</roleName> Jansen des
                        Schüchler</rs>, ihrer Eidame 3. <rs type="person" ref="#pe__heinrich_vinkch_QGW_II_I_499">Hainreichs des Vinchen, <roleName type="title">purgraf</roleName> zdem Greitschenstain</rs>, 4. <rs type="person" ref="#pe__johann_von_mannswoerth_QGW_II_I_675">Jansen von
                        Manswerd</rs> und 5. <rs type="person" ref="#pe__niklas_von_eslarn_QGW_II_I_569">Nichlas von Eslarn</rs>, 6. <rs type="person" ref="#pe__konrad_von_gars_QGW_II_I_603"><roleName type="title">hern</roleName> Chunrats von Gors</rs>, 7. <rs type="person" ref="#pe__stephan_raedler_QGW_II_I_571"><roleName type="title">hern</roleName> Stephans des Raedler</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>