               <rs type="event" ref="#ev__QGW_II_I_258"><rs type="fn" role="issuer"><rs type="person" ref="#pe__jakob_eisenmann_QGW_II_I_258">Jacob der Eisenmann von Prichsen,
                           <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                        Wienne</rs>, und <rs type="person" ref="#pe__katharina_QGW_II_I_258">Kathrei,
                        seine <roleName type="kin" corresp="#pe__jakob_eisenmann_QGW_II_I_258">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihres <rs type="person" ref="#pe__heinrich_von_hagenberg_QGW_II_I_436"><roleName type="title">Bergherrn</roleName>
                        <roleName type="title">hern</roleName> Hainreichs von Hakkenberch, <roleName type="kin" corresp="#pe__leopold_von_hagenberg_QGW_II_I_295"><add>sun</add></roleName>
                        <rs type="person" ref="#pe__leopold_von_hagenberg_QGW_II_I_295"><roleName type="title">hern</roleName> Leutoldes sun von
                     Hakkenberch</rs></rs></rs>, ein Joch Weingarten, der da leit ze Nidern
                  Su/efringen an dem Hornperch, haisset der Minnstain, welcher der vorgenanten
                  Katrein rechtes anerstorbens erbe ist von vater und von mu/eter, da man alle iar
                  von dient zwen emmer weins ze perchrecht und 2 dn. ze voitrecht . . . und leit
                  zenaehst hern Reinprechten des Zaunru/ede weingarten, um 80 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__ulrich_zeller_QGW_II_I_258"><roleName type="title">hern</roleName> Ulreichen dem Zeller, der
                        herzoginne huchenmaister</rs>, und seiner <rs type="person" ref="#pe__margarethe_QGW_II_I_258"><roleName type="kin" corresp="#pe__ulrich_zeller_QGW_II_I_258">Hausfrau</roleName>
                        Margreten</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_258"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="person" ref="#pe__jakob_eisenmann_QGW_II_I_258">1. des
                        Ausstellers</rs>, <rs>2. des Bergherrn</rs>, <rs type="person" ref="#pe__reinhard_zaunruede_QGW_II_I_297">3. <roleName type="title">hern</roleName> Reinprechts des Zaunru/eden, <roleName type="occ" corresp="#org__wien">judenrichter</roleName> ze Wienne</rs>, <rs type="person" ref="#pe__dietrich_urbetsch_QGW_II_I_950">4. <roleName type="title">hern</roleName> Dietreichs des Urwaetschen, <roleName type="occ" corresp="#org__wien">münzmaister</roleName> ze Wienne</rs>, und
                        <rs type="person" ref="#pe__dietrich_chleber_QGW_II_I_258">5. <roleName type="title">hern</roleName> Dietreichs des Chleber</rs>.</rs></rs>
