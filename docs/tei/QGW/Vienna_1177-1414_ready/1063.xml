                        <rs type="person" ref="#pe__ulrich_roessl_QGW_II_I_1025"><roleName type="title">hern</roleName> Ulreichs des Röz/zz/zleins, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienne</rs>.</rs></rs>
