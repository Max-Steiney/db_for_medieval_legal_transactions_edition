               <rs type="event" ref="#ev__QGW_II_I_1063"><rs type="fn" role="issuer"><rs type="person" ref="#pe__peter_QGW_II_I_1063">Peter <roleName type="kin" corresp="#pe__johann_schneider_QGW_II_I_1063"><add>sun</add></roleName>
                        <roleName type="kin" corresp="#pe__anna_QGW_II_I_1063"><add>sun</add></roleName></rs></rs>, <rs type="person" ref="#pe__johann_schneider_QGW_II_I_1063">Jannsen <roleName type="dead">seligen</roleName>, des <roleName type="prof">sneider</roleName></rs>, sun
                  bei <rs type="person" ref="#pe__anna_QGW_II_I_1063"><roleName type="title">fraun</roleName> Annen, seiner <roleName type="kin" corresp="#pe__johann_schneider_QGW_II_I_1063">hausfrawen</roleName>, die
                     nu Hainreichen den Hu/etstokch <roleName type="kin" corresp="#pe__heinrich_hutstock_QGW_II_I_1063"><add>hausfrau</add></roleName>
                     eleichen genomen hat</rs> , <triggerstring n="disp">verzichtet</triggerstring> zu
                  Gunsten <rs type="fn" role="recipient">
                     <rs type="person" ref="#pe__heinrich_hutstock_QGW_II_I_1063">seines <roleName type="kin" corresp="#pe__peter_QGW_II_I_1063">Stiefvaters</roleName></rs></rs>
                  <triggerstring n="disp">auf seinen Anspruch</triggerstring>
                  <triggerstring n="disp">an die von diesem und der Mutter mit gesammter Hand gekauften
                     Erbgüter</triggerstring>: von erst eins hauses, gelegen in dem Huenrge/asslein ze
                  Wienn zenechst dem haus, das weilnt . . der Waldnerinne gewesen ist darnach eins
                  weingartens, gelegen ze Neuburkch in der Cho/elrgru/eb, des ein halbs jeuch ist,
                  zenechst dem weingarten, der da haisset der Drêmel .</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1063"><rs type="fn" role="witness">Besiegelt mit
