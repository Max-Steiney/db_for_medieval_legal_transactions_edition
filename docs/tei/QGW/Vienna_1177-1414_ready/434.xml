            <date when="13530511">1353 V 11</date>
            <origDate instant="false">ze Wienne, an dem heiligen abent ze Phingsten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00434_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00434_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_434"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_padner_QGW_II_I_434">Jans der Padner von der Neuenstat
                     </rs>und <rs type="person" ref="#pe__katharina_QGW_II_I_434">Katrei, <roleName type="kin" corresp="#pe__johann_padner_QGW_II_I_434">seine
                           Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__ulrich_reindl_QGW_II_I_434">ihres <roleName type="title">Bergmeisters</roleName> Ulreichs Reindleins von Medlikch,
                           <roleName type="occ" corresp="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_596">pergmaister</roleName> des <rs type="person" ref="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_596"><roleName type="title">Herzogs</roleName> Albrecht zu Medlikch</rs></rs></rs>,
                  zwei Weingärten, welche Kathrein von ihren Grosseltern mütterlicherseits geerbt
                  und in der Theilung mit ihren Oheimen Reimprechten und Pauln, den prudern bei dem
                  Prunnen, erhalten hatte, beide gelegen ze Prunne in dem Paerbeinstal, der ainer
                  haisset der Rotenpurger (belastet mit ½ Eimer Wein Bergrecht, 1 Helbling
                  Voitrecht), und leit zenaehst Hainreichs chinder weingarten des Vogler, so haisset
                  der ander weingart der Tanner (belastet mit ½ Eimer Wein Bergrecht, 1 Helbling
                  Voitrecht), und leit zenaehst Hainreichs weingarten des Hefer, um 50 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__konrad_von_neuburg_QGW_II_I_434">dem <roleName type="occ" corresp="#org__wien">Wiener Bürger</roleName> Chunraden von
                        Neuenburch</rs> und <rs type="person" ref="#pe__margarethe_QGW_II_I_434">seiner <roleName type="kin" corresp="#pe__konrad_von_neuburg_QGW_II_I_434">Hausfrau</roleName> Margreten</rs></rs>. </rs></p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_434"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="#pe__johann_padner_QGW_II_I_434">des
                        Ausstellers</rs>, 2. <rs type="person" ref="#pe__ulrich_reindl_QGW_II_I_434">des Bergmeisters</rs>, 3.<rs type="person" ref="#pe__reimprecht_bei_dem_brunnen_QGW_II_I_434"> Reimprechts</rs>, 4. <rs type="person" ref="#pe__paul_bei_dem_brunnen_QGW_II_I_434">Pauln, der
                           <roleName type="kin" corresp="#pe__reimprecht_bei_dem_brunnen_QGW_II_I_434">pruder</roleName>
                        bei dem Prunnen</rs></rs>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>