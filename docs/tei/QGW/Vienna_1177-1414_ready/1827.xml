                     <rs type="fn" role="recipient"><rs type="org" ref="#org__wien">burgeren des rats
                        der stat zu Wienn</rs></rs>, dass <rs type="person" ref="#pe__konrad_kunig_QGW_II_I_1827">Conrad Kunig, herzog Johannsen <roleName type="occ" corresp="#pe__johann_herzog_von_bayern_QGW_II_I_1827">wirt</roleName> zu Regens( burg),</rs>
