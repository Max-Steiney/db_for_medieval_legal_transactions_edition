         <div type="abstract">
            <p><rs type="event" ref="#ev__QGW_II_II_1912"><rs type="fn" role="issuer"><rs
               type="person" ref="#pe__johann_QGW_II_II_1912"><roleName type="occ"
                           corresp="#org__melk-benediktiner">Abt</roleName> Johann von Melk</rs></rs>
                  <triggerstring n="disp">verleiht</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person"
                        ref="#pe__paul_wuerfel_QGW_II_II_1928">Paul dem Würffel</rs></rs> zwai tail
                  getraidzehent auf dreuczehen halb lehen, gelegen ze Honesdorf enhalb des pachs,
                  zwai tail zehent auf 52 jeuch achkern, gelegen ze Minkchendorf , und einen
                  Weinzehent auf vier Weingärten, gelegen ze Medling, genant in den Urtailn, <rs
                     type="event" ref="NULL">die er von<rs type="person"
                        ref="#pe__johann_pusenchoph_QGW_II_II_1912"> Hannsen dem Pusenchoph</rs>
                     gekauft hatte</rs>.</rs>
