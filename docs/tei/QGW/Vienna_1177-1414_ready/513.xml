            <origDate instant="false">ze Wienne, an sant Cholmans tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00513_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00513_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p><rs type="event" ref="#ev__QGW_II_I_513">
                  <rs type="fn" role="issuer"><rs type="person" ref="#pe__gertrud_QGW_II_I_504"><roleName type="title">Swester</roleName> Gedraut die Setzerinne,
                           <roleName type="occ" corresp="#org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">abtessinne</roleName></rs>, und <rs type="org" ref="#org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">der convent
                        gemain der gaestleichen vrowenchloster dacz sant Nichlas vor Stubentor ze
                        Wienne</rs>
                  </rs>, <triggerstring n="disp">beurkunden <add>ein abgeschlossenes
                        Tauschgeschäft</add></triggerstring> ein <rs type="fn" role="other"><triggerstring n="fn">mit</triggerstring>
                     <rs type="person" ref="#pe__jakob_poll_QGW_II_I_770"><roleName type="title">hern</roleName> Jacoben dem Pollen, <roleName type="occ" corresp="#org__wien-st_maria_im_rathaus">chaplan</roleName> der chapelln
                        Unser Vrowen in der purger Rathaus ze Wienne, hern Otten Haim
                     Stiftung</rs></rs> , abgeschlossenes Tauschgeschäft.<triggerstring n="disp">
                     <rs type="fn" role="recipient"><rs type="person" ref="#pe__jakob_poll_QGW_II_I_770">Sie geben</rs></rs></triggerstring><rs type="fn" role="other">
                     <triggerstring n="fn">mit <add>hant</add></triggerstring>
                     <rs type="person" ref="#pe__heinrich_puchveler_QGW_II_I_495">Hainreichs hant,
                        des pyrmeider, <roleName type="occ" corresp="#org__wien-schotten">amman</roleName> und <roleName type="occ" corresp="#org__wien-schotten">phleger</roleName> der Schotten gut ze Wienne</rs></rs>, ½ lb dn. gelts
                  ewigs purchrechts auf Weicharts haus, des puchsendrächsel, das da leit in der
                  Traibotenstrasse ze Wienne zenaechst Pürkchleins haus, des wolslaher , und <rs type="fn" role="recipient"><rs type="org" ref="#org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">erhalten
                           dafür<rs type="person" ref="#pe__gertrud_QGW_II_I_504">
                           <add>erhalten dafür</add></rs></rs></rs> 1/2 lb dn. gelts gruntrechts,
                  welches die Kapelle auf 30 jeuchart Klosteräckern ze Swechent gehabt hatte. Das
                  Grundrecht hatte der Kaplan gekauft für das Geld, mit dem das Burgrecht abgelöst
                  worden war, das der Kapelle von der Furtmül ze Swechent gedient wurde und das zu
                  der Jahrtagstiftung des genannten hern Otten und seiner Hausfrau Gedrauten
                  gehörte. </rs></p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_513"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: <rs type="person" ref="#pe__gertrud_QGW_II_I_504">1.
                           <add>Aussteller</add></rs>, <rs type="org" ref="#org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">2. der
                        Aussteller</rs>, <rs type="pe" ref="#pe__heinrich_puchveler_QGW_II_I_495">3.
                        des Schottenamtmannes</rs>.</rs></rs>
            </p></div><div type="nota"><p>Indorsat: Aufschrift des Magister Theodericus. K. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>