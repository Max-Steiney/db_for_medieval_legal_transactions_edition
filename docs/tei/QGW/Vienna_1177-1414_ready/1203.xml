                        <roleName type="kin" corresp="#pe__ludwig_von_tierna_QGW_II_I_1351"><add>bruder</add></roleName>, 2. <roleName type="title">hern</roleName> Rudolfs von Tyrna, <roleName type="occ" corresp="#org__oesterreich-herzogtum">hubmaister</roleName> in
                        Österreich</rs>, 3. <rs type="person" ref="#pe__ludwig_von_tierna_QGW_II_I_1351">
                        <roleName type="kin" corresp="#pe__friedrich_von_tierna_ii_QGW_II_I_1106"><add>vettern</add></roleName>Ludweigs von Tyrna, seins <roleName type="kin" corresp="#pe__rudolf_von_tierna_QGW_II_I_1351">bruders</roleName></rs>.</rs></rs></p></div><div type="nota"><p>Indorsat: Uber den Obern Werde. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>