                Schotten zu Wien</rs></rs>
            <triggerstring n="disp">bezeugen</triggerstring>, dass <rs type="fn" role="recipient"><rs type="person" ref="#pe__konrad_hubmeister_QGW_II_I_207">der <roleName type="title">Ritter</roleName>
