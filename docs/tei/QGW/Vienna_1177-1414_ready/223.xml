            <placeName>Wien</placeName>
            <date when="13400817">1340 VIII 17</date>
            <origDate instant="false">ze Wienne, des naehsten phinztages nach Unser Vrowen tage der
               schiedunge.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00223_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00223_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p><rs type="event" ref="#ev__QGW_II_I_223">
                  <rs type="fn" role="issuer"><rs type="person" ref="#pe__otto_von_wultzendorf_QGW_II_I_223">Otte von Wultzendorf, <rs type="person" ref="#pe__rudwein_QGW_II_I_223">des <roleName type="occ" corresp="#org__klosterneuburg-augustiner_chorherren">Propstes</roleName> Rudweins</rs>
                        <roleName type="occ" corresp="#pe__rudwein_QGW_II_I_223">perchmaister</roleName> und <roleName type="occ" corresp="#pe__rudwein_QGW_II_I_223" select="#pl__klosterneuburg">amptmann</roleName> ze Neuenburch</rs></rs>, <triggerstring n="disp">beurkundet</triggerstring>, dass vor ihn ze Otakchrinne <rs type="fn" role="other"><triggerstring n="fn">in rechtem etaiding</triggerstring>
                     <rs type="person" ref="#pe__dietrich_urbetsch_QGW_II_I_950"><roleName type="title">her</roleName> Dietreich der Urbetsch, <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                     Wienne</rs></rs>, <rs type="fn" role="other"><triggerstring n="fn">ze
                        gegenburte</triggerstring> dem egenanten <rs type="person" ref="#pe__rudwein_QGW_II_I_223">probest Rudwein</rs> und ander erbern leuten,
                     die desselben tages da waren</rs> , gekommen sei und wegen 3 lb dn. versessenen
                  gelts ewiges purchrechtes auf einem Weingarten, der da leit ze Otakchrinne, des
                  dreu virtail sint und haisset der Zairekcher, der weiln und e Jacobes, hern Rugers
                  sun, des chropphaten schreiber, gewesen ist, davon man dient alle iar ze rechtem
                  perchrecht dem goteshaus ze Neuenburch achthalb virtail weins und sechsthalben
                  phenninge ze voitrecht , Klage erhoben habe, <rs type="fn" role="recipient">worauf
                        <rs type="person" ref="#pe__dietrich_urbetsch_QGW_II_I_950">er</rs> des
                     Weingartens gewaltig gemacht worden sei</rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_223"><rs type="fn" role="witness">Besiegelt von
                        <rs type="person" ref="#pe__otto_von_wultzendorf_QGW_II_I_223"> dem
                        Aussteller</rs> und <rs type="person" ref="#pe__konrad_herrscheftel_QGW_II_I_447"><roleName type="title">hern</roleName> Chunrat dem Herscheftelin</rs>.</rs></rs></p></div><div type="nota"><p>Indorsat: super vinea chophater schreiber. </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>