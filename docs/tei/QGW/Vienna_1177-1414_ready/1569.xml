               <rs type="event" ref="#ev__QGW_II_I_1569"><rs type="fn" role="issuer"><rs type="person" ref="#pe__niklas_rorcholb_QGW_II_I_1129">Niclas der Rorkolb, <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                     Wienn</rs>,</rs>
                  <triggerstring n="disp">gibt</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__michael_frankch_QGW_II_I_1569"><roleName type="title">Bergherrn</roleName>
                        <roleName type="title">hern</roleName> Michels des Frankchen,
                              <unclear instant="false"><roleName type="occ" corresp="#org__wien-st_johann_in_der_burg">chaplan</roleName> Unser Vraun und sand Johanns chapellen, gelegen in
                           der herzogen Purkch ze Wienn</unclear></rs>,</rs>
                  <triggerstring n="disp">zu</triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="#org__wien-st_stephan">sand Morando
                        chapellen, gelegen dacz sand Stephann ze Wienn</rs>,</rs> seinen Weingarten,
                  genant der Toppler, gelegen dacz Sand Veit an dem Miesenchogel, des anderhalb
                  jeuch ist, zenegst dem weingarten, der weilnt Stephans von Sand Veit ist gewesen ,
                  von dem man 60 dn. für Bergrecht, Zehent und Voitrecht dient.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1569"><rs type="fn" role="witness">Besiegelt mit
