            <origDate instant="false">ze Wienn, des nächsten mantags vor sand Michels tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01309_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01309_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="#ev__QGW_II_I_1309"><rs type="fn" role="issuer"><rs type="person" ref="#pe__lucia_QGW_II_I_1018">Lucei, <rs type="person" ref="#pe__stephan_naezeuger_QGW_II_I_1011">Stephans des Nezeuger <roleName type="dead"><add>witib</add></roleName></rs>
                        <roleName type="kin" corresp="#pe__stephan_naezeuger_QGW_II_I_1011">wittib</roleName></rs>,
                     und <rs type="person" ref="#pe__johann_naezeuger_ii_QGW_II_I_1018">Jans der Nezeuger, ir
                           <roleName type="kin" corresp="#pe__lucia_QGW_II_I_1018">sun</roleName></rs></rs>, <rs type="event" ref="#ev__QGW_II_I_1309_men_1">der seine Mündigkeit vor
                     dem Rathe bewiesen hatte</rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__michael_geukramer_QGW_II_I_1235"><roleName type="title">hern</roleName> Michels des Geuchramer, <roleName type="occ" corresp="#org__wien">purgermaister</roleName> und <roleName type="occ" corresp="#org__oesterreich-herzogtum" select="#pl__wien">münzmaister</roleName></rs>, und des <rs type="org" ref="#org__wien">rats
                        gemain der stat ze Wienn</rs></rs> zwei Drittel des Hauses, gelegen an dem
                  Hochenmarcht in dem Winkchl zenechst dem Ziegelhaus, <rs type="event" ref="#ev__QGW_II_I_1309_men_2">die ihnen in rechter Erbtheilung gegen der <rs type="person" ref="#pe__margarethe_QGW_II_I_1172">Lucein <roleName type="kin" corresp="#pe__lucia_QGW_II_I_1018">tochter</roleName> Margreten, Hainreichs
                           <roleName type="kin" corresp="#pe__heinrich_von_jamnitz_QGW_II_I_1778">hausfraun</roleName>
                        <rs type="person" ref="#pe__heinrich_von_jamnitz_QGW_II_I_1778"><add>Hainreich</add> von
                           Je/ampnicz, <roleName type="dead"><add>got gnad</add></roleName></rs> den
                        baiden <roleName type="dead">got gnad</roleName></rs> ,, zugefallen
                     waren</rs>, um 400 lb dn. dem <rs type="fn" role="recipient"><rs type="person" ref="#pe__michael_chotanner_QGW_II_I_1309">Wiener <roleName type="occ" corresp="#org__wien">Bürger</roleName> Micheln dem Chotaner</rs></rs>, <rs type="event" ref="#ev__QGW_II_I_1309_men_3">der sie mit Handen des Bürgermeisters und des Rathes
                     seiner <rs type="person" ref="#pe__kunigunde_QGW_II_I_1309"><roleName type="kin" corresp="#pe__michael_chotanner_QGW_II_I_1309">Hausfrau</roleName> Kunigunden</rs> zu
                     rechter Morgengabe vermacht</rs>.</rs></p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1309"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="#org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="#pe__ulrich_herwart_QGW_II_I_1098"><roleName type="occ" corresp="#org__wien">Stadtschreibers</roleName> Ulreichs des
