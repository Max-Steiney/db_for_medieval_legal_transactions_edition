   <text>
      <body>
         <div type="abstract" resp="cs">
            <p>
               <rs type="event" ref="#ev__QGW_II_I_1085"><rs type="fn" role="issuer"><rs
                        type="person" ref="#pe__johann_jan_QGW_II_I_1085">Janns der Jan, der
                           <roleName type="prof">goltsmid</roleName>, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienne</rs></rs>, <triggerstring
                     n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs
                        type="person" ref="#pe__paul_holzkaeufel_QGW_II_I_1010"><roleName type="occ"
                           corresp="#org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Pauln des Holzkäuffels</rs> und des
                        <rs type="org" ref="#org__wien">rates gemain der stat ze Wienn</rs></rs> ein
                  Haus, <rs type="event" ref="#ev__QGW_II_I_1085_men_1">das ihm seine <rs
                        type="person" ref="#pe__dorothea_QGW_II_I_895"><roleName type="dead"
                           >frühere</roleName>
                        <roleName type="kin" corresp="#pe__johann_jan_QGW_II_I_1085"
                           >Hausfrau</roleName> Dorothe</rs> hinterlassen hatte</rs>, gelegen in der
                  Goltsmiedgassen bei sand Stephan ze Wienn zenechst Hannsen haus des Görlitz , um
                  200 lb dn. <rs type="fn" role="recipient"><rs type="person"
                        ref="#pe__oswald_pauch_QGW_II_I_1371">Oswalden dem Pauch, dem <roleName
                           type="prof">goltsmied</roleName>, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienn</rs>, und seiner <rs
                        type="person" ref="#pe__margarethe_QGW_II_I_1085"><roleName type="kin"
                           corresp="#pe__oswald_pauch_QGW_II_I_1371">Hausfrau</roleName>
                        Margreten</rs></rs>.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_1085"><rs type="fn" role="witness">Besiegelt : 1.
                     mit dem Siegel des <rs type="person" ref="#pe__johann_jan_QGW_II_I_1085"
                        >Ausstellers</rs>, 2. mit dem <rs type="org" ref="#org__wien">städtischen
                        Grundsiegel</rs>, 3. mit dem Siegel <rs type="person"
                        ref="#pe__johann_prentschenk_QGW_II_I_1047">Hannsen des Prentschenkchen, des
                           <roleName type="prof">goltsmieds</roleName>, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienn</rs>.</rs></rs>
            </p>
         </div>
