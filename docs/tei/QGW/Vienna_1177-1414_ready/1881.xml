   <text>
      <body>
         <div type="abstract" resp="cs">
            <p>
               <rs type="event" ref="#ev__QGW_II_I_1881"><rs type="fn" role="issuer"><rs
                        type="person" ref="#pe__konrad_chiemseer_StB_I_178">Chunrat der Chiemseer,
                           <roleName type="occ" corresp="#org__wien-buergerspital"
                           >schpitolmaister</roleName> var Chernertor ze Wienn</rs>,</rs>
                  <triggerstring n="disp">bestätigt</triggerstring>, <rs type="fn" role="recipient">dass
                        <rs type="person" ref="#pe__johann_mosprunner_QGW_II_I_1096">Hans
                           Mosprunner<roleName type="rep"
                           corresp="#pe__johann_arnstorfer_QGW_II_I_1249"
                           ><add>geschefftherren</add></roleName></rs> und<rs type="person"
                        ref="#pe__oswald_pauch_QGW_II_I_1371"> Aswald der Pauch, paid <roleName
                           type="rep" corresp="#pe__johann_arnstorfer_QGW_II_I_1249"
                           >geschefftherren</roleName></rs></rs>
                  <rs type="person" ref="#pe__johann_arnstorfer_QGW_II_I_1249">Hansen des
                     Arnstorffer</rs> und <rs type="person" ref="#pe__margarethe_QGW_II_I_1614"
                     >Margreten, seiner <roleName type="kin"
                        corresp="#pe__johann_arnstorfer_QGW_II_I_1249">hausvraun</roleName>,
                  </rs>durch gotes willen van der übermass des <rs type="event" ref="#ev__QGW_II_I_1614"
                     >geschefts</rs> ihm 72 guter guldein <triggerstring n="disp">gegeben
                     haben,</triggerstring> davon man den armen leuten in das <rs type="org"
                     ref="#org__wien-buergerspital">Schpital ze Wienn </rs>chaufen sol smalcz und
                  chês und ander ding zu irn notdu/erften .</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_1881"><rs type="fn" role="witness">Besiegelt mit
                     dem petschad des <rs type="person" ref="#pe__konrad_chiemseer_StB_I_178"
                        >Ausstellers</rs>.</rs></rs>
            </p>
