               <rs type="event" ref="#ev__QGW_II_I_1579"><rs type="fn" role="issuer"><rs type="person" ref="#pe__albrecht_riemer_QGW_II_I_1579">Albrecht, der
                           <roleName type="prof">riemer</roleName>, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienn</rs>,</rs>
                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__konrad_vorlauf_QGW_II_I_1320"><roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Chunraten des Vorlauffs</rs> und des
                        <rs type="org" ref="#org__wien">rats gemain der stat ze Wienn</rs></rs> 2 lb
                  dn. <triggerstring n="disp">geltes purkrechts</triggerstring> (ablösbar) auf seinem
                  Hause, gelegen in der Su/eenigerstrass ze Wienn an ainem tail zenechst Niklas haus
                  des Weissen und an dem andern tail zenechst Jacobs haus des Wunsam , um 16 lb dn.
                     <rs type="fn" role="recipient">den <rs type="org" ref="#org__wien-st_stephan">curherren dacz Allerheiligen tumkirchen dacz sand Stephan ze Wienn zu einem
                        ewigen Jahrtage</rs>, <rs type="event" ref="#ev__QGW_II_I_1579_men_1">den frau Ann, Pauln des
                        Irrensteigs witiben, in die vorgenannt cur dacz sand Stephan ze Wienn ze
                        widem geschafft hat</rs>.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1579"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="#org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="#pe__paul_wagendruessel_QGW_II_I_1064">Wiener <roleName type="occ" corresp="#org__wien">Bürgers</roleName> Pauln des
                        Wagendrussel</rs>.</rs></rs>
