            <date when="13540611">1354 VI 11</date>
            <origDate instant="false">ze Wienne, an Unsers Herren Leichnam abent.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00455_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00455_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_455"><rs type="fn" role="issuer"><rs type="person" ref="#pe__friedrich_hurnpekch_QGW_II_I_455">Fridreich der Hoernwekch,
                           <roleName type="prof">chamrer</roleName>
                        <rs type="person" ref="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_596">Herzog Albrechts</rs>,</rs> und <rs type="person" ref="#pe__engel_QGW_II_I_455">Engel, seine <roleName type="kin" corresp="#pe__friedrich_hurnpekch_QGW_II_I_455">Hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">bestätigen</triggerstring>, dass der Weingarten, gelegen ze
                  Medlich an dem Wartperg under der Laimgrueb und haisst der Gotsman zenest des
                  pharrer weingarten von Medlich ,den Engel ihrem Eidam <rs type="person" ref="#pe__stephan_naezeuger_QGW_II_I_1011">Stephan dem Netzeuger <roleName type="kin" corresp="#pe__engel_QGW_II_I_455"><add>eidam</add></roleName></rs>
                  <triggerstring n="disp">ze rechter haimsteuer</triggerstring> bei seiner Vermählung mit
                  seiner ersten Frau, <rs type="person" ref="#pe__anna_QGW_II_I_455">ihrer <roleName type="kin" corresp="#pe__siegfried_hurnpekch_QGW_II_I_455"><add>Tochter</add></roleName>
                     <roleName type="kin" corresp="#pe__engel_QGW_II_I_455">Tochter</roleName>
                     Annen</rs> aus ihrer ersten Ehe mit <rs type="person" ref="#pe__siegfried_hurnpekch_QGW_II_I_455">Seifriden dem Hoerwekchen</rs>
                  gegeben hatte, Stephan dem Netzeuger <rs type="person" ref="#pe__anna_QGW_II_I_455">nach dem Tode <add><roleName type="dead">wittibe</roleName></add></rs> Annas
                  in rechter Theilung gegen Frau Engel und <rs type="person" ref="#pe__konrad_hurnpekch_QGW_II_I_455">ihren <roleName type="kin" corresp="#pe__engel_QGW_II_I_455">Sohn</roleName>
                     <add><roleName type="kin" corresp="#pe__siegfried_hurnpekch_QGW_II_I_455">Sohn</roleName></add>aus derselben Ehe Chunraten</rs> zugefallen sei. Zu
                  rechter ebenteuer gegen ungerechtfertigte Ansprüche auf diesen Weingarten setzen
                  sie ihm folgende Gülten: 1. <rs type="fn" role="other"><triggerstring n="fn">Mit
                        Handen</triggerstring> des <rs type="person" ref="#pe__jakob_von_chrut_QGW_II_I_226">Grundherrn des <roleName type="title">Ritters</roleName>
                        <roleName type="title">hern</roleName> Jacobs von Chrut</rs></rs> 18 sh. dn.
                  Burgrechts auf Hainreichs haus und hofstat weingarten daran, gelegen ze
                  Praitensee, zenest Ulreichs haus des Hietzinger , von dem man 39 dn. an S.
                  Michaels Tag zu Grundrecht dient, 2. <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__hermann_von_eslarn_QGW_II_I_1185">des Bergherrn
                           <roleName type="title">hern</roleName> Hermans von Eslarn</rs></rs> 18
                  sh. dn. Burgrechts auf <rs type="person" ref="#pe__konrad_poytis_QGW_II_I_455">Chunrats weingarten des Poytis</rs>, der do leit in dem Amaispach, des ain
                  viertail ist, zenest <rs type="person" ref="#pe__heinrich_cholrer_QGW_II_I_455">Hainreichs weingarten des Cholrer</rs> , belastet mit 30 dn. für Bergrecht und
                  Zehent und 3 Helbling für Voitrecht, 3. <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des Bergherrn <rs type="person" ref="#pe__konrad_urbetsch_QGW_II_I_950">hern Chunrats des
                     Urbetschen</rs></rs> dritthalb lb dn. gelts purchrechts auf Chunrats weingarten
                  des Poytis, gelegen ze Praitensee in dem Altenperg, des ain jeuch ist, zenest der
                  herren weingarten datz den Schotten ze Wienn , belastet mit ½ lb dn. Bergrecht und
                  6 dn. Voit-[ Seite 108]recht.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_455"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person" ref="#pe__jakob_von_chrut_QGW_II_I_226">Grundherrn</rs>, 2., 3. der <rs type="person" ref="#pe__hermann_von_eslarn_QGW_II_I_1185">Bergherren</rs>
                     <rs type="person" ref="#pe__konrad_urbetsch_QGW_II_I_950"><add>Bergherren</add></rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>