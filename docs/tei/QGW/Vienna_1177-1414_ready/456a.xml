            <placeName>Wien</placeName>
            <date when="13540802">1354 VIII 02</date>
            <origDate instant="false">ze Wienne, an sand Stephans abent in dem snit.</origDate></creation></profileDesc></teiHeader><facsimile/><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="#ev__QGW_II_I_456a"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_schuetzenmeister_QGW_II_I_815">Jans, <roleName type="kin" corresp="#pe__niklas_schmied_QGW_II_I_456a"><add>sun</add></roleName>
                        <rs type="person" ref="#pe__niklas_schmied_QGW_II_I_456a">Niclos sun des smits in dem
                           Vischhof ze Wienne saelig</rs>,</rs> und <rs type="person" ref="#pe__katharina_QGW_II_I_456a">Katrei, seine <roleName type="kin" corresp="#pe__johann_schuetzenmeister_QGW_II_I_815">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> ihrer <rs type="person" ref="#pe__kunigunde_QGW_II_I_456a"><roleName type="title">Grundfrau</roleName>
                        <roleName type="title">vraun</roleName> Chunigunden, <roleName type="kin" corresp="#pe__herbert_auf_der_saeule_QGW_II_I_184"><add>wittibe</add></roleName>
                        <rs type="person" ref="#pe__herbert_auf_der_saeule_QGW_II_I_184"><roleName type="title">hern</roleName> Herborts <roleName type="dead">wittibe</roleName> auf der Saeuln</rs></rs></rs>, 14 lb dn.
                     <triggerstring n="disp">gelts purchrechts</triggerstring> auf ihrem Hause, gelegen in
                  der Münzerstrasse ze Wienn an dem ekke des gaessleins, das aus dem Chamerhof get,
                  gegen Stephans haus des Pollen über und stosst an Stephans haus des Strobein , um
                  140 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__jakob_poll_QGW_II_I_770"><roleName type="title">hern</roleName>
                        Jacoben dem Polln, <roleName type="occ" corresp="#org__wien-st_maria_im_rathaus">chapellan</roleName> der
                        chapellen Unser Vraun in der purger Rathaus ze Wienne, hern Ottenhaim
                        Stiftung saelig</rs></rs> . Jakob der Poll hat dieses Burgrecht gekauft von
                  dem Erlöse für den Verkauf zweier Weingärten an dem Nuz/zperge, der ainer haisset
                  das Aekerl, des anderthalb viertail sind, so haisset der ander weingart die
                  Schosse, des ain halbes jeuch ist, die Jans, hern Ulreichs sun des Nagels, den
                  baiden got genade, der genannten Kapelle zu einer ewigen Messe geschafft
                  hatte.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_456a">Besiegelt mit den Siegeln: <rs type="fn" role="witness"><rs type="person" ref="#pe__johann_schuetzenmeister_QGW_II_I_815">1. des Ausstellers</rs>, <rs type="person" ref="#pe__kunigunde_QGW_II_I_456a">2. der Grundfrau</rs>, 
                           <rs type="person" ref="#pe__berthold_schuetzenmeister_QGW_II_I_153">3. Perchtolts des
                           Schützenmaister, des <roleName type="kin" corresp="#pe__johann_schuetzenmeister_QGW_II_I_815">Bruders</roleName>
                           des Ausstellers</rs>, <rs type="person" ref="#pe__dietrich_flusthart_QGW_II_I_572">4. <roleName type="title">hern</roleName> Dietreichs des Flustharts, <roleName type="occ" corresp="#org__wien">purigermaister</roleName> ze Wienne</rs>, <rs type="person" ref="#pe__ulrich_von_der_linden_QGW_II_I_456a">5. Ulreichs von der
                        Linden, der Katrei <roleName type="kin" corresp="#pe__katharina_QGW_II_I_456a">Oheim</roleName></rs>, <rs type="person" ref="#pe__konrad_schoenaicher_QGW_II_I_459">6. <roleName type="title">hern</roleName> Chunrats des Schönaicher, des Ausstellers
                              <roleName type="kin" corresp="#pe__johann_schuetzenmeister_QGW_II_I_815">Schwager</roleName>,</rs> <rs type="person" ref="#pe__johann_poll_QGW_II_I_850">7. <roleName type="title">hern</roleName>
                        Jansen des Pollen</rs></rs>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>