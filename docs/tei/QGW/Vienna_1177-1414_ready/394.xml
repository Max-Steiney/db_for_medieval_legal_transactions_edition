                           <roleName type="title">hern</roleName> Seifrits, <rs type="person" ref="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_596">herzog
                           Albrechts</rs>
                        <roleName type="occ" corresp="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_596">anwalt</roleName> in der münze ze Wienn</rs>, 4. seines <rs type="person" ref="#pe__johann_von_der_schemnitz_QGW_II_I_394">Vetters Jansen
                        von der Schebnicz</rs></rs>.</rs>
