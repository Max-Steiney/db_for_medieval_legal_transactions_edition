            <origDate instant="false">ze Wienne, des nechsten freitags nach sand Merten tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00993_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00993_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_993"><rs type="fn" role="issuer"><rs type="person" ref="#pe__heinrich_scheczl_QGW_II_I_1240">Hainreich der Schetzl, der
                           <roleName type="prof">vischer</roleName> ze Wienne</rs>, und <rs type="person" ref="#pe__katharina_QGW_II_I_993">Kathrei, seine <roleName type="kin" corresp="#pe__heinrich_scheczl_QGW_II_I_1240">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">schaffen und
                     vermachen sich gegenseitig</triggerstring> ihre Güter, insbesondere <triggerstring n="disp">schafft</triggerstring> Kathrei ihrem <rs type="fn" role="recipient"><rs type="person" ref="#pe__heinrich_scheczl_QGW_II_I_1240">Manne</rs></rs> die
                  Güter, <rs type="event" ref="#ev__QGW_II_I_993_men_1">die ihr in rechter Theilung mit ihren Kindern
                     aus ihrer früheren Ehe mit <rs type="person" ref="#pe__konrad_peppler_QGW_II_I_993"><roleName type="dead"><add>verstorbener</add></roleName>
                        <roleName type="kin" corresp="#pe__katharina_QGW_II_I_993"><add>Ehemann</add></roleName> Chunraten dem Pepler</rs> zugefallen
                     waren</rs>, während sie die Güter aus ihrer Ehe mit <rs type="person" ref="#pe__trautmann_QGW_II_I_993"><roleName type="dead"><add>verstorbener</add></roleName>
                     <roleName type="kin" corresp="#pe__katharina_QGW_II_I_993"><add>Ehemann</add></roleName> Trautmann</rs> dem <rs type="fn" role="recipient"><rs type="person" ref="#pe__pernold_QGW_II_I_993"><roleName type="kin" corresp="#pe__katharina_QGW_II_I_993">Sohne</roleName>
                        <roleName type="kin" corresp="#pe__trautmann_QGW_II_I_993"><add>Sohn</add></roleName> desselben Pernolden</rs></rs>
                  <triggerstring n="disp">übergeben hat</triggerstring>. </rs></p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_993"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. <rs type="person" ref="#pe__thomas_swaeml_QGW_II_I_1012"><roleName type="title">hern</roleName> Thomans des Swemmleins <roleName type="occ" corresp="#org__wien"><add>Ratsherr</add></roleName></rs>, 2. <rs type="person" ref="#pe__pilgrim_snaeczl_QGW_II_I_1015"><roleName type="title">hern</roleName> Pilgreims des Sneczleins, baid des <roleName type="occ" corresp="#org__wien">rats der stat ze Wienne</roleName></rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>