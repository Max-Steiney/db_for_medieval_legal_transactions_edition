               <rs type="event" ref="#ev__QGW_II_I_547"><rs type="fn" role="issuer"><rs type="person" ref="#pe__ortolf_weber_QGW_II_I_547">Ortolf, der weber von Stokcherau</rs>,
                        und<rs type="person" ref="#pe__katharina_QGW_II_I_547"> Katrei, seine
                           <roleName type="kin" corresp="#pe__ortolf_weber_QGW_II_I_547">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__christian_pohrlitzer_QGW_II_I_547">Christans des
                        Poherliczer, <roleName type="occ" corresp="#org__wien-schotten">amptman</roleName> und <roleName type="occ" corresp="#org__wien-schotten">phleger</roleName> der Schotten gut ze Wienn</rs></rs>, 1 lb dn. gelts
