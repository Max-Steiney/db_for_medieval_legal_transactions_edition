   <text>
      <body>
         <div type="abstract" resp="ks">
            <p>
               <rs type="event" ref="#ev__QGW_II_I_356"><rs type="fn" role="issuer"><rs type="person"
                        ref="#pe__niklas_paltram_QGW_II_I_353">Nicla der Paltram, <roleName
                           type="occ" corresp="#pe__johanna_von_pfirt_QGW_II_I_304"
                           >perigmaister</roleName> der herzogin Johanna</rs></rs>, <triggerstring
                     n="disp">beurkundet</triggerstring>, dass vor ihm in der Schranne zu Medlinch <rs
                     type="fn" role="other"><rs type="person"
                        ref="#pe__haunold_schuchler_QGW_II_I_170"><roleName type="title"
                           >her</roleName> Haunolt der Schuechler, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienn,</rs>
                     <triggerstring n="fn">mit Vorsprechen</triggerstring></rs> geklagt habe <rs type="fn"
                     role="other"><triggerstring n="fn">hinz</triggerstring>
                     <rs type="person" ref="#pe__leopold_QGW_II_I_356">Leutolts weingarten, des
                           <roleName type="kin" corresp="#pe__jude_von_perchtoldsdorf_QGW_II_I_356"
                              ><add>sun</add></roleName>
                        <rs type="person" ref="#pe__jude_von_perchtoldsdorf_QGW_II_I_356">Juden sun
                           von Perichtoltzdorf</rs></rs></rs>, der do leit in dem Prunnerpach, um 2
                  lb dn. versessenes Burgrecht und um die zwispil, di mit recht darauf gegangen
                  sind. Er gibt dem Kläger <rs type="fn" role="other">die in no 353 genannten
                        <triggerstring n="fn">Boten und Schätzleute</triggerstring><rs type="person"
                        ref="#pe__heinrich_werder_QGW_II_I_304"><add>Hainreichen den
                        Werder</add></rs>, <rs type="person" ref="#pe__martin_sulzer_QGW_II_I_353"
                           ><add>Merten den Sulczer</add></rs>
                     <rs type="person" ref="#pe__eberhard_choelbl_QGW_II_I_447"><add>Eberharten den
                           Cho/elblein</add></rs></rs> mit und macht <rs type="fn" role="recipient"
                     >ihn</rs> nach deren Aussage des Weingartens gewaltig.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_356"><rs type="fn" role="witness">Besiegelt wie no
                        353<rs type="person" ref="#pe__niklas_paltram_QGW_II_I_353"><add>1. des
                           Ausstellers</add></rs>, <rs type="person"
                        ref="#pe__wulfing_von_goetzendorf_QGW_II_I_421">
                        <roleName type="title"><add>hern</add></roleName>
                        <add>Wulfungs von Geczendorf,</add>
                        <roleName type="occ" corresp="#org__oesterreich-herzogtum"
                              ><add>huebmaister</add></roleName>
                        <add>in Oesterreich und</add>
                        <roleName type="occ"
                           corresp="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_596"
                           select="#pl__moedling"><add>purggraf</add></roleName>
                        <add>ze Medlinch des herzogs Albrecht</add></rs>.</rs></rs></p>
         </div>
         <div type="nota">
            <p>Indorsat: Aufschrift des Magister Theodericus. N. </p>
         </div>
