                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> seines <rs type="person" ref="#pe__georg_von_seefeld_QGW_II_I_394"><roleName type="occ" corresp="#org__klosterneuburg-augustiner_chorherren">Bergmeisters</roleName>
