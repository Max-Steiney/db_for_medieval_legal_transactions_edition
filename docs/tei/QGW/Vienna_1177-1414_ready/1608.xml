            <date when="14041215">1404 XII 15</date>
            <origDate instant="false">ze Wienn, des montags nach sand Lucein tag, der heiligen
               junkchfraun.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01608_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01608_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="#ev__QGW_II_I_1608"><rs type="fn" role="issuer"><rs type="person" ref="#pe__niklas_rot_QGW_II_I_1608">Niklas der Rot, <roleName type="occ" corresp="#org__wien-st_stephan">curherr</roleName> dacz sand Stephan ze Wienn
                        und <roleName type="occ" corresp="#org__erdberg-st_paul">pharrer</roleName> dacz
                           <rs type="org" ref="#org__erdberg-st_paul">sand Paul ze Erdpurkch bei
                           Wienn</rs></rs>, und <rs type="person" ref="#pe__margarethe_QGW_II_I_1608">Margret, <roleName type="kin" corresp="#pe__niklas_chaeser_QGW_II_I_1608"><add>witib</add></roleName>
                        <rs type="person" ref="#pe__niklas_chaeser_QGW_II_I_1608">Niklas <roleName type="dead">witib</roleName> des Cheser daselbs</rs></rs>,</rs>
                  <triggerstring n="disp">geben</triggerstring> nach dem Gebote Herzog Rudolfs IV. <rs type="fn" role="recipient">dem <rs type="person" ref="#pe__christian_tatler_QGW_II_I_1608"><roleName type="occ" corresp="#org__wien">Wiener Bürger</roleName>
                        Christann dem Tatler</rs> und seiner <rs type="person" ref="#pe__agnes_QGW_II_I_1608"><roleName type="kin" corresp="#pe__christian_tatler_QGW_II_I_1608">Hausfrau</roleName> Agnesen</rs></rs> 8 ½
                  lb dn. <triggerstring n="disp">geltes purkrechts</triggerstring> von ihrem Hause,
                  gelegen bei dem Rotenturm ze Wienn zenechst Petreins haus des Helffants, um 68 lb
                  dn. abzulösen, welche Margret, <rs type="event" ref="#ev__QGW_II_I_1608_men_1">die einst das
                     Burgrecht mit diesem Vorbehalte zur Kirche S. Paul gewidmet hatte,</rs>
                  einstweilen einnimmt.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1608"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln der <rs type="org" ref="#org__erdberg-st_paul">Kirche von S.
                        Paul</rs> und <rs type="person" ref="#pe__paul_geir_QGW_II_I_1406">Pauln des Geyr, des
                           <roleName type="occ" corresp="#org__wien">rats der stat</roleName> ze
                        Wienn</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>