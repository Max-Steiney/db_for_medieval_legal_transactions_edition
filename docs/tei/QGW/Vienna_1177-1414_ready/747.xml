                     <triggerstring n="disp">nehmen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen </triggerstring>des <rs type="person" ref="#pe__johann_goldstain_QGW_II_I_747"><roleName type="occ" corresp="#org__poetzleinsdorf">Bergmeisters</roleName> Jannsen des
                        Goltstains von Peczleinstorf, <roleName type="occ" corresp="#pe__anna_QGW_II_I_596">amptman</roleName> der <rs type="person" ref="#pe__anna_QGW_II_I_596"><roleName type="title">Frau</roleName> Annen,
                              <roleName type="kin" corresp="#pe__johann_von_kuenring_QGW_II_I_281"><add>wittib</add></roleName>
                           <rs type="person" ref="#pe__johann_von_kuenring_QGW_II_I_281"><roleName type="title">hern</roleName> Jansen <roleName type="dead">seligen</roleName> wittib von Chünring von
                     Seveld</rs></rs></rs></rs>,<rs type="fn" role="recipient">von dem <rs type="person" ref="#pe__heinrich_QGW_II_I_747">
                        <roleName type="prof">Priester</roleName>
                        <roleName type="title">hern</roleName> Hainreichen, <roleName type="occ" corresp="#org__wien-st_stephan-altar_st_maria-messe_strobein">Kaplan</roleName> der von
                           <rs type="person" ref="#pe__stephan_strobein_QGW_II_I_1086"><roleName type="title">hern</roleName> Stephan dem Strobein</rs> bei S. Stephan
                        gestifteten Messe</rs></rs>, ein Joch Weingarten, gelegen ze Peczleinstorf
                  und haisset der Rueppolt, zenechst Jorigen weingarten von Neunburg , von dem man 3
                  Eimer Wein zu Bergrecht und 3 dn. zu Voitrecht dient, <triggerstring n="disp">auf
                     acht Jahre in Bestand</triggerstring>, mit dem Rechte, darin jährlich 60 Tagwerke
                  ze gru/eben, und mit der Verpflichtung, von dem in Wien gepressten Moste dem
                  Kaplan und seinen Amtsnachfolgern den dritten Theil bei der presse aus dem grant
                  in ireu vas abzugeben. <rs type="fn" role="other">Sie stellen <rs type="person" ref="#pe__ilsung_QGW_II_I_747">sich selbst</rs>
                     <rs type="person" ref="#pe__elisabeth_QGW_II_I_747"><add>sich selbst</add></rs>
                     und die <rs type="person" ref="#pe__niklas_schoen_QGW_II_I_747"><roleName type="kin" corresp="#pe__elisabeth_QGW_II_I_747">Eltern</roleName> der
                        Elsbeth Nichlasen den Schönen, gesessen ze Nidern Sufring</rs>, und <rs type="person" ref="#pe__wendelmut_QGW_II_I_747">Wendelmuten <roleName type="kin" corresp="#pe__elisabeth_QGW_II_I_747"><add>Eltern</add></roleName></rs>
                     <triggerstring n="fn">zu Bürgen</triggerstring></rs>.</rs>
