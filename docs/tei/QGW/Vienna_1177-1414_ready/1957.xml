   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="#ev__QGW_II_II_1957"><rs type="fn" role="issuer"><rs type="org" ref="#org__bruenn">Bürgermeister und Rath der Stadt zu Brunne</rs></rs>
                  <triggerstring n="disp">theilen<add> mit</add></triggerstring>
                  <rs type="fn" role="recipient"><rs type="org" ref="#org__wien">dem Bürgermeister
                        und Rath der Stadt zu Wienne</rs></rs> mit, dass ihre <rs type="person" ref="#pe__peter_scheibeben_QGW_II_II_1957"><roleName type="occ" corresp="#org__bruenn">Mitbürger</roleName> Peter Scheibeben</rs>, <rs type="person" ref="#pe__honnus_piernar_QGW_II_II_1957">Honnus Piernar<roleName type="occ" corresp="#org__bruenn"><add>Mitbürger</add></roleName></rs>,
               <rs type="person" ref="#pe__martin_chunusch_QGW_II_II_1957">Mertl Chunusch<roleName type="occ" corresp="#org__bruenn"><add>Mitbürger</add></roleName></rs>
                  und der <rs type="person" ref="#pe__niklas_QGW_II_II_1957"><roleName type="occ" corresp="#org__bruenn">Rat</roleName> Nikal</rs> vor ihnen
                  wegen des von <rs type="person" ref="#pe__stephan_muenich_QGW_II_II_1957">Stephl
                     Münich</rs> in Wien zurückgelassenen Gutes erschienen seien, dass sie ihnen,
                  entsprechend der Forderung des Wiener Rathes, einen Quittbrief ausstellen und
                  dieselben den <rs type="person" ref="#pe__matthias_scheibeben_QGW_II_II_1957">Mathes genant Scheibeben</rs> zur Uebernahme des Gutes bevollmächtigt
                  haben.</rs>
            </p>
         </div>
