                        <rs type="person" ref="#pe__stephan_leitner_QGW_II_I_1012">Wiener <roleName type="occ" corresp="#org__wien">Bürgers</roleName>
                        <roleName type="title">hern</roleName> Stephans des Leitner</rs>.</rs></rs>
