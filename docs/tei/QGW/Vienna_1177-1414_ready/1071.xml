               <rs type="event" ref="#ev__QGW_II_I_1071"><rs type="fn" role="issuer"><rs type="person" ref="#pe__leopold_prenner_QGW_II_I_1071">Leupolt der Prenner, <roleName type="occ" corresp="#org__wiener_neustadt">purger</roleName> ze der
                        Neunstat</rs>,</rs>
                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__paul_holzkaeufel_QGW_II_I_1010"><roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName>
