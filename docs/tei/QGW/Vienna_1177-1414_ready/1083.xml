            <placeName>Wien</placeName>
            <date when="13850301">1385 III 01</date>
            <date from="99999999" to="99999999"/>
            <origDate instant="false">ze Wienn, des nächsten mitichens nach sand Mathias tag, des heiligen
               zwelfpoten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01083_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01083_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1083"><rs type="fn" role="issuer"><rs type="person" ref="#pe__ulrich_zinkk_QGW_II_I_1066a">Ulreich der Zinkk, <roleName type="occ" corresp="#org__wien-buergerspital">obrister spitalmaister</roleName> der
                        purger Spital vor Kernertor ze Wienn</rs></rs> , <triggerstring n="disp">bestätigt</triggerstring>, die hernachbenannten ziegelwerichstet, gelegen vor
                  Kernertor bei den Ziegelöfen ze Wienn, <rs type="event" ref="#ev__QGW_II_I_1083_men_1">welche <rs type="person" ref="#pe__kunigunde_spieglerin_QGW_II_I_1075"><roleName type="title">Frau</roleName> Kunigund die Spieglerinne</rs> dem <rs type="org" ref="#org__wien-buergerspital">Spital</rs> zu einem <rs type="org" ref="#org__wien-buergerspital-messe_spieglerin">ewigen Jahrtage</rs>
                     geschafft hatte</rs>, und zwar von erst zwo hofstet, <rs type="event" ref="#ev__QGW_II_I_1083_men_2">die von maister Mertten gechauft sind</rs>, und zwen ziegelöfen
                  daran zenechst dem Me/anschein und ein hofstat weingartens und zwen ziegelöfen
                  daran, <rs type="event" ref="#ev__QGW_II_I_1083_men_3">das von <rs type="person" ref="#pe__niklas_poll_QGW_II_I_1083">Niclasen <roleName type="dead">seligen</roleName>
                        dem Pöllein</rs> gechauft ist</rs>, genant die Grodlerinne, und aber ein
                  hofstat weingartens und zwen ziegelöfen daran, <rs type="event" ref="#ev__QGW_II_I_1083_men_4">die von
                     den <rs type="org" ref="#org__wien-st_klara">geistleichen fraun dacz sand Chlarn
                        ze Wienn</rs> gechauft sind</rs>, das alles nu zu einander gefangen ist, als
                  es weilnt <rs type="person" ref="#pe__michael_rentsch_spiegler">Michel
                        <roleName type="dead">selig</roleName> der Re/antsch, der egenanten fraun
                     Kunigunden eleicher <roleName type="kin" corresp="#pe__kunigunde_spieglerin_QGW_II_I_1075">wirt</roleName></rs> innegehabt hat , <triggerstring n="disp">übernommen zu
                     haben</triggerstring>, und <triggerstring n="disp">verpflichtet sich und seine
                     Amtsnachfolger</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">gegenüber <add>zur
                        Abhaltung</add></triggerstring>
                     <rs type="person" ref="#pe__johann_spiegler_QGW_II_I_1075">Jannsen dem Spiegler, dem <roleName type="kin" corresp="#pe__kunigunde_spieglerin_QGW_II_I_1075">Stiefsohne</roleName> der
                        Erblasserin</rs></rs> , zur Abhaltung des <rs type="fn" role="recipient"><rs type="org" ref="#org__wien-buergerspital-messe_spieglerin">Jahrtages</rs></rs> an dem nächsten Sonntage vor sand Simans und sand Judas
                  tag, der heiligen zwelfpoten.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1083"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="#org__wien-buergerspital">Spitalssiegel</rs>.</rs></rs></p></div><div type="nota"><p/></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>