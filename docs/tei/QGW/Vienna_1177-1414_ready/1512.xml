                  <triggerstring n="disp">stellt</triggerstring>
                  <rs type="fn" role="recipient">ihrem <rs type="person" ref="#pe__johann_QGW_II_I_1512"><roleName type="kin" corresp="#pe__katharina_QGW_II_I_1512">Oheim</roleName> Hannsen, dem
