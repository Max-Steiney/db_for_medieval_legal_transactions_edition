                              <rs type="event" ref="#ev__QGW_II_I_682"><rs type="fn" role="issuer"><rs type="person" ref="#pe__niklas_poll_QGW_II_I_1083">Niclas der
                                                Polle, <roleName type="occ" corresp="#org__wien">purger</roleName> ze
                                                Wienne</rs></rs>, <triggerstring n="disp">stiftet</triggerstring> gemäss einer mit seiner <rs type="fn" role="other"><rs type="person" ref="#pe__katharina_QGW_II_I_953"><roleName type="kin" corresp="#pe__niklas_poll_QGW_II_I_1083">Hausfrau</roleName> Kathrei</rs>
