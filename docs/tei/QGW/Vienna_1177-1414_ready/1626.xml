            <origDate instant="false">ze Wienn, des phinztags vor sand Bertelmes tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01626_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01626_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p>
               <rs type="event" ref="#ev__QGW_II_I_1626"><rs type="fn" role="issuer"><rs type="person" ref="#pe__martin_hausleitter_QGW_II_I_1234">Mert der
                        Hausleiter, des <roleName type="occ" corresp="#org__wien">rats</roleName> der
                        stat ze Wienn,</rs> und <rs type="person" ref="#pe__katharina_QGW_II_I_1603">Kathrei, seine <roleName type="kin" corresp="#pe__martin_hausleitter_QGW_II_I_1234">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                  <rs type="person" ref="#pe__daniel_QGW_II_I_1626">ihres
                           <roleName type="title">Grundherrn</roleName>
                        <roleName type="title">pruder</roleName> Daniels, <roleName type="occ" corresp="#org__wien-heiligengeistspital">maister</roleName> des hauses
                        dacz dem Heiligen Geist enhalb der prugk vor Kernertor ze Wienn</rs></rs> ,
                  ihr Haus, gelegen ze Grinzingen zenechst Jacobin haus der Goltstainin, und ist
                  weilent Larenz seligen, des richter von Grinzingen gewesen, und ein hofstat
                  weingartens hinden daran , wovon man 24 dn. zu Grundrecht dient, <rs type="fn" role="recipient"><rs type="person" ref="#pe__anna_QGW_II_I_1597"><roleName type="title">fraun</roleName> Annen, Jacobs des Stichels <roleName type="kin" corresp="#pe__jakob_stichel_QGW_II_II_3713">witiben</roleName></rs></rs>, um 40 lb dn., die herkomen sind von des
                  hauses wegen, gelegen am Graben ze Wienn, <rs type="event" ref="NULL">welches <rs type="person" ref="#pe__jakob_stichel_QGW_II_II_3713">Jakob der Stichel</rs>
                     seiner Frau zu Leibgeding und nach ihrem Tode zu einer <rs type="org" ref="#org__wien-st_stephan-messe_stichel">ewigen Messe</rs> bei S. Stephan
                     geschafft hatte, mit der Bestimmung, dass Anna das Haus und den Weingarten zu
                     Lebzeiten innehaben und Beides nach ihrem Tode zu dieser Messe gewidmet werden
                     soll.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1626"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln des <rs type="person" ref="#pe__martin_hausleitter_QGW_II_I_1234">Ausstellers</rs>, des <rs type="person" ref="#pe__daniel_QGW_II_I_1626">Grundherrn</rs> und des <rs type="person" ref="#pe__ulrich_wolf_QGW_II_I_1366">Wiener <roleName type="occ" corresp="#org__wien">Bürgers</roleName> Ulreichs des
                  Wolffs</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>