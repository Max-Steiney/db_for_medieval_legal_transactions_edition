            <origDate instant="false">ze Wienne, des samstages vor sande Thomas tage, des h.
               zwelifpoten.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00575_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00575_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_575"><rs type="fn" role="issuer"><rs type="person" ref="#pe__haunold_schuchler_QGW_II_I_170">Haunolt der Schüchler, <roleName type="occ" corresp="#org__wien">purgermaister</roleName></rs>, und <rs type="org" ref="#org__wien">der rat gemain der stat ze Wienne</rs></rs>
                  <triggerstring n="disp">bestätigen</triggerstring>, dass<rs type="fn" role="recipient">
                     <rs type="person" ref="#pe__jakob_poll_QGW_II_I_770"> ihr <roleName type="occ" corresp="#org__wien-st_maria_im_rathaus">Kaplan</roleName> her Jacob der
                        Poll</rs></rs>
                  <triggerstring n="disp">nach dem Gebote Herzog Rudolfs IV.</triggerstring> 12 . lb dn.
                  an 20 dn. gelts <triggerstring n="disp">purchrechts</triggerstring> (4 lb dn. auf
                  Nichlas haus des Stainer an dem Hochenmarcht ze Wienne, 15 sh. 10 dn. auf Haunolts
                  des Schüchler haus an dem Chienmarkchte ze Wienne, 4 lb dn. auf hern Jacobs haus
                  von Eslarn auf sande Peters freithof ze Wienne und 2 lb dn. auf 1/2 Joch
                  Weingarten ze Obern Sufringen, das Leupolt, Arnolts aidem, ist) um 95 lb 80 dn.
                     <triggerstring n="disp">abzulösen gegeben</triggerstring> und davon 47 lb 80 dn.
                     <triggerstring n="impl_rules">zur Herstellung des Ziegeldaches</triggerstring> auf
                  der abseit der egenanten chapellen, und 48 lb dn. zum Ankauf des Hauses, das do
                  leit an der egenanten chapelln, das Merten, des chramer, gewesen ist, verwendet
                  habe.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_575"><rs type="fn" role="witness"><rs type="org" ref="#org__wien">Besiegelt mit der Stadt chlainem anhangundem
                     insigil</rs></rs>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>