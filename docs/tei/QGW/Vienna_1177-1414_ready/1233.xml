            <date when="13920623">1392 VI 23</date>
            <origDate instant="false">ze Wienne, an sand Johanns abend ze
            Sunnbenden.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01233_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01233_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="cs"><p><rs type="event" ref="#ev__QGW_II_I_1233"><rs type="fn" role="issuer"><rs type="person" ref="#pe__michael_geukramer_QGW_II_I_1235">Michel der
                        Geuchramer, <roleName type="occ" corresp="#org__wien">purgermaister</roleName> und <roleName type="occ" corresp="#org__oesterreich-herzogtum" select="#pl__wien">munzmaister</roleName></rs>, und der <rs type="org" ref="#org__wien">rat
                        gemain der stat ze Wienne</rs></rs>
                  <triggerstring n="disp">beurkunden</triggerstring>, dass <rs type="fn" role="other"><rs type="person" ref="#pe__albrecht_fleischhacker">Albrecht, der <roleName type="prof">fleischhakcher</roleName>
                        <roleName type="rep" corresp="#pe__ulrich_goll_QGW_II_I_1233"><add>für</add></roleName></rs>, <triggerstring n="fn"><add>an ainem
                           tail</add></triggerstring></rs> für sich und seinen <rs type="person" ref="#pe__ulrich_goll_QGW_II_I_1233">unmündigen <roleName type="kin" corresp="#pe__albrecht_fleischhacker">Sohn</roleName> Ulreich</rs> aus seiner
                     <rs type="person" ref="#pe__anna_QGW_II_I_1233"><roleName type="kin" corresp="#pe__albrecht_fleischhacker">Ehe</roleName> mit <roleName type="title">Frau</roleName> Annen, des <rs type="person" ref="#pe__alter_goll_QGW_II_I_1233">alten Gollen <roleName type="dead"><add>got gnad</add></roleName></rs>
                     <roleName type="kin" corresp="#pe__alter_goll_QGW_II_I_1233">tochter</roleName>,
                     den baiden <roleName type="dead">got gnad</roleName></rs>, an ainem tail, und
                     <rs type="fn" role="other"><rs type="person" ref="#pe__johann_goll_QGW_II_I_1088">Hans der Go/el, der <roleName type="prof">fleischhakcher</roleName>, an seins suns <roleName type="rep" corresp="#pe__friedrich_QGW_II_I_1233">stat</roleName><roleName type="rep" corresp="#pe__laurenz_QGW_II_I_1233"><add>anstatt</add></roleName>
                        <roleName type="rep" corresp="#pe__wolfgang_QGW_II_I_1233"><add>anstatt</add></roleName></rs><triggerstring n="fn"><add>an dem andern
                           tail</add></triggerstring></rs>
                  <rs type="person" ref="#pe__friedrich_QGW_II_I_1233">Fridreichs, der zu den Zeiten
                     innerlandes nicht gewesen ist <roleName type="kin" corresp="#pe__johann_goll_QGW_II_I_1088"><add>suns</add></roleName><roleName type="kin" corresp="#pe__margarethe_QGW_II_I_1233"><add>suns</add></roleName></rs>, den er gehabt hat mit seiner <rs type="person" ref="#pe__margarethe_QGW_II_I_1233"><roleName type="kin" corresp="#pe__johann_goll_QGW_II_I_1088">hausfrawen</roleName> Margreten auch
                        <roleName type="dead">guter gedechtnuss</roleName>, der vorgenanten Annen
                        <roleName type="kin" corresp="#pe__anna_QGW_II_I_1233">swester</roleName></rs> und anstatt <rs type="person" ref="#pe__laurenz_QGW_II_I_1233">Larenzen <roleName type="kin" corresp="#pe__anna_QGW_II_I_1233"><add>Kinder</add></roleName><roleName type="kin" corresp="#pe__martin_goll_QGW_II_I_1233"><add>Kinder</add></roleName></rs> und <rs type="person" ref="#pe__wolfgang_QGW_II_I_1233">Wolfgangen, der beiden unmündigen <roleName type="kin" corresp="#pe__martin_goll_QGW_II_I_1233"><add>Kinder</add></roleName>
                     <roleName type="kin" corresp="#pe__anna_QGW_II_I_1233">Kinder</roleName>
                     Annas</rs> aus ihrer früheren Ehe mit <rs type="person" ref="#pe__martin_goll_QGW_II_I_1233"><roleName type="kin" corresp="#pe__anna_QGW_II_I_1233"><add>Ehe</add></roleName> Merten dem Golen,
                     dem <roleName type="prof">fleischhakcher</roleName>
                     <roleName type="dead"><add>früheren</add></roleName></rs>, an dem andern tail,
                     <triggerstring n="disp">vor sie ihren Streit über folgende Güter gebracht
                     haben</triggerstring>: ein haus, gelegen bei sand Larenzen an dem
                  Altenfleischmarkcht zu Wienn zenest der padstuben , welches Mert der Goll mit
                  seiner Hausfrau Anna gekauft hatte ein fleischpankch, gelegen an dem Liechtensteg
                  under den Obern Fleischpenkchen ze Wienn zenest der fleischpank, die weilnt Jorgen
                  des Schentenmarkchts gewesen ist, die der egenanten fraun Annen und <rs type="person" ref="#pe__ulrich_goll_QGW_II_I_1233">irem <roleName type="kin" corresp="#pe__anna_QGW_II_I_1233">bruder</roleName> Ulreichen, der vor ir
                        <roleName type="dead">verschaiden</roleName> ist</rs>, gechauft ist gewesen
                  ein fleischpankch, gelegen under den Neuen Fleischpenkchen ze Wienne zunest der
                  fleischpankch, die weilnt Rugers seligen des Münichs gewesen ist zwen weingarten,
                  ainer gelegen in dem Mitternperg zu AIz/zz/z, des ain halbs jeuch ist, und der
                  ander vor der Pollin hof, das alles von dem egenanten <rs type="person" ref="#pe__alter_goll_QGW_II_I_1233">alten Goln, der vorgenanten kinder <roleName type="kin" corresp="#pe__wolfgang_QGW_II_I_1233">ennen</roleName><roleName type="kin" corresp="#pe__laurenz_QGW_II_I_1233"><add>ennen</add></roleName><roleName type="kin" corresp="#pe__ulrich_QGW_II_I_1233"><add>ennen</add></roleName></rs>,
                  herkomen ist. Der Bürgermeister und Rath <triggerstring n="disp">entscheiden
                     dahin</triggerstring>, dass das Haus an <rs type="fn" role="recipient">die beiden
                        <rs type="person" ref="#pe__laurenz_QGW_II_I_1233">Kinder</rs>
                     <rs type="person" ref="#pe__wolfgang_QGW_II_I_1233"><add>Kinder</add></rs> der
                     Anna aus ihrer ersten Ehe</rs>, die erste Fleischbank an <rs type="fn" role="recipient">ihre drei <rs type="person" ref="#pe__ulrich_QGW_II_I_1233">Kinder</rs></rs> aus beiden Ehen fallen, die von dem alten Golen
                  hinterlassenen Güter zur Hälfte dem <rs type="fn" role="recipient"><rs type="person" ref="#pe__friedrich_QGW_II_I_1233"><roleName type="kin" corresp="#pe__anna_QGW_II_I_1233">Schwestersohne</roleName> der Anna,
                        Friedrich</rs></rs>, zur Hälfte ihren drei Kindern gehören sollen.</rs></p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1233"><rs type="fn" role="witness">Besiegelt mit
                     der <rs type="org" ref="#org__wien">stat zu Wienn chlainem anhangundem
                        insigel</rs></rs>.</rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>