   <text>
      <body>
         <div type="abstract" resp="ks">
            <p>
               <rs type="event" ref="#ev__QGW_II_I_194"><rs type="fn" role="issuer"><rs type="person"
                        ref="#pe__katharina_QGW_II_I_194">Katrei, <roleName type="kin"
                           corresp="#pe__friedrich_pruknaer_QGW_II_I_194"><add>tochter</add></roleName><rs
                           type="person" ref="#pe__friedrich_pruknaer_QGW_II_I_194"><roleName
                              type="title">hern</roleName> Fridreichs tochter des Pruknaer,
                              <roleName type="dead">dem got genade</roleName></rs></rs></rs>,
                     <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__ulrich_QGW_II_I_194">ihres <roleName type="title"
                           >Bergherrn</roleName>
                        <roleName type="occ" corresp="#org__wien-deutsche_herren">bru/oder</roleName>
                        Ulreichs, <roleName type="occ" corresp="#org__wien-deutsche_herren"
                           >comiteur</roleName> dacz dem Tautschen haus ze Wienn</rs></rs>, ein ihr
                     <rs type="event" ref="#ev__QGW_II_I_194_men_1">von ihrem Vater angefallenes
                     halbes Joch Weingarten</rs>, der da leit dacz Chlaitzingen und haisset der
                  Pogner zenaechst hern Chunrades weingarten, des hansgraven, do man alle iar von
                  dienet 62 dn. für perchrecht und für voitrecht , um 57 lb dn. <rs type="fn"
                     role="recipient"><rs type="person" ref="#pe__konrad_QGW_II_I_194">Chunraden, dem
                        pekchen in der Schauffellukchen</rs>, <rs type="person"
                        ref="#pe__margarethe_QGW_II_I_194"><roleName type="kin"
                           corresp="#pe__konrad_QGW_II_I_194">seiner Hausfrau</roleName>
                        Margreten</rs> und <rs type="person"
                        ref="#pe__heinrich_in_dem_gewelten_keller_QGW_II_I_194">seinem <roleName
                           type="kin" corresp="#pe__konrad_QGW_II_I_194">Bruder</roleName>
                        Hainreichen in dem geweltem cheler.</rs></rs></rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_194">Besiegelt mit den Siegeln: <rs type="fn"
                     role="witness"><rs type="org" ref="#org__wien-deutsche_herren">1. der Herren
                        datz dem Taeutschen haus ze Wienn,</rs>
                     <rs type="person" ref="#pe__pitrolf_QGW_II_I_194">2. <roleName type="title"
                           >hern</roleName> Pitrolfs, <roleName type="occ"
                           corresp="#org__grauscharn-pfarre">pfarrer</roleName> ze Grauscharn und
                           <roleName type="occ" corresp="#org__passau-domkapitel"
                           >chorherre</roleName> ze Passau,</rs>
                     <rs type="person" ref="#pe__dietrich_urbetsch_QGW_II_I_950">3. <roleName
                           type="title">hern</roleName> Dietreiches des Urbetzschen, <roleName
                           type="occ" corresp="#org__wien">richter</roleName> ze Wienn,</rs>
                     <rs type="person" ref="#pe__konrad_von_eslarn_QGW_II_I_178">4. <roleName
                           type="title">hern</roleName> Chunrades von Eslarn, <roleName type="occ"
                           corresp="#org__wien">purgermaister</roleName> ze Wienn.</rs></rs></rs>
            </p>
         </div>
         <div type="nota">
            <p>Indorsat: Aufschrift des Magister Theodericus. M. </p>
         </div>
