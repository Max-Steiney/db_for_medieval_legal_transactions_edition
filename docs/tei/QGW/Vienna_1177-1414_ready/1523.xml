            <date when="14030112">1403 I 12</date>
            <origDate instant="false">ze Wienn, des nachsten freitags vor sand Anthonien tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01523_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01523_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="#ev__QGW_II_I_1523"><rs type="fn" role="issuer"><rs type="person" ref="#pe__peter_angerfelder_QGW_II_I_1373">Peter der Angervelder, <roleName type="occ" corresp="#org__wien">statrichter</roleName> ze
                     Wienn</rs>,</rs>
                  <triggerstring n="disp">beurkundet, dass vor ihm in der Bürgerschranne</triggerstring>
                  <rs type="fn" role="other">der <rs type="person" ref="#pe__georg_neuer_QGW_II_I_1195">Wiener
                           <roleName type="occ" corresp="#org__wien">Bürger</roleName> Jo/erg
                        der Neuer <roleName type="rep" corresp="#pe__otto_murbecz_QGW_II_I_1543">an<add>statt</add></roleName><roleName type="rep" corresp="#pe__wilhelm_QGW_II_I_1523">an<add>statt</add></roleName></rs>
                     <triggerstring n="fn"><add>mit Vorsprechen</add></triggerstring></rs>
                  <rs type="person" ref="#pe__otto_murbecz_QGW_II_I_1543">Otten des Murbeczen</rs>
                  und <rs type="person" ref="#pe__wilhelm_QGW_II_I_1523">Wilhalm, seines
                           <unclear instant="false"><roleName type="kin" corresp="#pe__otto_murbecz_QGW_II_I_1543">enikchels</roleName></unclear></rs>, stat mit Vorsprechen <rs type="fn" role="other"><triggerstring n="fn">auf</triggerstring>
                     <rs type="person" ref="#pe__johann_hansgraf_QGW_II_I_1112">Hannsen des Hannsgrafen</rs></rs>
                  haus und wachsglet, gelegen in der Hindern Peckchenstrass ze Wienn zwischen
                  Petreins des Zêkel und Niclas Oswalts heusern, <triggerstring n="disp">geklagt
                     habe</triggerstring>, darumb das derselb Hanns der Hansgraf das egenant sein haus
                  und wachsglet rechtleich nicht hiet inngehabt als leibgedings recht wer, und auch
                  nicht verdient hiet, damit dem egenanten Wilhalmen, seinem sun, dasselb haus und
                  der wachsglet wer vervallen nach des briefs sag und laut, der darumb vor offen
                  gericht gelesen und verho/ert ward, und dass Jörg auf Beides ein verpot genommen
                  habe. Da nun Hanns sich freiwillig vor Gericht des Hauses und Wachsglets
                  entäussert, <triggerstring n="disp">macht</triggerstring> der Richter den <rs type="fn" role="recipient"><rs type="person" ref="#pe__georg_neuer_QGW_II_I_1195">Kläger <roleName type="rep" corresp="#pe__wilhelm_QGW_II_I_1523">anstatt</roleName></rs></rs> Wilhalms beider Objecte <triggerstring n="disp">gewaltig</triggerstring>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1523"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="#pe__peter_angerfelder_QGW_II_I_1373">Aussteller</rs>.</rs></rs></p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>