            <date when="13551204">1355 XII 04</date>
            <origDate instant="false">ze Wienne, des nächsten freitags nach sande Andres
               tage.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00472_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00472_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="ks"><p>
               <rs type="event" ref="#ev__QGW_II_I_472"><rs type="fn" role="issuer"><rs type="person" ref="#pe__michael_vierdung_QGW_II_I_272">Michel der Schu/echler, <roleName type="occ" corresp="#org__wien">richter</roleName> ze Wienn</rs></rs>,
                     <triggerstring n="disp">beurkundet</triggerstring>, dass vor ihm in der
                  Bürgerschranne <rs type="fn" role="other"><rs type="person" ref="#pe__gebhard_schreiber_QGW_II_I_472">der <roleName type="title">erber
                           chnecht</roleName> Gebhart, <roleName type="occ" corresp="#pe__konrad_urbetsch_QGW_II_I_950"><add>Schreiber</add></roleName>
                        <rs type="person" ref="#pe__konrad_urbetsch_QGW_II_I_950"><roleName type="title">hern</roleName> Chunrats Schreiber des Urbetschen</rs>,
                           <roleName type="rep" corresp="#pe__konrad_urbetsch_QGW_II_I_950">an seines
                           Herrn Statt</roleName></rs>
                     <triggerstring n="fn">mit Vorsprechen</triggerstring></rs>
                  <rs type="fn" role="other"><triggerstring n="fn">auf</triggerstring>
                     <rs type="person" ref="#pe__ulrich_genaem_QGW_II_I_311">Ulreichs haus und
                        fleischpanch des Gnemen</rs></rs>, gelegen an einander in der Chernerstrasse
                  ze Wienne zenechst Chonrats haus des Herschefftleins, umb ainen halben zenten
                  unslides gelts, versessens purchrechts , und die darauf ertheilten zwispilde
                  geklagt habe. Er gibt dem Kläger <rs type="fn" role="other"><rs type="person" ref="#pe__heinrich_puchveler_QGW_II_I_495">Hainreichen, den puchveler
                           <roleName type="occ" corresp="#org__wien"><add>vorsprechen</add></roleName></rs>, und <rs type="person" ref="#pe__otto_haekchl_QGW_II_I_391">Otten den Hekchlein, die zwen <roleName type="occ" corresp="#org__wien">vorsprechen</roleName></rs>, als
                        <triggerstring n="fn">Schätzleute</triggerstring></rs> mit und macht nach deren
                  Aussage <rs type="fn" role="recipient"><rs type="person" ref="#pe__konrad_urbetsch_QGW_II_I_950"><roleName type="title">hern</roleName> Chunraten den Urbetschen</rs></rs> des Hauses und der
                  Fleischbank gewaltig.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_472"><rs type="fn" role="witness">Besiegelt von
                     dem <rs type="person" ref="#pe__michael_vierdung_QGW_II_I_272">Aussteller</rs></rs></rs>.</p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>