               <rs type="event" ref="#ev__QGW_II_I_205"><rs type="fn" role="issuer"><rs type="person" ref="#pe__otto_QGW_II_I_205">Otte, <rs type="person" ref="#pe__otto_herzog_von_oesterreich_QGW_II_I_837">herzogen Otten</rs>
                        <roleName type="occ" corresp="#pe__otto_herzog_von_oesterreich_QGW_II_I_837">chamerschreiber</roleName> in Österreich,</rs>
                     <rs type="person" ref="#pe__elisabeth_QGW_II_I_205">und Elspeth, seine <roleName type="kin" corresp="#pe__otto_QGW_II_I_205">Hausfrau</roleName></rs></rs>,
                     <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="recipient"><rs type="person" ref="#pe__katharina_QGW_II_I_205">ihrer<roleName type="title"> Grundfrau</roleName>
                        <roleName type="title">swester</roleName> Kathrein, <roleName type="occ" corresp="#org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">aptessinne</roleName> dacz sand Nichlos,</rs></rs> ihren Baumgarten, der
                  da leit ze Altunaue zenehst dem Ratgeben auf der Widem, davon man dient alle jar
                  ze rechtem gruntrecht 30 dn. den vrowen hinz sand Nichlos und 80 dn. den herren
                  von dem Heiligen chreucz ze purchrecht , um 17 lb dn. <rs type="fn" role="recipient"><rs type="person" ref="#pe__konrad_wiltwercher_QGW_II_I_204">Chunraden dem Wiltwercher, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienn,</rs> und <rs type="person" ref="#pe__margarethe_QGW_II_I_204"><roleName type="title">vron</roleName>
                        Mergarten, seiner <roleName type="kin" corresp="#pe__konrad_wiltwercher_QGW_II_I_204">Hausfrau</roleName></rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_205"><rs type="fn" role="witness">Besiegelt mit
