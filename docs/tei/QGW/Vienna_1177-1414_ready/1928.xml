   <text>
      <body>
         <div type="abstract">
            <p>
               <rs type="event" ref="#ev__QGW_II_II_1928"><rs type="fn" role="issuer"><rs type="person" ref="#pe__katharina_QGW_II_II_1928">Kathrei, <rs type="person" ref="#pe__michael_kind_QGW_II_II_1928">Michels des Kinds <roleName type="dead">witib</roleName> von Praunstorf</rs>,<roleName type="kin" corresp="#pe__michael_kind_QGW_II_II_1928"><add>witib</add></roleName></rs> und <rs type="person" ref="#pe__margarethe_stainaprunnerin_QGW_II_II_1928">Margrecht die
                        Stainaprunerin, ir <roleName type="kin" corresp="#pe__katharina_QGW_II_II_1921">swester</roleName></rs>
                  </rs>, <triggerstring n="disp">verzichten</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__rudolf_angerfelder_QGW_II_I_1335"><roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName> <roleName type="title">hern</roleName> Rudolfs des
                        Angervelder</rs> und <rs type="org" ref="#org__wien">des Rathes</rs></rs>
                  gegen Empfang von 46 lb dn. <rs type="fn" role="other"><triggerstring n="fn">zu
                        Gunsten</triggerstring>
                     <rs type="person" ref="#pe__johann_radeundel_QGW_II_II_1928">der Witwe Kathrei
                        ihres <roleName type="kin" corresp="#pe__katharina_QGW_II_II_1921">Bruders</roleName> Hans des Rada/eundl</rs></rs> auf ihre wartung an den
                  von diesem der genannten Witwe zu Leibgeding hinterlassenen Gütern: einem Hause,
                  gelegen in der Schulstrass, genant under dem Nuspaum, an ainem tail zenechst dem
                  haus, das weilent des Seber gewesen ist, und an dem andern tail zenechst des Magen
                  haus , von dem man dem Propste von St. Stephan 3 lb dn. Burgrecht dient, einem
                  Stadel, gelegen vor Stubentor bei der Neuenpruck, und dem Futterrecht.</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_II_1928"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="#org__wien">städtischen Grundsiegel</rs> und dem Siegel
               <rs type="person" ref="#pe__paul_wuerfel_QGW_II_II_1928">hern Pauln des
                        Würffels, <roleName type="occ" corresp="#org__oesterreich-herzogtum">münssmaister</roleName> in Osterreich</rs>.</rs></rs>
            </p>
