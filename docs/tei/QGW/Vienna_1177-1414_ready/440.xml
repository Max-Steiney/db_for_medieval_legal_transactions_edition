               <rs type="event" ref="#ev__QGW_II_I_440"><rs type="fn" role="issuer"><rs type="person" ref="#pe__johann_minnganch_QGW_II_I_770">Janns der Minngang</rs>,<rs type="person" ref="#pe__anna_QGW_II_I_440"> Anna, seine <roleName type="kin" corresp="#pe__johann_minnganch_QGW_II_I_770">Hausfrau</roleName></rs>, und
                        <rs type="person" ref="#pe__niklas_minnganch_QGW_II_I_440">Nichlas der
                        Minngang, sein <roleName type="kin" corresp="#pe__johann_minnganch_QGW_II_I_770">Bruder</roleName></rs>,</rs>
                  <triggerstring n="disp">verkaufen mit gesammter Hand</triggerstring> ihres rechten
                  Eigens das Drittheil an den 3 lb 35 dn. gelts, die da ligent auf fumfthalben und
                  zwainzich viertailn weingarten, der fumfzehen viertail weingarten ligent oberhalb
                  des Greiffen holz, so ligent die andern zehenthalb viertail weingarten vor dem
                  Aingern, und auf einem chrautgarten, gelegen auf der Schotten wisen , um 7 lb dn.
                     <rs type="fn" role="recipient"><rs type="person" ref="#pe__johann_von_segenberg_QGW_II_I_789">dem <roleName type="occ" corresp="#org__wien">Wiener Bürger </roleName>Jansen von Segenberch</rs>
                     und <rs type="person" ref="#pe__gertrud_QGW_II_I_789">seiner <roleName type="kin" corresp="#pe__johann_von_segenberg_QGW_II_I_789">Hausfrau</roleName> Gedrauten</rs></rs>.</rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_440"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1., 2. <rs type="person" ref="#pe__johann_minnganch_QGW_II_I_770">der Aussteller</rs>
                     <rs type="person" ref="#pe__niklas_minnganch_QGW_II_I_440"><add>Aussteller</add></rs>, 3. <rs type="person" ref="#pe__michael_poll_QGW_II_I_440">ihres <roleName type="kin" corresp="#pe__johann_minnganch_QGW_II_I_770">Oheims</roleName><roleName type="kin" corresp="#pe__niklas_minnganch_QGW_II_I_440"><add>Oheim</add></roleName> Michels des Pollen</rs></rs>.</rs>
