            <placeName>Wien</placeName>
            <date when="14030609">1403 VI 09</date>
            <origDate instant="false">Geben zu Wienn an sambstag vor sand Veits tag, nach Kristi gepurd 1400 jar,
               darnach in dem 3. jar. </origDate></creation></profileDesc></teiHeader><text><body><div type="abstract" resp="kg"><p><rs type="event" ref="#ev__QGW_II_I_1542a"><rs type="fn" role="issuer"><rs type="person" ref="#pe__wilhelm_herzog_von_oesterreich_QGW_II_I_1313">Herzog
                     Wilhelm</rs></rs>
                  <triggerstring n="disp">beurkundet, dass</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="disp">vor seinem</triggerstring>
                     <rs type="person" ref="#pe__berthold_von_wehingen_QGW_II_I_1055"><roleName type="occ" corresp="#pe__wilhelm_herzog_von_oesterreich_QGW_II_I_1313">Kanzler</roleName>
                        <roleName type="occ" corresp="#org__freising-dioezese">Bischof</roleName>
                        Berthold von Freising</rs>, seinem <rs type="person" ref="#pe__rudolf_von_wallsee_QGW_II_I_1205"><roleName type="occ" corresp="#pe__wilhelm_herzog_von_oesterreich_QGW_II_I_1313">Hofmeister</roleName>
                        Rudolf von Walsse</rs>, seinem <rs type="person" ref="#pe__friedrich_von_wallsee_QGW_II_I_1344"><roleName type="occ" corresp="#pe__wilhelm_herzog_von_oesterreich_QGW_II_I_1313">Landmarschall</roleName>
                        Friedreich von Walsse</rs>, <rs type="person" ref="#pe__friedrich_von_stubenberg_QGW_II_I_1542a">Fridreichen von
                        Stubenberg, <rs type="person" ref="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_1020">Herzogs Albrecht</rs>
                        <roleName type="occ" corresp="#pe__albrecht_herzog_von_oesterreich_QGW_II_I_1020">Hofmeister</roleName></rs>, und seinen anderen Räthen</rs>
                  <rs type="fn" role="other"><rs type="person" ref="#pe__rudolf_von_tierna_QGW_II_I_1351">Rudolf
                        von Tirna</rs> für sich und seine Geschwister <triggerstring n="fn"><add>geklagt</add></triggerstring>
                  </rs> zu weilent Hannsen des Stosser nachgelassenen Gütern um 5132 lb dn.
                     <triggerstring n="disp">geklagt</triggerstring> und <rs type="event" ref="NULL">einen ihm von Dietreichen dem Prenner, munssmaister ze Wienn, ausgestellten
                     behabbrief</rs> vorgewiesen <triggerstring n="disp">habe</triggerstring>. <rs type="fn" role="other"><triggerstring n="fn">Dagegen</triggerstring> habe der <rs type="person" ref="#pe__konrad_vorlauf_QGW_II_I_1320">Wiener <roleName type="occ" corresp="#org__wien">Bürger</roleName> Chunrat der Vorlauf <roleName type="rep" corresp="#org__wien">anstatt</roleName></rs></rs> des
                  Bürgermeisters an den Nachlass Anspruch erhoben von gescheffts wegen, das der
                  egenant Hanns Stosser mit im getan hat, und <rs type="event" ref="NULL">eine
                     Urkunde Herzogs Albrecht III. sowie einen von demselben Münzmeister dem Peter
                     Stosser ertheilten behabbrief</rs> vorgelegt. Die Herren und Räthe entscheiden
                     <rs type="fn" role="recipient">zu Gunsten <rs type="person" ref="#pe__rudolf_von_tierna_QGW_II_I_1351">Rudolfs von Tirna</rs></rs>.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>