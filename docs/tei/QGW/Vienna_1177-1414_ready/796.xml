            <div type="abstract" resp="cs">
                <p>
                    <rs type="event" ref="#ev__QGW_II_I_796"><rs type="fn" role="issuer"><rs
                                type="person" ref="#pe__heinrich_von_fuenfkirchen_QGW_II_I_796"
                                >Hainreich von Fümfchirchen, der <roleName type="prof"
                                    >chürsner</roleName></rs>, und seine <rs type="person"
                                ref="#pe__anna_QGW_II_I_796"><roleName type="kin"
                                    corresp="#pe__heinrich_von_fuenfkirchen_QGW_II_I_796"
                                    >Hausfrau</roleName> Ann</rs></rs>
                        <triggerstring n="disp">verkaufen</triggerstring>
                        <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des
                                <rs type="person" ref="#pe__thomas_swaeml_QGW_II_I_1012"><roleName
                                    type="occ" corresp="#org__wien">Bürgermeisters</roleName>
                                <roleName type="title">hern</roleName> Thomans des Swêmmleins</rs>
                            und des <rs type="org" ref="#org__wien">rats gemaine der stat ze
                                Wienne</rs></rs> ihre Brandstatt eines Hauses, gelegen innerhalb
                        Werdertor ze Wienne zenechst Steuz/zz/zen haus, des Juden, von der man hern
                        Jannsen an dem Chienmarcht 60 dn. zu Burgrecht dient, um 3 lb dn. <rs
                            type="fn" role="recipient"><rs type="person"
                                ref="#pe__michael_von_perg_QGW_II_I_796">Micheln von Perg, dem
                                    <roleName type="prof">chursner</roleName></rs>, und seiner <rs
                                type="person" ref="#pe__lucia_QGW_II_I_796"><roleName type="kin"
                                    corresp="#pe__michael_von_perg_QGW_II_I_796">Hausfrau</roleName>
                                Lucein</rs></rs>.</rs>
                </p>
            </div>
            <div type="seal">
                <p><rs type="event" ref="#ev__QGW_II_I_796"><rs type="fn" role="witness">Besiegelt
                            mit dem <rs type="org" ref="#org__wien">städtischen Grundsiegel</rs> und
                            dem Siegel <rs type="person" ref="#pe__thomas_raedler_QGW_II_I_1014"
                                    ><roleName type="title">hern</roleName> Thomans des Raedler, des
                                    <roleName type="occ" corresp="#org__wien">rats der stat ze
                                    Wienn</roleName></rs>.</rs></rs>
                </p>
