            <origDate instant="false">ze Wienn, an sand Larenzen abend.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00735_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_00735_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="lp"><p>
               <rs type="event" ref="#ev__QGW_II_I_735"><rs type="fn" role="issuer"><rs type="person" ref="#pe__leopold_von_asparn_QGW_II_I_735">Leupolt von Asparn, <roleName type="occ" corresp="#org__wien-st_niklas_vor_dem_stubentor_zisterzienserinnen">schaffer</roleName> der geistleichen vrowen dacz sand Nichlas ze
                        Wienn</rs>, und <rs type="person" ref="#pe__katharina_QGW_II_I_735"> Katrei,
                        seine <roleName type="kin" corresp="#pe__leopold_von_asparn_QGW_II_I_735">Hausfrau</roleName></rs></rs>, <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person" ref="#pe__niklas_wuerfel_QGW_II_I_1001">
                        <roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName>
                        <roleName type="title">hern</roleName> Niclas des Würfels</rs> und <rs type="org" ref="#org__wien">des rates gemain der stat ze Wienn</rs></rs>
                  ihres rechten Kaufgutes ein Haus, gelegen bei Stubentor ze Wienn, das weiln des
                  Stier gewesen ist, zenechst Rugers haus, des rostauscher von La , von dem man zu
                  dem ewigen Jahrtage, den her Chunrat in dem Tuemprobsthof selig ze sand Stephan ze
                  Wienn gestiftet hat, 5 lb dn., den geistlichen Frauen dacz sand Larenzen ze Wienn
                  ½ lb dn., hern Nichlasen dem Würfel 5 ½ lb dn. ze purchrecht dient, um 27 lb dn.
                     <rs type="fn" role="recipient"><rs type="person" ref="#pe__paul_QGW_II_I_735">Pauln, dem <roleName type="prof">rostauscher</roleName> ze Wienn</rs>, und
                        <rs type="person" ref="#pe__elisabeth_QGW_II_I_735">seiner <roleName type="kin" corresp="#pe__paul_QGW_II_I_735">Hausfrau</roleName>
                        Elsbeten</rs>.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_735"><rs type="fn" role="witness">Besiegelt : 1.
                        <rs type="org" ref="#org__wien">mit dem städtischen Grundsiegel</rs>, den
                     Siegeln 2.<rs type="person" ref="#pe__jakob_chetner_QGW_II_I_284">
                        <roleName type="title">hern</roleName> Jacobs des Chetner, <roleName type="occ" corresp="#org__wien">des rates der stat ze
                        Wienn</roleName></rs>, 3. <rs type="person" ref="#pe__albrecht_rampersdorfer_QGW_II_I_388"><roleName type="title">hern</roleName> Albrechts des Ramperstorfer, <roleName type="occ" corresp="#org__wien">purger</roleName> ze Wienn</rs>.</rs></rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>