            <origDate instant="false">ze Wienn, des nachsten phinztags nach sand Ulreichs tag.</origDate></creation></profileDesc></teiHeader><facsimile><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01548_r.jpg"/></surface><surface><graphic url="http://images.monasterium.net/pics/AT-WStLA/HA-U/WStLA-HA-Urkunden_01548_v.jpg"/></surface></facsimile><text><body><div type="abstract" resp="kg"><p>
               <rs type="event" ref="#ev__QGW_II_I_1548"><rs type="fn" role="issuer"><rs type="person" ref="#pe__agnes_QGW_II_I_1548">Agnes, <roleName type="kin" corresp="#pe__niklas_fraunmesser_QGW_II_I_1548"><add>hausfrau</add></roleName>
                        <rs type="person" ref="#pe__niklas_fraunmesser_QGW_II_I_1548">Niklas hausfrau
                           des Fraunmessers</rs> und <rs type="person" ref="#pe__peter_kremser_QGW_II_I_1148">Petreins <roleName type="dead">seligen</roleName> des Chremser, des
                              <roleName type="prof">schuster</roleName></rs>, <roleName type="kin" corresp="#pe__peter_kremser_QGW_II_I_1148">tochter</roleName></rs>,</rs>
                  <triggerstring n="disp">verkauft</triggerstring>
                  <rs type="fn" role="other">mit Handen des <rs type="person" ref="#pe__haunold_schuchler_QGW_II_I_1557"><roleName type="occ" corresp="#org__wien">Bürgermeisters</roleName>
                        <roleName type="title">Herrn</roleName> Haunolts des Schuchler</rs> und des
                        <rs type="org" ref="#org__wien">rats gemain der stat ze Wienn</rs></rs> 12
                  sh. dn. <triggerstring n="disp">geltes purkrechts (ablösbar)</triggerstring> auf ihrem
                  Hause, gelegen auf dem Steig bei den Predigern ze Wienn an ainem tail zenechst des
                  Hasenpalkchs haus, des fleischakcher, und an dem andern tail zenechst Niklas haus
                  von Krems, von dem man dem Wiener Bürger Merten, dem wachsgiesser, 1 lb dn. zu
                  Burgrecht dient, <rs type="event" ref="#ev__QGW_II_I_1548_men_1">und dessen eine Hälfte sie von ihrem
                     Vater, die andere von ihrer Stiefmutter Kristein geerbt hatte,</rs> um 12 lb
                  dn. <rs type="fn" role="recipient">der <rs type="person" ref="#pe__katharina_neunmarkterin_QGW_II_I_1196"><roleName type="title">Frau</roleName>
                        Kathrein der Neumarkchterin</rs>.</rs></rs>
            </p></div><div type="seal"><p><rs type="event" ref="#ev__QGW_II_I_1548"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="#org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="#pe__georg_neuer_QGW_II_I_1195">Wiener <roleName type="occ" corresp="#org__wien">Bürgers</roleName> Jorgen des Neuer</rs>.</rs></rs>
