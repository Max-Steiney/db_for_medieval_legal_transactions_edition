   <text>
      <body>
         <div type="abstract" resp="kg">
            <p>
               <rs type="event" ref="#ev__QGW_II_I_1453"><rs type="fn" role="issuer"><rs
                        type="person" ref="#pe__margarethe_chranvogelin_QGW_II_I_1129">Margret die
                        Kranfoglin, <roleName type="occ" corresp="#org__wien"
                           >purgerin</roleName> ze Wienn</rs></rs>, <triggerstring n="disp"
                     >stiftet</triggerstring> eine <rs type="fn" role="recipient"><rs type="org"
                        ref="#org__wien-st_stephan-altar_st_martin-messe_chranvogel">ewige Messe auf
                        sand Merten altar, gelegen in Allerheiligen tumkirchen dacz sand Stephan ze
                        Wienn</rs></rs>, und <triggerstring n="disp">widmet</triggerstring> zu derselben
                  erstens <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring><rs
                        type="person" ref="#pe__dorothea_von_gutenstain_QGW_II_I_1520"><roleName
                           type="title">swester</roleName> Dorothen von Gu/etenstain, <roleName
                           type="occ" corresp="#org__wien-st_klara">abtessinn</roleName> dacz sand
                        Chlarn ze Wienne</rs></rs>, ½ Joch Weingarten, des weilent zwen weinge/arten
                  gewesen sind, gelegen ze Grinzing in dem Kirichgraben und haisset die Krephlinn,
                  zenechst dem weingarten, genant die Hannsgrafinn , von dem man dem <rs type="org"
                     ref="#org__wien-st_klara">S. Clarakloster</rs> 30 dn. für Berg- und Voitrecht
                  und dem Pfarrer dacz der Heiligenstat zu einem ewigen Jahrtag 1 lb dn. dient,
                  zweitens 10 lb dn. geltes, gelegen ze Rêkendorf, <rs type="event"
                     ref="#ev__QGW_II_I_1453_men_1">die sie von dem <rs type="person"
                        ref="#pe__johann_schenk_von_ried_QGW_II_I_1416"><roleName type="title"
                           >Ritter</roleName>
                        <roleName type="title">hern</roleName> Hannsen dem Schenkchen von Ried</rs>
                     gekauft hatte.</rs></rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_1453">Besiegelt mit den Siegeln: <rs type="fn"
                     role="witness">1. der <rs type="person"
                        ref="#pe__dorothea_von_gutenstain_QGW_II_I_1520">Bergfrau</rs>, 2. <rs
                        type="person" ref="#pe__dietrich_prenner_QGW_II_I_1178"><roleName
                           type="title">hern</roleName> Dietreichs des Prenner, <roleName type="occ"
                           corresp="#org__oesterreich-herzogtum">münssmaister in
                           Österreich</roleName></rs>, 5. <rs type="person"
                        ref="#pe__niklas_von_der_schemnitz_iii_QGW_II_I_1371">Niclas des Schêrmiczer
                           <roleName type="title"><add>Bürger</add></roleName></rs>, 4. <rs
                        type="person" ref="#pe__michael_menschein_QGW_II_I_1218">Michels des
                        Mênscheins, paid <roleName type="title">purger ze
                  Wienn</roleName></rs></rs>.</rs>
            </p>
         </div>
