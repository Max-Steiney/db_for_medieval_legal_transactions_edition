   <text>
      <body>
         <div type="abstract" resp="cs">
            <p>
               <rs type="event" ref="#ev__QGW_II_I_1627"><rs type="fn" role="issuer"><rs
                        type="person" ref="#pe__martin_hausleitter_QGW_II_I_1234">Mert der
                        Hausleitter, des <roleName type="occ" corresp="#org__wien">rats</roleName>
                        der stat ze Wienn,</rs> und <rs type="person"
                        ref="#pe__katharina_QGW_II_I_1603">Kathrei, seine <roleName type="kin"
                           corresp="#pe__martin_hausleitter_QGW_II_I_1234"
                     >Hausfrau</roleName></rs>,</rs>
                  <triggerstring n="disp">verkaufen</triggerstring>
                  <rs type="fn" role="other"><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__haug_von_wehing_QGW_II_I_1627">ihres <roleName
                           type="title">Bergherrn</roleName>
                        <roleName type="title">pruder</roleName> Haugen von Wêching, <roleName
                           type="occ" corresp="#org__wien-st_johann_in_der_kaerntnerstrasse"
                           >comiteur</roleName> des hauses dacz sand Johanns in der Kernerstrass ze
                        Wienn,</rs>
                     <rs type="person" ref="#pe__dorothea_von_gutenstain_QGW_II_I_1520">der <roleName
                           type="title">Bergfrau</roleName>
                        <roleName type="title">swester</roleName> Dorothen von Gutenstain, <roleName
                           type="occ" corresp="#org__wien-st_klara">abtessin</roleName> dacz sand
                        Chlarn ze Wienn</rs>, und <rs type="person"
                        ref="#pe__niklas_wuerfel_von_nussdorf_QGW_II_I_1107">des <roleName
                           type="title">Bergmeisters</roleName> Niclas des Würffels ze Nusdorf,
                           <roleName type="occ" corresp="#org__klosterneuburg">amptman</roleName> des
                        chlosters ze Neunburg</rs></rs>, ein Joch Weingarten, das sie mit gesammter
                  Hand gekauft hatten, genannt der Ringk, gelegen ze Grinzingen zenechst maister
                  Andres weingarten des Purniczer an ainem tail und zenechst hern Hainreichs
                  weingarten von Vorchaim, chapellan dacz sand Stephan, an dem andern tail, von dem
                  man nach S. Johann ½ Eimer Wein zu Bergrecht und einen Helbling zu Voitrecht, nach
                  S. Clara 7/4 Wein zu Bergrecht und 1 dn. zu Voitrecht,. dem Kloster ze Neunburch ½
                  Eimer Wein zu Bergrecht und 1 dn. zu Voitrecht dient, und zwo hofstet, gelegen
                  nebeneinander unden vor dem Ring, von deren einer zenechst Hannsen hofstat des
                  Seber man nach S. Clara 9 dn. zu Bergrecht und von der andern zenechst Niclas
                  hofstat des Retenperger dem Kloster ze Neunburgk 9 dn. zu Bergrecht dient, unter
                  den in no 1626 angeführten Bedingungen um 240 lb dn. <rs type="fn"
                     role="recipient"><rs type="person" ref="#pe__anna_QGW_II_I_1619"><roleName
                           type="title">fraun</roleName> Annen, Jacobs des Stichels <roleName
                           type="kin" corresp="#pe__jakob_stichel_QGW_II_II_3713"
                        >witiben</roleName></rs></rs> .</rs>
            </p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_I_1627"><rs type="fn" role="witness">Besiegelt mit
                     den Siegeln: 1. des <rs type="person"
                        ref="#pe__martin_hausleitter_QGW_II_I_1234">Ausstellers</rs>, 2. des <rs
                        type="person" ref="#pe__haug_von_wehing_QGW_II_I_1627">Bergherrn</rs>, 3. der
                        <rs type="person" ref="#pe__dorothea_von_gutenstain_QGW_II_I_1520"
                        >Bergfrau</rs>, 4. des <rs type="person"
                        ref="#pe__niklas_wuerfel_von_nussdorf_QGW_II_I_1107">Bergmeisters</rs>, 5.
                     des <rs type="person" ref="#pe__andreas_vischl_QGW_II_I_1089">Wiener <roleName type="occ" corresp="#org__wien">Bürgers</roleName> Andres des
                        Vischleins</rs>.</rs></rs>
            </p>
         </div>
