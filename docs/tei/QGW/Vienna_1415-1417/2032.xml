   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="#ev__QGW_II_II_2032">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="#pe__jakob_asperlaibel_QGW_II_II_2032">Jacob Asperlaibel, <roleName
                           type="occ" corresp="#org__wien">burger</roleName> ze Wienn</rs>, und <rs
                        type="person" ref="#pe__katharina_QGW_II_II_2032"> Kathrei, sein<roleName
                           type="kin" corresp="#pe__jakob_asperlaibel_QGW_II_II_2032">
                           hausfrau</roleName></rs></rs>, verkaufen <rs type="fn" role="other"
                        ><triggerstring n="fn">mit Handen</triggerstring>
                     <rs type="person" ref="#pe__rudolf_angerfelder_QGW_II_I_1335">des <roleName
                           type="occ" corresp="#org__wien">Bürger<add>meister</add></roleName>- und
                           <roleName type="occ" corresp="#org__wien">Münzmeisters</roleName> Rudolfs
                        des Angervelder</rs>
                     <rs type="org" ref="#org__wien">und des rats gemain der stat ze Wienn</rs></rs>
                  5½ lb dn. gelts purkrechts (ablösbar) auf ihrem Hause, gelegen in dem
                  Schiltergesslein zenechst Ulreichs haus des Schabenchês, um 44 lb dn. <rs
                     type="fn" role="recipient"><rs type="person"
                        ref="#pe__laurenz_von_neunburg_QGW_II_II_2032"><roleName type="title"
                           >hern</roleName> Laurenzen von Neunburg, <roleName type="occ"
                           corresp="#org__wien-st_stephan">echter</roleName> dacz sand Stephan und
                           <roleName type="occ"
                           corresp="#org__wien-st_stephan-altar_allerheiligen-messe_osterhofer"
                           >Kaplan</roleName></rs>
                     <rs type="event" ref="NULL"><rs type="fn" role="issuer">der von <rs
                              type="person" ref="#pe__anna_QGW_II_II_2032"><roleName type="title"
                                 >frau</roleName>Ann, <rs type="person"
                                 ref="#pe__heinrich_osterhofer_QGW_II_II_2032">Heinreichs von
                                 Osterhoven <roleName type="dead"
                                 ><add>witib</add></roleName></rs><roleName type="kin"
                                 corresp="#pe__heinrich_osterhofer_QGW_II_II_2032"
                                    >witib</roleName></rs>, auf <rs type="org" ref="#org__wien-st_stephan-altar_allerheiligen-messe_osterhofer">Allerheiligen altar daselbs gestifteten
                           Messe</rs>.</rs></rs></rs>
               </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_II_2032"><rs type="fn" role="witness">Besiegelt mit
                     dem <rs type="org" ref="#org__wien">städtischen Grundsiegel</rs> und dem Siegel
                     des <rs type="person" ref="#pe__johann_fuechsel_QGW_II_I_1562">Wiener <roleName
                           type="occ" corresp="#org__wien">Bürgers</roleName> Hansen des
                        Füchsleins</rs></rs>. </rs></p>
         </div>
