   <text>
      <body>
         <div type="abstract">
            <p><rs type="event" ref="#ev__QGW_II_II_2043">
                  <rs type="fn" role="issuer"><rs type="person" ref="#pe__gilg_haider_QGW_II_II_2043"
                        >Gilig Haider, <roleName type="occ" corresp="#org__enzesfeld"
                        >pfleger</roleName> zu Enczesveld</rs>, und <rs type="person"
                        ref="#pe__anna_QGW_II_II_2043">Anna, sein <roleName type="kin"
                           corresp="#pe__gilg_haider_QGW_II_II_2043">hausfrau</roleName></rs>,
                     </rs> theilen <rs type="fn" role="recipient"><rs type="person"
                        ref="#pe__konrad_chiemseer_StB_I_178">Chunraten dem Chiemseer, <roleName
                           type="occ" corresp="#org__wien">des raczs</roleName> der stat ze
                        Wienn</rs>, und <rs type="person" ref="#pe__paul_wuerfel_QGW_II_II_1928"
                        >Pauln dem Würffel<roleName type="occ" corresp="#org__wien"
                        >purger</roleName>, daselbs</rs>, mit, </rs><rs type="event" ref="NULL">dass
                           sie<add><rs type="fn" role="issuer"><rs type="person"
                              ref="#pe__gilg_haider_QGW_II_II_2043">Gilig Haider</rs> und <rs
                              type="person" ref="#pe__anna_QGW_II_II_2043">Anna, sein <roleName
                                 type="kin" corresp="#pe__gilg_haider_QGW_II_II_2043"
                                 >hausfrau</roleName></rs></rs></add> dem <rs type="fn"
                        role="recipient"><rs type="person" ref="#pe__peter_eila_QGW_II_II_2043"
                              ><roleName type="prof">Goldschmied</roleName> Petern von Eila</rs> ihr
                        Haus an dem Alten Rosmarkt, in dem er wohnt, für 80 lb dn. verpfändet
                        haben</rs></rs>, und ersuchen sie, ihn deshalb in der stat saczpuech zu
                  schreiben. Er soll das Haus vom nächsten St. Michaelstage über vier Jahre
                  innehaben, nach welcher Zeit es frei von jeder Schuld wieder an sie zurückfallen
                  solle. </rs></p>
         </div>
         <div type="seal">
            <p><rs type="event" ref="#ev__QGW_II_II_2043"><rs type="fn" role="witness">Siegler: <rs
                        type="person" ref="#pe__gilg_haider_QGW_II_II_2043">der Aussteller</rs> und
                        <rs type="person" ref="#pe__johann_fuechsel_QGW_II_I_1562">der Wiener
                           <roleName type="occ" corresp="#org__wien">Bürger</roleName> Hanns der
                        Füxl</rs>.</rs>
               </rs></p>
