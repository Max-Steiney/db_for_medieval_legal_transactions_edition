         <div type="abstract">
            <p><rs type="event" ref="#ev__QGW_II_II_2035">
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="#pe__matthias_fluegel_QGW_II_II_2035"><roleName type="occ"
                           corresp="#org__kuttenberg"><add>münzerschopfen</add></roleName>Mathes
                        Flügel</rs>,<rs type="person" ref="#pe__lukas_muenczer_QGW_II_II_2035"
                           ><roleName type="occ" corresp="#org__kuttenberg"
                           ><add>münzerschopfen</add></roleName>Lucas Münczer</rs>, <rs
                        type="person" ref="#pe__wenzel_taepler_QGW_II_II_1909"><roleName type="occ"
                           corresp="#org__kuttenberg"><add>münzerschopfen</add></roleName>Wenczlaw
                        Topler</rs>, <rs type="person" ref="#pe__burkhard_rosental_QGW_II_II_2035"
                        >Purkart von Rosental, <roleName type="occ" corresp="#org__kuttenberg"
                           >münzerschopfen</roleName> in den smiden</rs>, <rs type="person"
                        ref="#pe__hanmann_alder_QGW_II_II_1909"><roleName type="occ"
                           corresp="#org__kuttenberg"><add>schopfen</add></roleName>Hanman
                     Alder</rs>, <rs type="person" ref="#pe__johann_piesk_QGW_II_II_2035"><roleName
                           type="occ" corresp="#org__kuttenberg"><add>schopfen</add></roleName>Hannus
                        von Piesk</rs>, <rs type="person" ref="#pe__johann_swab_QGW_II_II_1974"
                        >Hannus Swab, <roleName type="occ" corresp="#org__kuttenberg"
                           >schopfen</roleName> in dem preghaus</rs>, bestätigen</rs>, dass <rs
                     type="person" ref="#pe__heinrich_flemming_QGW_II_II_2035">Heinreich Flemming,
                        <roleName type="prof">goltsmid</roleName> auf dem perg zum Chutten</rs>, ein
                  vierteil einer smiden, gelegen auf dem königlichen Münzhofe, genant in der Prager
                  smiden, um 50 schock grosser gueter Prager pfenning von <rs type="person"
                     ref="#pe__paul_meiler_QGW_II_II_2035">Paul Meiler, etwenn <roleName type="occ"
                        corresp="#org__kuttenberg">perkschreiber</roleName> des pergs zun
                     Chutten</rs> , gekauft habe. </rs></p>
