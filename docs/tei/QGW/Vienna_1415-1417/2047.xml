         <div type="abstract">
            <p><rs type="event" ref="#ev__QGW_II_II_2047">
                  <rs type="fn" role="issuer"><rs type="person" ref="#pe__agnes_QGW_II_II_2047"
                        >Agnes, <rs type="person" ref="#pe__martin_fraunmesser_QGW_II_II_2047"
                           >Mertten des Fraunmesser</rs>
                        <roleName type="kin" corresp="#pe__martin_fraunmesser_QGW_II_II_2047"
                           >hausfrau</roleName></rs></rs>, verkauft <rs type="fn" role="other"
                        ><triggerstring n="fn">mit Handen</triggerstring> des <rs type="person"
                        ref="#pe__rudolf_angerfelder_QGW_II_I_1335"><roleName type="occ"
                           corresp="#org__wien">Bürger<add>meister</add></roleName>- und <roleName
                           type="occ" corresp="#org__wien">Münzmeisters</roleName> Ruedolfs des
                        Angervelder </rs>und des <rs type="org" ref="#org__wien">rats</rs> gemain der stat
                        ze Wienn</rs> 3½ lb dn. gelts purkrechts (ablösbar) auf ihrem Hause,
                  gelegen auf dem Steig bei den Predigern zenechst fraun Elsbeten der Chremserin
                  haus, um 28 lb dn. dem <rs type="fn" role="recipient"><rs type="person"
                        ref="#pe__christian_QGW_II_II_2047"><roleName type="prof">Priester</roleName>
                        <roleName type="title">hern</roleName> Christann, <roleName type="occ"
                           corresp="#org__wien-st_stephan-altar_st_maria-messe_strobein"
                           >Kaplan</roleName> der von Stephann dem Strobein bei St. Stephan
                        gestifteten Messe</rs>, <rs type="org"
                        ref="#org__wien-st_stephan-altar_st_maria-messe_strobein">zu dieser
                        Messe</rs></rs>. </rs></p>
