                     <rs type="place" ref="pl__wien-immo_kamerhof_4"><roleName type="owner" corresp="pe__andreas_dietram_QGW_II_III_4173">seins</roleName> hawss,
                           <roleName type="topo" corresp="pl__wien-kamerhof">gelegen vor dem
                           Kamerhof am egk</roleName>, <roleName type="topo" corresp="pl__wien-tuchlauben">zenagst <add>an aim tail</add></roleName>
                        <rs type="place" ref="pl__wien-tuchlauben">den langen Tuchlauben</rs> an aim
                        tail <roleName type="topo" corresp="pl__wien-immo_kamerhof_2">und an dem
                           andern zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_kamerhof_2"><roleName type="owner" corresp="pe__simon_salczer_QGW_II_III_4173"><rs type="person" ref="pe__simon_salczer_QGW_II_III_4173">Symons Salczer, seins
                                    <roleName type="kin" corresp="pe__andreas_dietram_QGW_II_III_4173">aidems</roleName></rs></roleName> haws</rs>, ausgenomen des
                        gwantgwelbs darunder. <rs type="event" ref="ev__SB_CD_00058_men_1"><rs type="fn" role="transactiongood_II">Uber die <measure>zwaihundert
                                 pfunt phening</measure></rs>, <rs type="fn" role="recipient">die
                                 <rs type="person" ref="pe__wilhelm_mertinger_QGW_II_II_3715">Wilhalm Merttinger</rs> und <rs type="person" ref="pe__anna_SB_CD_00058"><roleName type="title">frawn</roleName>
                                 Annen <roleName type="kin" corresp="pe__wilhelm_mertinger_QGW_II_II_3715">weilent seiner
                                    hausfra(wn)</roleName>, <rs type="person" ref="pe__berthold_schuetzperger_SB_CD_00058">Berchtolden
                                    Schützperger</rs>
                                 <roleName type="kin" corresp="pe__berthold_schuetzperger_SB_CD_00058">tochtter</roleName>
                                 <roleName type="dead">seligen</roleName></rs> nagsten erben</rs>
                           <triggerstring n="disp">vor</triggerstring> darauf <triggerstring n="disp">verschriben sein</triggerstring>, <rs type="fn" role="issuer"><rs type="place" ref="pl__wien-immo_kamerhof_4">davon</rs> man</rs>
                           demselben Merttinger <triggerstring n="disp">jerlichen dint <add>ains
                                 satzbriefs</add></triggerstring>
                           <rs type="fn" role="transactiongood_I"><measure>zwaintzig phunt
                                 phening</measure>, <triggerstring n="disp">nach lautt ains
                                 satzbriefs</triggerstring></rs>, den er darumb hat</rs></rs>.</rs>
                  <rs type="fn" role="transactiongood_II">Umb <measure>funfthalb hundert phunt
                        phening</measure></rs>
                  <rs type="fn" role="issuer">dem <rs type="person" ref="pe__johann_marchart_QGW_II_II_3350"><roleName type="title">erbern</roleName> Hannsen Marcharten, seinem <roleName type="kin" corresp="pe__andreas_dietram_QGW_II_III_4173">vettern</roleName></rs> und
