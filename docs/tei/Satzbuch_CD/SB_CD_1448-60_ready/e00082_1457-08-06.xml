      <body>
         <div type="entry" resp="kg">
            <p><rs type="event" ref="ev__SB_CD_00082"><rs type="fn" role="issuer"><rs type="person"
                        ref="pe__andreas_heming_QGW_II_II_3728">Andre Hemyng der <roleName
                           type="prof">tuchbraytter</roleName>
                        <roleName type="title_ref" corresp="pl__wien">zu</roleName> Wien</rs> und
                        <rs type="person" ref="pe__dorothea_QGW_II_II_3728">Dorothe sein <roleName
                           type="kin" corresp="pe__andreas_heming_QGW_II_II_3728"
                           >hausfraw</roleName></rs></rs>
                  <triggerstring n="disp">habent versaczt</triggerstring>
                  <rs type="fn" role="transactiongood_I"><rs type="place"
                        ref="pl__wien-immo_weihenburg_11"><roleName type="owner"
                           corresp="pe__andreas_heming_QGW_II_II_3728">ir</roleName>
                        <roleName type="owner" corresp="pe__dorothea_QGW_II_II_3728"
                           ><add>ir</add></roleName> haws, <roleName type="topo"
                           corresp="pl__wien-weihenburg">gelegen in der Weihenpurgk</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_weihenburg_12"
                           >zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_weihenburg_12"><roleName type="owner"
                              corresp="pe__veit_illuminierer_QGW_II_II_3728">Veiten
                              Illuminerer</roleName> haws</rs></rs>,</rs>
                  <rs type="fn" role="recipient">den <rs type="person"
                        ref="pe__niklas_von_bladen_QGW_II_II_3719"><roleName type="title"
                           >edln</roleName>
                        <roleName type="title">hern</roleName> Niclasen</rs> und<note>
                        <p rend="footnote text"> Hern Niclasen und: Links neben der Zeile
                           eingefügt.</p>
                     </note>
                     <rs type="person" ref="pe__wenzel_von_bladen_QGW_II_II_3706"><roleName
                           type="title"><add>edln</add></roleName>
                        <roleName type="title"><add>hern</add></roleName> Wenczlaben, <roleName
                           type="kin" corresp="pe__niklas_von_bladen_QGW_II_II_3719"
                           >gepruder</roleName><note>
                           <p rend="footnote text"> Gepruder: Über der Zeile eingefügt.</p>
                        </note> vom Bladen</rs> und seinen erben</rs>
                  <rs type="fn" role="transactiongood_II">umb <measure>virczig guter Ungrischer
                        guldein in gold</measure>
                     <triggerstring n="impl_rules">oder aber für yeden benanten guldein ain phunt und
                        vir phenig. Und sind zu beczaln auf sand Kathrein tag nagst kunftig oder
                        ynner den nagsten virczehen tagen, darnach ungeverlich an alles
                        vercziehen</triggerstring>.</rs>
                  <date>Actum an Samstag vor sand Larenczen tag, anno etc. lvii<hi rend="super"
                        >o</hi></date>.</rs></p>
            <p rend="Summa">Summa lxxx s. d.</p>
            <p rend="Nachtrag"><rs type="event" ref="ev__SB_CD_00082"><triggerstring n="disp">Den sacz
                     habent</triggerstring>
                  <rs type="fn" role="issuer"><rs type="person"
                        ref="pe__niklas_von_bladen_QGW_II_II_3719">die ge(nanten) geprüder</rs>
                     <rs type="person" ref="pe__wenzel_von_bladen_QGW_II_II_3706"><add>die
                           ge(nanten) geprüder</add></rs></rs>
                  <triggerstring n="disp">ledig gesagt</triggerstring> nach lautt ainer quittung, Den die
                     <rs type="fn" role="recipient"><rs type="person"
                        ref="pe__andreas_heming_QGW_II_II_3728">der ge(nant) Hemyng</rs></rs> darumb
                  hat.</rs></p>
            <p rend="Nachtrag">Albren Praitenstainer<note>
                  <p rend="footnote text"> Albren Praitenstainer: [Sachkommentar] Diese Anmerkung
                     verweist wahrscheinlich auf einen Grundbucheintrag über einen gewissen Albrecht
                     Praitenstainer, den man vergessen hat, an dieser Stelle zu platzieren.</p>
               </note>
            </p>
