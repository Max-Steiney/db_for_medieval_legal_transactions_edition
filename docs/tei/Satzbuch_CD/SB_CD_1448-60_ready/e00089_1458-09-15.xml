                  <triggerstring n="disp">hat versaczt</triggerstring>
                  <rs type="fn" role="transactiongood_I"><rs type="place"
                        ref="pl__wien-immo_kohlmarkt_11"><roleName type="owner"
                           corresp="pe__andreas_meichsner_QGW_II_II_3332">sein</roleName> haws,
                           <roleName type="topo" corresp="pl__wien-kohlmarkt">gelegen am alten
                           Kolmarkt</roleName>
                        <roleName type="topo" corresp="pl__wien-immo_kohlmarkt_7">zenagst</roleName>
                        <rs type="place" ref="pl__wien-immo_kohlmarkt_7"><roleName type="owner"
                              corresp="pe__johann_meurl_QGW_II_III_4046">Hannsen Mew´rl</roleName>
                           haws</rs>. <rs type="event" ref="ev__SB_CD_00057">Davon man jérlich dint
                           hern Niclasen Kilber, caplan der mess, die Ulreich Flekch auf unser Frawn
                           altar, in Sand Johanns capellen vor Werdertor gelegen, gestifft hat, zway
                           phunt phenig zu purkrecht, die abczulösen sind mit zwainczigk phunt
                           phenigen nach lautt ains purkrechtbriefs und nicht mer</rs></rs>.</rs>
                  <rs type="fn" role="recipient">Seinen <rs type="person"
                        ref="pe__katharina_SB_CD_00089"><roleName type="kin"
                           corresp="pe__andreas_meichsner_QGW_II_II_3332">kindern</roleName>
                        Kathrein</rs>, <rs type="person" ref="pe__barbara_SB_CD_00089"><roleName
                           type="kin" corresp="pe__andreas_meichsner_QGW_II_II_3332"
                              ><add>kindern</add></roleName>Barbaren</rs>, <rs type="person"
                        ref="pe__elisabeth_SB_CD_00089"><roleName type="kin"
                           corresp="pe__andreas_meichsner_QGW_II_II_3332"
                           ><add>kindern</add></roleName>Elspeten</rs> und <rs type="person"
                        ref="pe__pankraz_meichsner_SB_CD_00089"><roleName type="kin"
                           corresp="pe__andreas_meichsner_QGW_II_II_3332"
                           ><add>kindern</add></roleName>Pangréczen, die noch nicht vogtpér
                        sein</rs>, und irn erben</rs>
                  <rs type="fn" role="transactiongood_II">umb <measure>achthalbsundzwainczigk phunt
                        phenig</measure>, <triggerstring n="reason">die in von muterlichs erbtails
                        wegen zugepürnt, von <rs type="event" ref="ev__SB_CD_00089_men_1"><rs
                              type="fn" role="transactiongood_I"><rs type="place"
                                 ref="pl__wien-immo_greffen_1">dem weingarten <roleName type="topo"
                                    corresp="pl__wien-greffen">in kúrczen Grefften</roleName>,
                                    <roleName type="topo" corresp="pl__wien-immo_greffen_2"
                                    >zenagst</roleName>
                                 <rs type="place" ref="pl__wien-immo_greffen_2"><roleName
                                       type="owner" corresp="pe__achatius_sachsenlander_SB_CD_00089"
                                          ><rs type="person"
                                          ref="pe__achatius_sachsenlander_SB_CD_00089">Achaczen
                                          Sachsenlander</rs></roleName> weingarten</rs>
                              gelegen</rs>,</rs> den <rs type="fn" role="issuer"><rs type="person"
                                 ref="pe__andreas_meichsner_QGW_II_II_3332">der egenant Andre
                                 Meichsner</rs></rs>
                           <rs type="fn" role="recipient"><rs type="person"
                                 ref="pe__margarethe_facs_762_TextRegion_1658324158833_2030"
                                 cert="high">der Larencz Goltsmidin</rs></rs>
                           <triggerstring n="disp">verkaufft hat</triggerstring></rs>.</triggerstring>
                     <triggerstring n="impl_rules">Und sind zu beczaln, wenn die egenanten kinder
                        vogtper werdent an alles vercziehen</triggerstring>.</rs>
                  <date>Actum an Freitag nach sand Mathens tag apostoli et ewangeliste, anno etc.
                        lviii<hi rend="super">o</hi></date>.</rs></p>
