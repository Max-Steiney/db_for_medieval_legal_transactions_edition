            <date when="1396-01-18">1396 Januar 18</date>
         </creation></profileDesc></teiHeader><text><body><div type="header"><p>erwandtschaftsweisung für Elsbeth, Mutter des Ulrich Grefenawer</p></div><div><p><rs type="event" ref="#ev__StB_I_24">V Einbr. 2 Zg. (Indez: Item frewntschaft Ulreichs
                  des Grevenawer) !tem an eritag vor sand Angnesen tag kom fur den rat <rs type="fn" role="recipient"><rs type="person" ref="#pe__ulrich_graefenauer_StB_I_24">Ulreich der Grefenawer an sein selbs und an seiner miterben <roleName type="rep" corresp="#pe__paul_StB_I_24">stat</roleName><roleName type="rep" corresp="#pe__anna_StB_I_24"><add>stat</add></roleName><roleName type="rep" corresp="#pe__wendel_StB_I_24"><add>stat</add></roleName></rs>
                     <rs type="person" ref="#pe__paul_StB_I_24">Pauln</rs>, <rs type="person" ref="#pe__anna_StB_I_24">Annen</rs> und <rs type="person" ref="#pe__wendel_StB_I_24">Wentlein</rs></rs> und hat da <rs type="fn" role="other"><triggerstring n="fn">beweist mit</triggerstring> den erbern leuten, mit
                        <rs type="person" ref="#pe__ortolf_graefenauer_StB_I_24">Ortolfen dem
                        Grefenawer <roleName type="title"><add>erber</add></roleName></rs> und mit
                        <rs type="person" ref="#pe__niklas_geisliczer_StB_I_24">Niclasen dem
                        Geisliczer <roleName type="title"><add>erber</add></roleName></rs></rs>, das
                     <rs type="person" ref="#pe__elisabeth_StB_I_24">sein <roleName type="kin" corresp="#pe__ulrich_graefenauer_StB_I_24">mueter</roleName>
                     <roleName type="title">fraw</roleName> Elspet <roleName type="kin" corresp="#pe__heinrich_von_chruegsperg_StB_I_24"><add>rechtew
                           geswistreyd</add></roleName></rs> und des <rs type="person" ref="#pe__heinrich_von_chruegsperg_StB_I_24">egenanten Pawln <roleName type="kin" corresp="#pe__paul_StB_I_24">vater</roleName> Haireich von
                     Chruegsperg <roleName type="kin" corresp="#pe__andreas_von_od_StB_I_24"><add>rechtew geswistreyd</add></roleName></rs> und <rs type="person" ref="#pe__andreas_von_od_StB_I_24">der vorgenanten Annen <roleName type="kin" corresp="#pe__anna_StB_I_24">vater</roleName> Andre von Od <roleName type="kin" corresp="#pe__wolfhard_graefenauer_StB_I_24"><add>rechtew
                           geswistreyd</add></roleName></rs> und <rs type="person" ref="#pe__wolfhard_graefenauer_StB_I_24">der obgenanten Wenntlein <roleName type="kin" corresp="#pe__wendel_StB_I_24">vater</roleName> Wolfhart der
                     Grefenawer <roleName type="kin" corresp="#pe__andreas_graefenauer_StB_I_24"><add>rechtew geswistreyd</add></roleName></rs> und <rs type="person" ref="#pe__andreas_graefenauer_StB_I_24">Andre der Grefenawer , <roleName type="dead">dem got gnad</roleName>, <roleName type="kin" corresp="#pe__elisabeth_StB_I_24">rechtew
                        geswistreyd</roleName></rs> gewesen sind von vater und von
                  mueter. Als darumb die obgenanten erbern leut mit irn trewn an ayde stat vor offem
                  rat habent gesagt, als si ze recht solten.</rs>
            </p></div><div type="lists"><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/placeList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/personList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/eventList.xml" xpointer="element(/1/2/1/1)"/><xi:include xmlns:xi="http://www.w3.org/2001/XInclude" href="../../../../indices/orgList.xml" xpointer="element(/1/2/1/1)"/></div></body></text></TEI>