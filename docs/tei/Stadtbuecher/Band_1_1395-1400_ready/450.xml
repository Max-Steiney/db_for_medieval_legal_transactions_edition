                  <div type="header">
                        <p>Verwandtschaftsweisung für Hans von Eselarn und Heinrich Schuchier</p>
                  </div>                   <div type="entry" resp="rs">
                        <p> 2 Einbr. 2 Zg. (Indez: Item frewntschaft Hansen von Eslarn und des
                              Schuchler) <rs type="event" ref="#ev__StB_I_450">(/01.74 v) Item des
                                    nachsten sambcztags nach sand Mertten tag <rs type="fn"
                                          role="other"><triggerstring n="fn">komen fur den
                                                rat</triggerstring><rs type="person"
                                                ref="#pe__johann_von_eslarn_QGW_II_I_1208">Hanns von
                                                Eselarn</rs>und <rs type="person"
                                                ref="#pe__heinrich_schuchler_QGW_II_I_499">Hainreich
                                                der <roleName type="prof" cert="unknown"
                                                  >Schuchler</roleName></rs></rs> und habent da <rs
                                          type="fn" role="witness">
                                          <rs type="person" ref="#pe__stephan_leitner_QGW_II_I_1012"
                                                >Stephann dem Leyttner</rs> und mit <rs
                                                type="person" ref="#pe__johann_list_QGW_II_I_1109"
                                                >Jannsen dem List</rs></rs>, das <rs type="fn"
                                          role="recipient"><rs type="person"
                                                ref="#pe__johann_von_eslarn_QGW_II_I_1208">si
                                                  <roleName type="kin"
                                                  corresp="#pe__heinrich_schuchler_QGW_II_I_499"
                                                  ><add>rechtew geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__magdalena_StB_I_450_a"><add>rechtew
                                                  geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__magdalena_StB_I_450_b"><add>rechtew
                                                  geswistreyd chind</add></roleName>
                                                <roleName type="kin" corresp="#pe__agnes_StB_I_450"
                                                  ><add>rechtew geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__katharina_StB_I_450"><add>rechtew
                                                  geswistreyd chind</add></roleName></rs>
                                          <rs type="person"
                                                ref="#pe__heinrich_schuchler_QGW_II_I_499"
                                                  ><add>si</add><roleName type="kin"
                                                  corresp="#pe__johann_von_eslarn_QGW_II_I_1208"
                                                  ><add>rechtew geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__magdalena_StB_I_450_a"><add>rechtew
                                                  geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__magdalena_StB_I_450_b"><add>rechtew
                                                  geswistreyd chind</add></roleName>
                                                <roleName type="kin" corresp="#pe__agnes_StB_I_450"
                                                  ><add>rechtew geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__katharina_StB_I_450"><add>rechtew
                                                  geswistreyd chind</add></roleName></rs>und <rs
                                                type="person" ref="#pe__magdalena_StB_I_450_a"
                                                  ><roleName type="title">fraw</roleName>Magdalen,
                                                  <rs type="person"
                                                  ref="#pe__jakob_dorn_QGW_II_I_1378">Jacobs des
                                                  Dorns</rs>
                                                <roleName type="kin"
                                                  corresp="#pe__jakob_dorn_QGW_II_I_1378">hawsfrawn
                                                  mueter</roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__heinrich_schuchler_QGW_II_I_499"
                                                  ><add>rechtew geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__johann_von_eslarn_QGW_II_I_1208"
                                                  ><add>rechtew geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__magdalena_StB_I_450_b"><add>rechtew
                                                  geswistreyd chind</add></roleName>
                                                <roleName type="kin" corresp="#pe__agnes_StB_I_450"
                                                  ><add>rechtew geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__katharina_StB_I_450"><add>rechtew
                                                  geswistreyd chind</add></roleName></rs>, <rs
                                                type="person" ref="#pe__agnes_StB_I_450"><roleName
                                                  type="title">fraw</roleName> Angnes, <rs
                                                  type="person"
                                                  ref="#pe__hermann_von_mulndorf_StB_I_450">Herman
                                                  Mueldorfs</rs>
                                                <roleName type="kin"
                                                  corresp="#pe__hermann_von_mulndorf_StB_I_450"
                                                  >hawsfraw</roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__heinrich_schuchler_QGW_II_I_499"
                                                  ><add>rechtew geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__magdalena_StB_I_450_a"><add>rechtew
                                                  geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__magdalena_StB_I_450_b"><add>rechtew
                                                  geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__johann_von_eslarn_QGW_II_I_1208"
                                                  ><add>rechtew geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__katharina_StB_I_450"><add>rechtew
                                                  geswistreyd chind</add></roleName></rs>, und <rs
                                                type="person" ref="#pe__magdalena_StB_I_450_b"><rs
                                                  type="person"
                                                  ref="#pe__stephan_leitner_QGW_II_I_1012">Stephans
                                                  des Leyttner</rs>
                                                <roleName type="kin"
                                                  corresp="#pe__stephan_leitner_QGW_II_I_1012"
                                                  >hawsfraw</roleName>, auch genant Magdalen
                                                  <roleName type="kin"
                                                  corresp="#pe__heinrich_schuchler_QGW_II_I_499"
                                                  ><add>rechtew geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__magdalena_StB_I_450_a"><add>rechtew
                                                  geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__johann_von_eslarn_QGW_II_I_1208"
                                                  ><add>rechtew geswistreyd chind</add></roleName>
                                                <roleName type="kin" corresp="#pe__agnes_StB_I_450"
                                                  ><add>rechtew geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__katharina_StB_I_450"><add>rechtew
                                                  geswistreyd chind</add></roleName></rs>, und <rs
                                                type="person" ref="#pe__katharina_StB_I_450"
                                                  ><roleName type="title">fraw</roleName>
                                                  Kathrei<roleName type="kin"
                                                  corresp="#pe__johann_magseit_StB_I_450"
                                                  ><add>hawsfraw</add></roleName>, <rs type="person"
                                                  ref="#pe__johann_magseit_StB_I_450">Hannsen
                                                  hawsfraw des Magseytts</rs>
                                                <roleName type="kin"
                                                  corresp="#pe__heinrich_schuchler_QGW_II_I_499"
                                                  ><add>rechtew geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__magdalena_StB_I_450_a"><add>rechtew
                                                  geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__magdalena_StB_I_450_b"><add>rechtew
                                                  geswistreyd chind</add></roleName>
                                                <roleName type="kin" corresp="#pe__agnes_StB_I_450"
                                                  ><add>rechtew geswistreyd chind</add></roleName>
                                                <roleName type="kin"
                                                  corresp="#pe__johann_von_eslarn_QGW_II_I_1208"
                                                  ><add>rechtew geswistreyd
                                                chind</add></roleName></rs>, rechtew geswistreyd
                                          chind sind gewesen von vater und von mueter</rs>. Als
                                    darumb die obgenanten erbern leut mit irn trewn an ayde stat vor
                                    offem rat habent gesagt, als si ze recht solten.</rs>
                        </p>
                  </div>
