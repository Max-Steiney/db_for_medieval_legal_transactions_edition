            den rat <rs type="fn" role="other"><rs type="person" ref="#pe__margarethe_StB_I_83"><roleName type="title">fraw</roleName> Margret, <roleName type="kin" corresp="#pe__stephan_hueter_StB_I_83">wittib</roleName>
