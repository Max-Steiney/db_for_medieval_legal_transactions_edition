      <text>
            <body>
                  <div type="header">
                        <p>Verwandtschaftsweisung für Hans Prunner</p>
                  </div>
                  <div type="entry" resp="rs">
                        <p> Einbr. 2 Zg. (Index: Item frewntschaft Hansen des Prfmner) <rs
                                    type="event" ref="#ev__StB_I_442">Des nachsten freytags nach sand
                                    Mertten tag <rs type="fn" role="other"><triggerstring n="fn">kom
                                                fur den rat</triggerstring><rs type="person"
                                                ref="#pe__johann_brunner_StB_I_442">Hanns der
                                                Prunner</rs></rs> und hat da <rs type="fn"
                                          role="witness">beweist mit den erbern leuten, als er ze
                                          recht solt, mit <rs type="person"
                                                ref="#pe__niklas_von_schemnitz_StB_I_442"><roleName
                                                  type="title"><add>erbern</add></roleName>Niclasen
                                                dem Scherniczer</rs> und mit <rs type="person"
                                                ref="#pe__leonhard_gutenprunner_QGW_II_I_889"
                                                  ><roleName type="title"
                                                  ><add>erbern</add></roleName>Lienharten dem
                                                Gutenprunner</rs></rs>, das <rs type="fn"
                                          role="recipient"><rs type="person"
                                                ref="#pe__johann_brunner_StB_I_442">er <roleName
                                                  type="kin"
                                                  corresp="#pe__friedrich_brunner_StB_I_442"
                                                  ><add>recht bruder</add></roleName></rs></rs> und
                                          <rs type="fn" role="issuer"><rs type="person"
                                                ref="#pe__friedrich_brunner_StB_I_442">Fridreich der
                                                Prunner, <roleName type="dead">dem got
                                                  genad</roleName>, zwen <roleName type="kin"
                                                  corresp="#pe__johann_brunner_StB_I_442">recht
                                                  bruder</roleName></rs> gewesen sind von vater und
                                          von mueter</rs>. Als darumb die obgenanten erbern leut mit
                                    irn trewn an ayde stat vor unser in offem rat habent gesagt, als
                                    si ze recht solten.</rs>
                        </p>
                  </div>
